<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SchoolManager.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
        <div class="container">

            <a class="navbar-brand fw-bold me-3"
               style="font-size: 1rem;"
               asp-area="MainScreen"
               asp-controller="MainScreen"
               asp-action="Index">
                SE Sistema Educativo
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto" style="gap: 0.25rem;">

                    <li class="nav-item">
                        <a class="nav-link px-2"
                           asp-area="MainScreen"
                           asp-controller="MainScreen"
                           asp-action="Index">
                            <i class="bi bi-house-fill me-1"></i> Inicio
                        </a>
                    </li>

                    @if (User?.Identity?.IsAuthenticated == false)
                    {
                        <li class="nav-item">
                            <a class="nav-link px-2"
                               asp-area="Enrollment"
                               asp-controller="PreEnrollment"
                               asp-action="Index">
                                Preinscripción
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-2"
                               asp-area="Procedures"
                               asp-controller="Request"
                               asp-action="Index">
                                Trámites
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Student") || User.IsInRole("Administrator"))
                    {
                        <li class="nav-item">
                            <a class="nav-link px-2"
                               asp-area="MainScreen"
                               asp-controller="MainScreen"
                               asp-action="SistemaEscolar">
                                Sistema Escolar
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Administrator"))
                    {
                        <li class="nav-item">
                            <a class="nav-link px-2"
                               asp-area="MainScreen"
                               asp-controller="MainScreen"
                               asp-action="PanelAdministrativo">
                                Panel Administrativo
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Teacher"))
                    {
                        <li class="nav-item">
                            <a class="nav-link px-2"
                               asp-area="MainScreen"
                               asp-controller="MainScreen"
                               asp-action="CalificacionesDocente">
                                Calificaciones
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Student"))
                    {
                        <li class="nav-item">
                            <a class="nav-link px-2"
                               asp-area="MainScreen"
                               asp-controller="MainScreen"
                               asp-action="CalificacionesEstudiante">
                                Mis Calificaciones
                            </a>
                        </li>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a asp-area="MainScreen"
                               asp-controller="MainScreen"
                               asp-action="Extension"
                               class="nav-link px-2">
                                Extensión
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-area="MainScreen"
                               asp-controller="MainScreen"
                               asp-action="Tramites"
                               class="nav-link px-2">
                                Trámites
                            </a>
                        </li>
                    }


                    @if (User.IsInRole("Administrator"))
                    {
                        <li class="nav-item">
                            <a class="nav-link px-2"
                               asp-area="MainScreen"
                               asp-controller="Foro"
                               asp-action="Index">
                                Foro Admin
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link px-2"
                               asp-area="MainScreen"
                               asp-controller="Foro"
                               asp-action="ForoPublico">
                                Foro
                            </a>
                        </li>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <form asp-area="UserMng" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="nav-link btn btn-link text-decoration-none px-2">
                                    <i class="bi bi-box-arrow-right me-1"></i> Cerrar Sesión
                                </button>
                            </form>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

   
    <main role="main" class="container mt-4">
        @RenderBody()
    </main>

   
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>