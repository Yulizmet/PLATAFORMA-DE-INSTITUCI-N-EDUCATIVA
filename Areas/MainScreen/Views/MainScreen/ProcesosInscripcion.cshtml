@{
    ViewData["Title"] = "Procesos de Inscripción";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container text-center">

        <h2 class="sistema-title mb-3">Procesos de Inscripción</h2>
        <p class="sistema-subtitle mb-5">
            Selecciona el proceso que deseas realizar
        </p>

        <div class="row justify-content-center g-5">

            <!-- Preinscripción -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-calificaciones text-start">

                    <div class="sistema-icon icon-calificaciones">
                        <i class="bi bi-file-earmark-text"></i>
                    </div>

                    <h4>Preinscripción</h4>

                    <p class="text-muted mt-3">
                        Registra tus datos y selecciona el programa académico.
                    </p>

                    <a href="#" class="btn btn-calificaciones mt-3">
                        Iniciar Preinscripción →
                    </a>

                </div>
            </div>

            <!-- Inscripción -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-servicio text-start">

                    <div class="sistema-icon icon-servicio">
                        <i class="bi bi-check-circle"></i>
                    </div>

                    <h4>Inscripción</h4>

                    <p class="text-muted mt-3">
                        Finaliza tu proceso académico y confirma tu inscripción.
                    </p>

                    <a href="#" class="btn btn-servicio mt-3">
                        Realizar Inscripción →
                    </a>

                </div>
            </div>

        </div>
    </div>
</section>
