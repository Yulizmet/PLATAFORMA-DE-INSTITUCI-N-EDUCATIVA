@model SchoolManager.Models.ForoPublicacion

@{
    ViewData["Title"] = "Editar Publicación";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    var imagenActual = Model.Imagenes?.FirstOrDefault()?.UrlImagen;
}

<section class="admin-section">
    <div class="container">

        <div class="admin-card">
            <h2 class="admin-title mb-4">Editar Publicación</h2>

            <form asp-area="MainScreen"
                  asp-controller="Foro"
                  asp-action="Edit"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="PublicacionId" />

                <div class="mb-4">
                    <label class="form-label fw-semibold">Selecciona el Diseño</label>

                    <div class="design-buttons">
                        <button type="button" class="design-btn @(Model.EstiloVisual == "clasico" ? "active" : "")" data-style="clasico">Clásico</button>
                        <button type="button" class="design-btn @(Model.EstiloVisual == "destacado" ? "active" : "")" data-style="destacado">Destacado</button>
                        <button type="button" class="design-btn @(Model.EstiloVisual == "minimalista" ? "active" : "")" data-style="minimalista">Minimalista</button>
                        <button type="button" class="design-btn @(Model.EstiloVisual == "banner" ? "active" : "")" data-style="banner">Banner</button>
                        <button type="button" class="design-btn @(Model.EstiloVisual == "horizontal" ? "active" : "")" data-style="horizontal">Horizontal</button>
                    </div>

                    <input type="hidden" id="EstiloVisual" name="EstiloVisual" value="@Model.EstiloVisual" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Título *</label>
                    <input type="text"
                           class="form-control"
                           id="tituloInput"
                           name="Titulo"
                           value="@Model.Titulo"
                           required>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Descripción *</label>
                    <textarea class="form-control"
                              id="descInput"
                              name="Descripcion"
                              rows="5"
                              required>@Model.Descripcion</textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Link Externo</label>
                    <input type="url"
                           class="form-control"
                           name="LinkExterno"
                           value="@Model.LinkExterno">
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Imagen</label>
                    <input type="file"
                           class="form-control"
                           id="imagenInput"
                           name="imagenArchivo"
                           accept="image/*">
                </div>

                <div class="row mb-4">
                    <div class="col-12 col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-semibold">Fecha Inicio</label>
                        <input type="datetime-local"
                               class="form-control"
                               name="FechaInicio"
                               value="@Model.FechaInicio.ToString("yyyy-MM-ddTHH:mm")"
                               required>
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold">Fecha Fin</label>
                        <input type="datetime-local"
                               class="form-control"
                               name="FechaFin"
                               value="@(Model.FechaFin?.ToString("yyyy-MM-ddTHH:mm"))">
                    </div>
                </div>

                <div class="form-check mb-4">
                    <input class="form-check-input"
                           type="checkbox"
                           name="Activo"
                           value="true"
                           @(Model.Activo ? "checked" : "")>
                    <label class="form-check-label">Activo</label>
                </div>

                <div class="foro-form-actions">
                    <button type="submit" class="btn btn-calificaciones">Guardar cambios</button>
                    <a asp-area="MainScreen"
                       asp-controller="Foro"
                       asp-action="Index"
                       class="btn btn-outline-danger">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>

        <div class="preview-section mt-5">
            <h4 class="mb-4">Vista Previa</h4>

            <div id="previewContainer" class="preview-card @($"{Model.EstiloVisual}-style")">
                <img id="previewImage"
                     src="@imagenActual"
                     alt="Vista previa"
                     class="img-fluid rounded mb-3 @(string.IsNullOrEmpty(imagenActual) ? "d-none" : "")"
                     style="max-height:250px; object-fit:cover; width:100%;">

                <h3 id="previewTitle">@Model.Titulo</h3>
                <p id="previewDesc">@Model.Descripcion</p>
                <a href="#" class="btn btn-calificaciones btn-sm">Leer más</a>
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <script>
        const buttons = document.querySelectorAll('.design-btn');
        const preview = document.getElementById('previewContainer');
        const estiloHidden = document.getElementById('EstiloVisual');

        const tituloInput = document.getElementById('tituloInput');
        const descInput = document.getElementById('descInput');
        const imagenInput = document.getElementById('imagenInput');

        const previewTitle = document.getElementById('previewTitle');
        const previewDesc = document.getElementById('previewDesc');
        const previewImage = document.getElementById('previewImage');

        buttons.forEach(btn => {
            btn.addEventListener('click', function () {
                buttons.forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                const style = this.dataset.style;
                estiloHidden.value = style;
                preview.className = "preview-card " + style + "-style";
            });
        });

        tituloInput.addEventListener('input', () => {
            previewTitle.textContent = tituloInput.value || "Título de ejemplo";
        });

        descInput.addEventListener('input', () => {
            previewDesc.textContent = descInput.value || "Descripción de ejemplo";
        });

        imagenInput.addEventListener('change', function () {
            const file = this.files[0];

            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    previewImage.src = e.target.result;
                    previewImage.classList.remove('d-none');
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}