@model SchoolManager.Models.ForoPublicacion

@{
    ViewData["Title"] = "Detalle de Publicación";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    var imagen = Model.Imagenes?.FirstOrDefault();
}

<section class="admin-section">
    <div class="container">
        <div class="admin-card">
            <h2 class="admin-title mb-4">Detalle de la Publicación</h2>

            @if (imagen != null)
            {
                <img src="@imagen.UrlImagen"
                     class="img-fluid rounded mb-4"
                     style="max-height:300px; object-fit:cover; width:100%;">
            }

            <h3 class="mb-2">@Model.Titulo</h3>
            <p class="text-muted text-capitalize mb-4">@Model.EstiloVisual</p>
            <p class="mb-4">@Model.Descripcion</p>

            @if (!string.IsNullOrWhiteSpace(Model.LinkExterno))
            {
                <div class="mb-4">
                    <strong>Link:</strong><br />
                    <a href="@Model.LinkExterno" target="_blank">@Model.LinkExterno</a>
                </div>
            }

            <div class="foro-meta mb-4">
                <div class="foro-meta-item">
                    <strong>Fecha inicio</strong>
                    <span>@Model.FechaInicio.ToString("yyyy-MM-dd HH:mm")</span>
                </div>

                <div class="foro-meta-item">
                    <strong>Fecha fin</strong>
                    <span>@(Model.FechaFin?.ToString("yyyy-MM-dd HH:mm") ?? "Sin fecha fin")</span>
                </div>

                <div class="foro-meta-item">
                    <strong>Activo</strong>
                    <span>@(Model.Activo ? "Sí" : "No")</span>
                </div>

                <div class="foro-meta-item">
                    <strong>ID</strong>
                    <span>@Model.PublicacionId</span>
                </div>
            </div>

            <div class="foro-detail-actions">
                <a asp-area="MainScreen"
                   asp-controller="Foro"
                   asp-action="Edit"
                   asp-route-id="@Model.PublicacionId"
                   class="btn btn-warning">
                    Editar
                </a>

                <a asp-area="MainScreen"
                   asp-controller="Foro"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Volver
                </a>
            </div>
        </div>
    </div>
</section>