@model SchoolManager.Models.ForoPublicacion

@{
    ViewData["Title"] = "Detalle de Publicación";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    var imagen = Model.Imagenes?.FirstOrDefault();
}

<section class="admin-section">
    <div class="container">
        <div class="admin-card">
            <h2 class="admin-title mb-4">Detalle de la Publicación</h2>

            @if (imagen != null)
            {
                <img src="@imagen.UrlImagen"
                     class="img-fluid rounded mb-4"
                     style="max-height:300px; object-fit:cover; width:100%;">
            }

            <h3>@Model.Titulo</h3>
            <p class="text-muted text-capitalize">@Model.EstiloVisual</p>
            <p>@Model.Descripcion</p>

            @if (!string.IsNullOrWhiteSpace(Model.LinkExterno))
            {
                <p>
                    <strong>Link:</strong>
                    <a href="@Model.LinkExterno" target="_blank">@Model.LinkExterno</a>
                </p>
            }

            <p><strong>Fecha inicio:</strong> @Model.FechaInicio.ToString("yyyy-MM-dd HH:mm")</p>
            <p><strong>Fecha fin:</strong> @(Model.FechaFin?.ToString("yyyy-MM-dd HH:mm") ?? "Sin fecha fin")</p>
            <p><strong>Activo:</strong> @(Model.Activo ? "Sí" : "No")</p>

            <div class="mt-4">
                <a asp-area="MainScreen"
                   asp-controller="Foro"
                   asp-action="Edit"
                   asp-route-id="@Model.PublicacionId"
                   class="btn btn-warning">
                    Editar
                </a>

                <a asp-area="MainScreen"
                   asp-controller="Foro"
                   asp-action="Index"
                   class="btn btn-outline-secondary ms-2">
                    Volver
                </a>
            </div>
        </div>
    </div>
</section>