@{
    ViewData["Title"] = "Extensión";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container text-center">

        <h2 class="sistema-title mb-3">Extensión</h2>

        <p class="sistema-subtitle mb-5">
            Programas académicos complementarios
        </p>

        <div class="cards-container">

            <!-- Tutorías -->
            <div class="card-custom text-start">
                <div class="card-icon">
                    <i class="bi bi-person-video3"></i>
                </div>

                <div class="card-title">
                    Tutorías
                </div>

                <div class="card-text">
                    Accede a sesiones de acompañamiento académico personalizadas.
                </div>

                <div class="card-actions">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-area="Gestion"
                           asp-controller="Tutorship"
                           asp-action="Controlador"
                           class="btn btn-main">
                            Ver Tutorías →
                        </a>
                    }
                    else
                    {
                        <a asp-area="UserMng"
                           asp-controller="Account"
                           asp-action="Login"
                           asp-route-returnUrl="/Gestion/Tutorship/Controlador"
                           class="btn btn-secondary">
                            <i class="bi bi-lock-fill"></i> Iniciar Sesión
                        </a>
                    }
                </div>
            </div>

            <!-- Enfermería y Psicología -->
            <div class="card-custom text-start">
                <div class="card-icon">
                    <i class="bi bi-heart-pulse-fill"></i>
                </div>

                <div class="card-title">
                    Enfermería y Psicología
                </div>

                <div class="card-text">
                    Consulta servicios de enfermería y apoyo psicológico, agenda citas y recibe orientación especializada.
                </div>

                <div class="card-actions">
                    <a asp-area="Medical"
                       asp-controller="Dashboard"
                       asp-action="Index"
                       class="btn btn-main">
                        Ir a Servicios →
                    </a>
                </div>
            </div>

            <!-- Servicio Social -->
            <div class="card-custom text-start">
                <div class="card-icon">
                    <i class="bi bi-briefcase-fill"></i>
                </div>

                <div class="card-title">
                    Servicio Social
                </div>

                <div class="card-text">
                    Gestiona tu proceso de servicio social, horas acumuladas y seguimiento institucional.
                </div>

                <div class="card-actions">
                    <a href="#" id="btnServicioSocial" class="btn btn-main">
                        Ir a Servicio Social →
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var btnServicioSocial = document.getElementById('btnServicioSocial');

        if (btnServicioSocial) {
            btnServicioSocial.addEventListener('click', function (e) {
                e.preventDefault();

                var isAssigned = true; // aquí luego puedes meter tu lógica real

                if (!isAssigned) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Acceso Restringido',
                        text: 'No has sido asignado a ningún maestro para entrar a este apartado.',
                        confirmButtonText: 'Entendido',
                        confirmButtonColor: '#8C1B1B'
                    });
                } else {
                    window.location.href = '/SocialService/Account/Index';
                }
            });
        }
    });
</script>