@{
    ViewData["Title"] = "Extensión";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container text-center">

        <h2 class="sistema-title mb-3">Extensión</h2>
        <p class="sistema-subtitle mb-5">
            Programas académicos complementarios
        </p>

        <div class="row justify-content-center g-5">

            <!-- Tutorías -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-calificaciones text-start">

                    <div class="sistema-icon icon-calificaciones">
                        <i class="bi bi-person-video3"></i>
                    </div>

                    <h4>Tutorías</h4>

                    <p class="text-muted mt-3">
                        Accede a sesiones de acompañamiento académico personalizadas.
                    </p>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Controlador" class="btn btn-calificaciones mt-3">
                            Ver Tutorías →
                        </a>
                    }
                    else
                    {
                        <a asp-area="UserMng" asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Gestion/Tutorship/Controlador" class="btn btn-secondary mt-3">
                            <i class="bi bi-lock-fill"></i> Iniciar Sesión para acceder
                        </a>
                    }

                </div>
            </div>

            <!-- Enfermería y Psicología -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-servicio text-start">

                    <div class="sistema-icon icon-servicio">
                        <i class="bi bi-heart-pulse-fill"></i>
                    </div>

                    <h4>Enfermería y Psicología</h4>

                    <p class="text-muted mt-3">
                        Consulta servicios de enfermería y apoyo psicológico,
                        agenda citas y recibe orientación especializada.
                    </p>

                    <a href="#" class="btn btn-servicio mt-3">
                        Ir a Servicios de Apoyo →
                    </a>

                </div>
            </div>

            <!-- SERVICIO SOCIAL -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-servicio text-start">

                    <div class="sistema-icon icon-servicio">
                        <i class="bi bi-briefcase-fill"></i>
                    </div>

                    <h4>Servicio Social</h4>

                    <p class="text-muted mt-3">
                        Gestiona tu proceso de servicio social, horas acumuladas y seguimiento institucional.
                    </p>

                    <a href="#" id="btnServicioSocial" class="btn btn-servicio mt-4">
                        Ir a Servicio Social →
                    </a>
                </div>
            </div>

                </div>
            </div>


</section>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var btnServicioSocial = document.getElementById('btnServicioSocial');
        if (btnServicioSocial) {
            btnServicioSocial.addEventListener('click', function(e) {
                e.preventDefault();
                var isAssigned = true; // Cambia esto si necesitas lógica de asignación

                if (!isAssigned) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Acceso Restringido',
                        text: 'No has sido asignado a ningún maestro para entrar a este apartado.',
                        confirmButtonText: 'Entendido',
                        confirmButtonColor: '#b23b3b'
                    });
                } else {
                    window.location.href = '/SocialService/Account/Index';
                }
            });
        }
    });
</script>

