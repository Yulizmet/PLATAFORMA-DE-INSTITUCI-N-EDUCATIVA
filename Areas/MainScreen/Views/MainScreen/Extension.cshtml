@{
    ViewData["Title"] = "Extensión";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container text-center">

        <h2 class="sistema-title mb-3">Extensión</h2>
        <p class="sistema-subtitle mb-5">
            Programas académicos complementarios
        </p>

        <div class="row justify-content-center g-5">

            <!-- Tutorías -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-calificaciones text-start">

                    <div class="sistema-icon icon-calificaciones">
                        <i class="bi bi-person-video3"></i>
                    </div>

                    <h4>Tutorías</h4>

                    <p class="text-muted mt-3">
                        Accede a sesiones de acompañamiento académico personalizadas.
                    </p>

                    <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Controlador" class="btn btn-calificaciones mt-3">
                        Ver Tutorías →
                    </a>

                </div>
            </div>

            <!-- Servicio Social -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-servicio text-start">

                    <div class="sistema-icon icon-servicio">
                        <i class="bi bi-briefcase-fill"></i>
                    </div>

                    <h4>Servicio Social</h4>

                    <p class="text-muted mt-3">
                        Consulta convocatorias y seguimiento institucional.
                    </p>

                    <a href="#" class="btn btn-servicio mt-3">
                        Ir a Servicio Social →
                    </a>

                </div>
            </div>

        </div>
    </div>
</section>

