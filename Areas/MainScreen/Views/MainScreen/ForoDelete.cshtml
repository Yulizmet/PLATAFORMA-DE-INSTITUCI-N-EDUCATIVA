@model SchoolManager.Models.ForoPublicacion

@{
    ViewData["Title"] = "Eliminar Publicación";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="admin-section">
    <div class="container">

        <div class="admin-card">
            <h2 class="admin-title mb-4 text-danger">
                Eliminar Publicación
            </h2>

            <p class="text-muted mb-4">
                ¿Estás seguro de que deseas eliminar esta publicación? Esta acción no se puede deshacer.
            </p>

            <hr />

            <div class="foro-meta mb-4">
                <div class="foro-meta-item">
                    <strong>Título</strong>
                    <span>@Model.Titulo</span>
                </div>

                <div class="foro-meta-item">
                    <strong>Descripción</strong>
                    <span>@Model.Descripcion</span>
                </div>

                <div class="foro-meta-item">
                    <strong>Estilo visual</strong>
                    <span class="text-capitalize">@Model.EstiloVisual</span>
                </div>

                <div class="foro-meta-item">
                    <strong>Fecha inicio</strong>
                    <span>@Model.FechaInicio.ToString("yyyy-MM-dd HH:mm")</span>
                </div>

                <div class="foro-meta-item">
                    <strong>Fecha fin</strong>
                    <span>
                        @(Model.FechaFin != null
                                                ? Model.FechaFin.Value.ToString("yyyy-MM-dd HH:mm")
                                                : "Sin fecha fin")
                    </span>
                </div>
            </div>

            <form asp-area="MainScreen"
                  asp-controller="Foro"
                  asp-action="Delete"
                  method="post">

                <input type="hidden" asp-for="PublicacionId" />

                <div class="foro-delete-actions">
                    <button type="submit" class="btn btn-danger">
                        Eliminar
                    </button>

                    <a asp-area="MainScreen"
                       asp-controller="Foro"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>

    </div>
</section>