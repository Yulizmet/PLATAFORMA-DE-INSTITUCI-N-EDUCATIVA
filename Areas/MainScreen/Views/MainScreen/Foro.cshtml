@model IEnumerable<SchoolManager.Models.ForoPublicacion>

@{
    ViewData["Title"] = "Administrador - Foro";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="admin-section">
    <div class="container">

        <div class="foro-header-actions justify-content-between mb-4">
            <h2 class="admin-title mb-0">Administrador del Foro</h2>

            <a asp-area="MainScreen"
               asp-controller="Foro"
               asp-action="Create"
               class="btn btn-calificaciones">
                Nueva Publicación
            </a>
        </div>

        <div class="admin-card">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle foro-admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Título</th>
                                <th>Estilo</th>
                                <th>Fecha inicio</th>
                                <th>Activo</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Titulo</td>
                                    <td class="text-capitalize">@item.EstiloVisual</td>
                                    <td>@item.FechaInicio.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@(item.Activo ? "Sí" : "No")</td>
                                    <td class="text-end">
                                        <div class="foro-actions">
                                            <a asp-area="MainScreen"
                                               asp-controller="Foro"
                                               asp-action="Details"
                                               asp-route-id="@item.PublicacionId"
                                               class="btn btn-sm btn-outline-secondary">
                                                Ver
                                            </a>

                                            <a asp-area="MainScreen"
                                               asp-controller="Foro"
                                               asp-action="Edit"
                                               asp-route-id="@item.PublicacionId"
                                               class="btn btn-sm btn-warning">
                                                Editar
                                            </a>

                                            <a asp-area="MainScreen"
                                               asp-controller="Foro"
                                               asp-action="Delete"
                                               asp-route-id="@item.PublicacionId"
                                               class="btn btn-sm btn-danger">
                                                Eliminar
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="foro-empty-state">
                    No hay publicaciones registradas todavía.
                </p>
            }
        </div>

    </div>
</section>