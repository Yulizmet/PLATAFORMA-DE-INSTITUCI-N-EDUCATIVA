@{
    ViewData["Title"] = "Sistema Escolar";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container text-center">

        <h2 class="sistema-title mb-3">
            Sistema Escolar
        </h2>

        <p class="sistema-subtitle mb-5">
            Accede a los módulos principales del sistema académico
        </p>

        <div class="row justify-content-center g-5">

            <!-- CALIFICACIONES -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-calificaciones text-start">

                    <div class="sistema-icon icon-calificaciones">
                        <i class="bi bi-bar-chart-fill"></i>
                    </div>

                    <h4>Calificaciones</h4>

                    <p class="text-muted mt-3">
                        Consulta tus materias, historial académico y resultados de evaluación en tiempo real.
                    </p>

                    <a href="#" class="btn btn-calificaciones mt-3">
                        Ver Calificaciones →
                    </a>

                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var btnServicioSocial = document.getElementById('btnServicioSocial');
        if (btnServicioSocial) {
            btnServicioSocial.addEventListener('click', function(e) {
                e.preventDefault();
                var isAssigned = @Html.Raw((ViewBag.IsStudentAssignedToSocialService ?? true).ToString().ToLower());

                if (!isAssigned) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Acceso Restringido',
                        text: 'No has sido asignado a ningún maestro para entrar a este apartado.',
                        confirmButtonText: 'Entendido',
                        confirmButtonColor: '#b23b3b'
                    });
                } else {
                    window.location.href = '@Url.Action("Index", "Account", new { area = "SocialService" })';
                }
            });
        }
    });
</script>