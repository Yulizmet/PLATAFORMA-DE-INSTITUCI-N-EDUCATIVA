@model SchoolManager.Areas.MainScreen.ViewModels.PanelAdministrativoViewModel
@{
    ViewData["Title"] = "Panel Administrativo";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container text-center">

        <h2 class="sistema-title mb-3">
            Panel de Control Administrativo
        </h2>

        <p class="sistema-subtitle mb-5">
            Gestiona la configuración académica, asignaciones e inscripciones
        </p>

        <div class="row justify-content-center g-5">

            <!-- NUEVO CICLO ESCOLAR (WIZARD) -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-calificaciones text-start">
                    <div class="sistema-icon icon-calificaciones">
                        <i class="bi bi-magic"></i>
                    </div>
                    <h4>Nuevo Ciclo Escolar</h4>
                    <p class="text-muted mt-3">
                        Configura un ciclo completo paso a paso: nivel, materias, grupos y asignación de profesores.
                    </p>
                    <div class="mt-4">
                        <a asp-area="Grades"
                           asp-controller="SchoolCycleWizard"
                           asp-action="Step1"
                           class="btn btn-calificaciones w-100">
                            <i class="bi bi-play-circle"></i> Iniciar Asistente
                        </a>
                    </div>
                    <p class="text-muted small mt-3 mb-0">
                        <i class="bi bi-info-circle"></i> El asistente te guiará en 4 pasos para configurar todo el ciclo.
                    </p>
                </div>
            </div>

            <!-- CONFIGURACIÓN ACADÉMICA -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-calificaciones text-start">
                    <div class="sistema-icon icon-calificaciones">
                        <i class="bi bi-gear"></i>
                    </div>
                    <h4>Configuración Académica</h4>
                    <p class="text-muted mt-3">
                        Crea y administra niveles escolares, materias y grupos para el ciclo actual.
                    </p>
                    <div class="d-flex gap-2 mt-4">
                        <a asp-area="Grades" asp-controller="GradeLevels" asp-action="Index"
                           class="btn btn-calificaciones flex-fill">
                            Niveles
                        </a>
                        <a asp-area="Grades" asp-controller="Subjects" asp-action="Index"
                           class="btn btn-calificaciones flex-fill">
                            Materias
                        </a>
                        <a asp-area="Grades" asp-controller="Groups" asp-action="Index"
                           class="btn btn-calificaciones flex-fill">
                            Grupos
                        </a>
                    </div>
                </div>
            </div>

@*             <!-- ASIGNACIONES -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-calificaciones text-start">
                    <div class="sistema-icon icon-calificaciones">
                        <i class="bi bi-person-badge"></i>
                    </div>
                    <h4>Asignaciones</h4>
                    <p class="text-muted mt-3">
                        Asigna profesores a materias y gestiona los grupos de cada asignación.
                    </p>
