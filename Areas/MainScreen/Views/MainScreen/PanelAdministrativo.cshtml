                        <a asp-area="Grades" asp-controller="TeacherSubject" asp-action="Create"
                           class="btn btn-calificaciones w-100 mb-2">
                            <i class="bi bi-plus-circle"></i> Nueva Asignación
                        </a>
                        <a asp-area="Grades" asp-controller="TeacherSubject" asp-action="Index"
                           class="btn btn-outline-secondary w-100">
                            <i class="bi bi-list"></i> Gestionar Asignaciones
                        </a>
                    </div>
                </div>
            </div>

            <!-- INSCRIPCIONES -->
            <div class="col-lg-5 col-md-6">
                <div class="sistema-card border-calificaciones text-start">
                    <div class="sistema-icon icon-calificaciones">
                        <i class="bi bi-person-plus"></i>
                    </div>
                    <h4>Asignar Estudiantes a Grupos</h4>
                    <p class="text-muted mt-3">
                        Administra los estudiantes en los grupos escolares.
                    </p>
                    <div class="mt-4">
                       <a asp-area="Grades" asp-controller="Enrollment" asp-action="SelectGroupForAssignment"
                           class="btn btn-calificaciones w-100 mb-2">
                            <i class="bi bi-person-plus"></i> Asignar Estudiante a Grupo
                        </a>
                        <a asp-area="Grades" asp-controller="Enrollment" asp-action="SelectGroupForViewing"
                           class="btn btn-outline-secondary w-100 mb-2">
                            <i class="bi bi-people"></i> Ver Estudiantes por Grupo
                        </a> 
                        <a asp-area="Grades" asp-controller="Groups" asp-action="Index"
                           class="btn btn-calificaciones w-100">
                            <i class="bi bi-gear"></i> Gestionar Grupos
                        </a>
                    </div>
                    <p class="text-muted small mt-3 mb-0">
                        <i class="bi bi-info-circle"></i> Selecciona el grupo en la siguiente pantalla.
                    </p>
                </div>
            </div> *@

        </div>
    </div>
</section>
