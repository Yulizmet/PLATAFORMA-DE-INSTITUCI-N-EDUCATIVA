@model SchoolManager.Areas.MainScreen.ViewModels.PanelAdministrativoViewModel
@{
    ViewData["Title"] = "Panel Administrativo";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container text-center">

        <h2 class="sistema-title mb-3">
            Panel de Control Administrativo
        </h2>

        <p class="sistema-subtitle mb-5">
            Gestiona la configuración académica, asignaciones e inscripciones
        </p>

        <div class="cards-container">

            <!-- NUEVO CICLO ESCOLAR -->
            <div class="card-custom text-start">
                <div class="card-icon">
                    <i class="bi bi-magic"></i>
                </div>

                <div class="card-title">
                    Nuevo Ciclo Escolar
                </div>

                <div class="card-text">
                    Configura un ciclo completo paso a paso: nivel, materias, grupos y asignación de profesores.
                </div>

                <div class="card-actions">
                    <a asp-area="Grades"
                       asp-controller="SchoolCycleWizard"
                       asp-action="Step1"
                       class="btn btn-main w-100">
                        <i class="bi bi-play-circle"></i> Iniciar Asistente
                    </a>
                </div>

                <p class="text-muted small mt-3 mb-0">
                    <i class="bi bi-info-circle"></i> El asistente te guiará en 4 pasos para configurar todo el ciclo.
                </p>
            </div>

            <!-- CONFIGURACIÓN ACADÉMICA -->
            <div class="card-custom text-start">
                <div class="card-icon">
                    <i class="bi bi-gear"></i>
                </div>

                <div class="card-title">
                    Configuración Académica
                </div>

                <div class="card-text">
                    Crea y administra niveles escolares, materias y grupos para el ciclo actual.
                </div>

                <div class="card-actions d-flex flex-wrap gap-2">
                    <a asp-area="Grades"
                       asp-controller="GradeLevels"
                       asp-action="Index"
                       class="btn btn-main flex-fill">
                        Niveles
                    </a>

                    <a asp-area="Grades"
                       asp-controller="Subjects"
                       asp-action="Index"
                       class="btn btn-main flex-fill">
                        Materias
                    </a>

                    <a asp-area="Grades"
                       asp-controller="Groups"
                       asp-action="Index"
                       class="btn btn-main flex-fill">
                        Grupos
                    </a>
                </div>
            </div>

            <!-- KARDEX -->
            <div class="card-custom text-start">
                <div class="card-icon">
                    <i class="bi bi-file-earmark-text"></i>
                </div>

                <div class="card-title">
                    Kardex Estudiantil
                </div>

                <div class="card-text">
                    Consulta el historial académico y calificaciones de los estudiantes.
                </div>

                <div class="card-actions">
                    <a asp-area="Grades"
                       asp-controller="Kardex"
                       asp-action="Index"
                       class="btn btn-main w-100">
                        <i class="bi bi-search"></i> Consultar Kardex
                    </a>
                </div>
            </div>

            @* 
            <!-- ASIGNACIONES -->
            <div class="card-custom text-start">
                <div class="card-icon">
                    <i class="bi bi-person-badge"></i>
                </div>

                <div class="card-title">
                    Asignaciones
                </div>

                <div class="card-text">
                    Asigna profesores a materias y gestiona los grupos de cada asignación.
                </div>

                <div class="card-actions d-flex flex-column gap-2">
                    <a asp-area="Grades"
                       asp-controller="TeacherSubject"
                       asp-action="Create"
                       class="btn btn-main w-100">
                        <i class="bi bi-plus-circle"></i> Nueva Asignación
                    </a>

                    <a asp-area="Grades"
                       asp-controller="TeacherSubject"
                       asp-action="Index"
                       class="btn btn-outline-secondary w-100">
                        <i class="bi bi-list"></i> Gestionar Asignaciones
                    </a>
                </div>
            </div>

            <!-- INSCRIPCIONES -->
            <div class="card-custom text-start">
                <div class="card-icon">
                    <i class="bi bi-person-plus"></i>
                </div>

                <div class="card-title">
                    Asignar Estudiantes a Grupos
                </div>

                <div class="card-text">
                    Administra los estudiantes en los grupos escolares.
                </div>

                <div class="card-actions d-flex flex-column gap-2">
                    <a asp-area="Grades"
                       asp-controller="Enrollment"
                       asp-action="SelectGroupForAssignment"
                       class="btn btn-main w-100">
                        <i class="bi bi-person-plus"></i> Asignar Estudiante a Grupo
                    </a>

                    <a asp-area="Grades"
                       asp-controller="Enrollment"
                       asp-action="SelectGroupForViewing"
                       class="btn btn-outline-secondary w-100">
                        <i class="bi bi-people"></i> Ver Estudiantes por Grupo
                    </a>

                    <a asp-area="Grades"
                       asp-controller="Groups"
                       asp-action="Index"
                       class="btn btn-main w-100">
                        <i class="bi bi-gear"></i> Gestionar Grupos
                    </a>
                </div>

                <p class="text-muted small mt-3 mb-0">
                    <i class="bi bi-info-circle"></i> Selecciona el grupo en la siguiente pantalla.
                </p>
            </div>
            *@

        </div>
    </div>
</section>