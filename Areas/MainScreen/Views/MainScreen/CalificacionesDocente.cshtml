@{
    ViewData["Title"] = "Mi Espacio Docente";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container text-center">

        <h2 class="sistema-title mb-3">
            Mi Espacio Docente
        </h2>

        <p class="sistema-subtitle mb-5">
            Aquí puedes capturar calificaciones y dar seguimiento a tus grupos
        </p>

        <div class="cards-container">

            <div class="card-custom text-start">
                <div class="card-icon">
                    <i class="bi bi-pencil-square"></i>
                </div>

                <div class="card-title">
                    Mis Clases
                </div>

                <div class="card-text">
                    Captura las calificaciones de tus grupos por unidad y agrega recuperaciones.
                </div>

                <div class="card-actions">
                    <a href="/Grades/GradeCapture/MyClasses" class="btn btn-main">
                        Ir a Mis Clases →
                    </a>
                </div>
            </div>

            <div class="card-custom text-start">
                <div class="card-icon">
                    <i class="bi bi-clipboard-data"></i>
                </div>

                <div class="card-title">
                    Calificaciones Finales
                </div>

                <div class="card-text">
                    Calcula promedios, consulta resultados y asigna extraordinarios.
                </div>

                <div class="card-actions">
                    <a href="/Grades/FinalGrades" class="btn btn-main">
                        Ver Finales →
                    </a>
                </div>
            </div>

            @if (User.IsInRole("Teacher"))
            {
                <div class="card-custom text-start">
                    <div class="card-icon">
                        <i class="bi bi-bar-chart"></i>
                    </div>

                    <div class="card-title">
                        Reportes
                    </div>

                    <div class="card-text">
                        Visualiza estadísticas de aprovechamiento y rendimiento académico.
                    </div>

                    <div class="card-actions">
                        <a href="/Estadisticas" class="btn btn-main">
                            Ver Reportes →
                        </a>
                    </div>
                </div>
            }

        </div>
    </div>
</section>