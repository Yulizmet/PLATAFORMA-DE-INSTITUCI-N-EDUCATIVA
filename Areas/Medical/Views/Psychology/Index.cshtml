@model IEnumerable<SchoolManager.ViewModels.PsychologyListVM>

@{
    Layout = "~/Areas/Medical/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Bitácoras Psicológicas";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

<div class="dashboard-header">
    <div class="header-content d-flex align-items-start justify-content-between flex-wrap">
        <div>
            <h2 class="text-white">BITÁCORAS PSICOLÓGICAS</h2>
            <div class="buttons-left">
                <a asp-action="Create" class="btn-header">
                    <i class="bi bi-plus-circle"></i> Crear Registro
                </a>
                <a asp-action="Index" class="btn-header">
                    <i class="bi bi-journal-medical"></i> Ver Registros
                </a>
                <a asp-action="Reporte" class="btn-header">
                    <i class="bi bi-file-earmark-bar-graph"></i> Reporte
                </a>
            </div>
        </div>
        <div class="buttons-right">
            <a asp-controller="Dashboard" asp-action="Index" class="btn-header">
                <i class="bi bi-arrow-left-circle"></i> Regresar al inicio
            </a>
        </div>
    </div>
</div>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <table id="tablaPsicologia" class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Matrícula</th>
                        <th>Alumno</th>
                        <th>Asistencia</th>
                        <th>Fecha</th>
                        <th>Folio</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Matricula</td>
                            <td>@item.NombreCompleto</td>
                            <td>
                                @if (item.Asistencia == "Asistió")
                                {
                                    <span class="badge asistencia-asistio">Asistió</span>
                                }
                                else if (item.Asistencia == "No asistió")
                                {
                                    <span class="badge asistencia-no">No asistió</span>
                                }
                                else if (item.Asistencia == "Justificado")
                                {
                                    <span class="badge asistencia-justificado">Justificado</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Asistencia</span>
                                }
                            </td>
                            <td data-sort="@item.Fecha.ToString("yyyyMMddHHmmss")">
                                @item.Fecha.ToString("dd/MM/yyyy hh:mm tt")
                            </td>
                            <td><strong>@item.Folio</strong></td>
                            <td>
                                <div class="d-flex gap-2">

                                    <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm"
                                       style="background:#38b6ff;color:white;border:none;"
                                       title="Ver">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm"
                                       style="background:#ffde59;color:white;border:none;"
                                       title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm"
                                       style="background:#ff3131;color:white;border:none;"
                                       title="Eliminar">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        var $jq = jQuery.noConflict(true);
        $jq(document).ready(function () {
            $jq('#tablaPsicologia').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                },
                "order": [[3, "desc"]],
                "columnDefs": [
                    { "orderable": false, "targets": 5 }
                ]
            });
        });
    </script>
}