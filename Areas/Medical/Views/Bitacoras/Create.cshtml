@model PIBitacoras.Models.Bitacora

@{
    ViewData["Title"] = "Nueva Bitácora Clínica";
}

<div class="container mt-4">
    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h2 class="mb-0">Nueva Bitácora Clínica</h2>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post">

                <div asp-validation-summary="All" class="text-danger"></div>

                <!-- HIDDEN REAL QUE SE ENVÍA -->
                <input type="hidden" asp-for="IdAlumno" id="IdAlumno" />

                <div class="row">

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Matrícula</label>
                        <input id="matricula" class="form-control" placeholder="Escribe matrícula" />
                    </div>

                    <div class="col-md-2 mb-3">
                        <label>.</label>
                        <button type="button" onclick="buscarAlumno()" class="btn btn-dark form-control">
                            Buscar
                        </button>
                    </div>

                    <div class="col-md-6"></div>

                    <div class="col-md-4 mb-3">
                        <label class="fw-bold">Nombre</label>
                        <input id="nombre" class="form-control" readonly />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="fw-bold">Apellido paterno</label>
                        <input id="paterno" class="form-control" readonly />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="fw-bold">Apellido materno</label>
                        <input id="materno" class="form-control" readonly />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="fw-bold">Tipo de sangre</label>
                        <input id="sangre" class="form-control" readonly />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="fw-bold">Peso</label>
                        <input id="peso" class="form-control" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Alergias</label>
                        <input id="alergias" class="form-control" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Condiciones crónicas</label>
                        <input id="condiciones" class="form-control" readonly />
                    </div>

                </div>

                <hr />

                <div class="mb-3">
                    <label asp-for="MotivoConsulta" class="form-label fw-bold">Motivo de consulta</label>
                    <input asp-for="MotivoConsulta" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="SignosVitales" class="form-label fw-bold">Signos vitales</label>
                    <input asp-for="SignosVitales" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Observaciones" class="form-label fw-bold">Observaciones</label>
                    <textarea asp-for="Observaciones" class="form-control"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Tratamiento" class="form-label fw-bold">Tratamiento / Acción</label>
                    <textarea asp-for="Tratamiento" class="form-control"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Estado" class="form-label fw-bold">Estado del paciente</label>
                    <select asp-for="Estado" class="form-control">
                        <option value="">Seleccionar estado</option>
                        <option value="Estable">Estable</option>
                        <option value="Urgente">Urgente</option>
                        <option value="Critico">Crítico</option>
                        <option value="Observacion">Observación</option>
                        <option value="Alta">Alta</option>
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="fw-bold">Folio</label>
                    <input asp-for="Folio" class="form-control" readonly placeholder="Se generará automáticamente" />
                </div>

                <hr />

                <div class="d-flex justify-content-between">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-success px-5">
                        Guardar Bitácora
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {

    <script>
        function buscarAlumno() {

            var matricula = $("#matricula").val();

            if (matricula === "") {
                alert("Escribe una matrícula");
                return;
            }

            $.get("/Bitacoras/BuscarPorMatricula", { matricula: matricula }, function (data) {

                if (data == null) {
                    alert("Alumno no encontrado o no tiene registro médico");
                    return;
                }

                // AQUI SE LLENA EL HIDDEN REAL
                $("#IdAlumno").val(data.alumnoId);

                $("#nombre").val(data.nombre);
                $("#paterno").val(data.paterno);
                $("#materno").val(data.materno);
                $("#sangre").val(data.sangre);
                $("#peso").val(data.peso);
                $("#alergias").val(data.alergias);
                $("#condiciones").val(data.condiciones);
            });
        }
    </script>

}