@{
    Layout = "~/Areas/Medical/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Panel de Control";
}
<div class="main-container">
    <div class="dashboard-main-header d-flex justify-content-between align-items-center">
        <div>
            <h2 class="text-white">Bienvenido, @(User.FindFirst("NombreCompleto")?.Value ?? User.Identity?.Name)</h2>
            <small>Sistema Médico - Panel de Control</small>
        </div>
        <a asp-area="MainScreen" asp-controller="MainScreen" asp-action="Index" class="home-btn">
            <i class="bi bi-house-door-fill"></i> Inicio
        </a>
    </div>
    <div class="cards-grid">

        @* Enfermería — Nurse, Head Nurse, Coordinator, Master *@
        @if (User.IsInRole("Nurse") || User.IsInRole("Head Nurse") ||
                User.IsInRole("Coordinator") || User.IsInRole("Master"))
        {
            <a asp-controller="Logbook" asp-action="Index" class="card-link">
                <div class="dashboard-card">
                    <div>
                        <div class="card-icon-box"><i class="bi bi-heart-pulse-fill"></i></div>
                        <h5>MÓDULO ENFERMERÍA</h5>
                        <p>Registro y control de consultas clínicas</p>
                    </div>
                    <span class="status-badge">IR AL MÓDULO →</span>
                </div>
            </a>
        }

        @* Psicología — Psychologist, Head of Psychology, Coordinator, Master *@
        @if (User.IsInRole("Psychologist") || User.IsInRole("Head of Psychology") ||
                User.IsInRole("Coordinator") || User.IsInRole("Master"))
        {
            <a asp-controller="Psychology" asp-action="Index" class="card-link">
                <div class="dashboard-card">
                    <div>
                        <div class="card-icon-box"><i class="bi bi-clipboard-check-fill"></i></div>
                        <h5>MÓDULO PSICOLOGÍA</h5>
                        <p>Registro y seguimiento psicológico</p>
                    </div>
                    <span class="status-badge">IR AL MÓDULO →</span>
                </div>
            </a>
        }

        @* Alumnos — todos *@
        @if (User.IsInRole("Nurse") || User.IsInRole("Psychologist") ||
                User.IsInRole("Head Nurse") || User.IsInRole("Head of Psychology") ||
                User.IsInRole("Coordinator") || User.IsInRole("Master"))
        {
            <a asp-controller="Students" asp-action="Index" class="card-link">
                <div class="dashboard-card">
                    <div>
                        <div class="card-icon-box"><i class="bi bi-people-fill"></i></div>
                        <h5>REGISTRO DE ALUMNOS</h5>
                        <p>Administración y control de estudiantes</p>
                    </div>
                    <span class="status-badge">IR AL MÓDULO →</span>
                </div>
            </a>
        }

        @* Staff — Heads, Coordinator, Master *@
        @if (User.IsInRole("Head Nurse") || User.IsInRole("Head of Psychology") ||
                User.IsInRole("Coordinator") || User.IsInRole("Master"))
        {
            <a asp-controller="Staff" asp-action="Index" class="card-link">
                <div class="dashboard-card">
                    <div>
                        <div class="card-icon-box"><i class="bi bi-bar-chart-fill"></i></div>
                        <h5>SEGUIMIENTO DE STAFF</h5>
                        <p>Estadísticas y seguimientos del Staff</p>
                    </div>
                    <span class="status-badge">IR AL MÓDULO →</span>
                </div>
            </a>
        }

    </div>
</div>