@model SchoolManager.Models.medical_logbook
@{
    Layout = "~/Areas/Medical/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Eliminar Bitácora Clínica";
}
<div class="dashboard-header">
    <div class="header-content">
        <h2 class="text-white">ELIMINAR BITÁCORA CLÍNICA</h2>
        <p class="mb-0">Sistema Médico - Bitácoras Clínicas</p>
    </div>
</div>
<div class="container mt-4">
    <div class="card p-4 shadow-sm">
        <div class="alert-delete mb-4">
            ¿Seguro que deseas eliminar esta bitácora clínica?
        </div>
        <h5 class="section-title">DATOS DE LA BITÁCORA</h5>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="info-block">
                    <label class="fw-bold text-uppercase">Matrícula</label>
                    <div class="info-box">@Model.MatriculaTemp</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-block">
                    <label class="fw-bold text-uppercase">Nombre del Alumno</label>
                    <div class="info-box">@Model.NombreCompletoTemp</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-block">
                    <label class="fw-bold text-uppercase">Folio</label>
                    <div class="info-box">@Model.Folio</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="info-block">
                    <label class="fw-bold text-uppercase">Motivo</label>
                    <div class="info-box">@Model.MotivoConsulta</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="info-block">
                    <label class="fw-bold text-uppercase">Fecha</label>
                    <div class="info-box">@Model.FechaHora.ToString("dd/MM/yyyy hh:mm tt")</div>
                </div>
            </div>
        </div>
        <hr class="section-divider" />
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn" style="border: 1.5px solid #6c757d;">
                    CANCELAR
                </a>
                <button type="submit" class="btn" style="border: 1.5px solid #6c757d;">
                    ELIMINAR
                </button>
            </div>
        </form>
    </div>
</div>