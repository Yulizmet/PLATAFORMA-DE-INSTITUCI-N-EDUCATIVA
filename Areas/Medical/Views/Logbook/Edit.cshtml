@model SchoolManager.Models.medical_logbook
@{
    Layout = "~/Areas/Medical/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Editar bitácora";
}
<div class="dashboard-header">
    <div class="header-content">
        <h2 class="text-white">EDITAR BITÁCORA CLÍNICA</h2>
        <p class="mb-0">Sistema Médico - Bitácoras Clínicas</p>
    </div>
</div>
<div class="container mt-4">
    <div class="card p-4 shadow-sm">
        <form asp-action="Edit" method="post" id="formEditBitacora">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="IdAlumno" />
            <input type="hidden" asp-for="FechaHora" />
            <input type="hidden" asp-for="Folio" />
            <input type="hidden" asp-for="CreatedAt" />
            <h5 class="section-title">INFORMACIÓN DE LA BITÁCORA</h5>
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="info-block">
                        <label class="fw-bold text-uppercase">Motivo</label>
                        <input asp-for="MotivoConsulta" class="form-control" required
                               oninvalid="this.setCustomValidity('El motivo es obligatorio')"
                               oninput="this.setCustomValidity('')" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-block">
                        <label class="fw-bold text-uppercase">Signos Vitales</label>
                        <input asp-for="SignosVitales" class="form-control" required
                               oninvalid="this.setCustomValidity('Los signos vitales son obligatorios')"
                               oninput="this.setCustomValidity('')" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-block">
                        <label class="fw-bold text-uppercase">Estado</label>
                        <select asp-for="Estado" class="form-control" required
                                oninvalid="this.setCustomValidity('Selecciona un estado')"
                                oninput="this.setCustomValidity('')">
                            <option value="">Seleccionar estado</option>
                            <option value="Estable">Estable</option>
                            <option value="Urgente">Urgente</option>
                            <option value="Critico">Crítico</option>
                            <option value="Observacion">Observación</option>
                            <option value="Alta">Alta</option>
                        </select>
                    </div>
                </div>
            </div>
            <hr class="section-divider" />
            <div class="row g-4">
                <div class="col-md-12">
                    <div class="info-block">
                        <label class="fw-bold text-uppercase">Observaciones</label>
                        <textarea asp-for="Observaciones" class="form-control" rows="4" required
                                  oninvalid="this.setCustomValidity('Las observaciones son obligatorias')"
                                  oninput="this.setCustomValidity('')"></textarea>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="info-block">
                        <label class="fw-bold text-uppercase">Tratamiento</label>
                        <textarea asp-for="Tratamiento" class="form-control" rows="4" required
                                  oninvalid="this.setCustomValidity('El tratamiento es obligatorio')"
                                  oninput="this.setCustomValidity('')"></textarea>
                    </div>
                </div>
            </div>
            <hr class="section-divider" />
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn px-4" style="border: 1.5px solid #6c757d;">
                    CANCELAR
                </a>
                <button type="submit" class="btn px-4" style="border: 1.5px solid #6c757d;">
                    GUARDAR CAMBIOS
                </button>
            </div>
        </form>
    </div>
</div>