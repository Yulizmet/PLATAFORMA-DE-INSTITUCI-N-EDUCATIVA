@model PIBitacoras.Models.Psicologia

@{
    ViewData["Title"] = "Detalle psicológico";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0">

        <!-- HEADER -->
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">
                DETALLE DE ATENCIÓN PSICOLÓGICA
            </h3>
        </div>

        <!-- BODY -->
        <div class="card-body p-4">

            <div class="row g-4">

                <!-- COLUMNA IZQUIERDA -->
                <div class="col-md-6">

                    <div class="info-box">
                        <label>Matrícula</label>
                        <div class="info-value">
                            @Model.MatriculaTemp
                        </div>
                    </div>

                    <div class="info-box">
                        <label>Folio</label>
                        <div class="info-value text-primary fw-bold">
                            @Model.Fol
                        </div>
                    </div>

                    <div class="info-box">
                        <label>Nombre del Alumno</label>
                        <div class="info-value">
                            @Model.NombreCompletoTemp
                        </div>
                    </div>

                    <div class="info-box">
                        <label>Fecha de Cita</label>
                        <div class="info-value">
                            @Model.AppointmentDatetime.ToString("dd/MM/yyyy hh:mm tt")
                        </div>
                    </div>

                </div>

                <!-- COLUMNA DERECHA -->
                <div class="col-md-6">

                    <div class="info-box">
                        <label>Asistencia</label>
                        <div class="info-value">
                            @if (Model.AttendanceStatus == "Asistió")
                            {
                                <span class="badge bg-success">Asistió</span>
                            }
                            else if (Model.AttendanceStatus == "No asistió")
                            {
                                <span class="badge bg-danger">No asistió</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    @Model.AttendanceStatus
                                </span>
                            }
                        </div>
                    </div>

                </div>

            </div>

            <hr class="mt-4" />

            <!-- OBSERVACIONES -->
            <div class="mb-4">
                <label class="fw-bold">Observaciones Psicológicas</label>
                <div class="info-area">
                    @Model.PsychologyObservations
                </div>
            </div>

            <hr />

            <!-- BOTONES -->
            <div class="d-flex justify-content-between">

                <a asp-action="Index" class="btn btn-secondary px-4">
                    Regresar
                </a>

                <a asp-action="Edit" asp-route-id="@Model.Id"
                   class="btn btn-warning text-white px-4">
                    Editar registro
                </a>

            </div>

        </div>
    </div>

</div>

<style>

    .info-box {
        margin-bottom: 18px;
    }

        .info-box label {
            font-weight: 700;
            color: #6c757d;
            display: block;
            font-size: 14px;
            margin-bottom: 3px;
        }

    .info-value {
        font-size: 18px;
        font-weight: 600;
        color: #212529;
        background: #f1f3f5;
        padding: 12px 14px;
        border-radius: 8px;
    }

    .info-area {
        background: #f1f3f5;
        padding: 15px;
        border-radius: 8px;
        font-size: 16px;
        min-height: 80px;
    }

</style>