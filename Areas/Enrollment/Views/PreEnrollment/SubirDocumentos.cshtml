@model SchoolManager.Models.preenrollment_docs

@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Documentos";
}

// Lista de documentos basada en tu modelo
@{
    var documentos = new Dictionary<string, bool>
    {
        { "Fotos", Model.Fotos },
        { "Pago de examen", Model.PagoExamen },
        { "Acta de nacimiento", Model.ActaNacimiento },
        { "CURP", Model.Curp },
        { "Certificados", Model.Certificados },
        { "Comprobante de domicilio", Model.ComprobanteDomicilio },
        { "Carta de buena conducta", Model.CartaBuenaConducta }
    };
}

<div class="main">
    <main class="content">
        <div class="container-fluid p-0">
            <h1 class="h3 mb-3">Documentos</h1>

            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Documentación</h5>
                        </div>
                        <div class="card-body">

                            <!-- ================= ENTREGADOS ================= -->
                            <h6 class="mb-3">Entregados</h6>
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Documento</th>
                                            <th style="width:140px">Estado</th>
                                            <th style="width:140px">Fecha</th>
                                            <th>Observaciones</th>
                                            <th style="width:260px">Anexar Documento</th>
                                            <th style="width:60px" class="text-center">Acción</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var doc in documentos.Where(d => d.Value))
                                        {
                                            <tr>
                                                <td>@doc.Key</td>
                                                <td>Entregado ✅</td>
                                                <td>@DateTime.Now.ToString("dd/MM/yyyy")</td>
                                                <td>-</td>
                                                <td>
                                                    <form asp-action="SubirDocumentos" asp-controller="PreEnrollment" asp-area="Enrollment" method="post" enctype="multipart/form-data">
                                                        <input type="file" name="@doc.Key.Replace(" ", "")" class="form-control form-control-sm" />
                                                        <input type="hidden" name="IdDocument" value="@Model.IdDocument" />
                                                        <button type="submit" class="btn btn-sm btn-success mt-1">Actualizar</button>
                                                    </form>
                                                </td>
                                                <td class="text-center">
                                                    <i class="fa-solid fa-check text-success"></i>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <!-- ================= POR ENTREGAR ================= -->
                            <h6 class="mt-4 mb-3">Por Entregar</h6>
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Documento</th>
                                            <th style="width:260px">Anexar Documento</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var doc in documentos.Where(d => !d.Value))
                                        {
                                            <tr>
                                                <td>@doc.Key</td>
                                                <td>
                                                    <form asp-action="SubirDocumentos" asp-controller="PreEnrollment" asp-area="Enrollment" method="post" enctype="multipart/form-data">
                                                        <input type="file" name="@doc.Key.Replace(" ", "")" class="form-control form-control-sm" />
                                                        <input type="hidden" name="IdDocument" value="@Model.IdDocument" />
                                                        <button type="submit" class="btn btn-sm btn-primary mt-1">Subir</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="d-flex justify-content-end mt-3">
                                <a href="@Url.Action("ConfirmarDatos", "PreEnrollment", new { area = "Enrollment", id = Model.IdData })" class="btn btn-primary">Siguiente</a>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>