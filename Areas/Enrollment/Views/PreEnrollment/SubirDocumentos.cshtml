@{
    ViewData["Title"] = "Documentos";
    Layout = "~/Areas/Enrollment/Views/_Layout.cshtml";
}

<div class="wrapper">
    <div class="main">
        <main class="content">
            <div class="container-fluid p-0">

                <h1 class="h3 mb-3">Documentos</h1>

                <div class="row">
                    <div class="col-12">
                        <div class="card">

                            <div class="card-header">
                                <h5 class="card-title mb-0">Documentación</h5>
                            </div>

                            <div class="card-body">

                                <h6 class="mb-3">Entregados</h6>
                                <div class="table-responsive">
                                    <table class="table table-bordered table-sm align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Documento</th>
                                                <th style="width:140px">Usuario</th>
                                                <th style="width:140px">Fecha</th>
                                                <th>Observaciones</th>
                                                <th style="width:260px">Anexar Documento</th>
                                                <th style="width:60px" class="text-center">Acción</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tbodyEntregados"></tbody>
                                    </table>
                                </div>

                                <h6 class="mt-4 mb-3">Por Entregar</h6>
                                <div class="table-responsive">
                                    <table class="table table-bordered table-sm align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Documento</th>
                                                <th style="width:260px">Anexar Documento</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tbodyPorEntregar"></tbody>
                                    </table>


                                </div>

                              

                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <button type="button" id="btnContinuar" class="btn btn-primary">
                        Siguiente
                    </button>
                </div>

            </div>
        </main>
    </div>
</div>

<img id="pdfLogo" src="@Url.Content("~/src/img/icons/ITACE.png")" style="display:none;" alt="logo">

@section Styles {
    <link href="@Url.Content("~/enrollment/static/css/app.css")" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
    <script src="@Url.Content("~/enrollment/static/js/app.js")"></script>

    <script>
        // URLs de navegación (Razor -> JS) - CON AREA
        window.PRE_URLS = {
            preinscripcion: '@Url.Action("Create", "PreEnrollment", new { area = "Enrollment" })',
            confirmar: '@Url.Action("ConfirmarPreinscripcion", "PreEnrollment", new { area = "Enrollment" })'
        };
    </script>

    <script src="@Url.Content("~/enrollment/src/js/modules/documentos-scripts.js")"></script>
    
}