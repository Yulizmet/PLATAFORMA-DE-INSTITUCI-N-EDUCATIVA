@{
    ViewData["Title"] = "Matrículas";
    Layout = "~/Areas/Enrollment/Views/_LayoutAdmin.cshtml";
}

@section Styles {
    <style>
        .alumno-row {
            cursor: default;
        }

            .alumno-row:hover {
                background-color: #f8f9fa;
            }
    </style>
}

<div class="mb-3">
    <h1 class="h3 d-inline align-middle">Matrículas</h1>
</div>

<div id="loading" class="text-center py-4">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Cargando...</span>
    </div>
    <p class="mt-2 text-muted">Cargando matrículas...</p>
</div>

<div id="error" class="alert alert-danger d-none" role="alert">
    No se pudieron cargar las matrículas. Intenta recargar la página.
</div>

<div id="empty" class="alert alert-info d-none" role="alert">
    No hay matrículas registradas aún.
</div>

<div id="tabla-container" class="d-none">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header pb-0">
                    <h5 class="card-title mb-0">Matrículas registradas</h5>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0" style="width:100%">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Nombre</th>
                                    <th class="d-none d-md-table-cell">Matrícula</th>
                                    <th class="d-none d-md-table-cell">Correo</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody id="tabla-body"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_URL = '@Url.Action("GetMatriculas", "PreEnrollment", new { area = "Enrollment" })';

        const loading = document.getElementById('loading');
        const error = document.getElementById('error');
        const empty = document.getElementById('empty');
        const tablaContainer = document.getElementById('tabla-container');
        const tablaBody = document.getElementById('tabla-body');

        let matriculasOriginales = [];

        function renderTabla(lista) {
            tablaBody.innerHTML = '';

            if (!lista || lista.length === 0) {
                tablaContainer.classList.add('d-none');
                empty.classList.remove('d-none');
                return;
            }

            empty.classList.add('d-none');
            error.classList.add('d-none');

            lista.forEach(m => {
                const tr = document.createElement('tr');
                tr.className = 'alumno-row';

                const estadoBadge = m.isActive
                    ? `<span class="badge bg-success">Activo</span>`
                    : `<span class="badge bg-warning text-dark">Inactivo</span>`;

                tr.innerHTML = `
                    <td>
                        <img src="@Url.Content("~/enrollment/admin/img/avatars/avatar.jpg")"
                             width="32"
                             height="32"
                             class="rounded-circle my-n1"
                             alt="Avatar">
                    </td>
                    <td>${m.nombreCompleto ?? ''}</td>
                    <td class="d-none d-md-table-cell">${m.matricula ?? ''}</td>
                    <td class="d-none d-md-table-cell">${m.email ?? ''}</td>
                    <td>${estadoBadge}</td>
                `;

                tablaBody.appendChild(tr);
            });

            tablaContainer.classList.remove('d-none');

            if (window.feather) {
                feather.replace();
            }
        }

        async function cargarMatriculas() {
            try {
                const response = await fetch(API_URL);

                if (!response.ok) {
                    throw new Error('Error al obtener matrículas');
                }

                const matriculas = await response.json();
                matriculasOriginales = matriculas || [];

                loading.classList.add('d-none');
                error.classList.add('d-none');
                empty.classList.add('d-none');

                if (!matriculasOriginales.length) {
                    tablaContainer.classList.add('d-none');
                    empty.classList.remove('d-none');
                    return;
                }

                renderTabla(matriculasOriginales);

            } catch (err) {
                loading.classList.add('d-none');
                tablaContainer.classList.add('d-none');
                empty.classList.add('d-none');
                error.classList.remove('d-none');
                console.error(err);
            }
        }

        window.handleGlobalSearch = function (texto) {
            const termino = (texto || '').toLowerCase().trim();

            if (!termino) {
                renderTabla(matriculasOriginales);
                return;
            }

            const filtradas = matriculasOriginales.filter(m => {
                const nombre = (m.nombreCompleto ?? '').toLowerCase();
                const matricula = (m.matricula ?? '').toLowerCase();
                const email = (m.email ?? '').toLowerCase();
                const estado = m.isActive ? 'activo' : 'inactivo';

                return nombre.includes(termino)
                    || matricula.includes(termino)
                    || email.includes(termino)
                    || estado.includes(termino);
            });

            renderTabla(filtradas);
        };

        cargarMatriculas();
    </script>
}