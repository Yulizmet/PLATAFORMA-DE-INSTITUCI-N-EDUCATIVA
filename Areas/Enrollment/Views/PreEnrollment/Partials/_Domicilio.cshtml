@model SchoolManager.Areas.Enrollment.ViewModels.PreEnrollmentViewModel

<div class="card mb-4">
    <div class="card-header fw-bold text-uppercase">Domicilio</div>

    <div class="card-body row g-3">

        <div class="col-md-6">
            <label asp-for="Domicilio.street" class="form-label">Calle</label>
            <input asp-for="Domicilio.street" class="form-control" placeholder="Nombre de la calle" />
        </div>

        <div class="col-md-3">
            <label asp-for="Domicilio.exterior_number" class="form-label">Número exterior</label>
            <input asp-for="Domicilio.exterior_number" class="form-control" inputmode="numeric" pattern="[0-9]*" placeholder="Ej: 123" />
        </div>

        <div class="col-md-3">
            <label asp-for="Domicilio.interior_number" class="form-label">Número interior</label>
            <input asp-for="Domicilio.interior_number" class="form-control" inputmode="numeric" pattern="[0-9]*" placeholder="Ej: 1A" />
        </div>

        <div class="col-md-4">
            <label asp-for="Domicilio.postal_code" class="form-label">Código Postal</label>
            <input asp-for="Domicilio.postal_code" class="form-control" maxlength="5" inputmode="numeric" pattern="[0-9]{5}" placeholder="5 dígitos" />
        </div>

        <div class="col-md-4">
            <label asp-for="Domicilio.neighborhood" class="form-label">Colonia</label>
            <select asp-for="Domicilio.neighborhood" class="form-select" id="domColonia" disabled>
                <option value="">Sin selección</option>
            </select>
        </div>

        <div class="col-md-4">
            <label asp-for="Domicilio.state" class="form-label">Estado</label>
            <select asp-for="Domicilio.state" class="form-select" id="domEstado">
                <option value="">Sin selección</option>
            </select>
        </div>

        <div class="col-md-4">
            <label asp-for="Domicilio.city" class="form-label">Municipio</label>
            <select asp-for="Domicilio.city" class="form-select" id="domMunicipio" disabled>
                <option value="">Sin selección</option>
            </select>
        </div>

        <div class="col-md-6">
            <label asp-for="Domicilio.phone" class="form-label">Teléfono</label>
            <input asp-for="Domicilio.phone" class="form-control" inputmode="numeric" pattern="[0-9]{10}" maxlength="10" placeholder="10 dígitos" />
        </div>

    </div>
</div>
