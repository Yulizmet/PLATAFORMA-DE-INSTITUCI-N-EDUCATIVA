@model SchoolManager.Areas.Enrollment.ViewModels.PreEnrollmentViewModel

@{
    var modoConfirmacion = (ViewData["ModoConfirmacion"] as bool?) ?? false;
}

<div class="card mb-4" data-section="DatosEscolares">
    <div class="card-header fw-bold text-uppercase d-flex justify-content-between align-items-center">
        Datos escolares

        @if (modoConfirmacion)
        {
            <button type="button"
                    class="btn btn-outline-secondary btn-sm btn-editar"
                    data-target="DatosEscolares">
                Editar
            </button>
        }
    </div>

    <div class="card-body row g-3">

        <!-- ESCUELA Y CARRERA -->
        <div class="col-12 col-md-8">
            <label asp-for="DatosEscolares.school" class="form-label">Escuela de procedencia</label>
            <input asp-for="DatosEscolares.school"
                   class="form-control"
                   id="escProcedencia"
                   required
                   data-required="true" />
        </div>

        <div class="col-12 col-md-4">
            <label asp-for="DatosEscolares.degree" class="form-label">Carrera cursada</label>
            <input asp-for="DatosEscolares.degree"
                   class="form-control"
                   id="escCarrera"
                   required
                   data-required="true" />
        </div>

        <!-- ESTADO Y MUNICIPIO -->
        <div class="col-12 col-sm-6 col-md-4">
            <label asp-for="DatosEscolares.state" class="form-label">Estado</label>
            <select asp-for="DatosEscolares.state"
                    class="form-select"
                    id="escEstado"
                    required
                    data-required="true">
                <option value="">Sin selección</option>
            </select>
            <div class="invalid-feedback">Selecciona un estado.</div>
        </div>

        <div class="col-12 col-sm-6 col-md-4">
            <label asp-for="DatosEscolares.city" class="form-label">Municipio</label>
            <select asp-for="DatosEscolares.city"
                    class="form-select"
                    id="escMunicipio"
                    disabled
                    data-required="true">
                <option value="">Sin selección</option>
            </select>
            <div class="invalid-feedback">Selecciona un municipio.</div>
        </div>

        <!-- PROMEDIO -->
        <div class="col-12 col-sm-6 col-md-2">
            <label asp-for="DatosEscolares.average" class="form-label">Promedio</label>
            <input asp-for="DatosEscolares.average"
                   type="number"
                   step="0.1"
                   min="0"
                   max="10"
                   class="form-control"
                   placeholder="0.0"
                   id="escPromedio"
                   required
                   data-required="true" />
        </div>

        <!-- FECHAS -->
        <div class="col-12 col-sm-6 col-md-2">
            <label asp-for="DatosEscolares.start_date" class="form-label">Fecha de inicio</label>
            <input asp-for="DatosEscolares.start_date"
                   type="date"
                   class="form-control"
                   id="escFechaInicio"
                   lang="en-CA"
                   required
                   data-required="true" />
           
        </div>

        <div class="col-12 col-sm-6 col-md-2">
            <label asp-for="DatosEscolares.end_date" class="form-label">Fecha de terminación</label>
            <input asp-for="DatosEscolares.end_date"
                   type="date"
                   class="form-control"
                   id="escFechaFin"
                   lang="en-CA"
                   required
                   data-required="true" />
           
        </div>

        <!-- SISTEMA DE ESTUDIO Y TIPO DE SECUNDARIA -->
        <div class="col-12 col-md-6 col-lg-3">
            <label asp-for="DatosEscolares.study_system" class="form-label">Sistema de estudio</label>
            <select asp-for="DatosEscolares.study_system"
                    class="form-select"
                    id="escSistema"
                    required
                    data-required="true">
                <option value="">Sin selección</option>
                <option>Por cooperación</option>
                <option>Privada</option>
                <option>Pública</option>
            </select>
           
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <label asp-for="DatosEscolares.high_school_type" class="form-label">Tipo de secundaria</label>
            <select asp-for="DatosEscolares.high_school_type"
                    class="form-select"
                    id="escTipoPrepa"
                    required
                    data-required="true">
                <option value="">Sin selección</option>
                <option>Secundaria General</option>
                <option>Secundaria Técnica</option>
                <option>Telesecundaria</option>
                <option>Secundaria para Trabajadores</option>
                <option>Secundaria para Adultos</option>
                <option>Otro</option>
            </select>
        </div>

    </div>
</div>