@model SchoolManager.Areas.Enrollment.ViewModels.PreEnrollmentViewModel

@{
    var modoConfirmacion = (ViewData["ModoConfirmacion"] as bool?) ?? false;
}

<div class="card mb-4" data-section="OtrosDatos">
    <div class="card-header fw-bold text-uppercase d-flex justify-content-between align-items-center">
        Otros datos

        @if (modoConfirmacion)
        {
            <button type="button"
                    class="btn btn-outline-secondary btn-sm btn-editar"
                    data-target="OtrosDatos">
                Editar
            </button>
        }
    </div>

    <div class="card-body row g-3">

        <!-- BECA -->
        <div class="col-12">
            <label class="form-label fw-semibold d-block">¿Contaba con beca?</label>

            <div class="d-flex flex-wrap gap-3">

                <!-- NO -->
                <div class="form-check">
                    <input asp-for="Otros.beca"
                           class="form-check-input"
                           type="radio"
                           value="No"
                           checked="@(Model?.Otros?.beca == null || Model.Otros.beca == "No")"
                           required />

                    <label class="form-check-label">No</label>
                </div>

                <!-- SÍ -->
                <div class="form-check">
                    <input asp-for="Otros.beca"
                           class="form-check-input"
                           type="radio"
                           value="Sí"
                           checked="@(Model?.Otros?.beca == "Sí")"
                           required />

                    <label class="form-check-label">Sí</label>
                </div>

            </div>
        </div>

        <!-- COMUNIDAD INDIGENA -->
        <div class="col-12">
            <label class="form-label fw-semibold d-block">¿Proviene de alguna comunidad indígena?</label>
            <div class="d-flex flex-wrap gap-3">
                <div class="form-check">
                    <input asp-for="Otros.comu_indi" class="form-check-input" type="radio" value="false" checked>
                    <label class="form-check-label">No</label>
                </div>
                <div class="form-check">
                    <input asp-for="Otros.comu_indi" class="form-check-input" type="radio" value="true">
                    <label class="form-check-label">Sí</label>
                </div>
            </div>
        </div>

        <!-- LENGUA -->
        <div class="col-12">
            <label class="form-label fw-semibold d-block">¿Habla lengua indígena?</label>
            <div class="d-flex flex-wrap gap-3">
                <div class="form-check">
                    <input asp-for="Otros.lengu_indi" class="form-check-input" type="radio" value="false" checked>
                    <label class="form-check-label">No</label>
                </div>
                <div class="form-check">
                    <input asp-for="Otros.lengu_indi" class="form-check-input" type="radio" value="true">
                    <label class="form-check-label">Sí</label>
                </div>
            </div>
        </div>

        <!-- DISCAPACIDAD -->
        <div class="col-12">
            <label class="form-label fw-semibold d-block">¿Padece alguna discapacidad?</label>
            <div class="d-flex flex-wrap gap-3">
                <div class="form-check">
                    <input asp-for="Otros.incapa" class="form-check-input" type="radio" value="false" checked>
                    <label class="form-check-label">No</label>
                </div>
                <div class="form-check">
                    <input asp-for="Otros.incapa" class="form-check-input" type="radio" value="true">
                    <label class="form-check-label">Sí</label>
                </div>
            </div>
        </div>

        <!-- ENFERMEDAD -->
        <div class="col-12">
            <label class="form-label fw-semibold d-block">¿Padece alguna enfermedad?</label>
            <div class="d-flex flex-wrap gap-3">
                <div class="form-check">
                    <input asp-for="Otros.disease" class="form-check-input" type="radio" value="false" checked>
                    <label class="form-check-label">No</label>
                </div>
                <div class="form-check">
                    <input asp-for="Otros.disease" class="form-check-input" type="radio" value="true">
                    <label class="form-check-label">Sí</label>
                </div>
            </div>
        </div>

        <!-- COMO SE ENTERO -->
        <div class="col-12 mt-3">
            <label class="form-label fw-semibold">
                ¿Cómo conoció esta institución y sus programas académicos?
            </label>
            <select asp-for="Otros.comment" class="form-select"
                    required data-required="true">
                <option value="">Sin selección</option>
                <option value="Amigos">Amigos</option>
                <option value="Familia">Familia</option>
                <option value="Redes sociales">Redes sociales</option>
                <option value="Internet">Internet</option>
                <option value="Radio/TV">Radio/TV</option>
                <option value="Feria educativa">Feria educativa</option>
                <option value="Visita a escuela">Visita a escuela</option>
                <option value="Otro">Otro</option>
            </select>
        </div>

    </div>
</div>