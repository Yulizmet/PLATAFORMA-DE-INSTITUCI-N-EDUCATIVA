@model SchoolManager.Areas.Enrollment.ViewModels.PreEnrollmentViewModel

<div class="card mb-4">
    <div class="card-header fw-bold text-uppercase">
        DATOS GENERALES
    </div>

    <div class="card-body">

        <!-- ================= FILA 1 ================= -->
        <div class="row g-3">

            <div class="col-md-4">
                <label asp-for="DatosGenerales.PaternalLastName" class="form-label">
                    Apellido paterno
                </label>
                <input asp-for="DatosGenerales.PaternalLastName" class="form-control" />
                <span asp-validation-for="DatosGenerales.PaternalLastName" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="DatosGenerales.MaternalLastName" class="form-label">
                    Apellido materno
                </label>
                <input asp-for="DatosGenerales.MaternalLastName" class="form-control" />
                <span asp-validation-for="DatosGenerales.MaternalLastName" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label">
                    Nombre(s)
                </label>
                <input type="text" class="form-control" />
            </div>

        </div>

        <!-- ================= FILA 2 ================= -->
        <div class="row g-3 mt-2">

            <div class="col-md-3">
                <label asp-for="DatosGenerales.Gender" class="form-label">
                    Género
                </label>
                <select asp-for="DatosGenerales.Gender" class="form-select">
                    <option value="">Sin selección</option>
                    <option value="Femenino">Femenino</option>
                    <option value="Masculino">Masculino</option>
                </select>
                <span asp-validation-for="DatosGenerales.Gender" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="DatosGenerales.BirthDate" class="form-label">
                    Fecha de nacimiento
                </label>
                <input asp-for="DatosGenerales.BirthDate" type="date" class="form-control" />
                <span asp-validation-for="DatosGenerales.BirthDate" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="DatosGenerales.MaritalStatus" class="form-label">
                    Estado civil
                </label>
                <select asp-for="DatosGenerales.MaritalStatus" class="form-select">
                    <option value="">Sin selección</option>
                    <option>Soltero(a)</option>
                    <option>Casado(a)</option>
                    <option>Viudo(a)</option>
                    <option>Divorciado(a)</option>
                </select>
                <span asp-validation-for="DatosGenerales.MaritalStatus" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="DatosGenerales.Nationality" class="form-label">
                    Nacionalidad
                </label>
                <select asp-for="DatosGenerales.Nationality" class="form-select">
                    <option value="">Sin selección</option>
                    <option>Mexicano(a)</option>
                    <option>Estadounidense</option>
                    <option>Canadiense</option>
                </select>
                <span asp-validation-for="DatosGenerales.Nationality" class="text-danger"></span>
            </div>

        </div>

        <!-- ================= CURP Y CORREO ================= -->
        <div class="row g-3 mt-4">

            <div class="col-md-6">
                <label asp-for="DatosGenerales.Curp" class="form-label">
                    CURP
                </label>

                <div class="input-group">
                    <input asp-for="DatosGenerales.Curp"
                           class="form-control"
                           maxlength="18"
                           placeholder="Ingresa tu CURP"
                           style="text-transform: uppercase;"
                           oninput="this.value = this.value.toUpperCase()" />

                    <a href="https://www.gob.mx/curp/"
                       target="_blank"
                       class="btn btn-outline-primary">
                        Consultar
                    </a>
                </div>

                <small class="text-muted">
                    La CURP debe contener exactamente 18 caracteres.
                </small>

                <span asp-validation-for="DatosGenerales.Curp" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="DatosGenerales.Email" class="form-label">
                    Correo electrónico
                </label>
                <input asp-for="DatosGenerales.Email"
                       class="form-control"
                       placeholder="ejemplo@correo.com" />
                <span asp-validation-for="DatosGenerales.Email" class="text-danger"></span>
            </div>

        </div>

        <!-- ================= SANGRE Y TRABAJA ================= -->
        <div class="row g-3 mt-4">

            <div class="col-md-6">
                <label asp-for="DatosGenerales.BloodType" class="form-label">
                    Tipo de sangre
                </label>
                <select asp-for="DatosGenerales.BloodType" class="form-select">
                    <option value="">Sin selección</option>
                    <option>A+</option>
                    <option>A-</option>
                    <option>B+</option>
                    <option>B-</option>
                    <option>AB+</option>
                    <option>AB-</option>
                    <option>O+</option>
                    <option>O-</option>
                </select>
                <span asp-validation-for="DatosGenerales.BloodType" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">
                    ¿Trabaja?
                </label>

                <div class="d-flex gap-3 mt-2">

                    <div class="form-check m-0">
                        <input asp-for="DatosGenerales.Work"
                               class="form-check-input"
                               type="radio"
                               id="trabajaNo"
                               value="false" />
                        <label class="form-check-label" for="trabajaNo">
                            No
                        </label>
                    </div>

                    <div class="form-check m-0">
                        <input asp-for="DatosGenerales.Work"
                               class="form-check-input"
                               type="radio"
                               id="trabajaSi"
                               value="true" />
                        <label class="form-check-label" for="trabajaSi">
                            Sí
                        </label>
                    </div>

                </div>
            </div>

        </div>

        <!-- ================= CAMPOS DE TRABAJO ================= -->
        <div class="row g-3 mt-3 d-none" id="camposTrabajo">

            <div class="col-md-4">
                <label asp-for="DatosGenerales.Occupation" class="form-label">
                    Ocupación
                </label>
                <input asp-for="DatosGenerales.Occupation" class="form-control" />
                <span asp-validation-for="DatosGenerales.Occupation" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="DatosGenerales.WorkAddress" class="form-label">
                    Dirección del trabajo
                </label>
                <input asp-for="DatosGenerales.WorkAddress" class="form-control" />
                <span asp-validation-for="DatosGenerales.WorkAddress" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="DatosGenerales.WorkPhone" class="form-label">
                    Teléfono del trabajo
                </label>
                <input asp-for="DatosGenerales.WorkPhone"
                       type="tel"
                       class="form-control" />
                <span asp-validation-for="DatosGenerales.WorkPhone" class="text-danger"></span>
            </div>

        </div>

    </div>
</div>

