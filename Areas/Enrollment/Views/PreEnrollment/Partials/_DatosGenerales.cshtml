@model SchoolManager.Areas.Enrollment.ViewModels.PreEnrollmentViewModel

@{
    var modoConfirmacion = (ViewData["ModoConfirmacion"] as bool?) ?? false;
}

<div class="card mb-4" data-section="DatosGenerales">
    <div class="card-header fw-bold text-uppercase d-flex justify-content-between align-items-center">
        DATOS GENERALES

        @if (modoConfirmacion)
        {
            <button type="button"
                    class="btn btn-outline-secondary btn-sm btn-editar"
                    data-target="DatosGenerales">
                Editar
            </button>
        }
    </div>

    <div class="card-body">

        <!-- ================= FILA 1 ================= -->
        <div class="row g-3">

            <div class="col-12 col-md-4">
                <label class="form-label">Apellido Paterno</label>
                <input asp-for="Persona.LastNamePaternal" class="form-control" required data-required="true" />
               
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">Apellido Materno</label>
                <input asp-for="Persona.LastNameMaternal" class="form-control" required data-required="true" />
              
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">Nombre(s)</label>
                <input asp-for="Persona.FirstName" class="form-control" required data-required="true" />
               
            </div>

        </div>

        <!-- ================= FILA 2 ================= -->
        <div class="row g-3 mt-2">

            <div class="col-12 col-sm-6 col-md-3">
                <label class="form-label">Género</label>
                <select asp-for="Persona.Gender" class="form-select" required data-required="true">
                    <option value="">Sin selección</option>
                    <option>Femenino</option>
                    <option>Masculino</option>
                </select>
               
            </div>

            <div class="col-12 col-sm-6 col-md-3">
                <label class="form-label">Fecha de Nacimiento</label>
                <input asp-for="Persona.BirthDate" type="date" class="form-control" required data-required="true" />
               
            </div>

            <div class="col-12 col-sm-6 col-md-3">
                <label class="form-label">Estado Civil</label>
                <select asp-for="DatosGenerales.MaritalStatus" class="form-select" required data-required="true">
                    <option value="">Sin selección</option>
                    <option>Soltero(a)</option>
                    <option>Casado(a)</option>
                    <option>Viudo(a)</option>
                    <option>Divorciado(a)</option>
                </select>
               
            </div>

            <div class="col-12 col-sm-6 col-md-3">
                <label class="form-label">Nacionalidad</label>
                <select asp-for="DatosGenerales.Nationality" class="form-select" required data-required="true">
                    <option value="">Sin selección</option>
                    <option>Mexicano(a)</option>
                    <option>Estadounidense</option>
                    <option>Canadiense</option>
                </select>
            
            </div>

        </div>

        <!-- ================= CURP Y CORREO ================= -->
        <div class="row g-3 mt-4">

            <div class="col-12 col-md-6">
                <label class="form-label">CURP</label>
                <div class="input-group">
                    <input asp-for="Persona.Curp"
                           class="form-control"
                           maxlength="18"
                           placeholder="Ingresa tu CURP"
                           style="text-transform: uppercase;"
                           oninput="this.value = this.value.toUpperCase()"
                           required
                           data-required="true" />
                    <a href="https://www.gob.mx/curp/" target="_blank" class="btn btn-outline-primary">Consultar</a>
                </div>
                <small class="text-muted">La CURP debe contener exactamente 18 caracteres.</small>
               
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label">Correo Electrónico</label>
                <input asp-for="Persona.Email"
                       class="form-control"
                       placeholder="ejemplo@correo.com"
                       required
                       data-required="true" />
              
            </div>

        </div>

        <!-- ================= TIPO DE SANGRE Y TRABAJO ================= -->
        <div class="row g-3 mt-2">

            <div class="col-12 col-md-6">
                <label class="form-label">Tipo de Sangre</label>
                <select asp-for="DatosGenerales.BloodType" class="form-select" required data-required="true">
                    <option value="">Sin selección</option>
                    <option>A+</option>
                    <option>A-</option>
                    <option>B+</option>
                    <option>B-</option>
                    <option>AB+</option>
                    <option>AB-</option>
                    <option>O+</option>
                    <option>O-</option>
                </select>
              
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label d-block">¿Trabaja actualmente?</label>
                <div class="d-flex flex-wrap gap-3 mt-1">
                    <div class="form-check m-0">
                        <input class="form-check-input"
                               type="radio"
                               asp-for="DatosGenerales.Work"
                               id="trabajaNo"
                               value="false"
                               required
                               data-required="true" />
                        <label class="form-check-label" for="trabajaNo">No</label>
                    </div>
                    <div class="form-check m-0">
                        <input class="form-check-input"
                               type="radio"
                               asp-for="DatosGenerales.Work"
                               id="trabajaSi"
                               value="true"
                               required
                               data-required="true" />
                        <label class="form-check-label" for="trabajaSi">Sí</label>
                    </div>
                </div>
               
            </div>

        </div>

        <!-- ================= CAMPOS DE TRABAJO ================= -->
        <div class="row g-3 mt-3 d-none" id="camposTrabajo">
            <div class="col-12 col-md-4">
                <label class="form-label">Ocupación</label>
                <input asp-for="DatosGenerales.Occupation" class="form-control" />
             
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">Dirección de Trabajo</label>
                <input asp-for="DatosGenerales.WorkAddress" class="form-control" />
              
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">Teléfono de Trabajo</label>
                <input asp-for="DatosGenerales.WorkPhone" class="form-control" />
              
            </div>
        </div>

    </div>
</div>