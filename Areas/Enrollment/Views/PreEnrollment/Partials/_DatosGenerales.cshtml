@model SchoolManager.Areas.Enrollment.ViewModels.PreEnrollmentViewModel

<div class="card mb-4">
    <div class="card-header fw-bold text-uppercase">
        DATOS GENERALES
    </div>

    <div class="card-body">

        <!-- ================= FILA 1 ================= -->
        <div class="row g-3">

            <div class="col-md-4">
                <label asp-for="Persona.LastNamePaternal" class="form-label">
                    Apellido paterno
                </label>
                <input asp-for="Persona.LastNamePaternal" class="form-control" />
                <span asp-validation-for="Persona.LastNamePaternal" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Persona.LastNameMaternal" class="form-label">
                    Apellido materno
                </label>
                <input asp-for="Persona.LastNameMaternal" class="form-control" />
                <span asp-validation-for="Persona.LastNameMaternal" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Persona.FirstName" class="form-label">
                    Nombre(s)
                </label>
                <input asp-for="Persona.FirstName" class="form-control" />
                <span asp-validation-for="Persona.FirstName" class="text-danger"></span>
            </div>

        </div>

        <!-- ================= FILA 2 ================= -->
        <div class="row g-3 mt-2">

            <div class="col-md-3">
                <label asp-for="Persona.Gender" class="form-label">
                    Género
                </label>
                <select asp-for="Persona.Gender" class="form-select">
                    <option value="">Sin selección</option>
                    <option value="Femenino">Femenino</option>
                    <option value="Masculino">Masculino</option>
                </select>
                <span asp-validation-for="Persona.Gender" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="Persona.BirthDate" class="form-label">
                    Fecha de nacimiento
                </label>
                <input asp-for="Persona.BirthDate" type="date" class="form-control" />
                <span asp-validation-for="Persona.BirthDate" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="DatosGenerales.MaritalStatus" class="form-label">
                    Estado civil
                </label>
                <select asp-for="DatosGenerales.MaritalStatus" class="form-select">
                    <option value="">Sin selección</option>
                    <option>Soltero(a)</option>
                    <option>Casado(a)</option>
                    <option>Viudo(a)</option>
                    <option>Divorciado(a)</option>
                </select>
                <span asp-validation-for="DatosGenerales.MaritalStatus" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="DatosGenerales.Nationality" class="form-label">
                    Nacionalidad
                </label>
                <select asp-for="DatosGenerales.Nationality" class="form-select">
                    <option value="">Sin selección</option>
                    <option>Mexicano(a)</option>
                    <option>Estadounidense</option>
                    <option>Canadiense</option>
                </select>
                <span asp-validation-for="DatosGenerales.Nationality" class="text-danger"></span>
            </div>

        </div>

        <!-- ================= CURP Y CORREO ================= -->
        <div class="row g-3 mt-4">

            <div class="col-md-6">
                <label asp-for="Persona.Curp" class="form-label">
                    CURP
                </label>

                <div class="input-group">
                    <input asp-for="Persona.Curp"
                           class="form-control"
                           maxlength="18"
                           placeholder="Ingresa tu CURP"
                           style="text-transform: uppercase;"
                           oninput="this.value = this.value.toUpperCase()" />

                    <a href="https://www.gob.mx/curp/"
                       target="_blank"
                       class="btn btn-outline-primary">
                        Consultar
                    </a>
                </div>

                <span asp-validation-for="Persona.Curp" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Persona.Email" class="form-label">
                    Correo electrónico
                </label>
                <input asp-for="Persona.Email"
                       class="form-control"
                       placeholder="ejemplo@correo.com" />
                <span asp-validation-for="Persona.Email" class="text-danger"></span>
            </div>

        </div>

    </div>
</div>