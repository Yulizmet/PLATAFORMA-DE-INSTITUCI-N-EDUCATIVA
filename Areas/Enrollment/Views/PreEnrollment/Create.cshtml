@model SchoolManager.Areas.Enrollment.ViewModels.PreEnrollmentViewModel
@{
    Layout = "~/Areas/Enrollment/Views/_Layout.cshtml";
    ViewData["Title"] = "Preinscripción";
}

<main class="content">

    <div class="container-fluid p-0">
        <h1 class="h3 mb-3"><strong>Datos del Aspirante</strong></h1>
    </div>

    <div class="container my-5">

        <form asp-action="Create" method="post">

            <!-- Carrera -->
            <div class="card mb-4">
                <div class="card-body">
                    <label asp-for="DatosGenerales.IdCareer" class="form-label">
                        Carrera solicitada
                    </label>

                    <select asp-for="DatosGenerales.IdCareer"
                            asp-items="ViewBag.IdCareer"
                            class="form-select"
                            required>
                        <option value="">Sin selección</option>
                    </select>

                    <span asp-validation-for="DatosGenerales.IdCareer" class="text-danger"></span>
                </div>
            </div>

            <!-- 🔥 IMPORTANTE: pasar el Model COMPLETO -->
            <partial name="Partials/_DatosGenerales" model="Model" />
            <partial name="Partials/_DatosEscolares" model="Model" />
            <partial name="Partials/_Domicilio" model="Model" />
            <partial name="Partials/_Tutor" model="Model" />
            <partial name="Partials/_OtrosDatos" model="Model" />

            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary">
                    Continuar
                </button>
            </div>

        </form>

    </div>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
