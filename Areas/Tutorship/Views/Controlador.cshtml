@{
    ViewData["Title"] = "Panel de Control";

}



<div class="dashboard-header position-relative">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold m-0">Bienvenido, @ViewBag.NombreUsuario</h2>
        <i class="bi bi-person-circle fs-2"></i>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="input-group">
                <span class="input-group-text bg-white border-0" style="border-radius: 10px 0 0 10px; padding-left: 20px;">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" class="form-control search-input border-0" placeholder="Buscar alumnos, reportes, grupos..." aria-label="Buscar">

                <button class="btn btn-light ms-2" type="button" style="border-radius: 10px;"><i class="bi bi-funnel-fill"></i></button>
                <button class="btn btn-light ms-2" type="button" style="border-radius: 10px;"><i class="bi bi-grid-fill"></i></button>
            </div>
        </div>
    </div>
</div>

<div class="container" style="margin-top: -2rem;">
    <div class="row g-4">

        <div class="col-md-6 col-lg-3">
            <a asp-area="Gestion" asp-controller="Tutorship" asp-action="EntrevistaInicial" class="text-decoration-none">
                <div class="card dashboard-card shadow-sm p-4 text-center">
                    <div class="card-icon-box">
                        <i class="bi bi-chat-text-fill"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--utt-red);">ENTREVISTA INICIAL</h5>
                    <p class="text-muted small">Módulo de Alumno y Tutor</p>
                    <hr class="my-3" style="border-color: var(--utt-beige);">
                    <span class="status-badge">
                        IR AL MÓDULO <i class="bi bi-arrow-right-short"></i>
                    </span>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">

            <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Asistencia" class="text-decoration-none">
                <div class="card dashboard-card shadow-sm p-4 text-center">
                    <div class="card-icon-box">
                        <i class="bi bi-calendar-check-fill"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--utt-red);">CONTROL ASISTENCIA</h5>
                    <p class="text-muted small">Registro diario por grupo</p>
                    <hr class="my-3" style="border-color: var(--utt-beige);">
                    <span class="status-badge">
                        IR AL MÓDULO <i class="bi bi-arrow-right-short"></i>
                    </span>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Seguimiento" class="text-decoration-none">
                <div class="card dashboard-card shadow-sm p-4 text-center">
                    <div class="card-icon-box">
                        <i class="bi bi-clipboard-data-fill"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--utt-red);">SEGUIMIENTO</h5>
                    <p class="text-muted small">Feedback y reportes</p>
                    <hr class="my-3" style="border-color: var(--utt-beige);">
                    <span class="status-badge">
                        IR AL MÓDULO <i class="bi bi-arrow-right-short"></i>
                    </span>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a asp-area="Gestion" asp-controller="Tutorship" asp-action="ListaDeAlumnos" class="text-decoration-none">
                <div class="card dashboard-card shadow-sm p-4 text-center">
                    <div class="card-icon-box">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--utt-red);">LISTA DE ALUMNOS</h5>
                    <p class="text-muted small">Directorio, fotos y filtros</p>
                    <hr class="my-3" style="border-color: var(--utt-beige);">
                    <span class="status-badge">
                        VER LISTA <i class="bi bi-arrow-right-short"></i>
                    </span>
                </div>
            </a>
        </div>

    </div>
</div>

<div class="text-center mt-5 text-muted small">
    Innovación tecnológica impulsada por la Universidad Tecnológica de Tamaulipas Norte
</div>