@{
    ViewData["Title"] = "Panel de Control - Tutorías";
    int roleId = ViewBag.RoleId ?? 0;
}

<div class="dashboard-header position-relative ">
    <div class="d-flex justify-content-between align-items-center">

        @if (roleId == 1)
        {
            <h2 class="fw-bold m-0">Bienvenido alumno, @ViewBag.NombreUsuario</h2>
        }
        else if (roleId == 2)
        {
            <h2 class="fw-bold m-0">Bienvenido profesor, @ViewBag.NombreUsuario</h2>
        }
        else if (roleId == 3)
        {
            <h2 class="fw-bold m-0">Bienvenido administrador, @ViewBag.NombreUsuario</h2>
        }
        else
        {
            <h2 class="fw-bold m-0">Bienvenido, @ViewBag.NombreUsuario</h2>
        }

        <i class="bi bi-person-circle fs-2"></i>
    </div>

   
</div>


<div class="container mt-4">
    <div class="row g-4 justify-content-center">

        @if (roleId == 1)
        {
            <div class="col-12 col-md-6">
                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="EntrevistaInicial" class="text-decoration-none">
                    <div class="card dashboard-card shadow-sm p-4 text-center h-100">
                        <div class="card-icon-box">
                            <i class="bi bi-chat-text-fill"></i>
                        </div>
                        <h5 class="fw-bold" style="color: var(--utt-red);">ENTREVISTA INICIAL</h5>
                        <p class="text-muted small">Módulo de Alumno y Tutor</p>
                        <hr class="my-3" style="border-color: var(--utt-beige);">
                        <span class="status-badge">
                            LLENAR ENTREVISTA <i class="bi bi-arrow-right-short"></i>
                        </span>
                    </div>
                </a>
            </div>
        }

        @if (roleId == 2)
        {
            <div class="col-12 col-md-6">
                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Asistencia" class="text-decoration-none">
                    <div class="card dashboard-card shadow-sm p-4 text-center h-100">
                        <div class="card-icon-box">
                            <i class="bi bi-calendar-check-fill"></i>
                        </div>
                        <h5 class="fw-bold" style="color: var(--utt-red);">CONTROL ASISTENCIA</h5>
                        <p class="text-muted small">Registro diario por grupo</p>
                        <hr class="my-3" style="border-color: var(--utt-beige);">
                        <span class="status-badge">
                            IR AL MÓDULO <i class="bi bi-arrow-right-short"></i>
                        </span>
                    </div>
                </a>
            </div>

            @* <div class="col-12 col-md-6">
                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Seguimiento" class="text-decoration-none">
                    <div class="card dashboard-card shadow-sm p-4 text-center h-100">
                        <div class="card-icon-box">
                            <i class="bi bi-clipboard-data-fill"></i>
                        </div>
                        <h5 class="fw-bold" style="color: var(--utt-red);">SEGUIMIENTO</h5>
                        <p class="text-muted small">Feedback y reportes</p>
                        <hr class="my-3" style="border-color: var(--utt-beige);">
                        <span class="status-badge">
                            IR AL MÓDULO <i class="bi bi-arrow-right-short"></i>
                        </span>
                    </div>
                </a>
            </div> *@

            <div class="col-12 col-md-6">
                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="ListaDeAlumnos" class="text-decoration-none">
                    <div class="card dashboard-card shadow-sm p-4 text-center h-100">
                        <div class="card-icon-box">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <h5 class="fw-bold" style="color: var(--utt-red);">LISTA DE ALUMNOS</h5>
                        <p class="text-muted small">Directorio, fotos y filtros</p>
                        <hr class="my-3" style="border-color: var(--utt-beige);">
                        <span class="status-badge">
                            VER LISTA <i class="bi bi-arrow-right-short"></i>
                        </span>
                    </div>
                </a>
            </div>

            <div class="col-12 col-md-6">
                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="ReporteEntrevistas" class="text-decoration-none">
                    <div class="card dashboard-card shadow-sm p-4 text-center h-100">
                        <div class="card-icon-box">
                            <i class="bi bi-file-earmark-person-fill"></i>
                        </div>
                        <h5 class="fw-bold mt-3" style="color: var(--utt-red);">ESTATUS ENTREVISTAS</h5>
                        <p class="text-muted small">Revisa quién de tu grupo falta por llenar</p>
                        <hr class="my-3" style="border-color: var(--utt-beige);">
                        <span class="status-badge">
                            VER MI GRUPO <i class="bi bi-arrow-right-short"></i>
                        </span>
                    </div>
                </a>
            </div>
        }

        @if (roleId == 3)
        {
            <div class="col-12 col-md-6">
                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="ListaDeAlumnos" class="text-decoration-none">
                    <div class="card dashboard-card shadow-sm p-4 text-center h-100">
                        <div class="card-icon-box" style="background-color: var(--utt-beige); color: var(--utt-dark-red);">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <h5 class="fw-bold mt-3" style="color: var(--utt-red);">LISTA DE ALUMNOS</h5>
                        <p class="text-muted small">Directorio general de la escuela</p>
                        <hr class="my-3" style="border-color: var(--utt-beige);">
                        <span class="status-badge">
                            VER LISTA <i class="bi bi-arrow-right-short"></i>
                        </span>
                    </div>
                </a>
            </div>

            <div class="col-12 col-md-6">
                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Asistencia" class="text-decoration-none">
                    <div class="card dashboard-card shadow-sm p-4 text-center h-100">
                        <div class="card-icon-box" style="background-color: var(--utt-beige); color: var(--utt-dark-red);">
                            <i class="bi bi-calendar-check-fill"></i>
                        </div>
                        <h5 class="fw-bold mt-3" style="color: var(--utt-red);">CONTROL ASISTENCIA</h5>
                        <p class="text-muted small">Revisar asistencia por grupos</p>
                        <hr class="my-3" style="border-color: var(--utt-beige);">
                        <span class="status-badge">
                            VER ASISTENCIA <i class="bi bi-arrow-right-short"></i>
                        </span>
                    </div>
                </a>
            </div>

            <div class="col-12 col-md-6">
                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="AsignarTutores" class="text-decoration-none">
                    <div class="card dashboard-card shadow-sm p-4 text-center h-100">
                        <div class="card-icon-box" style="background-color: var(--utt-beige); color: var(--utt-dark-red);">
                            <i class="bi bi-diagram-3-fill"></i>
                        </div>
                        <h5 class="fw-bold mt-3" style="color: var(--utt-red);">ASIGNAR TUTORES</h5>
                        <p class="text-muted small">Vincular maestros con grupos</p>
                        <hr class="my-3" style="border-color: var(--utt-beige);">
                        <span class="status-badge">
                            GESTIONAR <i class="bi bi-arrow-right-short"></i>
                        </span>
                    </div>
                </a>
            </div>

            <div class="col-12 col-md-6">
                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="ReporteEntrevistas" class="text-decoration-none">
                    <div class="card dashboard-card shadow-sm p-4 text-center h-100">
                        <div class="card-icon-box" style="background-color: var(--utt-beige); color: var(--utt-dark-red);">
                            <i class="bi bi-file-earmark-bar-graph-fill"></i>
                        </div>
                        <h5 class="fw-bold mt-3" style="color: var(--utt-red);">REPORTE GENERAL</h5>
                        <p class="text-muted small">Ver estatus de toda la escuela</p>
                        <hr class="my-3" style="border-color: var(--utt-beige);">
                        <span class="status-badge">
                            VER REPORTE <i class="bi bi-arrow-right-short"></i>
                        </span>
                    </div>
                </a>
            </div>

            <div class="col-12 col-md-6">
                <div class="card dashboard-card shadow-sm p-4 text-center h-100">
                    <div class="card-icon-box" style="background-color: var(--utt-beige); color: var(--utt-dark-red);">
                        <i class="bi bi-arrow-clockwise"></i>
                    </div>

                    <h5 class="fw-bold mt-3" style="color: var(--utt-red);">NUEVO CICLO</h5>
                    <p class="text-muted small">Requerir actualización de datos a todos los alumnos</p>
                    <hr class="my-3" style="border-color: var(--utt-beige);">

                    <button type="button" class="btn btn-sm w-100 fw-bold shadow-sm"
                            style="background-color: var(--utt-dark-red); color: white;"
                            data-bs-toggle="modal" data-bs-target="#modalNuevoCiclo">
                        <i class="bi bi-exclamation-circle"></i> SOLICITAR ACTUALIZACIÓN
                    </button>
                </div>
            </div>
        }

    </div>
</div>

<div class="modal fade" id="modalNuevoCiclo" tabindex="-1" aria-labelledby="modalNuevoCicloLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <div class="modal-header" style="background-color: var(--utt-dark-red); color: white;">
                <h5 class="modal-title fw-bold" id="modalNuevoCicloLabel">
                    <i class=""></i> Confirmar Nuevo Ciclo
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            <div class="modal-body p-4" style="background-color: var(--utt-white);">
                <p class="text-dark fs-5 text-center mb-4">
                    ¿Estás seguro de iniciar un nuevo ciclo escolar?
                </p>
                <div class="">
                    <strong><i class="bi bi-info-circle-fill"></i> Atención:</strong> Esto cambiará el estatus de <em>todas</em> las entrevistas a "Requiere Actualización" y obligará a todos los alumnos a revisar y guardar su información nuevamente.
                </div>
            </div>

            <div class="modal-footer" style="background-color: var(--utt-light);">
                <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Cancelar</button>

                <form asp-area="Gestion" asp-controller="Tutorship" asp-action="ReiniciarEntrevistasCuatrimestre" method="post">
                    <button type="submit" class="btn fw-bold text-white shadow-sm" style="background-color: var(--utt-red);">
                        <i class="bi bi-check-circle-fill"></i> Sí, Iniciar Ciclo
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

<div class="text-center mt-5 text-muted small">
@*     Innovación tecnológica impulsada por la Universidad Tecnológica de Tamaulipas Norte
 *@</div>