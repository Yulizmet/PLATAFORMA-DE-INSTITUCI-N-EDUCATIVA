@model IEnumerable<SchoolManager.Models.users_user>
@{
    ViewData["Title"] = "Directorio de Alumnos";
    
    int roleId = ViewBag.RoleId ?? 0;

    var dictGruposCabecera = ViewBag.Grupos as Dictionary<int, string> ?? new Dictionary<int, string>();
    string nombreMiGrupo = "Cargando grupo...";
    
    if (roleId == 2 && Model != null && Model.Any())
    {
        int primerId = Model.First().UserId;
        if (dictGruposCabecera.ContainsKey(primerId))
        {
            nombreMiGrupo = dictGruposCabecera[primerId];
        }
    }
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

<div class="container-fluid p-3 p-md-4 mt-2 mt-md-4">
    
    <div class="d-flex flex-column flex-md-row align-items-center justify-content-center position-relative mb-4 gap-3">
        <div class="w-100 w-md-auto text-start text-md-center position-md-absolute start-0 top-50 translate-middle-y-md">
            <button type="button" onclick="history.back()" class="btn btn-sm btn-outline-secondary fw-bold shadow-sm px-3" style="border-radius: 20px;">
                <i class="bi bi-arrow-left me-1"></i> Regresar
            </button>
        </div>
        <h2 class="fw-bold m-0 text-center fs-4 fs-md-2" style="color: var(--brand-dark);">Directorio de Alumnos</h2>
    </div>
    
    <div class="card border-0 shadow-sm mb-4 mb-md-5" style="border-radius: 10px;">
        <div class="card-body p-3 p-md-4">
            
            @if (roleId == 3)
            {
                <form id="filtroForm" class="row g-3 align-items-end">
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-bold text-dark mb-1">Grado</label>
                        <select id="filtroGrado" class="form-select shadow-sm" name="grado" style="border-color: #ddd;">
                            <option value="">Todos los grados...</option>
                            @if (ViewBag.GradosDisponibles != null)
                            {
                                foreach (int gradoDb in ViewBag.GradosDisponibles)
                                {
                                    <option value="@gradoDb" selected="@(ViewBag.GradoSeleccionado == gradoDb)">@gradoDb</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-5">
                        <label class="form-label fw-bold text-dark mb-1">Grupo</label>
                        <select id="filtroGrupo" class="form-select shadow-sm" name="grupo" style="border-color: #ddd;">
                            <option value="">Todos los grupos...</option>
                            @if (ViewBag.GruposDisponibles != null)
                            {
                                foreach (string grupoDb in ViewBag.GruposDisponibles)
                                {
                                    <option value="@grupoDb" selected="@(ViewBag.GrupoSeleccionado == grupoDb)">@grupoDb</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-3 mt-4 mt-md-0">
                        <button type="submit" class="btn btn-secondary-brand w-100 fw-bold shadow-sm py-2">
                            <i class="bi bi-funnel-fill"></i> Filtrar Lista
                        </button>
                    </div>
                </form>
            }
            else if (roleId == 2)
            {
                <div class="row g-3 align-items-end">
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-bold mb-1" style="color: var(--brand-dark);"><i class="bi bi-person-video3 me-2"></i>Mi Grupo Asignado</label>
                        <input type="text" class="form-control shadow-sm bg-light fw-bold" value="@nombreMiGrupo" readonly disabled style="border-color: #ddd; color: #555;">
                    </div>
                </div>
            }

            @if (ViewBag.MensajeFiltro != null)
            {
                <div class="alert alert-warning mt-4 mb-0 text-center fw-bold shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.MensajeFiltro
                </div>
            }
        </div>
    </div>

    <div class="table-responsive bg-white rounded shadow-sm border p-2 p-md-3">
        <table id="tablaAlumnos" class="table table-hover table-cards w-100 mb-0">
            <thead class="table-light">
                <tr>
                    <th class="text-center py-3" style="min-width: 80px;">Foto</th>
                    <th class="py-3 min-vw-25">Información del Alumno</th>
                    <th class="text-start text-sm-end py-3" style="min-width: 280px; padding-right: 1.5rem;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <style>
        .dataTables_wrapper .row:first-child { margin-bottom: 1.5rem; padding: 0 0.5rem; }
        .dataTables_wrapper .row:last-child { margin-top: 1.5rem; padding: 0 0.5rem; }
        div.dataTables_wrapper div.dataTables_filter input {
            border-radius: 8px; border: 1px solid #ced4da; padding: 0.35rem 0.75rem; transition: all 0.15s ease-in-out;
            width: 100%; 
            max-width: 300px;
        }
        div.dataTables_wrapper div.dataTables_filter input:focus {
            outline: none; border-color: var(--brand-dark); box-shadow: 0 0 0 0.25rem rgba(140, 27, 27, 0.25); 
        }
        div.dataTables_wrapper div.dataTables_length select { border-radius: 8px; border: 1px solid #ced4da; padding-left: 0.5rem; }
    </style>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            var tabla = $('#tablaAlumnos').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                pageLength: 10,
                processing: true,
                serverSide: true, 
                ajax: {
                    url: "@Url.Action("ObtenerDataAlumnos", "Alumnos", new { area = "Gestion" })",
                    type: "GET",
                    data: function (d) {
                        d.grado = $('#filtroGrado').val();
                        d.grupo = $('#filtroGrupo').val();
                    }
                },
                columns: [
                    { 
                        data: null, 
                        orderable: false, 
                        className: "text-center ps-2 ps-md-3 align-middle",
                        render: function(data, type, row) {
                            let imgSrc = row.foto ? row.foto : "https://ui-avatars.com/api/?name=" + encodeURIComponent(row.nombre) + "&background=8C1B1B&color=fff";
                            return '<img src="' + imgSrc + '" alt="Foto" class="rounded-circle border" style="object-fit: cover; width: 50px; height: 50px; border-color: #ddd !important;">';
                        }
                    },
                    { 
                        data: "nombreCompleto",
                        className: "align-middle",
                        render: function(data, type, row) {
                            return '<div class="fw-bold fs-6 text-dark mb-1 text-wrap text-break">' + data + '</div>' +
                                   '<div class="text-muted small d-flex flex-wrap gap-1">' +
                                        '<span class="badge bg-light text-dark border">Matrícula: ' + row.matricula + '</span>' +
                                        '<span class="badge" style="background-color: var(--brand-secondary); color: var(--brand-white);">Grado y Grupo: ' + row.grupoTexto + '</span>' +
                                   '</div>';
                        }
                    },
                    { 
                        data: null, 
                        orderable: false, 
                        className: "text-start text-sm-end pe-2 pe-md-3 align-middle",
                        render: function(data, type, row) {
                            let urlEntrevista = '@Url.Action("VerEntrevistaAlumno", "Entrevista", new { area = "Gestion" })/' + row.userId;
                            let urlSeguimiento = '@Url.Action("Seguimiento", "Seguimiento", new { area = "Gestion" })?matriculaBuscar=' + encodeURIComponent(row.matricula);

                            return '<div class="d-flex flex-column flex-sm-row gap-2 justify-content-sm-end mt-2 mt-sm-0">' +
                                        '<a href="' + urlEntrevista + '" class="btn btn-action-seguimiento shadow-sm btn-sm px-3 py-2 text-center w-100 w-sm-auto"><i class="bi bi-file-text me-1"></i> Entrevista</a>' +
                                        '<a href="' + urlSeguimiento + '" class="btn btn-action-seguimiento shadow-sm btn-sm px-3 py-2 text-center w-100 w-sm-auto"><i class="bi bi-graph-up me-1"></i> Seguimiento</a>' +
                                   '</div>';
                        }
                    }
                ]
            });

            $('#filtroForm').on('submit', function (e) {
                e.preventDefault();
                tabla.ajax.reload();
            });
        });
    </script>
}