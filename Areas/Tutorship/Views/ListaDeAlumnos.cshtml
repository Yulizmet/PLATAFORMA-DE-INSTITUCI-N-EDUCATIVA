@{
    ViewData["Title"] = "Mis Alumnos Asignados";
}



<div class="container-fluid p-0">

    <h2 class="fw-bold mb-4" style="color: var(--utt-dark-red);">Directorios de Alumnos</h2>

    <div class="filter-container">
        <form class="row g-3 align-items-end" method="get" asp-action="ListaDeAlumnos">

            <div class="col-md-4">
                <label class="form-label fw-bold">Grado</label>
                <select class="form-select" name="grado" style="border-color: var(--utt-beige);">
                    <option value="">Todos los grados...</option>
                    @if (ViewBag.GradosDisponibles != null)
                    {
                        foreach (int gradoDb in ViewBag.GradosDisponibles)
                        {
                            if (ViewBag.GradoSeleccionado == gradoDb)
                            {
                                <option value="@gradoDb" selected>@gradoDb</option>
                            }
                            else
                            {
                                <option value="@gradoDb">@gradoDb</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label fw-bold">Grupo</label>
                <select class="form-select" name="grupo" style="border-color: var(--utt-beige);">
                    <option value="">Todos los grupos...</option>
                    @if (ViewBag.GruposDisponibles != null)
                    {
                        foreach (string grupoDb in ViewBag.GruposDisponibles)
                        {
                            if (ViewBag.GrupoSeleccionado == grupoDb)
                            {
                                <option value="@grupoDb" selected>@grupoDb</option>
                            }
                            else
                            {
                                <option value="@grupoDb">@grupoDb</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="col-md-4">
                <button type="submit" class="btn w-100 fw-bold"
                        style="background-color: var(--utt-beige); color: var(--utt-dark-red);">
                    <i class="bi bi-funnel-fill"></i> Filtrar Lista
                </button>
            </div>
        </form>

        @if (ViewBag.MensajeFiltro != null)
        {
            <div class="alert alert-warning mt-3 text-center">
                <i class="bi bi-exclamation-triangle"></i> @ViewBag.MensajeFiltro
            </div>
        }
    </div>

    <div class="student-list">

        <div class="d-none d-md-flex px-4 mb-2 text-muted small fw-bold">
            <div style="width: 70px;">FOTO</div>
            <div class="flex-grow-1">INFORMACIÓN DEL ALUMNO</div>
            <div style="width: 300px;" class="text-center">ACCIONES</div>
        </div>

        @{
            var dictMatriculas = ViewBag.Matriculas as Dictionary<int, string> ?? new Dictionary<int, string>();
            var dictGrupos = ViewBag.Grupos as Dictionary<int, string> ?? new Dictionary<int, string>();
            var dictFotos = ViewBag.FotosPerfil as Dictionary<int, string> ?? new Dictionary<int, string>();
        }

        @foreach (var alumno in Model)
        {
            @if (alumno.Person != null)
            {
                string matriculaAlumno = dictMatriculas.ContainsKey(alumno.UserId) ? dictMatriculas[alumno.UserId] : "Sin Matrícula";
                string grupoAlumno = dictGrupos.ContainsKey(alumno.UserId) ? dictGrupos[alumno.UserId] : "Sin Grupo";

                string rutaFoto = dictFotos.ContainsKey(alumno.UserId) ? dictFotos[alumno.UserId] : "";
                bool tieneFoto = !string.IsNullOrEmpty(rutaFoto);

                string imgSrc = tieneFoto
                ? rutaFoto
                : $"https://ui-avatars.com/api/?name={alumno.Person.FirstName}&background=8C1B1B&color=fff";

                <div class="student-row">
                    <div style="width: 70px;">
                        <img src="@imgSrc" class="avatar-circle" alt="Foto de @alumno.Person.FirstName" style="object-fit: cover; width: 50px; height: 50px; border-radius: 50%;">
                    </div>

                    <div class="flex-grow-1 ps-2">
                        <div class="student-name">@alumno.Person.FirstName @alumno.Person.LastNamePaternal @alumno.Person.LastNameMaternal</div>

                        <div class="student-meta">
                            Matrícula: @matriculaAlumno | Grado y Grupo: @grupoAlumno
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end flex-wrap">
                        <a asp-area="Gestion" asp-controller="Tutorship" asp-action="VerEntrevistaAlumno" asp-route-id="@alumno.UserId" class="btn btn-action-entrevista">
                            <i class="bi bi-file-text"></i> Ver Entrevista
                        </a>

                        <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Seguimiento" asp-route-matriculaBuscar="@matriculaAlumno" class="btn btn-action-seguimiento">
                            <i class="bi bi-graph-up"></i> Ver Seguimiento
                        </a>
                    </div>
                </div>
            }
        }
        @* <div class="student-row">
            <div style="width: 70px;">
                <img src="https://ui-avatars.com/api/?name=Diego+Gonzalez&background=8C1B1B&color=fff" class="avatar-circle" alt="Foto">
            </div>
            <div class="flex-grow-1 ps-2">
                <div class="student-name">Diego González</div>
                <div class="student-meta">Matrícula: 220015 • TIC-4A</div>
            </div>
            <div class="d-flex gap-2 justify-content-end flex-wrap">
                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="DetalleEntrevista" asp-route-id="3" class="btn btn-action-entrevista">
                    <i class="bi bi-file-text"></i> Ver Entrevista
                </a>
                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Seguimiento" asp-route-id="3" class="btn btn-action-seguimiento">
                    <i class="bi bi-graph-up"></i> Ver Seguimiento
                </a>
            </div>
        </div> *@
    </div>
</div>