@model IEnumerable<SchoolManager.Models.users_user>
@{
    ViewData["Title"] = "Directorio de Alumnos";
    
    int roleId = ViewBag.RoleId ?? 0;

    var dictGruposCabecera = ViewBag.Grupos as Dictionary<int, string> ?? new Dictionary<int, string>();
    string nombreMiGrupo = "Cargando grupo...";
    
    if (roleId == 2 && Model != null && Model.Any())
    {
        int primerId = Model.First().UserId;
        if (dictGruposCabecera.ContainsKey(primerId))
        {
            nombreMiGrupo = dictGruposCabecera[primerId];
        }
    }
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

<div class="container-fluid p-0 mt-4">
    <div class="position-relative mb-4 text-center">
        <div class="position-absolute top-50 start-0 translate-middle-y">
            <button type="button" onclick="history.back()" class="btn btn-sm btn-outline-secondary fw-bold shadow-sm px-3" style="border-radius: 20px;">
                <i class="bi bi-arrow-left me-1"></i> Regresar
            </button>
        </div>

        <h2 class="fw-bold m-0" style="color: var(--brand-dark);">Directorio de Alumnos</h2>
    </div>
    <div class="card border-0 shadow-sm mb-5" style="border-radius: 10px;">
        <div class="card-body p-4">
            
            @if (roleId == 3)
            {
                <form class="row g-3 align-items-end" method="get"  asp-controller="Alumnos" asp-action="ListaDeAlumnos">
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-dark">Grado</label>
                        <select class="form-select shadow-sm" name="grado" style="border-color: #ddd;">
                            <option value="">Todos los grados...</option>
                            @if (ViewBag.GradosDisponibles != null)
                            {
                                foreach (int gradoDb in ViewBag.GradosDisponibles)
                                {
                                    <option value="@gradoDb" selected="@(ViewBag.GradoSeleccionado == gradoDb)">@gradoDb</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-5">
                        <label class="form-label fw-bold text-dark">Grupo</label>
                        <select class="form-select shadow-sm" name="grupo" style="border-color: #ddd;">
                            <option value="">Todos los grupos...</option>
                            @if (ViewBag.GruposDisponibles != null)
                            {
                                foreach (string grupoDb in ViewBag.GruposDisponibles)
                                {
                                    <option value="@grupoDb" selected="@(ViewBag.GrupoSeleccionado == grupoDb)">@grupoDb</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <button type="submit" class="btn btn-secondary-brand w-100 fw-bold shadow-sm">
                            <i class="bi bi-funnel-fill"></i> Filtrar Lista
                        </button>
                    </div>
                </form>
            }
            else if (roleId == 2)
            {
                <div class="row g-3 align-items-end">
                    <div class="col-md-6">
                        <label class="form-label fw-bold" style="color: var(--brand-dark);"><i class="bi bi-person-video3 me-2"></i>Mi Grupo Asignado</label>
                        <input type="text" class="form-control shadow-sm bg-light fw-bold" value="@nombreMiGrupo" readonly disabled style="border-color: #ddd; color: #555;">
                    </div>
                </div>
            }

            @if (ViewBag.MensajeFiltro != null)
            {
                <div class="alert alert-warning mt-4 mb-0 text-center fw-bold shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.MensajeFiltro
                </div>
            }
        </div>
    </div>

    <table id="tablaAlumnos" class="table table-cards w-100">
        <thead>
            <tr>
                <th class="text-center" style="width: 80px;">Foto</th>
                <th>Información del Alumno</th>
                <th class="text-end" style="width: 320px; padding-right: 1.5rem;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @{
                var dictMatriculas = ViewBag.Matriculas as Dictionary<int, string> ?? new Dictionary<int, string>();
                var dictGrupos = ViewBag.Grupos as Dictionary<int, string> ?? new Dictionary<int, string>();
                var dictFotos = ViewBag.FotosPerfil as Dictionary<int, string> ?? new Dictionary<int, string>();
            }

            @foreach (var alumno in Model)
            {
                @if (alumno.Person != null)
                {
                    string matriculaAlumno = dictMatriculas.ContainsKey(alumno.UserId) ? dictMatriculas[alumno.UserId] : "Sin Matrícula";
                    string grupoAlumno = dictGrupos.ContainsKey(alumno.UserId) ? dictGrupos[alumno.UserId] : "Sin Grupo";
                    string rutaFoto = dictFotos.ContainsKey(alumno.UserId) ? dictFotos[alumno.UserId] : "";
                    bool tieneFoto = !string.IsNullOrEmpty(rutaFoto);

                    string imgSrc = tieneFoto ? rutaFoto : $"https://ui-avatars.com/api/?name={alumno.Person.FirstName}&background=8C1B1B&color=fff";
                    string nombreCompleto = $"{alumno.Person.FirstName} {alumno.Person.LastNamePaternal} {alumno.Person.LastNameMaternal}";

                    <tr>
                        <td class="text-center ps-3">
                            <img src="@imgSrc" alt="Foto" class="rounded-circle border" style="object-fit: cover; width: 55px; height: 55px; border-color: #ddd !important;">
                        </td>

                        <td data-sort="@nombreCompleto">
                            <div class="fw-bold fs-6 text-dark mb-1">@nombreCompleto</div>
                            <div class="text-muted small">
                                <span class="badge bg-light text-dark border me-2">Matrícula: @matriculaAlumno</span>
                                <span class="badge" style="background-color: var(--brand-secondary); color: var(--brand-white);">Grado y Grupo: @grupoAlumno</span>
                            </div>
                        </td>

                        <td class="text-end pe-3">
                            <div class="d-flex gap-2 justify-content-end">
                                <a asp-area="Gestion" asp-controller="Seguimiento" asp-action="VerEntrevistaAlumno" asp-route-id="@alumno.UserId" class="btn btn-action-seguimiento shadow-sm btn-sm px-3 py-2">
                                    <i class="bi bi-file-text"></i> Entrevista
                                </a>
                                <a asp-area="Gestion" asp-controller="Seguimiento" asp-action="Seguimiento" asp-route-matriculaBuscar="@matriculaAlumno" class="btn btn-action-seguimiento shadow-sm btn-sm px-3 py-2">
                                    <i class="bi bi-graph-up"></i> Seguimiento
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
        $('#tablaAlumnos').DataTable({
        language: {
        url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
        },
        lengthMenu: [[10, 25, 50, -1], [10, 25, 50, "Todos"]],
        pageLength: 10,
        columnDefs: [
        { orderable: false, targets: [0, 2] },
        { searchable: false, targets: [0, 2] }
        ],
        order: [[1, 'asc']]
        });
        });
    </script>
}