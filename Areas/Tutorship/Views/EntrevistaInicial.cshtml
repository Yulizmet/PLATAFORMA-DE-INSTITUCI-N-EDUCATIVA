@model SchoolManager.Models.users_user

@{
    ViewData["Title"] = "Entrevista Inicial";
    var entrevistaGuardada = ViewBag.Entrevista as SchoolManager.Models.tutorship_interview;
    bool estaCompletada = entrevistaGuardada != null && entrevistaGuardada.Status == "Completada";
    bool requiereActualizacion = entrevistaGuardada != null && entrevistaGuardada.Status == "Requiere Actualizacion";
    string atributoBloqueo = estaCompletada ? "disabled" : "";

    var rutaImagen = (entrevistaGuardada != null && !string.IsNullOrEmpty(entrevistaGuardada.FilePath) && entrevistaGuardada.FilePath != "Sin archivo")
        ? entrevistaGuardada.FilePath
        : "https://via.placeholder.com/150?text=Sin+Foto";
}

<div class="container-fluid px-3 px-md-4 mt-4 mb-5">
    <div class="row align-items-center mb-4 mt-3">
        <div class="col-12 col-md-3 text-start mb-3 mb-md-0">
            <button type="button" onclick="history.back()" class="btn btn-sm btn-outline-secondary fw-bold shadow-sm px-3" style="border-radius: var(--radius-pill);">
                <i class="bi bi-arrow-left me-1"></i> Regresar
            </button>
        </div>
        <div class="col-12 col-md-6 text-center">
            <h2 class="fw-bold m-0" style="color: var(--brand-dark); font-family: var(--font-titulos);">Entrevista Inicial de Tutoría</h2>
        </div>
        <div class="col-12 col-md-3 d-none d-md-block"></div>
    </div>

    <div class="card border-0 shadow-soft" style="background-color: var(--surface-card); border-radius: var(--radius-md); overflow: hidden;">
        <div class="card-body p-4">

            @if (requiereActualizacion)
            {
                <div class="alert alert-warning shadow-sm border-0 mb-4" style="border-radius: var(--radius-sm);">
                    <h5 class="fw-bold"><i class="bi bi-bell-fill"></i> ¡Nuevo Ciclo Escolar!</h5>
                    <p class="mb-0">Por favor, revisa que tu información sea correcta y actualiza si es necesario.</p>
                </div>
            }

            <form asp-area="Gestion" asp-controller="Entrevista" asp-action="GuardarEntrevista" method="post" enctype="multipart/form-data">
                <input type="hidden" name="UserId" value="@Model.UserId" />

                <div class="p-4 rounded mb-4 shadow-sm" style="background-color: var(--surface-muted); border: 1px solid var(--border-soft);">
                    <h5 class="fw-bold mb-4" style="color: var(--brand-dark); font-family: var(--font-titulos);">Datos del Alumno</h5>
                    <div class="row align-items-center">
                        <div class="col-12 col-md-3 text-center mb-4 mb-md-0">
                            <div class="position-relative d-inline-block">
                                <img id="previewFoto" src="@rutaImagen" class="rounded-circle shadow-soft border border-4 border-white" style="width: 140px; height: 140px; object-fit: cover;">
                                <label id="btnCamara" for="inputFoto" class="position-absolute bottom-0 end-0 btn btn-sm text-white rounded-circle shadow" style="width: 38px; height: 38px; background-color: var(--brand-primary); display: flex; align-items: center; justify-content: center; cursor: pointer; @(estaCompletada ? "pointer-events: none; opacity: 0.5;" : "")">
                                    <i class="bi bi-camera-fill"></i>
                                </label>
                                <input type="file" id="inputFoto" name="FotoPerfil" accept="image/*" class="d-none" onchange="mostrarPrevisualizacion(this)" @atributoBloqueo>
                            </div>
                        </div>
                        <div class="col-12 col-md-9">
                            <div class="row g-3">
                                <div class="col-12 col-sm-6">
                                    <label class="form-label fw-bold small text-muted">Nombre Completo</label>
                                    <input type="text" class="form-control bg-white border-0 shadow-sm" value="@Model.Person.FirstName @Model.Person.LastNamePaternal @Model.Person.LastNameMaternal" readonly>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label class="form-label fw-bold small text-muted">Matrícula</label>
                                    <input type="text" class="form-control bg-white border-0 shadow-sm" value="@ViewBag.Matricula" readonly>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label class="form-label fw-bold small text-muted">Correo</label>
                                    <input type="text" class="form-control bg-white border-0 shadow-sm" value="@Model.Person.Email" readonly>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label class="form-label fw-bold small text-muted">Carrera</label>
                                    <select class="form-select border-0 shadow-sm" name="Carrera" @atributoBloqueo required>
                                        <option value="">Seleccione una carrera...</option>
                                        <option value="Software">Desarrollo de Software</option>
                                        <option value="Mantenimiento">Mantenimiento Industrial</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <h5 class="mb-4 mt-5 fw-bold" style="color: var(--brand-dark); border-bottom: 2px solid var(--brand-secondary); padding-bottom: 8px; font-family: var(--font-titulos);">I. Aspectos Personales y Familiares</h5>
                <div class="row g-4">
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-bold">1. Estado Civil</label>
                        <select class="form-select border-0 shadow-sm" name="EstadoCivil" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="Soltero">Soltero/a</option>
                            <option value="Casado">Casado/a</option>
                            <option value="UnionLibre">Unión Libre</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-bold">2. ¿Tienes hijos?</label>
                        <select class="form-select border-0 shadow-sm" name="TieneHijos" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="No">No</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3+">3 o más</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-bold">3. ¿Trabajas actualmente?</label>
                        <select class="form-select border-0 shadow-sm" name="Trabaja" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="No">No</option>
                            <option value="Si">Sí</option>
                            <option value="Esporadico">Ocasionalmente</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-bold">4. Medio de transporte principal</label>
                        <select class="form-select border-0 shadow-sm" name="Transporte" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="Publico">Transporte Público</option>
                            <option value="Propio">Vehículo Propio</option>
                            <option value="Caminando">Caminando</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-bold">5. ¿Cuántos hermanos tienes?</label>
                        <select class="form-select border-0 shadow-sm" name="Hermanos" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="0">Hijo único</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3+">3 o más</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-bold">6. ¿Con quién vives actualmente?</label>
                        <select class="form-select border-0 shadow-sm" name="ViveCon" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="Padres">Ambos Padres</option>
                            <option value="Madre">Solo Madre</option>
                            <option value="Solo">Solo/a</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold">7. Describe tu situación familiar actual (Solo letras)</label>
                        <textarea class="form-control border-0 shadow-sm" name="SituacionFamiliar" rows="2" onkeypress="return soloLetras(event)" placeholder="Ej. Apoyo constante de mi familia..." @atributoBloqueo required></textarea>
                    </div>
                </div>

                <h5 class="mb-4 mt-5 fw-bold" style="color: var(--brand-dark); border-bottom: 2px solid var(--brand-secondary); padding-bottom: 8px; font-family: var(--font-titulos);">II. Antecedentes y Hábitos Académicos</h5>
                <div class="row g-4">
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-bold">8. Promedio de Bachillerato (Solo números)</label>
                        <input type="text" class="form-control border-0 shadow-sm" name="PromedioPrepa" onkeypress="return soloNumerosYDecimal(event)" placeholder="Ej. 8.5" maxlength="4" @atributoBloqueo required>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-bold d-block">9. ¿Reprobaste materias en el nivel anterior?</label>
                        <div class="d-flex gap-4 mt-2">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="ReproboAnterior" id="repNo" value="No" @atributoBloqueo required>
                                <label class="form-check-label" for="repNo">No</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="ReproboAnterior" id="repSi" value="Si" @atributoBloqueo required>
                                <label class="form-check-label" for="repSi">Sí</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-bold">10. ¿Cuentas con equipo de cómputo propio?</label>
                        <select class="form-select border-0 shadow-sm" name="EquipoComputo" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="Laptop">Sí, Laptop</option>
                            <option value="Escritorio">Sí, Escritorio</option>
                            <option value="No">No tengo</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-bold">11. Calidad de tu Internet en casa</label>
                        <select class="form-select border-0 shadow-sm" name="Internet" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="Buena">Buena / Estable</option>
                            <option value="Regular">Regular</option>
                            <option value="Mala">Mala / Falla mucho</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold">12. ¿Por qué elegiste esta carrera?</label>
                        <textarea class="form-control border-0 shadow-sm" name="MotivoCarrera" rows="3" placeholder="Explica tus motivos..." @atributoBloqueo required></textarea>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-5">
                    @if (estaCompletada)
                    {
                        <button type="button" id="btnModificar" class="btn btn-lg fw-bold" style="background-color: var(--btn-editar); border-radius: var(--radius-sm);" onclick="habilitarEdicion()">
                            <i class="bi bi-pencil-square"></i> Modificar Respuestas
                        </button>
                        <button type="submit" id="btnGuardarCambios" class="btn btn-lg fw-bold text-white d-none shadow-brand" style="background-color: var(--brand-dark); border-radius: var(--radius-sm);">
                            <i class="bi bi-check-circle"></i> Guardar Cambios
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-lg fw-bold text-white shadow-brand" style="background-color: var(--brand-dark); border-radius: var(--radius-sm);">
                            <i class="bi bi-send-fill me-2"></i> Enviar Información
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function soloLetras(e) {
            var key = e.keyCode || e.which;
            var tecla = String.fromCharCode(key).toLowerCase();
            var letras = " áéíóúabcdefghijklmnñopqrstuvwxyz";
            if (letras.indexOf(tecla) == -1) return false;
        }

        function soloNumerosYDecimal(e) {
            var key = e.keyCode || e.which;
            var tecla = String.fromCharCode(key);
            var expresion = /[0-9.]/;
            if (!expresion.test(tecla)) return false;
        }

        function mostrarPrevisualizacion(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewFoto').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function habilitarEdicion() {
            const campos = document.querySelectorAll("select, input, textarea");
            campos.forEach(campo => campo.removeAttribute("disabled"));
            document.getElementById("btnModificar").classList.add("d-none");
            document.getElementById("btnGuardarCambios").classList.remove("d-none");
            document.getElementById("btnCamara").style.pointerEvents = "auto";
            document.getElementById("btnCamara").style.opacity = "1";
        }
    </script>
}