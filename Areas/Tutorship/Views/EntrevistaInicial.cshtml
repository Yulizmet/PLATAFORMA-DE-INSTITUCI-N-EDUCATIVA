@model SchoolManager.Models.users_user

@{
    ViewData["Title"] = "Entrevista Inicial";

    var entrevistaGuardada = ViewBag.Entrevista as SchoolManager.Models.tutorship_interview;

    bool estaCompletada = entrevistaGuardada != null && entrevistaGuardada.Status == "Completada";
    bool requiereActualizacion = entrevistaGuardada != null && entrevistaGuardada.Status == "Requiere Actualizacion";


    string atributoBloqueo = estaCompletada ? "disabled" : "";

    bool tieneFotoGuardada = entrevistaGuardada != null &&
                             !string.IsNullOrEmpty(entrevistaGuardada.FilePath) &&
                             entrevistaGuardada.FilePath != "Sin archivo";

    var rutaImagen = tieneFotoGuardada
        ? entrevistaGuardada.FilePath
        : "https://via.placeholder.com/150?text=Sin+Foto";

    string atributoRequeridoFoto = tieneFotoGuardada ? "" : "required";
}

<div class="container mt-5">
    <div class="card shadow border-0">

        <div class="card-header-utt p-4 rounded-top" style="background-color: var(--utt-red, #dc3545); color: white;">
            <h3 class="mb-0 fw-bold"><i class="bi bi-person-lines-fill"></i> Entrevista Inicial de Tutoría</h3>
        </div>

        <div class="card-body p-4" style="background-color: var(--utt-white);">

            @if (requiereActualizacion)
            {
                <div class="alert alert-warning shadow-sm border-warning mb-4">
                    <h5 class="fw-bold text-dark"><i class="bi bi-bell-fill text-warning"></i> ¡Nuevo Ciclo Escolar!</h5>
                    <p class="mb-0 text-dark">
                        Por favor, revisa que tu información siga siendo correcta. Si cambiaste de transporte, internet, o situación laboral, actualízalo y haz clic en <strong>Enviar Información</strong> al final de la página.
                    </p>
                </div>
            }

            <form asp-area="Gestion" asp-controller="Tutorship" asp-action="GuardarEntrevista" method="post" enctype="multipart/form-data">

                <input type="hidden" name="UserId" value="@Model.UserId" />

                <div class="p-3 rounded mb-4" style="background-color: var(--utt-light);">
                    <h5 class="fw-bold" style="color: var(--utt-dark-red);">Datos del Alumno</h5>

                    <div class="row mb-4 align-items-center justify-content-center">
                        <div class="col-md-12 text-center">
                            <div class="position-relative d-inline-block">
                                <img id="previewFoto" src="@rutaImagen"
                                     alt="Foto del Alumno" class="rounded-circle shadow-sm"
                                     style="width: 150px; height: 150px; object-fit: cover; border: 4px solid var(--utt-white);">

                                <label id="btnCamara" for="inputFoto" class="position-absolute bottom-0 end-0 btn btn-sm btn-utt-primary rounded-circle"
                                       style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; cursor: pointer; @(estaCompletada ? "pointer-events: none; opacity: 0.5;" : "")"
                                       title="Subir Foto">
                                    <i class="bi bi-camera-fill"></i>
                                </label>

                                <input type="file" id="inputFoto" name="FotoPerfil" accept="image/*" class="d-none" onchange="mostrarPrevisualizacion(this)" @atributoRequeridoFoto @atributoBloqueo>
                            </div>
                            <p class="text-muted small mt-2">
                                Click en la cámara para subir tu foto <span class="text-danger fw-bold">*(Obligatorio)</span>
                            </p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Nombre Completo</label>
                            <input type="text" class="form-control"
                                   value="@Model.Person.FirstName @Model.Person.LastNamePaternal @Model.Person.LastNameMaternal"
                                   readonly
                                   style="border-color: var(--utt-beige); background-color: #e9ecef;">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Matrícula</label>
                            <input type="text" class="form-control"
                                   value="@ViewBag.Matricula"
                                   readonly
                                   style="border-color: var(--utt-beige); background-color: #e9ecef;">
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Correo</label>
                            <input type="text" class="form-control"
                                   value="@Model.Person.Email"
                                   readonly
                                   style="border-color: var(--utt-beige); background-color: #e9ecef;">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Carrera</label>
                            <select class="form-select" name="Carrera" style="border-color: var(--utt-beige);" @atributoBloqueo required>
                                <option value="">Seleccione una carrera...</option>
                                <option value="valor1">Carrera1</option>
                                <option value="valor2">Carrera2</option>
                            </select>
                        </div>
                    </div>
                </div>

                <h5 class="mb-4 mt-2" style="color: var(--utt-red); border-bottom: 2px solid var(--utt-beige); padding-bottom: 5px;">
                    I. Aspectos Personales y Familiares
                </h5>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">1. Estado Civil</label>
                        <select class="form-select" name="EstadoCivil" style="border-color: var(--utt-beige);" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="Soltero">Soltero/a</option>
                            <option value="Casado">Casado/a</option>
                            <option value="UnionLibre">Unión Libre</option>
                            <option value="Divorciado">Divorciado/a</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">2. ¿Tienes hijos?</label>
                        <select class="form-select" name="TieneHijos" style="border-color: var(--utt-beige);" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="No">No</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3+">3 o más</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">3. ¿Trabajas actualmente?</label>
                        <select class="form-select" name="Trabaja" id="selectTrabaja" style="border-color: var(--utt-beige);" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="No">No</option>
                            <option value="Si">Sí</option>
                            <option value="Esporadico">Ocasionalmente</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">4. Medio de transporte principal</label>
                        <select class="form-select" name="Transporte" style="border-color: var(--utt-beige);" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="Publico">Transporte Público</option>
                            <option value="Propio">Vehículo Propio</option>
                            <option value="Familiar">Me traen mis padres/familiares</option>
                            <option value="Caminando">Caminando</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">5. ¿Cuántos hermanos tienes?</label>
                        <select class="form-select" name="Hermanos" style="border-color: var(--utt-beige);" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="0">Soy hijo único</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4+">4 o más</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">6. ¿Con quién vives actualmente?</label>
                        <select class="form-select" name="ViveCon" style="border-color: var(--utt-beige);" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="Padres">Ambos Padres</option>
                            <option value="Madre">Solo Madre</option>
                            <option value="Padre">Solo Padre</option>
                            <option value="Familiares">Otros Familiares</option>
                            <option value="Solo">Solo/a</option>
                            <option value="Pareja">Pareja</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">7. Describe brevemente tu situación familiar actual</label>
                    <textarea class="form-control" name="SituacionFamiliar" rows="2"
                              placeholder="Ej. Buena relación, apoyo económico estable, etc."
                              style="border-color: var(--utt-beige);" @atributoBloqueo required></textarea>
                </div>

                <h5 class="mb-4 mt-5" style="color: var(--utt-red); border-bottom: 2px solid var(--utt-beige); padding-bottom: 5px;">
                    II. Antecedentes y Hábitos Académicos
                </h5>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">8. Promedio de Bachillerato</label>
                        <input type="number" step="0.1" min="0" max="10" class="form-control" name="PromedioPrepa"
                               placeholder="Ej. 8.5" style="border-color: var(--utt-beige);" @atributoBloqueo required>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">9. ¿Reprobaste materias en el nivel anterior?</label>
                        <div class="d-flex gap-3 mt-2">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="ReproboAnterior" id="repNo" value="No" @atributoBloqueo required>
                                <label class="form-check-label" for="repNo">No</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="ReproboAnterior" id="repSi" value="Si" @atributoBloqueo required>
                                <label class="form-check-label" for="repSi">Sí</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">10. ¿Cuentas con equipo de cómputo propio?</label>
                        <select class="form-select" name="EquipoComputo" style="border-color: var(--utt-beige);" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="Laptop">Sí, Laptop</option>
                            <option value="Escritorio">Sí, Escritorio</option>
                            <option value="Prestado">Uso uno prestado/familiar</option>
                            <option value="No">No tengo</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">11. Calidad de tu Internet en casa</label>
                        <select class="form-select" name="Internet" style="border-color: var(--utt-beige);" @atributoBloqueo required>
                            <option value="">Selecciona una opción...</option>
                            <option value="Buena">Buena / Estable</option>
                            <option value="Regular">Regular / Lenta a veces</option>
                            <option value="Mala">Mala / Falla mucho</option>
                            <option value="Datos">Solo uso datos móviles</option>
                            <option value="No">No tengo internet</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">12. ¿Por qué elegiste esta carrera?</label>
                    <textarea class="form-control" name="MotivoCarrera" rows="3"
                              placeholder="Explica tus motivos principales..."
                              style="border-color: var(--utt-beige);" @atributoBloqueo required></textarea>
                </div>

                <div class="d-grid gap-2 mt-5">
                    @if (estaCompletada)
                    {
                        <button type="button" id="btnModificar" class="btn btn-warning btn-lg fw-bold" onclick="habilitarEdicion()">
                            <i class="bi bi-pencil-square"></i> Modificar Respuestas
                        </button>

                        <button type="submit" id="btnGuardarCambios" class="btn btn-success btn-lg fw-bold d-none">
                            <i class="bi bi-check-circle"></i> Guardar Cambios
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-utt-primary btn-lg fw-bold">
                            Enviar Información
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function mostrarPrevisualizacion(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewFoto').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function habilitarEdicion() {
            const campos = document.querySelectorAll("select, input[type='radio'], textarea, input[type='number']");
            campos.forEach(campo => {
                campo.removeAttribute("disabled");
            });

            document.getElementById("btnModificar").classList.add("d-none");
            document.getElementById("btnGuardarCambios").classList.remove("d-none");

            const btnCamara = document.getElementById("btnCamara");
            const inputFoto = document.getElementById("inputFoto");

            if (btnCamara) {
                btnCamara.style.pointerEvents = "auto";
                btnCamara.style.opacity = "1";
            }
            if (inputFoto) {
                inputFoto.removeAttribute("disabled");
            }
        }
    </script>
}