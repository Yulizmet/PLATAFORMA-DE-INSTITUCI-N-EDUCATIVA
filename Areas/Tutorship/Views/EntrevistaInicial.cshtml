@model SchoolManager.Models.tutorship_interview

@{
    ViewData["Title"] = "Entrevista Inicial";
}

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header-utt p-4 rounded-top" style="background-color: var(--utt-red, #dc3545); color: white;">
            <h3 class="mb-0 fw-bold"><i class="bi bi-person-lines-fill"></i> Entrevista Inicial de Tutoría</h3>
        </div>

        <div class="card-body p-4" style="background-color: var(--utt-white);">
            <form asp-area="Gestion" asp-controller="Tutorship" asp-action="GuardarEntrevista" method="post" enctype="multipart/form-data">

                <div class="p-3 rounded mb-4" style="background-color: var(--utt-light);">
                    <h5 class="fw-bold" style="color: var(--utt-dark-red);">Datos del Alumno</h5>

                    <div class="row mb-4 align-items-center justify-content-center">
                        <div class="col-md-12 text-center">
                            <div class="position-relative d-inline-block">
                                <img id="previewFoto" src="https://via.placeholder.com/150?text=Sin+Foto"
                                     alt="Foto del Alumno" class="rounded-circle shadow-sm"
                                     style="width: 150px; height: 150px; object-fit: cover; border: 4px solid var(--utt-white);">

                                <label for="inputFoto" class="position-absolute bottom-0 end-0 btn btn-sm btn-utt-primary rounded-circle"
                                       style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; cursor: pointer;"
                                       title="Subir Foto">
                                    <i class="bi bi-camera-fill"></i>
                                </label>
                                <input type="file" id="inputFoto" name="FotoPerfil" accept="image/*" class="d-none" onchange="mostrarPrevisualizacion(this)">
                            </div>
                            <p class="text-muted small mt-2">Click en la cámara para subir tu foto (Opcional)</p>
                        </div>
                    </div>
                </div>

                <h5 class="mb-4 mt-2" style="color: var(--utt-red); border-bottom: 2px solid var(--utt-beige); padding-bottom: 5px;">
                    I. Aspectos Personales y Familiares
                </h5>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">1. Estado Civil</label>
                        <input type="hidden" name="Answers[0].QuestionCategory" value="Aspectos Personales y Familiares" />
                        <input type="hidden" name="Answers[0].QuestionText" value="1. Estado Civil" />
                        <select class="form-select" name="Answers[0].AnswerText" style="border-color: var(--utt-beige);" required>
                            <option value="Soltero">Soltero/a</option>
                            <option value="Casado">Casado/a</option>
                            <option value="UnionLibre">Unión Libre</option>
                            <option value="Divorciado">Divorciado/a</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">2. ¿Tienes hijos?</label>
                        <input type="hidden" name="Answers[1].QuestionCategory" value="Aspectos Personales y Familiares" />
                        <input type="hidden" name="Answers[1].QuestionText" value="2. ¿Tienes hijos?" />
                        <select class="form-select" name="Answers[1].AnswerText" style="border-color: var(--utt-beige);" required>
                            <option value="No">No</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3+">3 o más</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">3. ¿Trabajas actualmente?</label>
                        <input type="hidden" name="Answers[2].QuestionCategory" value="Aspectos Personales y Familiares" />
                        <input type="hidden" name="Answers[2].QuestionText" value="3. ¿Trabajas actualmente?" />
                        <select class="form-select" name="Answers[2].AnswerText" id="selectTrabaja" style="border-color: var(--utt-beige);" required>
                            <option value="No">No</option>
                            <option value="Si">Sí</option>
                            <option value="Esporadico">Ocasionalmente</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">4. Medio de transporte principal</label>
                        <input type="hidden" name="Answers[3].QuestionCategory" value="Aspectos Personales y Familiares" />
                        <input type="hidden" name="Answers[3].QuestionText" value="4. Medio de transporte principal" />
                        <select class="form-select" name="Answers[3].AnswerText" style="border-color: var(--utt-beige);" required>
                            <option value="Publico">Transporte Público</option>
                            <option value="Propio">Vehículo Propio</option>
                            <option value="Familiar">Me traen mis padres/familiares</option>
                            <option value="Caminando">Caminando</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">5. ¿Cuántos hermanos tienes?</label>
                        <input type="hidden" name="Answers[4].QuestionCategory" value="Aspectos Personales y Familiares" />
                        <input type="hidden" name="Answers[4].QuestionText" value="5. ¿Cuántos hermanos tienes?" />
                        <select class="form-select" name="Answers[4].AnswerText" style="border-color: var(--utt-beige);" required>
                            <option value="0">Soy hijo único</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4+">4 o más</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">6. ¿Con quién vives actualmente?</label>
                        <input type="hidden" name="Answers[5].QuestionCategory" value="Aspectos Personales y Familiares" />
                        <input type="hidden" name="Answers[5].QuestionText" value="6. ¿Con quién vives actualmente?" />
                        <select class="form-select" name="Answers[5].AnswerText" style="border-color: var(--utt-beige);" required>
                            <option value="Padres">Ambos Padres</option>
                            <option value="Madre">Solo Madre</option>
                            <option value="Padre">Solo Padre</option>
                            <option value="Familiares">Otros Familiares</option>
                            <option value="Solo">Solo/a</option>
                            <option value="Pareja">Pareja</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">7. Describe brevemente tu situación familiar actual</label>
                    <input type="hidden" name="Answers[6].QuestionCategory" value="Aspectos Personales y Familiares" />
                    <input type="hidden" name="Answers[6].QuestionText" value="7. Describe brevemente tu situación familiar actual" />
                    <textarea class="form-control" name="Answers[6].AnswerText" rows="2" required
                              placeholder="Ej. Buena relación, apoyo económico estable, etc."
                              style="border-color: var(--utt-beige);"></textarea>
                </div>

                <h5 class="mb-4 mt-5" style="color: var(--utt-red); border-bottom: 2px solid var(--utt-beige); padding-bottom: 5px;">
                    II. Antecedentes y Hábitos Académicos
                </h5>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">8. Promedio de Bachillerato / Cuatrimestre anterior</label>
                        <input type="hidden" name="Answers[7].QuestionCategory" value="Antecedentes y Hábitos Académicos" />
                        <input type="hidden" name="Answers[7].QuestionText" value="8. Promedio de Bachillerato / Cuatrimestre anterior" />
                        <input type="number" step="0.1" min="0" max="10" class="form-control" name="Answers[7].AnswerText" required
                               placeholder="Ej. 8.5" style="border-color: var(--utt-beige);">
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">9. ¿Reprobaste materias en el nivel anterior?</label>
                        <input type="hidden" name="Answers[8].QuestionCategory" value="Antecedentes y Hábitos Académicos" />
                        <input type="hidden" name="Answers[8].QuestionText" value="9. ¿Reprobaste materias en el nivel anterior?" />
                        <div class="d-flex gap-3 mt-2">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="Answers[8].AnswerText" id="repNo" value="No" checked>
                                <label class="form-check-label" for="repNo">No</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="Answers[8].AnswerText" id="repSi" value="Si">
                                <label class="form-check-label" for="repSi">Sí</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">10. ¿Cuentas con equipo de cómputo propio?</label>
                        <input type="hidden" name="Answers[9].QuestionCategory" value="Antecedentes y Hábitos Académicos" />
                        <input type="hidden" name="Answers[9].QuestionText" value="10. ¿Cuentas con equipo de cómputo propio?" />
                        <select class="form-select" name="Answers[9].AnswerText" style="border-color: var(--utt-beige);" required>
                            <option value="Laptop">Sí, Laptop</option>
                            <option value="Escritorio">Sí, Escritorio</option>
                            <option value="Prestado">Uso uno prestado/familiar</option>
                            <option value="No">No tengo</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">11. Calidad de tu Internet en casa</label>
                        <input type="hidden" name="Answers[10].QuestionCategory" value="Antecedentes y Hábitos Académicos" />
                        <input type="hidden" name="Answers[10].QuestionText" value="11. Calidad de tu Internet en casa" />
                        <select class="form-select" name="Answers[10].AnswerText" style="border-color: var(--utt-beige);" required>
                            <option value="Buena">Buena / Estable</option>
                            <option value="Regular">Regular / Lenta a veces</option>
                            <option value="Mala">Mala / Falla mucho</option>
                            <option value="Datos">Solo uso datos móviles</option>
                            <option value="No">No tengo internet</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">12. ¿Por qué elegiste esta carrera?</label>
                    <input type="hidden" name="Answers[11].QuestionCategory" value="Antecedentes y Hábitos Académicos" />
                    <input type="hidden" name="Answers[11].QuestionText" value="12. ¿Por qué elegiste esta carrera?" />
                    <textarea class="form-control" name="Answers[11].AnswerText" rows="3" required
                              placeholder="Explica tus motivos principales..."
                              style="border-color: var(--utt-beige);"></textarea>
                </div>

                <div class="d-grid gap-2 mt-5">
                    <button type="submit" class="btn btn-success btn-lg" style="background-color: var(--utt-primary, #198754); border: none;">
                        <i class="bi bi-send-check-fill"></i> Enviar Entrevista Inicial
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function mostrarPrevisualizacion(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewFoto').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}