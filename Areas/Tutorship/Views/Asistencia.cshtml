@model List<SchoolManager.Models.users_user>

@{
    ViewData["Title"] = "Registro de Asistencia";
    int roleId = ViewBag.RoleId ?? 0;

    var gruposDisp = ViewBag.GruposDisponibles as List<SchoolManager.Models.grades_group>;
    var miGrupo = gruposDisp?.FirstOrDefault(g => g.GroupId == ViewBag.GrupoSeleccionado);
    string nombreMiGrupo = miGrupo != null ? $"Grado {miGrupo.GradeLevelId} | {miGrupo.Name}" : "Sin asignar";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

<div class="container-fluid mt-4 mb-5 px-3 px-md-4">

    <div class="d-flex flex-column flex-md-row align-items-center justify-content-center position-relative mb-4">
        <div class="w-100 w-md-auto text-start text-md-center mb-3 mb-md-0 position-md-absolute start-0 top-50 translate-middle-y-md">
            <button type="button" onclick="history.back()" class="btn btn-sm btn-outline-secondary fw-bold shadow-sm px-3" style="border-radius: 20px;">
                <i class="bi bi-arrow-left me-1"></i> Regresar
            </button>
        </div>
        <h2 class="fw-bold m-0 text-center" style="color: var(--brand-dark);">Registro de Asistencia</h2>
    </div>

    @if (TempData["AsistenciaExito"] != null)
    {
        <div class="alert alert-success shadow-sm text-center fw-bold">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["AsistenciaExito"]
        </div>
    }
    @if (TempData["AsistenciaError"] != null)
    {
        <div class="alert alert-danger shadow-sm text-center fw-bold">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["AsistenciaError"]
        </div>
    }

    @if (ViewBag.TemaSemanal != null)
    {
        var tema = ViewBag.TemaSemanal as SchoolManager.Models.tutorship_suggested_topic;
    
        <div class="card mb-4 border-0 shadow-sm animate__animated animate__fadeIn">
            <div class="card-body p-3 p-md-4">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start gap-3">
                    <div class="d-flex flex-column flex-sm-row gap-3 align-items-center align-items-sm-start text-center text-sm-start w-100">
                        <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                             style="background-color: var(--brand-secondary); width: 50px; height: 50px; min-width: 50px;">
                            <i class="bi bi-megaphone-fill text-white fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1" style="color: var(--brand-dark);">TEMA SUGERIDO DE LA SEMANA</h5>
                            <h4 class="fw-extrabold text-dark mb-2">@tema.Title</h4>
                            <p class="text-muted mb-3" style="font-size: 0.95rem;">@tema.Description</p>
                        
                            @if (tema.FilePath != "Sin archivo")
                            {
                                <a href="@tema.FilePath" target="_blank" class="btn btn-sm btn-dark rounded-pill px-3 shadow-sm d-inline-flex align-items-center">
                                    <i class="bi bi-file-earmark-pdf-fill text-danger me-2"></i> Descargar material de apoyo
                                </a>
                            }
                        </div>
                    </div>
                    <div class="text-center text-lg-end w-100 w-lg-auto border-top border-lg-0 pt-2 pt-lg-0">
                        <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                            <i class="bi bi-calendar-event me-1"></i> Semana activa
                        </span>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="p-3 p-md-4 rounded shadow-sm mb-4" style="background-color: #f4f4f4; border-left: 5px solid var(--brand-secondary);">
        <form asp-controller="Asistencia" asp-action="Asistencia" method="get" class="row g-3 align-items-end">
            <div class="col-12 col-md-6 col-xl-3">
                <label class="form-label fw-bold text-muted small mb-1">Contar faltas desde:</label>
                <input type="date" name="fechaInicio" value="@ViewBag.FechaInicio" class="form-control shadow-sm" style="border-color: #ddd;">
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <label class="form-label fw-bold text-muted small mb-1">Hasta:</label>
                <input type="date" name="fechaFin" value="@ViewBag.FechaFin" class="form-control shadow-sm" style="border-color: #ddd;">
            </div>

            <div class="col-12 col-md-6 col-xl-3 mt-4 mt-xl-0">
                <label class="form-label fw-bold mb-1" style="color: var(--brand-dark);">Día a pasar lista:</label>
                <input type="date" id="inputFechaVisual" name="fecha" value="@ViewBag.FechaSeleccionada" class="form-control shadow-sm border-2" style="border-color: var(--brand-dark);" required>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                @if (roleId == 3)
                {
                    <label class="form-label fw-bold mb-1">Grupo:</label>
                    <div class="d-flex gap-2">
                        <select class="form-select shadow-sm" name="groupId" style="border-color: #ddd;" required>
                            <option value="">Selecciona...</option>
                            @if (ViewBag.GruposDisponibles != null)
                            {
                                foreach (var grupo in ViewBag.GruposDisponibles)
                                {
                                    <option value="@grupo.GroupId" selected="@(ViewBag.GrupoSeleccionado == grupo.GroupId)">
                                        @grupo.GradeLevelId @grupo.Name
                                    </option>
                                }
                            }
                        </select>
                        <button type="submit" class="btn btn-primary-brand fw-bold shadow-sm px-3" title="Cargar Grupo">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                }
                else if (roleId == 2)
                {
                    <label class="form-label fw-bold mb-1">Mi Grupo:</label>
                    <div class="d-flex gap-2">
                        <input type="hidden" name="groupId" value="@ViewBag.GrupoSeleccionado" />
                        <input type="text" class="form-control shadow-sm bg-white text-muted fw-bold" value="@nombreMiGrupo" readonly disabled style="border-color: #ddd;">
                        <button type="submit" class="btn btn-primary-brand fw-bold shadow-sm px-3" title="Actualizar Fechas">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                }
            </div>
        </form>
    </div>

    @if (Model != null && Model.Any())
    {
        <form id="formAsistencia" asp-controller="Asistencia" asp-action="GuardarAsistencia" method="post">
            <input type="hidden" name="groupId" value="@ViewBag.GrupoSeleccionado" />
            <input type="hidden" id="hiddenFecha" name="fecha" value="@ViewBag.FechaSeleccionada" />
            <input type="hidden" name="fechaInicio" value="@ViewBag.FechaInicio" />
            <input type="hidden" name="fechaFin" value="@ViewBag.FechaFin" />

            <div class="alert text-center fw-bold shadow-sm mb-4" style="background-color: var(--brand-white); border: 2px dashed var(--brand-dark); color: #444;">
                <div class="d-flex flex-column flex-md-row align-items-center justify-content-center gap-2">
                    <span>
                        <i class="bi bi-calendar-check text-success me-1" style="font-size: 1.2rem;"></i>
                        Estás visualizando/modificando la asistencia del día:
                    </span>
                    <span style="color: var(--brand-dark); font-size: 1.2rem; text-decoration: underline;">
                        @{
                            DateTime fechaFormateada;
                            if (DateTime.TryParse(ViewBag.FechaSeleccionada, out fechaFormateada))
                            {
                                @fechaFormateada.ToString("dd / MM / yyyy")
                            }
                        }
                    </span>
                </div>
            </div>

            <div class="table-responsive shadow-sm rounded bg-white p-2 p-md-3 border">
                <table id="tablaAsistencia" class="table table-hover mb-0 w-100">
                    <thead class="table-brand-head text-center">
                        <tr>
                            <th class="py-3 text-nowrap">Matrícula</th>
                            <th class="text-start py-3 min-vw-25">Nombre del Alumno</th>
                            <th class="py-3 text-nowrap" title="Asistencias en el rango seleccionado">Asistencias</th>
                            <th class="py-3 text-nowrap" title="Faltas en el rango seleccionado">Faltas</th>
                            <th class="py-3 text-nowrap">Asistencia del Día</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var dictMatriculas = ViewBag.Matriculas as Dictionary<int, string> ?? new Dictionary<int, string>();
                            var dictAsistenciaHoy = ViewBag.AsistenciaHoy as Dictionary<int, bool> ?? new Dictionary<int, bool>();
                            
                            var dictDetalleFaltas = ViewBag.DetalleFaltas as Dictionary<int, List<string>> ?? new Dictionary<int, List<string>>();
                            var dictDetalleAsistencias = ViewBag.DetalleAsistencias as Dictionary<int, List<string>> ?? new Dictionary<int, List<string>>();
                            
                            int index = 0;
                            bool yaSePasoLista = dictAsistenciaHoy.Any();
                        }

                        @foreach (var alumno in Model)
                        {
                            string matricula = dictMatriculas.ContainsKey(alumno.UserId) ? dictMatriculas[alumno.UserId] : "S/N";
                            bool asistio = yaSePasoLista ? (dictAsistenciaHoy.ContainsKey(alumno.UserId) ? dictAsistenciaHoy[alumno.UserId] : false) : true;

                            var listaFaltas = dictDetalleFaltas.ContainsKey(alumno.UserId) ? dictDetalleFaltas[alumno.UserId] : new List<string>();
                            int totalFaltas = listaFaltas.Count;
                            string textoFaltas = totalFaltas > 0 ? "Faltó los días: " + string.Join(", ", listaFaltas) : "Sin faltas en el periodo";

                            var listaAsistencias = dictDetalleAsistencias.ContainsKey(alumno.UserId) ? dictDetalleAsistencias[alumno.UserId] : new List<string>();
                            int totalAsistencias = listaAsistencias.Count;
                            string textoAsistencias = totalAsistencias > 0 ? "Asistió los días: " + string.Join(", ", listaAsistencias) : "Sin asistencias en el periodo";

                            <tr>
                                <td class="text-center align-middle fw-bold text-muted">@matricula</td>
                                <td class="align-middle fw-bold text-dark">
                                    @alumno.Person.FirstName @alumno.Person.LastNamePaternal @alumno.Person.LastNameMaternal
                                </td>
                                
                                <td class="text-center align-middle">
                                    <span class="badge shadow-sm" title="@textoAsistencias" style="background-color: #e8f5e9; color: #2e7d32; font-size: 0.95rem; border: 1px solid #2e7d32; cursor: help;">
                                        @totalAsistencias
                                    </span>
                                </td>

                                <td class="text-center align-middle">
                                    <span class="badge shadow-sm" title="@textoFaltas" style="background-color: var(--brand-secondary); color: var(--brand-white); font-size: 0.95rem; cursor: help;">
                                        @totalFaltas
                                    </span>
                                </td>
                                
                                <td class="text-center align-middle">
                                    <input type="hidden" name="studentIds[@index]" value="@alumno.UserId" />
                                    <div class="form-check d-flex justify-content-center m-0">
                                        <input class="form-check-input border-secondary chk-asistencia" type="checkbox" name="isPresent[@index]" value="true" @(asistio ? "checked" : "") style="transform: scale(1.4); cursor: pointer;" @(yaSePasoLista ? "disabled" : "") />
                                        <input type="hidden" name="isPresent[@index]" value="false" />
                                    </div>
                                </td>
                            </tr>
                            index++;
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center mt-4 mb-5 gap-3">
                @if (yaSePasoLista)
                {
                    <div class="text-muted fw-bold text-center text-lg-start w-100" id="mensajeBloqueado">
                        <i class="bi bi-lock-fill text-warning me-1"></i> Asistencia bloqueada. Haz clic en editar para hacer cambios.
                    </div>
                    <div class="w-100 w-lg-auto d-flex flex-column flex-sm-row gap-2">
                        <button type="button" id="btnEditar" class="btn btn-secondary w-100 w-sm-auto px-4 px-md-5 btn-lg shadow text-white fw-bold">
                            <i class="bi bi-unlock-fill me-2"></i> Editar
                        </button>
                        <button type="submit" id="btnGuardar" class="btn btn-primary-brand w-100 w-sm-auto px-4 px-md-5 btn-lg shadow d-none fw-bold">
                            <i class="bi bi-save me-2"></i> Guardar
                        </button>
                    </div>
                }
                else
                {
                    <div class="w-100 d-none d-lg-block"></div>
                    <button type="submit" class="btn btn-primary-brand w-100 w-lg-auto px-5 btn-lg shadow fw-bold">
                        <i class="bi bi-save me-2"></i> Guardar Asistencia
                    </button>
                }
            </div>
        </form>
    }
    else if (ViewBag.GrupoSeleccionado != null)
    {
        <div class="text-center p-4 p-md-5 text-muted mt-4 bg-white rounded shadow-sm border">
            <i class="bi bi-people-fill" style="font-size: 3rem; color: var(--brand-secondary);"></i>
            <h4 class="mt-3 text-dark fw-bold">No hay alumnos asignados a este grupo.</h4>
            <p class="mb-0">Verifica la asignación de tutores en el panel de administración.</p>
        </div>
    }
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
        var table;
        if ($('#tablaAsistencia').length) {
        table = $('#tablaAsistencia').DataTable({
        "language": {
        "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
        },
        "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100]],
        "pageLength": 25,
        "columnDefs": [
        { "orderable": false, "targets": 4 },
        { "searchable": false, "targets": 4 }
        ],
        "order": [[1, 'asc']]
        });
        }

        $('#btnEditar').click(function () {
        table.$('.chk-asistencia').prop('disabled', false);
        $(this).addClass('d-none');
        $('#btnGuardar').removeClass('d-none');
        $('#mensajeBloqueado').html('<i class="bi bi-unlock-fill text-success me-1"></i> Modo edición activado. Realiza los cambios y guarda.');
        });

        $('#formAsistencia').on('submit', function () {
        var fechaReal = $('#inputFechaVisual').val();
        $('#hiddenFecha').val(fechaReal);
        table.destroy();
        });
        });
    </script>
}