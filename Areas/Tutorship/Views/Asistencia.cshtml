@model List<SchoolManager.Models.users_user>

@{
    ViewData["Title"] = "Control de Asistencia";
    int roleId = ViewBag.RoleId ?? 0;

    // Obtener el nombre del grupo para el maestro
    var gruposDisp = ViewBag.GruposDisponibles as List<SchoolManager.Models.grades_group>;
    var miGrupo = gruposDisp?.FirstOrDefault(g => g.GroupId == ViewBag.GrupoSeleccionado);
    string nombreMiGrupo = miGrupo != null ? $"Grado {miGrupo.GradeLevelId} | {miGrupo.Name}" : "Sin asignar";
}

<style>
    /* 1. Forzar a DataTables a usar la misma fuente del sistema */
    .dataTables_wrapper {
        font-family: inherit !important;
        font-size: 0.95rem; /* Un tamaño un poco más elegante */
    }

    /* 2. Poner las letras de "Buscar" y "Mostrar registros" en negrita (como tus otros títulos) */
    .dataTables_length label,
    .dataTables_filter label {
        font-weight: bold;
        color: #444; /* Un gris oscuro para que no desentone */
    }

    /* 3. Darle estilo a la cajita de texto de búsqueda y al selector */
    .dataTables_filter input,
    .dataTables_length select {
        border: 1px solid var(--utt-beige, #d3c4b1); /* Usa tu color beige de borde */
        border-radius: 0.375rem; /* Bordes redondeados como Bootstrap */
        padding: 0.25rem 0.5rem;
        box-shadow: 0 .125rem .25rem rgba(0,0,0,.075); /* Sombra suave */
    }

    /* 4. Estilo para el texto de abajo "Mostrando 1 a N registros" */
    .dataTables_info {
        font-weight: 500;
        color: #666;
        padding-top: 1rem !important;
    }

    /* 5. BONUS: Cambiar el botón azul de paginación por tu rojo UTTN */
    .page-item.active .page-link {
        background-color: var(--utt-red, #8b0000) !important;
        border-color: var(--utt-red, #8b0000) !important;
        color: white !important;
    }

    .page-link {
        color: var(--utt-red, #8b0000); /* Color de los números inactivos */
    }

        .page-link:hover {
            background-color: var(--utt-beige, #f5f5dc);
            color: var(--utt-red, #8b0000);
        }
</style>
<div class="container mt-4">
    <h2 class="text-center mb-4 fw-bold" style="color: var(--utt-red);">Registro de Asistencia</h2>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success shadow-sm text-center fw-bold"><i class="bi bi-check-circle-fill"></i> @TempData["Exito"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm text-center fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]</div>
    }

    <div class="p-4 rounded shadow-sm mb-4" style="background-color: var(--utt-light);">
        <form asp-action="Asistencia" method="get" class="row g-3 align-items-end">

            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small mb-1">Contar faltas desde:</label>
                <input type="date" name="fechaInicio" value="@ViewBag.FechaInicio" class="form-control shadow-sm" style="border-color: var(--utt-beige);">
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small mb-1">Hasta:</label>
                <input type="date" name="fechaFin" value="@ViewBag.FechaFin" class="form-control shadow-sm" style="border-color: var(--utt-beige);">
            </div>

            <div class="col-md-3">
                <label class="form-label fw-bold mb-1" style="color: var(--utt-dark-red);">Día a pasar lista:</label>
                <input type="date" name="fecha" value="@ViewBag.FechaSeleccionada" class="form-control shadow-sm border-2" style="border-color: var(--utt-dark-red);" required>
            </div>

            <div class="col-md-3">
                @if (roleId == 3)
                {
                    <label class="form-label fw-bold mb-1">Grupo:</label>
                    <div class="d-flex gap-2">
                        <select class="form-select shadow-sm" name="groupId" style="border-color: var(--utt-beige);" required>
                            <option value="">Selecciona...</option>
                            @if (ViewBag.GruposDisponibles != null)
                            {
                                foreach (var grupo in ViewBag.GruposDisponibles)
                                {
                                    <option value="@grupo.GroupId" selected="@(ViewBag.GrupoSeleccionado == grupo.GroupId)">
                                        @grupo.GradeLevelId @grupo.Name
                                    </option>
                                }
                            }
                        </select>
                        <button type="submit" class="btn btn-utt-primary fw-bold shadow-sm" title="Cargar Grupo">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                }
                else if (roleId == 2)
                {
                    <label class="form-label fw-bold mb-1">Mi Grupo:</label>
                    <div class="d-flex gap-2">
                        <input type="hidden" name="groupId" value="@ViewBag.GrupoSeleccionado" />
                        <input type="text" class="form-control shadow-sm bg-white text-muted fw-bold" value="@nombreMiGrupo" readonly disabled style="border-color: var(--utt-beige);">
                        <button type="submit" class="btn btn-utt-primary fw-bold shadow-sm" title="Actualizar Fechas">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                }
            </div>
        </form>
    </div>

    @if (Model != null && Model.Any())
    {
        <form id="formAsistencia" asp-action="GuardarAsistencia" method="post">
            <input type="hidden" name="groupId" value="@ViewBag.GrupoSeleccionado" />
            <input type="hidden" name="fecha" value="@ViewBag.FechaSeleccionada" />
            <input type="hidden" name="fechaInicio" value="@ViewBag.FechaInicio" />
            <input type="hidden" name="fechaFin" value="@ViewBag.FechaFin" />

            <div class="table-responsive shadow-sm rounded">
                <table id="tablaAsistencia" class="table table-hover mb-0">
                    <thead class="table-utt-head text-center">
                        <tr>
                            <th>Matrícula</th>
                            <th class="text-start">Nombre del Alumno</th>
                            <th title="Faltas en el rango de fechas seleccionado">Faltas en Periodo</th>
                            <th>Asistencia del Día</th>
                        </tr>
                    </thead>
                    <tbody style="background-color: var(--utt-white);">
                        @{
                            var dictMatriculas = ViewBag.Matriculas as Dictionary<int, string> ?? new Dictionary<int, string>();
                            var dictFaltas = ViewBag.FaltasTotales as Dictionary<int, int> ?? new Dictionary<int, int>();
                            var dictAsistenciaHoy = ViewBag.AsistenciaHoy as Dictionary<int, bool> ?? new Dictionary<int, bool>();

                            int index = 0;
                            bool yaSePasoLista = dictAsistenciaHoy.Any();
                        }

                        @foreach (var alumno in Model)
                        {
                            string matricula = dictMatriculas.ContainsKey(alumno.UserId) ? dictMatriculas[alumno.UserId] : "S/N";
                            int faltas = dictFaltas.ContainsKey(alumno.UserId) ? dictFaltas[alumno.UserId] : 0;
                            bool asistio = yaSePasoLista ? (dictAsistenciaHoy.ContainsKey(alumno.UserId) ? dictAsistenciaHoy[alumno.UserId] : false) : true;

                            <tr>
                                <td class="text-center align-middle fw-bold text-muted">@matricula</td>
                                <td class="align-middle fw-bold text-dark">
                                    @alumno.Person.FirstName @alumno.Person.LastNamePaternal @alumno.Person.LastNameMaternal
                                </td>
                                <td class="text-center align-middle">
                                    <span class="badge shadow-sm" style="background-color: var(--utt-beige); color: var(--utt-dark-red); font-size: 0.95rem; border: 1px solid var(--utt-dark-red);">
                                        @faltas
                                    </span>
                                </td>
                                <td class="text-center align-middle">
                                    <input type="hidden" name="studentIds[@index]" value="@alumno.UserId" />
                                    <div class="form-check d-flex justify-content-center m-0">
                                        <input class="form-check-input border-secondary" type="checkbox" name="isPresent[@index]" value="true" @(asistio ? "checked" : "") style="transform: scale(1.4); cursor: pointer;" @(yaSePasoLista ? "disabled" : "") />
                                        <input type="hidden" name="isPresent[@index]" value="false" />
                                    </div>
                                </td>
                            </tr>
                            index++;
                        }
                    </tbody>
                </table>
            </div>

            @if (!yaSePasoLista)
            {
                <div class="text-end mt-4 mb-5">
                    <button type="submit" class="btn btn-utt-primary px-5 btn-lg shadow">
                        <i class="bi bi-save me-2"></i> Guardar Asistencia
                    </button>
                </div>
            }
            else
            {
                <div class="alert alert-info mt-4 text-center fw-bold shadow-sm" style="border-left: 5px solid #0dcaf0;">
                    <i class="bi bi-info-circle-fill me-2"></i> La asistencia de este grupo ya fue guardada en la fecha seleccionada.
                </div>
            }
        </form>
    }
    else if (ViewBag.GrupoSeleccionado != null)
    {
        <div class="text-center p-5 text-muted mt-4 bg-light rounded shadow-sm">
            <i class="bi bi-people-fill" style="font-size: 3rem; color: var(--utt-beige);"></i>
            <h4 class="mt-3 text-dark">No hay alumnos asignados a este grupo.</h4>
            <p class="mb-0">Verifica la asignación de tutores en el panel de administración.</p>
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            // Verificamos que la tabla exista antes de iniciar
            if ($('#tablaAsistencia').length) {
                var table = $('#tablaAsistencia').DataTable({
                    "language": {
                        "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                    },
                    "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "Todos"]],
                    "pageLength": 25,
                    "columnDefs": [
                        // Quitamos las flechitas de ordenar en la columna del Checkbox (la número 3)
                        { "orderable": false, "targets": 3 }
                    ]
                });

                // Truco para que al guardar, se envíen todos los alumnos (incluso los ocultos en otra página)
                $('#formAsistencia').on('submit', function () {
                    table.destroy();
                });
            }
        });
    </script>
}