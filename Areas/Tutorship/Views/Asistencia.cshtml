@{
    ViewData["Title"] = "Control de Asistencia";
}

<div class="container mt-4">
    <h2 class="text-center mb-4 fw-bold" style="color: var(--utt-red);">Registro de Asistencia</h2>

    <div class="p-4 rounded shadow-sm mb-4" style="background-color: var(--utt-light);">
        <form asp-action="CargarLista" method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label fw-bold">Fecha</label>
                <input type="date" class="form-control" style="border-color: var(--utt-beige);">
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Materia</label>
                <select class="form-select" style="border-color: var(--utt-beige);">
                    <option>Desarrollo Web</option>
                    <option>Ingles</option>
                    <option>Matematicas</option>
                    <option>Integradora</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Grupo</label>
                <select class="form-select" style="border-color: var(--utt-beige);">
                    <option>TIC-4A</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="button" class="btn btn-utt-primary w-100">
                    Cargar Grupo
                </button>
            </div>
        </form>
    </div>

    <form asp-action="GuardarAsistencia" method="post">
        <div class="table-responsive shadow">
            <table class="table table-hover mb-0">
                <thead class="table-utt-head text-center">
                    <tr>
                        <th>Matrícula</th>
                        <th>Nombre</th>
                        <th>Faltas Totales</th>
                        <th>Asistencia</th>
                    </tr>
                </thead>
                <tbody style="background-color: var(--utt-white);">
                    <tr>
                        <td class="text-center align-middle">12345</td>
                        <td class="align-middle">Hernandez ana karengod</td>
                        <td class="text-center align-middle">
                            <span class="badge" style="background-color: var(--utt-beige); color: var(--utt-black);">2</span>
                        </td>
                        <td class="text-center">
                            <div class="form-check d-flex justify-content-center">
                                <input class="form-check-input" type="checkbox" value="true" checked style="transform: scale(1.3); cursor: pointer;">
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="text-end mt-4">
            <button type="submit" class="btn btn-utt-primary px-5 btn-lg">Guardar Asistencia</button>
        </div>
    </form>
</div>