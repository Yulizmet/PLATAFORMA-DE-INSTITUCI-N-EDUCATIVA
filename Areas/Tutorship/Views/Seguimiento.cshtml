@model SchoolManager.Models.users_user
@using System.Linq

@{
    ViewData["Title"] = "Seguimiento Académico";

    var historial = ViewBag.Historial as List<SchoolManager.Models.tutorship_monitoring> ?? new List<SchoolManager.Models.tutorship_monitoring>();
    var bitacoras = ViewBag.BitacorasPsicologia as IEnumerable<dynamic>;
}

<div class="container-fluid px-3 px-md-4 mt-4 mb-5">
    
    <div class="row align-items-center mb-4 mt-3">
        <div class="col-12 col-md-3 text-start mb-3 mb-md-0">
            <button type="button" onclick="history.back()" class="btn btn-sm btn-outline-secondary fw-bold shadow-sm px-3" style="border-radius: var(--radius-pill, 20px);">
                <i class="bi bi-arrow-left me-1"></i> Regresar
            </button>
        </div>
        <div class="col-12 col-md-6 text-center">
            <h2 class="fw-bold m-0" style="color: var(--brand-dark);">Historial de Seguimiento</h2>
            @if (!string.IsNullOrEmpty(ViewBag.Matricula))
            {
                <div class="mt-2">
                    <span class="badge shadow-sm px-3 py-2" style="background-color: var(--surface-card); color: var(--brand-black); border: 1px solid var(--border-soft); border-radius: var(--radius-pill, 20px); font-size: 0.95rem;">
                        <i class="bi bi-person-badge me-1" style="color: var(--brand-primary);"></i> Matrícula: <span class="fw-bold">@ViewBag.Matricula</span>
                    </span>
                </div>
            }
        </div>
        <div class="col-12 col-md-3 d-none d-md-block"></div>
    </div>

    @if (Model != null)
    {
        string nombreCompleto = $"{Model.Person.FirstName} {Model.Person.LastNamePaternal}";

        <div class="row g-4 justify-content-center">
            
            <div class="col-12 col-lg-4 d-flex align-items-start">
                <div class="card border-0 shadow-soft w-100" style="background-color: var(--surface-card); border-radius: var(--radius-md); overflow: hidden;">

                    <div class="card-header bg-transparent border-0 pt-4 d-flex justify-content-between align-items-center px-4">
                        <h4 class="fw-bold m-0" style="color: var(--brand-dark); font-family: var(--font-titulos);">Nuevo Feedback</h4>

                        <a asp-controller="Entrevista" asp-action="VerEntrevistaAlumno" asp-route-id="@Model.UserId"
                               class="btn btn-sm text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                               style="width: 32px; height: 32px; background-color: var(--brand-dark);"
                               title="Ver Expediente Completo">
                            <i class="bi bi-info"></i>
                        </a>
                    </div>

                    <div class="card-body p-4 pt-0">
                        <div class="d-flex align-items-center mb-3 text-muted">
                            <i class="bi bi-person-fill me-2"></i>
                            <span style="font-family: var(--font-cuerpo);">@nombreCompleto</span>
                        </div>
            
                        <hr class="mb-4" style="opacity: 0.1;">

                        <form asp-controller="Seguimiento" asp-action="GuardarSeguimiento" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="studentId" value="@Model.UserId" />
                            <input type="hidden" name="matricula" value="@ViewBag.Matricula" />

                            <div class="mb-3">
                                <label class="form-label fw-bold text-dark" style="font-family: var(--font-cuerpo);">Tipo de Reporte</label>
                                <select class="form-select" name="tipo" style="border-color: var(--border-medium); border-radius: var(--radius-xs);">
                                    <option value="Académico">Académico</option>
                                    <option value="Conductual">Conductual</option>
                                    <option value="Psicológico">Psicológico</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold text-dark" style="font-family: var(--font-cuerpo);">Observaciones</label>
                                <textarea class="form-control" name="observaciones" rows="5" style="border-color: var(--border-medium); border-radius: var(--radius-xs); resize: none;" required></textarea>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold text-dark" style="font-family: var(--font-cuerpo);">Adjuntar Evidencia</label>
                                <div class="position-relative shadow-sm" style="border-radius: var(--radius-xs); border: 1px solid var(--border-medium); overflow: hidden;">
                                    <input type="file" name="ArchivoAdjunto" id="evidenciaUpload" class="d-none"
                                           accept=".pdf,.jpg,.jpeg,.png"
                                           onchange="document.getElementById('fileName').textContent = this.files.length > 0 ? this.files[0].name : 'Ningún archivo seleccionado';">

                                    <label for="evidenciaUpload" class="d-flex align-items-center m-0 w-100" style="cursor: pointer; background-color: #ffffff;">
                                        <div class="px-3 py-3 fw-bold text-dark text-center bg-light border-end" style="min-width: 120px;">
                                            Elegir archivo
                                        </div>
                                        <div id="fileName" class="px-3 text-muted flex-grow-1 text-truncate" style="font-size: 0.9rem;">
                                            Ningún archivo seleccionado
                                        </div>
                                        <div class="px-3">
                                            <i class="bi bi-paperclip text-muted"></i>
                                        </div>
                                    </label>
                                </div>
                                <div class="form-text small text-muted mt-2">
                                    * Justificantes médicos, reportes firmados (PDF o Imagen).
                                </div>
                            </div>

                            <button type="submit" class="btn w-100 fw-bold text-white py-2 shadow-brand" style="background-color: var(--brand-dark); border-radius: var(--radius-sm);">
                                <i class="bi bi-download me-2" style="transform: rotate(180deg); display: inline-block;"></i> Guardar Reporte
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-8">
                
                <h4 class="mb-4 fw-bold" style="color: var(--brand-dark);">
                    Historial de Seguimiento
                </h4>
                @if (!historial.Any())
                {
                    <div class="text-center p-5 rounded border mt-3 mb-5" style="background-color: var(--surface-card); box-shadow: var(--shadow-soft);">
                        <i class="bi bi-folder2-open" style="font-size: 3rem; color: var(--brand-secondary);"></i>
                        <h5 class="mt-3 fw-bold" style="color: var(--brand-dark);">Sin reportes</h5>
                        <p class="text-muted mb-0">Este alumno no tiene reportes previos en su expediente.</p>
                    </div>
                }
                else
                {
                    <div class="mb-5 scroll-historial">
                        @foreach (var reporte in historial)
                        {
                            <div class="card mb-3 border-0" style="background-color: var(--surface-card); box-shadow: var(--shadow-soft); border-radius: var(--radius-sm, 12px); transition: transform 0.2s;">
                                <div class="card-body p-3 p-md-4">
                                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <h6 class="mb-0 fw-bold" style="color: var(--brand-black);">
                                                Reporte de Tutoría
                                            </h6>

                                            @if (reporte.FilePath != "Sin archivo")
                                            {
                                                <a href="@reporte.FilePath" target="_blank" class="badge text-decoration-none shadow-sm" style="background-color: var(--brand-secondary); color: var(--brand-white);">
                                                    <i class="bi bi-paperclip"></i> Ver Archivo
                                                </a>
                                            }
                                        </div>
                                        <div class="text-start text-md-end">
                                            <small class="badge border me-1" style="background-color: var(--surface-muted); color: var(--brand-black); border-color: var(--border-medium) !important;">@reporte.PerformanceLevel</small>
                                            <small class="text-muted fw-bold">@reporte.Date.ToString("dd MMM yyyy")</small>
                                        </div>
                                    </div>
                                    <p class="card-text m-0 p-3 rounded text-dark" style="font-size: 0.95rem; background-color: var(--surface-muted); border: 1px solid var(--border-soft);">
                                        @reporte.DetailedObservations
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                }

                <hr class="mb-4" style="border-color: var(--border-medium);" />
                
                <h4 class="mb-4 fw-bold" style="color: var(--brand-dark);">
                    Intervenciones Psicológicas
                </h4>

                @if (bitacoras == null || !bitacoras.Any())
                {
                    <div class="text-center p-4 rounded border mt-3 mb-4" style="background-color: var(--surface-muted); box-shadow: var(--shadow-soft);">
                        <i class="bi bi-journal-x" style="font-size: 2rem; color: var(--brand-secondary);"></i>
                        <p class="text-muted mb-0 mt-2">No hay registros psicológicos para este alumno.</p>
                    </div>
                }
                else
                {
                    <div class="scroll-historial mb-4">
                        @foreach (var psic in bitacoras)
                        {
                            <div class="card mb-3 border-0" style="background-color: var(--surface-card); box-shadow: var(--shadow-soft); border-radius: var(--radius-sm, 12px);">
                                <div class="card-body p-3 p-md-4">
                                    <div class="d-flex flex-wrap align-items-center mb-3 gap-2">
                                        <span class="badge shadow-sm" style="background-color: var(--btn-ver); color: var(--brand-black);">Folio: @psic.Fol</span>
                                        <small class="text-muted fw-bold">@psic.AppointmentDatetime.ToString("dd MMM yyyy - hh:mm tt")</small>
                                        
                                        @if (psic.AttendanceStatus == "Asistió")
                                        {
                                            <span class="badge" style="background-color: var(--btn-crear); color: var(--brand-black); font-size:0.7rem;">Asistió</span>
                                        }
                                        else if (psic.AttendanceStatus == "No asistió")
                                        {
                                            <span class="badge" style="background-color: var(--btn-eliminar); color: var(--brand-white); font-size:0.7rem;">Falta</span>
                                        }
                                        else
                                        {
                                            <span class="badge" style="background-color: var(--btn-editar); color: var(--brand-black); font-size:0.7rem;">Justificado</span>
                                        }
                                    </div>
                                    
                                    <p class="mb-0 text-dark" style="font-size: 0.95rem;">
                                        @(string.IsNullOrEmpty(psic.PsychologyObservations) ? "Sin observaciones previas." : psic.PsychologyObservations)
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                }

                <hr class="mb-4" style="border-color: var(--border-medium);" />
                
                <h4 class="mb-4 fw-bold" style="color: var(--brand-dark);">
                    Atención Clínica
                </h4>

                @{
                    var clinicas = ViewBag.BitacorasClinicas as IEnumerable<dynamic>;
                }

                @if (clinicas == null || !clinicas.Any())
                {
                    <div class="text-center p-4 rounded border mt-3 mb-4" style="background-color: var(--surface-muted); box-shadow: var(--shadow-soft);">
                        <i class="bi bi-clipboard2-pulse" style="font-size: 2rem; color: var(--brand-secondary);"></i>
                        <p class="text-muted mb-0 mt-2">No hay registros de atención clínica para este alumno.</p>
                    </div>
                }
                else
                {
                    <div class="scroll-historial mb-4">
                        @foreach (var clinica in clinicas)
                        {
                            <div class="card mb-3 border-0" style="background-color: var(--surface-card); box-shadow: var(--shadow-soft); border-radius: var(--radius-sm, 12px);">
                                <div class="card-body p-3 p-md-4">
                                    <div class="d-flex flex-wrap align-items-center mb-3 gap-2">
                                        <span class="badge shadow-sm" style="background-color: var(--btn-eliminar); color: var(--brand-white);">Folio: @clinica.Folio</span>
                                        <small class="text-muted fw-bold">@clinica.FechaHora.ToString("dd MMM yyyy - hh:mm tt")</small>
                                                
                                        @if (clinica.Estado == "Estable")
                                        {
                                            <span class="badge" style="background-color: var(--btn-crear); color: var(--brand-black); font-size:0.7rem;">Estable</span>
                                        }
                                        else if (clinica.Estado == "Grave" || clinica.Estado == "Traslado")
                                        {
                                            <span class="badge" style="background-color: var(--btn-eliminar); color: var(--brand-white); font-size:0.7rem;">@clinica.Estado</span>
                                        }
                                        else
                                        {
                                            <span class="badge" style="background-color: var(--btn-editar); color: var(--brand-black); font-size:0.7rem;">@clinica.Estado</span>
                                        }
                                    </div>
                                            
                                    <p class="mb-2 text-dark" style="font-size: 0.95rem;">
                                        <strong style="color: var(--brand-primary-light);">Motivo:</strong> @(string.IsNullOrEmpty(clinica.MotivoConsulta) ? "No especificado." : clinica.MotivoConsulta)
                                    </p>
                                    <p class="mb-0 text-muted" style="font-size: 0.90rem;">
                                        <strong>Acción / Tratamiento:</strong> @(string.IsNullOrEmpty(clinica.Tratamiento) ? "Ninguno registrado." : clinica.Tratamiento)
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                }

            </div>
            
        </div>
    }
</div>