@model SchoolManager.Models.users_user

@{
    ViewData["Title"] = "Seguimiento Académico";

    var historial = ViewBag.Historial as List<SchoolManager.Models.tutorship_monitoring> ?? new List<SchoolManager.Models.tutorship_monitoring>();
}

<div class="container mt-4 mb-5">
    <h2 class="text-center fw-bold mb-4" style="color: var(--brand-dark);">Historial de Seguimiento</h2>
    
    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <form method="get" asp-controller="Seguimiento" asp-action="Seguimiento">
                <div class="input-group input-group-lg shadow-sm" style="border-radius: 12px; overflow: hidden;">
                    <input type="text" name="matriculaBuscar" class="form-control border-0" placeholder="Buscar por Matrícula..."
                           value="@ViewBag.Matricula" required style="font-family: var(--font-cuerpo);">
                    <button class="btn btn-primary-brand border-0 px-4" type="submit">
                        <i class="bi bi-search me-2"></i> Buscar Alumno
                    </button>
                </div>
            </form>
        </div>
    </div>
    
</div>

    @if (Model != null)
    {
        string nombreCompleto = $"{Model.Person.FirstName} {Model.Person.LastNamePaternal}";

        <div class="container">
            <div class="row g-4 justify-content-center">
                
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm" style="background-color: var(--brand-white); border-radius: 12px; overflow: hidden;">

                        <div class="card-header bg-transparent border-0 pt-4 d-flex justify-content-between align-items-center px-4">
                            <h5 class="fw-bold m-0" style="color: var(--brand-dark);">Nuevo Feedback</h5>

                            <a asp-controller="Tutorship" asp-action="VerEntrevistaAlumno" asp-route-id="@Model.UserId"
                                   class="btn btn-sm btn-secondary-brand rounded-circle d-flex align-items-center justify-content-center"
                                   style="width: 32px; height: 32px;"
                                   title="Ver Expediente Completo">
                                <i class="bi bi-info-lg"></i>
                            </a>
                        </div>

                        <div class="card-body p-4 pt-3">
                            <h6 class="mb-4 text-muted border-bottom pb-2"><i class="bi bi-person-fill me-1"></i> @nombreCompleto</h6>

                        <form asp-controller="Seguimiento" asp-action="GuardarSeguimiento" method="post" enctype="multipart/form-data">
                                <input type="hidden" name="studentId" value="@Model.UserId" />
                                <input type="hidden" name="matricula" value="@ViewBag.Matricula" />

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Tipo de Reporte</label>
                                    <select class="form-select shadow-sm" name="tipo" style="border-color: var(--brand-secondary);">
                                        <option value="Académico">Académico</option>
                                        <option value="Conductual">Conductual</option>
                                        <option value="Psicológico">Psicológico</option>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Observaciones</label>
                                    <textarea class="form-control shadow-sm" name="observaciones" rows="5" style="border-color: var(--brand-secondary); resize: none;" required></textarea>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-bold">Adjuntar Evidencia</label>
                                    <div class="input-group shadow-sm">
                                        <input type="file" class="form-control" name="ArchivoAdjunto"
                                               accept=".pdf,.jpg,.jpeg,.png"
                                               style="border-color: var(--brand-secondary);">
                                        <label class="input-group-text bg-white" style="border-color: var(--brand-secondary);">
                                            <i class="bi bi-paperclip text-muted"></i>
                                        </label>
                                    </div>
                                    <div class="form-text small text-muted">
                                        * Justificantes médicos, reportes firmados (PDF o Imagen).
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary-brand w-100 fw-bold shadow">
                                    <i class="bi bi-save me-2"></i> Guardar Reporte
                                    
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <h4 class="mb-4 fw-bold" style="color: var(--brand-black);">Historial de Seguimiento</h4>

                    @if (!historial.Any())
                    {
                        <div class="text-center p-5 bg-white rounded shadow-sm border mt-3">
                            <i class="bi bi-folder2-open" style="font-size: 3rem; color: var(--brand-secondary);"></i>
                            <h5 class="mt-3 text-dark fw-bold">Sin reportes</h5>
                            <p class="text-muted mb-0">Este alumno no tiene reportes previos en su expediente.</p>
                        </div>
                    }
                    else
                    {
                        foreach (var reporte in historial)
                        {
                            <div class="card mb-3 dashboard-card-hover border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <h6 class="mb-0 fw-bold" style="color: var(--brand-black);">
                                                Reporte de Tutoría
                                            </h6>

                                            @if (reporte.FilePath != "Sin archivo")
                                            {
                                                <a href="@reporte.FilePath" target="_blank" class="badge text-decoration-none" style="background-color: var(--btn-ver); color: white;">
                                                    <i class="bi bi-paperclip"></i> Ver Archivo
                                                </a>
                                            }
                                        </div>
                                        <div class="text-end">
                                            <small class="text-muted d-block">@reporte.Date.ToString("dd MMM yyyy")</small>
                                            <small class="badge bg-light text-secondary border">@reporte.PerformanceLevel</small>
                                        </div>
                                    </div>
                                    <p class="card-text mt-3 p-3 bg-light rounded text-dark" style="font-size: 0.95rem; border: 1px solid rgba(0,0,0,0.05);">
                                        @reporte.DetailedObservations
                                    </p>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>