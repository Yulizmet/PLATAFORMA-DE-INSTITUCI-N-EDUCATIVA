
@model SchoolManager.Models.users_user
@using System.Linq

@{
    ViewData["Title"] = "Seguimiento Académico";

    var historial = ViewBag.Historial as List<SchoolManager.Models.tutorship_monitoring> ?? new List<SchoolManager.Models.tutorship_monitoring>();
    var bitacoras = ViewBag.BitacorasPsicologia as IEnumerable<dynamic>;
}

<div class="container mt-4 mb-4">
    <div class="position-relative mb-3 text-center">
        <div class="position-absolute top-50 start-0 translate-middle-y">
            <button type="button" onclick="history.back()" class="btn btn-sm btn-outline-secondary fw-bold shadow-sm px-3" style="border-radius: 20px;">
                <i class="bi bi-arrow-left me-1"></i> Regresar
            </button>
        </div>

        <h2 class="fw-bold m-0" style="color: var(--brand-dark);">Historial de Seguimiento</h2>
    </div>
    
    @if (!string.IsNullOrEmpty(ViewBag.Matricula))
    {
        <div class="text-center mb-5">
            <span class="badge bg-white text-dark border shadow-sm px-4 py-2" style="border-radius: 20px; font-size: 1rem;">
                <i class="bi bi-person-badge me-2" style="color: var(--brand-secondary);"></i> Matrícula: <span class="fw-bold" style="color: var(--brand-dark);">@ViewBag.Matricula</span>
            </span>
        </div>
    }
</div>

@if (Model != null)
{
    string nombreCompleto = $"{Model.Person.FirstName} {Model.Person.LastNamePaternal}";

    <div class="container">
        <div class="row g-4 justify-content-center">
            
            <div class="col-md-4">
                <div class="card border-0 shadow-sm" style="background-color: var(--brand-white); border-radius: 12px; overflow: hidden;">

                    <div class="card-header bg-transparent border-0 pt-4 d-flex justify-content-between align-items-center px-4">
                        <h5 class="fw-bold m-0" style="color: var(--brand-dark);">Nuevo Feedback</h5>

                        <a asp-controller="Entrevista" asp-action="VerEntrevistaAlumno" asp-route-id="@Model.UserId"
                               class="btn btn-sm btn-secondary-brand rounded-circle d-flex align-items-center justify-content-center"
                               style="width: 32px; height: 32px;"
                               title="Ver Expediente Completo">
                            <i class="bi bi-info-lg"></i>
                        </a>
                    </div>

                    <div class="card-body p-4 pt-3">
                        <h6 class="mb-4 text-muted border-bottom pb-2"><i class="bi bi-person-fill me-1"></i> @nombreCompleto</h6>

                        <form asp-controller="Seguimiento" asp-action="GuardarSeguimiento" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="studentId" value="@Model.UserId" />
                            <input type="hidden" name="matricula" value="@ViewBag.Matricula" />

                            <div class="mb-3">
                                <label class="form-label fw-bold text-dark" style="font-family: var(--font-cuerpo);">Tipo de Reporte</label>
                                <select class="form-select shadow-sm" name="tipo" style="border-color: var(--border-medium); border-radius: var(--radius-xs);">
                                    <option value="Académico">Académico</option>
                                    <option value="Conductual">Conductual</option>
                                    <option value="Psicológico">Psicológico</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold text-dark" style="font-family: var(--font-cuerpo);">Observaciones</label>
                                <textarea class="form-control shadow-sm" name="observaciones" rows="5" style="border-color: var(--border-medium); border-radius: var(--radius-xs); resize: none;" required></textarea>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Adjuntar Evidencia</label>
    
                                <div class="position-relative shadow-sm" style="border-radius: 8px; border: 1px solid var(--brand-secondary); overflow: hidden;">
                                    <input type="file" name="ArchivoAdjunto" id="evidenciaUpload" class="d-none"
                                           accept=".pdf,.jpg,.jpeg,.png"
                                           onchange="document.getElementById('fileName').textContent = this.files.length > 0 ? this.files[0].name : 'Ningún archivo seleccionado';">
        
                                    <label for="evidenciaUpload" class="d-flex align-items-center m-0 w-100" style="cursor: pointer; background-color: #ffffff;">
                                        <div class="px-3 py-2 fw-bold text-dark text-center" style="background-color: #f8f9fa; border-right: 1px solid var(--brand-secondary); min-width: 140px;">
                                            Elegir archivo
                                        </div>
                                        <div id="fileName" class="px-3 text-muted flex-grow-1 text-truncate" style="font-size: 0.95rem;">
                                            Ningún archivo seleccionado
                                        </div>
                                        <div class="px-3 border-start" style="border-color: #eee !important;">
                                            <i class="bi bi-paperclip text-muted"></i>
                                        </div>
                                    </label>
                                </div>
    
                                <div class="form-text small text-muted mt-2">
                                    * Justificantes médicos, reportes firmados (PDF o Imagen).
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary-brand w-100 fw-bold shadow">
                                <i class="bi bi-save me-2"></i> Guardar Reporte
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                
                <h4 class="mb-3 fw-bold" style="color: var(--brand-dark);">
                    Historial de Seguimiento
                </h4>

                @if (!historial.Any())
                {
                    <div class="text-center p-5 bg-white rounded shadow-sm border mt-3 mb-5">
                        <i class="bi bi-folder2-open" style="font-size: 3rem; color: var(--brand-secondary);"></i>
                        <h5 class="mt-3 text-dark fw-bold">Sin reportes</h5>
                        <p class="text-muted mb-0">Este alumno no tiene reportes previos en su expediente.</p>
                    </div>
                }
                else
                {
                    <div class="row g-2 mb-4 align-items-end bg-white p-3 rounded shadow-sm border" style="border-color: var(--border-soft) !important;">
                        <div class="col-12 col-md-5">
                            <label class="form-label small fw-bold text-muted mb-1"><i class="bi bi-funnel-fill me-1"></i> Filtrar por Tipo</label>
                            <select id="filtroTipo" class="form-select form-select-sm shadow-sm" style="border-color: var(--border-medium);">
                                <option value="">Todos los tipos</option>
                                <option value="Académico">Académico</option>
                                <option value="Conductual">Conductual</option>
                                <option value="Psicológico">Psicológico</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-5">
                            <label class="form-label small fw-bold text-muted mb-1"><i class="bi bi-calendar-event me-1"></i> Filtrar por Fecha</label>
                            <input type="date" id="filtroFecha" class="form-control form-control-sm shadow-sm" style="border-color: var(--border-medium);">
                        </div>
                        <div class="col-12 col-md-2">
                            <button type="button" id="btnLimpiarFiltros" class="btn btn-sm btn-outline-secondary w-100 shadow-sm" title="Limpiar filtros">
                                <i class="bi bi-eraser"></i> Limpiar
                            </button>
                        </div>
                    </div>

                    <div id="mensajeSinResultados" class="text-center p-4 rounded border mb-4 d-none" style="background-color: var(--surface-muted);">
                        <i class="bi bi-search" style="font-size: 2rem; color: var(--brand-secondary);"></i>
                        <h6 class="mt-3 fw-bold text-muted">No se encontraron reportes con estos filtros.</h6>
                    </div>

                    <div class="mb-4 mb-md-5 scroll-historial" id="listaReportes">
                        @foreach (var reporte in historial)
                        {
                            <div class="card mb-3 border-0 reporte-card"
                                 data-tipo="@reporte.PerformanceLevel"
                                 data-fecha="@reporte.Date.ToString("yyyy-MM-dd")"
                                 style="background-color: var(--surface-card); box-shadow: var(--shadow-soft); border-radius: var(--radius-sm, 12px); transition: transform 0.2s;">
                                
                                <div class="card-body p-3 p-md-4">
                                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <h6 class="mb-0 fw-bold" style="color: var(--brand-black);">
                                                Reporte de Tutoría
                                            </h6>

                                            @if (reporte.FilePath != "Sin archivo")
                                            {
                                                <a href="@reporte.FilePath" target="_blank" class="badge text-decoration-none" style="background-color: var(--btn-ver); color: white;">
                                                    <i class="bi bi-paperclip"></i> Ver Archivo
                                                </a>
                                            }
                                        </div>
                                        <div class="text-end">
                                            <small class="text-muted d-block">@reporte.Date.ToString("dd MMM yyyy")</small>
                                            <small class="badge bg-light text-secondary border">@reporte.PerformanceLevel</small>
                                        </div>
                                    </div>
                                    <p class="card-text mt-3 p-3 bg-light rounded text-dark" style="font-size: 0.95rem; border: 1px solid rgba(0,0,0,0.05);">
                                        @reporte.DetailedObservations
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                }

                <hr class="mb-4" style="opacity: 0.1;" />
                <h4 class="mb-4 fw-bold" style="color: var(--brand-black);">
                    @* <i class="bi bi-chat-heart-fill me-2" style="color: #38b6ff;"></i> *@ Intervenciones Psicológicas
                </h4>

                @if (bitacoras == null || !bitacoras.Any())
                {
                    <div class="text-center p-4 bg-light rounded shadow-sm border mt-3 mb-4">
                        <i class="bi bi-journal-x" style="font-size: 2rem; color: #ccc;"></i>
                        <p class="text-muted mb-0 mt-2">No hay registros psicológicos para este alumno.</p>
                    </div>
                }
                else
                {
                    <div class="scroll-historial mb-4">
                        @foreach (var psic in bitacoras)
                        {
                            <div class="card mb-3 border-0 shadow-sm" @* style="border-left: 5px solid #38b6ff !important;" *@>
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-2 gap-2">
                                        <span class="badge" style="background-color: #38b6ff; color: white;">Folio: @psic.Fol</span>
                                        <small class="text-muted fw-bold">@psic.AppointmentDatetime.ToString("dd MMM yyyy - hh:mm tt")</small>
                                        
                                        @if (psic.AttendanceStatus == "Asistió")
                                        {
                                            <span class="badge bg-success" style="font-size:0.7rem;">Asistió</span>
                                        }
                                        else if (psic.AttendanceStatus == "No asistió")
                                        {
                                            <span class="badge bg-danger" style="font-size:0.7rem;">Falta</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark" style="font-size:0.7rem;">Justificado</span>
                                        }
                                    </div>
                                    
                                    <p class="mb-0 text-dark" style="font-size: 0.95rem;">
                                        @(string.IsNullOrEmpty(psic.PsychologyObservations) ? "Sin observaciones previas." : psic.PsychologyObservations)
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                }

                <hr class="mb-4" style="opacity: 0.1;" />
                <h4 class="mb-4 fw-bold" style="color: var(--brand-black);">
                    @* <i class="bi bi-heart-pulse-fill me-2" style="color: #e53935;"></i> *@ Atención Clínica
                </h4>

                @{
                    var clinicas = ViewBag.BitacorasClinicas as IEnumerable<dynamic>;
                }

                @if (clinicas == null || !clinicas.Any())
                {
                    <div class="text-center p-4 bg-light rounded shadow-sm border mt-3 mb-4">
                        <i class="bi bi-clipboard2-pulse" style="font-size: 2rem; color: #ccc;"></i>
                        <p class="text-muted mb-0 mt-2">No hay registros de atención clínica para este alumno.</p>
                    </div>
                }
                else
                {
                    <div class="scroll-historial mb-4">
                        @foreach (var clinica in clinicas)
                        {
                            <div class="card mb-3 border-0 shadow-sm">
                            <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-2 gap-2">
                                <span class="badge" style="background-color: #e53935; color: white;">Folio: @clinica.Folio</span>
                                <small class="text-muted fw-bold">@clinica.FechaHora.ToString("dd MMM yyyy - hh:mm tt")</small>
                                        
                                @if (clinica.Estado == "Estable")
                                {
                                    <span class="badge bg-success" style="font-size:0.7rem;">Estable</span>
                                }
                                else if (clinica.Estado == "Grave" || clinica.Estado == "Traslado")
                                {
                                    <span class="badge bg-danger" style="font-size:0.7rem;">@clinica.Estado</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark" style="font-size:0.7rem;">@clinica.Estado</span>
                                }
                            </div>
                                    
                            <p class="mb-2 text-dark" style="font-size: 0.95rem;">
                                <strong style="color: #e53935;">Motivo:</strong> @(string.IsNullOrEmpty(clinica.MotivoConsulta) ? "No especificado." : clinica.MotivoConsulta)
                            </p>
                            <p class="mb-0 text-muted" style="font-size: 0.90rem;">
                                <strong>Acción / Tratamiento:</strong> @(string.IsNullOrEmpty(clinica.Tratamiento) ? "Ninguno registrado." : clinica.Tratamiento)
                            </p>
                            </div>
                            </div>
                        }
                    </div>
                }

            </div>
            
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const filtroTipo = document.getElementById('filtroTipo');
            const filtroFecha = document.getElementById('filtroFecha');
            const btnLimpiar = document.getElementById('btnLimpiarFiltros');
            const reportes = document.querySelectorAll('.reporte-card');
            const mensajeSinResultados = document.getElementById('mensajeSinResultados');

            if (filtroTipo && reportes.length > 0) {
                
                function aplicarFiltros() {
                    const tipoBuscado = filtroTipo.value.toLowerCase();
                    const fechaBuscada = filtroFecha.value; 
                    let reportesVisibles = 0;

                    reportes.forEach(card => {
                        const tipoCard = card.getAttribute('data-tipo').toLowerCase();
                        const fechaCard = card.getAttribute('data-fecha');

                        let cumpleTipo = (tipoBuscado === "" || tipoCard === tipoBuscado);
                        let cumpleFecha = (fechaBuscada === "" || fechaCard === fechaBuscada);

                        if (cumpleTipo && cumpleFecha) {
                            card.style.display = ''; 
                            reportesVisibles++;
                        } else {
                            card.style.display = 'none'; 
                        }
                    });

                    if (reportesVisibles === 0) {
                        mensajeSinResultados.classList.remove('d-none');
                    } else {
                        mensajeSinResultados.classList.add('d-none');
                    }
                }

                filtroTipo.addEventListener('change', aplicarFiltros);
                filtroFecha.addEventListener('change', aplicarFiltros);

                btnLimpiar.addEventListener('click', function() {
                    filtroTipo.value = '';
                    filtroFecha.value = '';
                    aplicarFiltros();
                });
            }
        });
    </script>
}