@model SchoolManager.Models.users_user
@using System.Linq

@{
    ViewData["Title"] = "Seguimiento Académico";

    var historial = ViewBag.Historial as List<SchoolManager.Models.tutorship_monitoring> ?? new List<SchoolManager.Models.tutorship_monitoring>();
    var bitacoras = ViewBag.BitacorasPsicologia as IEnumerable<dynamic>;
}

<div class="container-fluid px-3 px-md-4 mt-4 mb-4">
    
    <div class="d-flex flex-column flex-md-row align-items-center justify-content-center position-relative mb-3 gap-3">
        <div class="w-100 w-md-auto text-start text-md-center position-md-absolute start-0 top-50 translate-middle-y-md">
            <button type="button" onclick="history.back()" class="btn btn-sm btn-outline-secondary fw-bold shadow-sm px-3" style="border-radius: 20px;">
                <i class="bi bi-arrow-left me-1"></i> Regresar
            </button>
        </div>

        <h2 class="fw-bold m-0 text-center fs-4 fs-md-2" style="color: var(--brand-dark);">Historial de Seguimiento</h2>
    </div>
    
    @if (!string.IsNullOrEmpty(ViewBag.Matricula))
    {
        <div class="text-center mb-4 mb-md-5">
            <span class="badge bg-white text-dark border shadow-sm px-4 py-2 text-wrap" style="border-radius: 20px; font-size: 0.9rem;">
                <i class="bi bi-person-badge me-1 me-md-2" style="color: var(--brand-secondary);"></i> Matrícula: <span class="fw-bold" style="color: var(--brand-dark);">@ViewBag.Matricula</span>
            </span>
        </div>
    }
</div>

@if (Model != null)
{
    string nombreCompleto = $"{Model.Person.FirstName} {Model.Person.LastNamePaternal}";

    <div class="container-fluid px-3 px-md-4">
        <div class="row g-4 justify-content-center">
            
            <div class="col-12 col-lg-4">
                <div class="card border-0 shadow-sm mb-4" style="background-color: var(--brand-white); border-radius: 12px; overflow: hidden;">

                    <div class="card-header bg-transparent border-0 pt-4 d-flex justify-content-between align-items-center px-3 px-md-4">
                        <h5 class="fw-bold m-0 fs-5" style="color: var(--brand-dark);">Nuevo Feedback</h5>

                        <a asp-controller="Entrevista" asp-action="VerEntrevistaAlumno" asp-route-id="@Model.UserId"
                               class="btn btn-sm btn-secondary-brand rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                               style="width: 32px; height: 32px;"
                               title="Ver Expediente Completo">
                            <i class="bi bi-info-lg"></i>
                        </a>
                    </div>

                    <div class="card-body p-3 p-md-4 pt-3">
                        <h6 class="mb-4 text-muted border-bottom pb-2 text-wrap"><i class="bi bi-person-fill me-1"></i> @nombreCompleto</h6>

                        <form asp-controller="Seguimiento" asp-action="GuardarSeguimiento" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="studentId" value="@Model.UserId" />
                            <input type="hidden" name="matricula" value="@ViewBag.Matricula" />

                            <div class="mb-3">
                                <label class="form-label fw-bold">Tipo de Reporte</label>
                                <select class="form-select shadow-sm" name="tipo" style="border-color: var(--brand-secondary);">
                                    <option value="Académico">Académico</option>
                                    <option value="Conductual">Conductual</option>
                                    <option value="Psicológico">Psicológico</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Observaciones</label>
                                <textarea class="form-control shadow-sm" name="observaciones" rows="5" style="border-color: var(--brand-secondary); resize: none;" required></textarea>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Adjuntar Evidencia</label>
    
                                <div class="position-relative shadow-sm" style="border-radius: 8px; border: 1px solid var(--brand-secondary); overflow: hidden;">
                                    <input type="file" name="ArchivoAdjunto" id="evidenciaUpload" class="d-none"
                                           accept=".pdf,.jpg,.jpeg,.png"
                                           onchange="document.getElementById('fileName').textContent = this.files.length > 0 ? this.files[0].name : 'Ningún archivo seleccionado';">
        
                                    <label for="evidenciaUpload" class="d-flex align-items-center m-0 w-100" style="cursor: pointer; background-color: #ffffff;">
                                        <div class="px-2 px-md-3 py-2 fw-bold text-dark text-center" style="background-color: #f8f9fa; border-right: 1px solid var(--brand-secondary); min-width: 100px;">
                                            Examinar
                                        </div>
                                        <div id="fileName" class="px-2 px-md-3 text-muted flex-grow-1 text-truncate" style="font-size: 0.85rem;">
                                            Sin archivo
                                        </div>
                                        <div class="px-2 px-md-3 border-start" style="border-color: #eee !important;">
                                            <i class="bi bi-paperclip text-muted"></i>
                                        </div>
                                    </label>
                                </div>
    
                                <div class="form-text small text-muted mt-2 lh-sm">
                                    * Justificantes médicos, reportes firmados (PDF o Imagen).
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary-brand w-100 fw-bold shadow py-2">
                                <i class="bi bi-save me-2"></i> Guardar Reporte
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-8">
                
                <h4 class="mb-3 mb-md-4 fw-bold fs-5 fs-md-4" style="color: var(--brand-black);">
                    Historial de Seguimiento
                </h4>
                @if (!historial.Any())
                {
                    <div class="text-center p-4 p-md-5 bg-white rounded shadow-sm border mt-3 mb-4 mb-md-5">
                        <i class="bi bi-folder2-open" style="font-size: 3rem; color: var(--brand-secondary);"></i>
                        <h5 class="mt-3 text-dark fw-bold fs-6 fs-md-5">Sin reportes</h5>
                        <p class="text-muted mb-0 small small-md">Este alumno no tiene reportes previos en su expediente.</p>
                    </div>
                }
                else
                {
                    <div class="mb-4 mb-md-5 scroll-historial">
                        @foreach (var reporte in historial)
                        {
                            <div class="card mb-3 dashboard-card-hover border-0 shadow-sm">
                                <div class="card-body p-3 p-md-4">
                                    
                                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-2 gap-2">
                                        <div class="d-flex flex-wrap align-items-center gap-2">
                                            <h6 class="mb-0 fw-bold" style="color: var(--brand-black);">
                                                Reporte de Tutoría
                                            </h6>

                                            @if (reporte.FilePath != "Sin archivo")
                                            {
                                                <a href="@reporte.FilePath" target="_blank" class="badge text-decoration-none" style="background-color: var(--btn-ver); color: white;">
                                                    <i class="bi bi-paperclip"></i> Ver Archivo
                                                </a>
                                            }
                                        </div>
                                        <div class="text-start text-sm-end border-top border-sm-0 pt-2 pt-sm-0 w-100 w-sm-auto">
                                            <small class="text-muted d-inline d-sm-block me-2 me-sm-0">@reporte.Date.ToString("dd MMM yyyy")</small>
                                            <small class="badge bg-light text-secondary border">@reporte.PerformanceLevel</small>
                                        </div>
                                    </div>
                                    
                                    <p class="card-text mt-3 p-3 bg-light rounded text-dark lh-sm" style="font-size: 0.95rem; border: 1px solid rgba(0,0,0,0.05);">
                                        @reporte.DetailedObservations
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                }

                <hr class="mb-4" style="opacity: 0.1;" />
                
                <h4 class="mb-3 mb-md-4 fw-bold fs-5 fs-md-4" style="color: var(--brand-black);">
                    Intervenciones Psicológicas
                </h4>

                @if (bitacoras == null || !bitacoras.Any())
                {
                    <div class="text-center p-4 bg-light rounded shadow-sm border mt-3 mb-4">
                        <i class="bi bi-journal-x" style="font-size: 2rem; color: #ccc;"></i>
                        <p class="text-muted mb-0 mt-2 small small-md">No hay registros psicológicos para este alumno.</p>
                    </div>
                }
                else
                {
                    <div class="scroll-historial mb-4">
                        @foreach (var psic in bitacoras)
                        {
                            <div class="card mb-3 border-0 shadow-sm">
                                <div class="card-body p-3 p-md-4">
                                    <div class="d-flex flex-wrap align-items-center mb-2 gap-2">
                                        <span class="badge" style="background-color: #38b6ff; color: white;">Folio: @psic.Fol</span>
                                        <small class="text-muted fw-bold">@psic.AppointmentDatetime.ToString("dd MMM yyyy - hh:mm tt")</small>
                                        
                                        @if (psic.AttendanceStatus == "Asistió")
                                        {
                                            <span class="badge bg-success" style="font-size:0.7rem;">Asistió</span>
                                        }
                                        else if (psic.AttendanceStatus == "No asistió")
                                        {
                                            <span class="badge bg-danger" style="font-size:0.7rem;">Falta</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark" style="font-size:0.7rem;">Justificado</span>
                                        }
                                    </div>
                                    
                                    <p class="mb-0 text-dark lh-sm" style="font-size: 0.95rem;">
                                        @(string.IsNullOrEmpty(psic.PsychologyObservations) ? "Sin observaciones previas." : psic.PsychologyObservations)
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                }

                <hr class="mb-4" style="opacity: 0.1;" />
                
                <h4 class="mb-3 mb-md-4 fw-bold fs-5 fs-md-4" style="color: var(--brand-black);">
                    Atención Clínica
                </h4>

                @{
                    var clinicas = ViewBag.BitacorasClinicas as IEnumerable<dynamic>;
                }

                @if (clinicas == null || !clinicas.Any())
                {
                    <div class="text-center p-4 bg-light rounded shadow-sm border mt-3 mb-4">
                        <i class="bi bi-clipboard2-pulse" style="font-size: 2rem; color: #ccc;"></i>
                        <p class="text-muted mb-0 mt-2 small small-md">No hay registros de atención clínica para este alumno.</p>
                    </div>
                }
                else
                {
                    <div class="scroll-historial mb-4">
                        @foreach (var clinica in clinicas)
                        {
                            <div class="card mb-3 border-0 shadow-sm">
                                <div class="card-body p-3 p-md-4">
                                    <div class="d-flex flex-wrap align-items-center mb-2 gap-2">
                                        <span class="badge" style="background-color: #e53935; color: white;">Folio: @clinica.Folio</span>
                                        <small class="text-muted fw-bold">@clinica.FechaHora.ToString("dd MMM yyyy - hh:mm tt")</small>
                                                
                                        @if (clinica.Estado == "Estable")
                                        {
                                            <span class="badge bg-success" style="font-size:0.7rem;">Estable</span>
                                        }
                                        else if (clinica.Estado == "Grave" || clinica.Estado == "Traslado")
                                        {
                                            <span class="badge bg-danger" style="font-size:0.7rem;">@clinica.Estado</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark" style="font-size:0.7rem;">@clinica.Estado</span>
                                        }
                                    </div>
                                            
                                    <p class="mb-2 text-dark lh-sm" style="font-size: 0.95rem;">
                                        <strong style="color: #e53935;">Motivo:</strong> @(string.IsNullOrEmpty(clinica.MotivoConsulta) ? "No especificado." : clinica.MotivoConsulta)
                                    </p>
                                    <p class="mb-0 text-muted lh-sm" style="font-size: 0.90rem;">
                                        <strong>Acción / Tratamiento:</strong> @(string.IsNullOrEmpty(clinica.Tratamiento) ? "Ninguno registrado." : clinica.Tratamiento)
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                }

            </div>
            
        </div>
    </div>
    
}