@{
    ViewData["Title"] = "Asignación de Tutores";
    var maestros = ViewBag.Maestros as IEnumerable<SchoolManager.Models.users_user>;
    var grupos = ViewBag.Grupos as IEnumerable<SchoolManager.Models.grades_group>;
}

<div class="container mt-4 mt-md-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-7">

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
                <h2 class="fw-bold m-0 fs-3" style="color: var(--utt-dark-red);">
                    <i class="bi bi-diagram-3-fill"></i> Asignación de Tutores a Grupos
                </h2>
                <a asp-controller="Tutorship" asp-action="Controlador" class="btn btn-outline-secondary btn-sm align-self-start align-self-md-auto">
                    <i class="bi bi-arrow-left"></i> Regresar
                </a>
            </div>

            @if (TempData["AsignacionExito"] != null)
            {
                <div class="alert alert-success shadow-sm">
                    <i class="bi bi-check-circle-fill"></i> @TempData["AsignacionExito"]
                </div>
            }
            @if (TempData["AsignacionError"] != null)
            {
                <div class="alert alert-danger shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill"></i> @TempData["AsignacionError"]
                </div>
            }

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0 fs-6 fs-md-5">Vincular Maestro con Grupo</h5>
                </div>
                
                <div class="card-body p-3 p-md-4" style="background-color: var(--utt-light);">

                    <form asp-area="Gestion" asp-controller="Alumnos" asp-action="GuardarAsignacionTutor" method="post">

                        <div class="mb-4">
                            <label class="form-label fw-bold" style="color: var(--utt-black);">1. Selecciona al Maestro (Tutor)</label>
                            <select name="teacherId" class="form-select form-select-lg fs-6 fs-md-5" style="border-color: var(--utt-beige);" required>
                                <option value="">-- Elige un profesor --</option>
                                @if (maestros != null)
                                {
                                    foreach (var maestro in maestros)
                                    {
                                        <option value="@maestro.UserId">
                                            @maestro.Person.FirstName @maestro.Person.LastNamePaternal @maestro.Person.LastNameMaternal
                                        </option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold" style="color: var(--utt-black);">2. Selecciona el Grupo</label>
                            <select name="groupId" class="form-select form-select-lg fs-6 fs-md-5" style="border-color: var(--utt-beige);" required>
                                <option value="">-- Elige un grupo --</option>
                                @if (grupos != null)
                                {
                                    foreach (var grupo in grupos)
                                    {
                                        <option value="@grupo.GroupId">
                                            Grado @grupo.GradeLevelId | Grupo @grupo.Name
                                        </option>
                                    }
                                }
                            </select>
                            <div class="form-text mt-2 text-muted small">
                                * Al asignar, todos los alumnos actualmente inscritos en este grupo tendrán a este profesor como su tutor asignado en el sistema.
                            </div>
                        </div>

                        <div class="d-grid mt-4 mt-md-5">
                            <button type="submit" class="btn btn-utt-primary btn-lg fw-bold shadow fs-6 fs-md-5">
                                <i class="bi bi-link-45deg"></i> Guardar Asignación
                            </button>
                        </div>

                    </form>

                </div>
            </div>
            
        </div>
    </div>
</div>