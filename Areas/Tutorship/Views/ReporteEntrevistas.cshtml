@model IEnumerable<SchoolManager.Models.users_user>

@{
    ViewData["Title"] = "Estatus de Entrevistas";

    var dictMatriculas = ViewBag.Matriculas as Dictionary<int, string> ?? new Dictionary<int, string>();
    var dictGrupos = ViewBag.Grupos as Dictionary<int, string> ?? new Dictionary<int, string>();
    var dictEstatus = ViewBag.EstatusEntrevistas as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0" style="color: var(--utt-dark-red);">
            <i class="bi bi-file-earmark-person-fill"></i> Reporte de Entrevistas
        </h2>
        <a asp-action="Controlador" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver al panel
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="background-color: var(--utt-light);">
        <div class="card-body p-4">
            <form method="get" asp-action="ReporteEntrevistas" class="row align-items-end">
                <div class="col-md-8">
                    <label class="form-label fw-bold text-dark">Filtrar por Estatus:</label>
                    <select name="filtroEstatus" class="form-select border-danger">
                        <option value="">-- Mostrar Todos los Alumnos --</option>

                        @if (ViewBag.FiltroActual == "Completada")
                        {
                            <option value="Completada" selected>Completadas (Verde)</option>
                        }
                        else
                        {
                            <option value="Completada">Completadas (Verde)</option>
                        }

                        @if (ViewBag.FiltroActual == "Pendiente")
                        {
                            <option value="Pendiente" selected>Pendientes (Rojo)</option>
                        }
                        else
                        {
                            <option value="Pendiente">Pendientes (Rojo)</option>
                        }

                        @if (ViewBag.FiltroActual == "Requiere Actualizacion")
                        {
                            <option value="Requiere Actualizacion" selected>Requieren Actualización (Amarillo)</option>
                        }
                        else
                        {
                            <option value="Requiere Actualizacion">Requieren Actualización (Amarillo)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-utt-primary w-100 fw-bold">
                        <i class="bi bi-funnel-fill"></i> Aplicar Filtro
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header p-3" style="background-color: var(--utt-dark-red); color: white;">
            <h5 class="mb-0 fw-bold">Lista de Alumnos</h5>
        </div>
        <div class="card-body p-0" style="background-color: var(--utt-white);">

            @if (!Model.Any())
            {
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-search" style="font-size: 3rem;"></i>
                    <h4 class="mt-3 fw-bold">No hay resultados</h4>
                    <p>No se encontraron alumnos con el estatus seleccionado.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-muted small fw-bold">
                            <tr>
                                <th class="ps-4">ALUMNO</th>
                                <th>MATRÍCULA</th>
                                <th>GRUPO</th>
                                <th>CORREO</th>
                                <th class="text-center pe-4">ESTATUS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var alumno in Model)
                            {
                                string matricula = dictMatriculas.ContainsKey(alumno.UserId) ? dictMatriculas[alumno.UserId] : "Sin asignar";
                                string grupo = dictGrupos.ContainsKey(alumno.UserId) ? dictGrupos[alumno.UserId] : "Sin grupo";
                                string estatus = dictEstatus.ContainsKey(alumno.UserId) ? dictEstatus[alumno.UserId] : "Pendiente";

                          
                                string badgeColor = "bg-danger"; 
                                string iconEstatus = "";

                                if (estatus == "Completada")
                                {
                                    badgeColor = "bg-success";
                                    iconEstatus = "";
                                }
                                else if (estatus == "Requiere Actualizacion")
                                {
                                    badgeColor = "bg-warning text-dark";
                                    iconEstatus = "";
                                }

                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold" style="color: var(--utt-black);">
                                            @alumno.Person.FirstName @alumno.Person.LastNamePaternal @alumno.Person.LastNameMaternal
                                        </div>
                                    </td>
                                    <td><span class="text-secondary">@matricula</span></td>
                                    <td><span class="badge bg-light text-dark border">@grupo</span></td>
                                    <td><a href="mailto:@alumno.Email" class="text-decoration-none text-secondary small">@alumno.Email</a></td>
                                    <td class="text-center pe-4">
                                        <span class="badge @badgeColor p-2" style="width: 170px;">
                                            <i class="bi @iconEstatus"></i> @estatus
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        <div class="card-footer bg-light text-muted small text-end">
            Mostrando <span class="fw-bold">@Model.Count()</span> alumno(s)
        </div>
    </div>
</div>