@{
    ViewData["Title"] = "Estatus de Entrevistas";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

<div class="container mt-4 mb-5">
    <div class="position-relative mb-4 text-center">
        <div class="position-absolute top-50 start-0 translate-middle-y">
            <button type="button" onclick="history.back()" class="btn btn-sm btn-outline-secondary fw-bold shadow-sm px-3" style="border-radius: 20px;">
                <i class="bi bi-arrow-left me-1"></i> Regresar
            </button>
        </div>
        <h2 class="fw-bold m-0" style="color: var(--brand-dark);">Reporte de Entrevistas</h2>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px;">
        <div class="card-body p-4">
            <form id="filtroForm" class="row align-items-end g-3">
                <div class="col-md-8">
                    <label class="form-label fw-bold text-dark">Filtrar por Estatus:</label>
                    <select id="selectEstatus" class="form-select shadow-sm">
                        <option value="">-- Todos --</option>
                        <option value="Completada">Completadas</option>
                        <option value="Pendiente">Pendientes</option>
                        <option value="Requiere Actualizacion">Requieren Actualización</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-secondary-brand w-100 fw-bold shadow-sm">
                        <i class="bi bi-funnel-fill me-2"></i> Aplicar Filtro
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-header p-3" style="background-color: var(--brand-dark);">
            <h5 class="mb-0 fw-bold text-white"><i class="bi bi-people-fill me-2"></i> Lista de Alumnos</h5>
        </div>
        <div class="card-body p-4">
            <table id="tablaAjax" class="table table-hover align-middle w-100">
                <thead class="table-light text-muted small fw-bold">
                    <tr>
                        <th>ALUMNO</th>
                        <th>MATRÍCULA</th>
                        <th>GRUPO</th>
                        <th>CORREO</th>
                        <th class="text-center">ESTATUS</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
        var table = $('#tablaAjax').DataTable({
        language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
        processing: true,
        serverSide: true,
        ajax: {
        url: "@Url.Action("ObtenerDataReportes", "Entrevista", new { area = "Gestion" })",
        type: "POST",
        data: function (d) {
        d.filtroEstatus = $('#selectEstatus').val();
        }
        },
        lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
        pageLength: 25,
        columns: [
        {
        data: "nombre",
        render: function(data) {
        return '<div class="fw-bold text-dark ps-2">' + data + '</div>';
        }
        },
        {
        data: "matricula",
        render: function(data) {
        return '<span class="text-secondary">' + data + '</span>';
        }
        },
        {
        data: "grupo",
        orderable: false,
        render: function(data) {
        return '<span class="badge border shadow-sm" style="background-color: var(--brand-white); color: var(--brand-black);">' + data + '</span>';
        }
        },
        {
        data: "email",
        orderable: false,
        render: function(data) {
        let correo = data ? data : 'Sin correo';
        if(correo !== 'Sin correo') {
        return '<a href="mailto:' + correo + '" class="text-decoration-none text-secondary small"><i class="bi bi-envelope me-1"></i> ' + correo + '</a>';
        }
        return '<span class="text-muted small">' + correo + '</span>';
        }
        },
        {
        data: "estatus",
        className: "text-center pe-4",
        render: function(data) {
        let bgColor = "var(--btn-eliminar)";
        let textColor = "var(--brand-white)";
                            
        if (data === "Completada") {
        bgColor = "var(--btn-crear)";
        textColor = "var(--brand-black)";
        }
        else if (data === "Requiere Actualizacion") {
        bgColor = "var(--btn-editar)";
        textColor = "var(--brand-black)";
        }

        return '<span class="badge shadow-sm p-2 px-3" style="background-color: ' + bgColor + '; color: ' + textColor + '; font-size: 0.8rem; min-width: 120px;">' + data.toUpperCase() + '</span>';
        }
        }
        ]
        });

        $('#filtroForm').on('submit', function(e){
        e.preventDefault();
        table.draw();
        });
        });
    </script>
}