@model IEnumerable<SchoolManager.Models.users_user>

@{
    ViewData["Title"] = "Estatus de Entrevistas";

    var dictMatriculas = ViewBag.Matriculas as Dictionary<int, string> ?? new Dictionary<int, string>();
    var dictGrupos = ViewBag.Grupos as Dictionary<int, string> ?? new Dictionary<int, string>();
    var dictEstatus = ViewBag.EstatusEntrevistas as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container mt-4 mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold m-0" style="color: var(--brand-dark);">
            <i class="bi bi-file-earmark-person-fill"></i> Reporte de Entrevistas
        </h2>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="background-color: var(--brand-white); border-radius: 12px;">
        <div class="card-body p-4">
            <form method="get" asp-action="ReporteEntrevistas" class="row align-items-end g-3">
                <div class="col-md-8">
                    <label class="form-label fw-bold text-dark">Filtrar por Estatus:</label>
                    <select name="filtroEstatus" class="form-select shadow-sm" style="border-color: var(--brand-secondary);">
                        <option value="">-- Mostrar Todos los Alumnos --</option>
                        <option value="Completada" selected="@(ViewBag.FiltroActual == "Completada")">Completadas (Verde)</option>
                        <option value="Pendiente" selected="@(ViewBag.FiltroActual == "Pendiente")">Pendientes (Rojo)</option>
                        <option value="Requiere Actualizacion" selected="@(ViewBag.FiltroActual == "Requiere Actualizacion")">Requieren Actualización (Amarillo)</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-secondary-brand w-100 fw-bold shadow-sm">
                        <i class="bi bi-funnel-fill me-2"></i> Aplicar Filtro
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-header p-3" style="background-color: var(--brand-dark); color: var(--brand-white);">
            <h5 class="mb-0 fw-bold text-white"><i class="bi bi-card-checklist me-2"></i> Lista de Alumnos</h5>
        </div>
        <div class="card-body p-0">

            @if (!Model.Any())
            {
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-search" style="font-size: 3rem; color: var(--brand-secondary);"></i>
                    <h4 class="mt-3 fw-bold text-dark">No hay resultados</h4>
                    <p>No se encontraron alumnos con el estatus seleccionado.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-muted small fw-bold">
                            <tr>
                                <th class="ps-4 py-3">ALUMNO</th>
                                <th>MATRÍCULA</th>
                                <th>GRUPO</th>
                                <th>CORREO</th>
                                <th class="text-center pe-4">ESTATUS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var alumno in Model)
                            {
                                string matricula = dictMatriculas.ContainsKey(alumno.UserId) ? dictMatriculas[alumno.UserId] : "Sin asignar";
                                string grupo = dictGrupos.ContainsKey(alumno.UserId) ? dictGrupos[alumno.UserId] : "Sin grupo";
                                string estatus = dictEstatus.ContainsKey(alumno.UserId) ? dictEstatus[alumno.UserId] : "Pendiente";

                                string bgColor = "var(--btn-eliminar)"; 
                                string textColor = "var(--brand-white)";

                                if (estatus == "Completada")
                                {
                                    bgColor = "var(--btn-crear)"; 
                                    textColor = "var(--brand-black)"; 
                                }
                                else if (estatus == "Requiere Actualizacion")
                                {
                                    bgColor = "var(--btn-editar)"; 
                                    textColor = "var(--brand-black)"; 
                                }

                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark">
                                            @alumno.Person.FirstName @alumno.Person.LastNamePaternal @alumno.Person.LastNameMaternal
                                        </div>
                                    </td>
                                    <td><span class="text-secondary">@matricula</span></td>
                                    <td><span class="badge border shadow-sm" style="background-color: var(--brand-white); color: var(--brand-black);">@grupo</span></td>
                                    <td><a href="mailto:@alumno.Email" class="text-decoration-none text-secondary small"><i class="bi bi-envelope me-1"></i> @alumno.Email</a></td>
                                    <td class="text-center pe-4">
                                        <span class="badge shadow-sm p-2 px-3" style="background-color: @bgColor; color: @textColor; font-size: 0.8rem; min-width: 120px;">
                                            @estatus.ToUpper()
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        <div class="card-footer bg-light p-3 text-end d-flex justify-content-between align-items-center">
            <a asp-action="Controlador" class="btn btn-sm btn-outline-secondary fw-bold">
                <i class="bi bi-arrow-left me-1"></i> Panel de Control
            </a>
            <span class="text-muted small">Mostrando <span class="fw-bold text-dark">@Model.Count()</span> alumno(s)</span>
        </div>
    </div>
</div>