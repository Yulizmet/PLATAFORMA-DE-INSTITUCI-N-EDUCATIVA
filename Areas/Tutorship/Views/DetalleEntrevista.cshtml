@model SchoolManager.Models.tutorship_interview

@{
    ViewData["Title"] = "Resultados de Entrevista";
    
    // 1. Datos de Control
    int roleId = ViewBag.RoleId ?? 0;

    // 2. Datos del Alumno
    string nombreAlumno = Model?.Student?.Person != null
        ? $"{Model.Student.Person.FirstName} {Model.Student.Person.LastNamePaternal} {Model.Student.Person.LastNameMaternal}"
        : "Alumno Desconocido";
            
    string primerNombre = Model?.Student?.Person?.FirstName ?? "A";
    
    // 3. Lógica de la Foto
    string rutaFoto = ViewBag.FotoPerfil as string ?? "";
    bool tieneFoto = !string.IsNullOrEmpty(rutaFoto);
    // Usamos el color rojo de la marca (8C1B1B) para el avatar automático
    string imgSrc = tieneFoto ? rutaFoto : $"https://ui-avatars.com/api/?name={primerNombre}&background=8C1B1B&color=fff&size=128";
    
    // Extra
    string matricula = ViewBag.Matricula as string ?? "";
    string grupo = ViewBag.Grupo as string ?? "";
}

<div class="container-fluid mt-4 mb-5">

    <div class="card border-0 shadow-sm mb-4" style="border-radius: 10px;">
        <div class="card-body p-4 d-flex align-items-center flex-wrap gap-4">
            
            <div class="flex-shrink-0">
                <img src="@imgSrc" alt="Foto de @nombreAlumno" class="rounded-circle shadow-sm border border-2" style="width: 100px; height: 100px; object-fit: cover; border-color: #eee !important;">
            </div>
            
            <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <div>
                        <h3 class="fw-bold mb-1" style="color: var(--brand-dark);">@nombreAlumno</h3>
                        <div class="d-flex gap-2 mt-2">
                            @if (!string.IsNullOrEmpty(matricula))
                            {
                                <span class="badge shadow-sm" style="background-color: var(--brand-white); color: var(--brand-black)"><i class="bi bi-person-badge me-1"></i> @matricula</span>
                            }
                            @if (!string.IsNullOrEmpty(grupo))
                            {
                                <span class="badge shadow-sm" style="background-color: var(--brand-secondary); color: var(--brand-white);"><i class="bi bi-people-fill me-1"></i> @grupo</span>
                            }
                            <span class="badge shadow-sm" style="background-color: var(--btn-crear); color: var(--brand-black);"><i class="bi bi-check-circle-fill me-1"></i> Estado: @Model?.Status</span>
                        </div>
                    </div>
                    
                    @if (Model != null)
                    {
                        <div class="text-end text-muted">
                            <small class="fw-bold text-uppercase" style="letter-spacing: 0.5px;">Fecha de Entrevista</small><br />
                            <span class="fs-5 fw-bold text-dark">
                                <i class="bi bi-calendar-event me-1" style="color: var(--brand-dark);"></i> @Model.DateCompleted.ToString("dd / MM / yyyy")
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (Model == null || Model.Answers == null || !Model.Answers.Any())
    {
        <div class="text-center p-5 bg-white rounded shadow-sm border mt-4">
            <i class="bi bi-journal-x" style="font-size: 3rem; color: var(--brand-secondary);"></i>
            <h4 class="mt-3 text-dark fw-bold">Expediente Vacío</h4>
            <p class="text-muted mb-0">La entrevista de este alumno aún no ha sido completada o no se encontraron respuestas guardadas en el sistema.</p>
            <div class="mt-4">
                <a href="javascript:history.back()" class="btn btn-secondary-brand shadow-sm fw-bold px-4">
                    <i class="bi bi-arrow-left me-2"></i> Regresar
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0" style="border-radius: 10px; overflow: hidden;">
            <div class="card-header text-white py-3" style="background-color: var(--brand-dark);">
                <h5 class="mb-0 fw-bold text-white"><i class="bi bi-card-checklist me-2"></i> Detalles del Expediente</h5>
            </div>
            
            <div class="card-body p-0">
                <div class="container-fluid px-0">
                    @foreach (var answer in Model.Answers)
                    {
                        <div class="row m-0 border-bottom py-3 px-4 pregunta-row align-items-center">
                            
                            <div class="col-md-8 col-sm-12 fw-bold text-secondary mb-2 mb-md-0" style="font-size: 0.95rem;">
                                @answer.QuestionText
                            </div>
                            
                            <div class="col-md-4 col-sm-12 text-md-end text-sm-start fw-bold" style="color: #333;">
                                @if (answer.AnswerText == "No" || answer.AnswerText == "Ninguna")
                                {
                                    <span class="badge border text-secondary" style="background-color: #f4f4f4; font-size: 0.9rem;">
                                        <i class="bi bi-dash-circle me-1"></i> @answer.AnswerText
                                    </span>
                                }
                                else if (answer.AnswerText == "Sí" || answer.AnswerText == "Si")
                                {
                                    <span class="badge text-white shadow-sm" style="background-color: var(--brand-secondary); font-size: 0.9rem;">
                                        <i class="bi bi-exclamation-circle-fill me-1"></i> @answer.AnswerText
                                    </span>
                                }
                                else
                                {
                                    <span class="text-dark">@answer.AnswerText</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
            
            <div class="card-footer bg-light p-3 text-end">
                @if (roleId == 2)
                {
                    <a asp-area="Gestion" asp-controller="Tutorship" asp-action="ListaDeAlumnos" class="btn btn-secondary-brand shadow-sm fw-bold px-4">
                        <i class="bi bi-arrow-left me-2"></i> Volver al Directorio
                    </a>
                }
                else
                {
                    <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Controlador" class="btn btn-secondary-brand shadow-sm fw-bold px-4">
                        <i class="bi bi-arrow-left me-2"></i> Volver al Panel
                    </a>
                }
                <button onclick="window.print()" class="btn btn-action-seguimiento shadow-sm fw-bold px-4 ms-2">
                    <i class="bi bi-printer-fill me-2"></i> Imprimir
                </button>
            </div>
        </div>
    }
</div>