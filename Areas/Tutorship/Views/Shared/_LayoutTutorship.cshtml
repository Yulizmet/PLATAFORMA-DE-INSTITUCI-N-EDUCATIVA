<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Tutorías</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Merriweather:wght@400;700;900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/tutorship_layout.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-light border-bottom shadow-sm mb-4 tutorship-navbar position-relative">
            <div class="container-fluid d-flex align-items-center justify-content-between">
                <button class="btn btn-outline-light border-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#menuLateral" aria-controls="menuLateral" style="z-index:20;">
                    <i class="bi bi-list fs-3"></i>
                </button>

                <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Controlador" class="navbar-brand text-white position-absolute top-50 start-50 translate-middle text-center navbar-brand-portal" style="z-index:10;">
                    <div class="portal-title">TUTORÍAS</div>
                </a>

                <div class="ms-auto" style="z-index:20;">
                    <a asp-area="MainScreen" asp-controller="MainScreen" asp-action="Index" class="btn btn-outline-light border-0 d-flex align-items-center gap-2">
                        <i class="bi bi-house-door-fill fs-5"></i>
                    </a>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="offcanvas offcanvas-start offcanvas-tutorship" tabindex="-1" id="menuLateral" aria-labelledby="menuLateralLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title fw-bold text-white" id="menuLateralLabel" style="font-family: var(--font-titulos);">
                <i class="bi bi-compass-fill me-2"></i> Navegación
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column">
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a asp-area="Gestion" asp-controller="Tutorship" asp-action="Controlador" class="nav-link">
                        <i class="bi bi-house-door-fill me-2"></i> Panel Principal
                    </a>
                </li>

                <hr class="my-2" style="border-color:#ddd;">

                @if (User.IsInRole("Student"))
                {
                    <li class="nav-item">
                        <a asp-area="Gestion" asp-controller="Entrevista" asp-action="EntrevistaInicial" class="nav-link">
                            <i class="bi bi-chat-text-fill me-2"></i> Entrevista Inicial
                        </a>
                    </li>
                }

                @if (User.IsInRole("Teacher"))
                {
                    <li class="nav-item">
                        <a asp-area="Gestion" asp-controller="Asistencia" asp-action="Asistencia" class="nav-link">
                            <i class="bi bi-calendar-check-fill me-2"></i> Control de Asistencia
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Gestion" asp-controller="Seguimiento" asp-action="Seguimiento" class="nav-link">
                            <i class="bi bi-clipboard-data-fill me-2"></i> Seguimiento
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Gestion" asp-controller="Alumnos" asp-action="ListaDeAlumnos" class="nav-link">
                            <i class="bi bi-people-fill me-2"></i> Lista de Alumnos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Gestion" asp-controller="Entrevista" asp-action="ReporteEntrevistas" class="nav-link">
                            <i class="bi bi-file-earmark-person-fill me-2"></i> Estatus Entrevistas
                        </a>
                    </li>
                }

                @if (User.IsInRole("Administrator") || User.IsInRole("Master"))
                {
                    <li class="nav-item">
                        <a asp-area="Gestion" asp-controller="Alumnos" asp-action="ListaDeAlumnos" class="nav-link">
                            <i class="bi bi-people-fill me-2"></i> Lista de Alumnos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Gestion" asp-controller="Seguimiento" asp-action="Seguimiento" class="nav-link">
                            <i class="bi bi-clipboard-data-fill me-2"></i> Seguimiento General
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Gestion" asp-controller="Asistencia" asp-action="Asistencia" class="nav-link">
                            <i class="bi bi-calendar-check-fill me-2"></i> Control de Asistencia
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Gestion" asp-controller="Alumnos" asp-action="AsignarTutores" class="nav-link">
                            <i class="bi bi-diagram-3-fill me-2"></i> Asignar Tutores
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="Gestion" asp-controller="Entrevista" asp-action="ReporteEntrevistas" class="nav-link">
                            <i class="bi bi-file-earmark-bar-graph-fill me-2"></i> Reporte General
                        </a>
                    </li>
                }
            </ul>

            <div class="mt-auto text-center text-muted small pb-3">
                <hr>
                Sistema de Gestión Académica<br>
                Módulo de Tutorías
            </div>
        </div>
    </div>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center py-3" style="font-size: .92rem;">
            &copy; 2026 - Sistema de Gestión Académica -
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none" style="color: var(--brand-dark);">Aviso de Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>