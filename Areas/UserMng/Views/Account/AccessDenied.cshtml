@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Acceso Denegado</title>
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background: #F7F3F0;
        }
        .container {
            text-align: center;
            padding: 40px;
        }
        h1 { color: #6B1A2A; font-size: 3rem; }
        p { color: #666; margin: 16px 0; }
        .btn {
            display: inline-block;
            padding: 12px 24px;
            margin: 8px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 0.9rem;
            cursor: pointer;
        }
        .btn-back {
            background: #6B1A2A;
            color: white;
            border: none;
        }
        .btn-logout {
            background: transparent;
            color: #6B1A2A;
            border: 2px solid #6B1A2A;
        }
    </style>
</head>
<body>
<div class="container">
    <h2>Acceso Denegado</h2>
    <p>No tienes permisos para acceder a esta página.</p>

    <a href="/" class="btn btn-back">Ir al Inicio</a>

    <form asp-area="UserMng"
          asp-controller="Account"
          asp-action="Logout"
          method="post"
          style="display:inline;">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-logout">
            Cerrar Sesión
        </button>
    </form>
</div>
</body>
</html>