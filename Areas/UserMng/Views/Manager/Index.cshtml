@model SchoolManager.Areas.UserMng.ViewModels.DashboardVM

@{
    Layout = "_UserLayout";
    ViewData["Title"] = "Panel de Control";
}

<div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded">
    <div>
        <h2 class="mb-0 text-dark"><i class="bi bi-clipboard-data me-2"></i>Panel de Control</h2>
        <p class="text-muted small mb-0">Vista general de usuarios y roles del sistema.</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                    <i class="bi bi-people-fill fs-3 text-primary"></i>
                </div>
                <div>
                    <h3 class="mb-0">@Model.TotalActiveUsers</h3>
                    <small class="text-muted">Usuarios activos</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                    <i class="bi bi-person-vcard-fill fs-3 text-success"></i>
                </div>
                <div>
                    <h3 class="mb-0">@Model.TotalActivePersons</h3>
                    <small class="text-muted">Personas registradas</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3 me-3">
                    <i class="bi bi-diagram-3-fill fs-3 text-warning"></i>
                </div>
                <div>
                    <h3 class="mb-0">@Model.Roles.Count</h3>
                    <small class="text-muted">Roles activos</small>
                </div>
            </div>
        </div>
    </div>
</div>

<h5 class="text-muted mb-3"><i class="bi bi-grid-fill me-2"></i>Roles del sistema</h5>

<div class="row">
    @foreach (var role in Model.Roles)
    {
        <div class="col-md-4 col-lg-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="rounded-circle bg-@(role.Color) bg-opacity-10 d-inline-flex p-3 mb-3">
                        <i class="bi @role.Icon fs-2 text-@(role.Color)"></i>
                    </div>
                    <h6 class="fw-bold">@role.DisplayName</h6>
                    <p class="text-muted small mb-2" style="min-height: 40px;">
                        @role.Description
                    </p>
                    <div class="mb-3">
                        <span class="badge bg-@(role.Color) bg-opacity-75 fs-6">
                            @role.ActiveCount
                        </span>
                        <small class="text-muted d-block mt-1">usuarios activos</small>
                    </div>
                    <a href="@role.Url" class="btn btn-outline-@(role.Color) btn-sm w-100">
                        Gestionar
                    </a>
                </div>
            </div>
        </div>
    }
</div>