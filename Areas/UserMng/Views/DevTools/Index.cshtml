@{
    ViewData["Title"] = "DevTools - Herramientas de Desarrollo";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<div class="container py-4" style="max-width: 540px;">
    <div class="card border-warning shadow-sm">
        <div class="card-header bg-warning text-dark fw-bold d-flex justify-content-between align-items-center">
            <span id="cardTitle">
                <i class="bi bi-person-plus-fill me-1"></i> Crear Usuario Rápido
            </span>

            <!-- ══ Switch ══ -->
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch"
                       id="modeSwitch" onchange="toggleMode()">
                <label class="form-check-label small" for="modeSwitch" id="switchLabel">
                    Agregar Rol
                </label>
            </div>
        </div>

        <div class="card-body">
            <div id="userForm">

                @if (TempData["Result"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-1"></i> @TempData["Result"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form method="post" action="quickuser">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input type="text" name="firstName" class="form-control"
                                   required placeholder="Ej: Carlos" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Rol</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-shield"></i></span>
                            <select name="roleName" class="form-select" required>
                                <option value="" disabled selected>-- Seleccionar rol --</option>
                                @foreach (var role in ViewBag.Roles)
                                {
                                    <option value="@role.Name">@role.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input type="text" name="password" class="form-control" value="Test1234!" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-bold">
                        <i class="bi bi-lightning-fill me-1"></i> Crear usuario de prueba
                    </button>
                </form>
            </div>
            <div id="roleForm" style="display: none;">

                @if (TempData["RoleResult"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-1"></i> @TempData["RoleResult"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["RoleError"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i> @TempData["RoleError"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form method="post" action="createrole">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre del Rol</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-tag"></i></span>
                            <input type="text" name="name" class="form-control"
                                   required placeholder="Ej: Coordinator" />
                        </div>
                        <small class="text-muted">Nombre interno del rol (en inglés preferentemente).</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Descripción</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-card-text"></i></span>
                            <input type="text" name="description" class="form-control"
                                   placeholder="Ej: Coordinador académico" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-info w-100 fw-bold text-white">
                        <i class="bi bi-plus-circle-fill me-1"></i> Crear Rol
                    </button>
                </form>

                <!-- Lista de roles existentes -->
                <hr />
                <h6 class="text-muted mb-2">
                    <i class="bi bi-list-ul me-1"></i> Roles existentes
                </h6>
                <div class="table-responsive" style="max-height: 200px; overflow-y: auto;">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Descripción</th>
                                <th class="text-center">Activo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in ViewBag.Roles)
                            {
                                <tr>
                                    <td class="text-muted">@role.RoleId</td>
                                    <td class="fw-semibold">@role.Name</td>
                                    <td class="text-muted small">@role.Description</td>
                                    <td class="text-center">
                                        @if (role.IsActive)
                                        {
                                            <span class="badge bg-success">Sí</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    function toggleMode() {
        const isRoleMode = document.getElementById('modeSwitch').checked;
        const userForm   = document.getElementById('userForm');
        const roleForm   = document.getElementById('roleForm');
        const cardTitle  = document.getElementById('cardTitle');
        const switchLabel = document.getElementById('switchLabel');

        if (isRoleMode) {
            userForm.style.display = 'none';
            roleForm.style.display = 'block';
            cardTitle.innerHTML = '<i class="bi bi-shield-plus me-1"></i> Agregar Rol';
            switchLabel.textContent = 'Crear Usuario';
        } else {
            userForm.style.display = 'block';
            roleForm.style.display = 'none';
            cardTitle.innerHTML = '<i class="bi bi-person-plus-fill me-1"></i> Crear Usuario Rápido';
            switchLabel.textContent = 'Agregar Rol';
        }
    }

    @if (TempData["RoleResult"] != null || TempData["RoleError"] != null)
    {
        <text>
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('modeSwitch').checked = true;
            toggleMode();
        });
        </text>
    }
</script>
}