@using SchoolManager.Areas.Grades.ViewModels.Breadcrumbs
@using SchoolManager.Areas.Grades.ViewModels.GradeLevels
@model IEnumerable<GradeLevelViewModel>

@{
    ViewData["Title"] = "Niveles Escolares";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";

    // Breadcrumbs
    var breadcrumbs = new BreadcrumbViewModel();
    breadcrumbs.AddItem("Panel Administrativo", "/PanelAdministrativo");
    breadcrumbs.AddItem("Niveles Escolares");

    // Obtener el filtro actual de la URL
    var filtroActual = Context.Request.Query["estado"].ToString();
    var mostrarSoloAbiertos = string.IsNullOrEmpty(filtroActual) || filtroActual == "abiertos";
}

<partial name="_Breadcrumb" model="breadcrumbs" />

<section class="sistema-section py-4">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="users-title">
                <i class="bi bi-layers me-2" style="color: #8C1B1B;"></i>
                Niveles Escolares
            </h1>
            <a asp-action="Create" class="btn btn-calificaciones">
                <i class="bi bi-plus-circle me-2"></i>Nuevo Nivel
            </a>
        </div>

        <!-- Filtros -->
        <div class="sistema-card mb-4">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="fw-semibold mb-2">Filtrar por estado:</h5>
                    <div class="btn-group" role="group">
                        <a asp-action="Index" asp-route-estado="abiertos"
                           class="btn @(mostrarSoloAbiertos ? "btn-calificaciones" : "btn-outline-secondary")">
                            <i class="bi bi-check-circle me-2"></i>Solo Abiertos
                        </a>
                        <a asp-action="Index" asp-route-estado="todos"
                           class="btn @(!mostrarSoloAbiertos ? "btn-calificaciones" : "btn-outline-secondary")">
                            <i class="bi bi-list me-2"></i>Todos
                        </a>
                    </div>
                </div>
                <div class="col-md-6 text-md-end">
                    <span class="text-muted">
                        @if (mostrarSoloAbiertos)
                        {
                            <text>Mostrando niveles abiertos (@Model.Count())</text>
                        }
                        else
                        {
                            <text>Mostrando todos los niveles (@Model.Count())</text>
                        }
                    </span>
                </div>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert" style="background-color: #d4edda; color: #155724; border-left: 5px solid #28a745;">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background-color: #f8d7da; color: #721c24; border-left: 5px solid #D42D2D;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="mb-3">
                    <i class="bi bi-layers" style="font-size: 4rem; color: #B1A596;"></i>
                </div>
                <h5 class="text-muted">
                    @if (mostrarSoloAbiertos)
                    {
                        <text>No hay niveles abiertos</text>
                    }
                    else
                    {
                        <text>No hay niveles escolares registrados</text>
                    }
                </h5>
                <p class="text-muted mb-4">
                    @if (mostrarSoloAbiertos && !string.IsNullOrEmpty(filtroActual))
                    {
                        <a asp-action="Index" asp-route-estado="todos">Ver todos los niveles</a>
                    }
                    else
                    {
                        <text>Comienza creando el primer nivel escolar</text>
                    }
                </p>
                <a asp-action="Create" class="btn btn-calificaciones">
                    <i class="bi bi-plus-circle me-2"></i>Crear Nivel
                </a>
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="sistema-card @(item.IsOpen ? "border-calificaciones" : "border-secondary")">
                            <div class="sistema-icon @(item.IsOpen ? "icon-calificaciones" : "icon-servicio") mb-4">
                                <i class="bi bi-layers"></i>
                            </div>

                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h4 class="fw-bold" style="color: #1f2937;">@item.Name</h4>
                                    <small class="text-muted">@item.StartDate.ToString("yyyy")</small>
                                </div>
                                <span class="badge @(item.IsOpen ? "bg-success" : "bg-secondary")">
                                    @(item.IsOpen ? "Abierto" : "Cerrado")
                                </span>
                            </div>

                            <div class="mb-3">
                                <small class="text-muted d-block">Período</small>
                                <span>@item.StartDate.ToString("dd/MM/yyyy") - @item.EndDate.ToString("dd/MM/yyyy")</span>
                            </div>

                            <div class="mb-3">
                                <small class="text-muted d-block">Calificación mínima</small>
                                <span class="fw-bold" style="color: #8C1B1B;">@item.MinPassingGrade.ToString("F1")</span>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-6">
                                    <div class="p-2 text-center" style="background-color: #f8f9fa; border-radius: 10px;">
                                        <span class="h5 mb-0 fw-bold" style="color: #D42D2D;">@item.GroupsCount</span>
                                        <small class="text-muted d-block">Grupos</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-2 text-center" style="background-color: #f8f9fa; border-radius: 10px;">
                                        <span class="h5 mb-0 fw-bold" style="color: #8C1B1B;">@item.SubjectsCount</span>
                                        <small class="text-muted d-block">Materias</small>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Details" asp-route-id="@item.GradeLevelId"
                                   class="btn btn-sm" style="background-color: #f0f0f0; color: #4a5568; border-radius: 10px; padding: 8px 12px;"
                                   title="Ver detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.GradeLevelId"
                                   class="btn btn-sm" style="background-color: #8C1B1B; color: white; border-radius: 10px; padding: 8px 12px;"
                                   title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-sm"
                                        style="background-color: #620900; color: white; border-radius: 10px; padding: 8px 12px;"
                                        data-bs-toggle="modal" data-bs-target="#deleteModal-@item.GradeLevelId"
                                        title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Modal de Confirmación de Eliminación -->
                        <div class="modal fade" id="deleteModal-@item.GradeLevelId" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content" style="border-radius: 20px; border: none;">
                                    <div class="modal-header" style="background-color: #8C1B1B; color: white; border-radius: 20px 20px 0 0;">
                                        <h5 class="modal-title">
                                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                            Confirmar Eliminación
                                        </h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body p-4">
                                        <p>¿Estás seguro de eliminar el nivel <strong style="color: #8C1B1B;">@item.Name</strong>?</p>
                                        @if (item.GroupsCount > 0 || item.SubjectsCount > 0)
                                        {
                                            <p class="mt-3 p-3" style="background-color: #fff3cd; color: #856404; border-radius: 10px;">
                                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                                Este nivel tiene @item.GroupsCount grupos y @item.SubjectsCount materias asociadas.
                                            </p>
                                        }
                                        <p class="text-danger mb-0">
                                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                            Esta acción no se puede deshacer.
                                        </p>
                                    </div>
                                    <div class="modal-footer border-0">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius: 10px; background-color: #6c757d;">
                                            <i class="bi bi-x-circle me-2"></i>Cancelar
                                        </button>
                                        <form asp-action="Delete" asp-route-id="@item.GradeLevelId" method="post">
                                            <button type="submit" class="btn" style="background-color: #D42D2D; color: white; border-radius: 10px;">
                                                <i class="bi bi-trash me-2"></i>Eliminar
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>