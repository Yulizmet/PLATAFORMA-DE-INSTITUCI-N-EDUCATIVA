@model IEnumerable<SchoolManager.Models.grades_grade_level>

@{
    ViewData["Title"] = "Niveles Escolares";
    Layout = "~/Pages/Shared/_Layout.cshtml";

}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">
            <i class="fas fa-layer-group me-2"></i>Niveles Escolares
        </h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nuevo Nivel
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="fas fa-layer-group fa-4x text-muted"></i>
            </div>
            <h5 class="text-muted">No hay niveles escolares registrados</h5>
            <p class="text-muted mb-4">Comienza creando el primer nivel escolar</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Crear Nivel
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm @(item.IsOpen ? "border-success" : "border-secondary")">
                        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0 fw-bold">@item.Name</h5>
                            <span class="badge @(item.IsOpen ? "bg-success" : "bg-secondary")">
                                @(item.IsOpen ? "Abierto" : "Cerrado")
                            </span>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-6">
                                    <small class="text-muted d-block">Inicio</small>
                                    <span class="fw-semibold">@item.StartDate.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">Fin</small>
                                    <span class="fw-semibold">@item.EndDate.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-around text-center py-2">
                                <div>
                                    <span class="h5 mb-0 fw-bold">@item.Groups?.Count() ?? 0</span>
                                    <small class="text-muted d-block">Grupos</small>
                                </div>
                                <div class="vr"></div>
                                <div>
                                    <span class="h5 mb-0 fw-bold">@item.Subjects?.Count() ?? 0</span>
                                    <small class="text-muted d-block">Materias</small>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3 d-flex justify-content-end gap-2">
                            <a asp-action="Details" asp-route-id="@item.GradeLevelId"
                               class="btn btn-sm btn-outline-info" title="Ver detalles">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.GradeLevelId"
                               class="btn btn-sm btn-outline-primary" title="Editar">
                                <i class="fas fa-edit"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal" data-bs-target="#deleteModal-@item.GradeLevelId"
                                    title="Eliminar">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Modal de Confirmación de Eliminación -->
                    <div class="modal fade" id="deleteModal-@item.GradeLevelId" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Confirmar Eliminación</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <p>¿Estás seguro de eliminar el nivel <strong>@item.Name</strong>?</p>
                                    <p class="text-danger mb-0">
                                        <i class="fas fa-exclamation-triangle me-2"></i>
                                        Esta acción no se puede deshacer.
                                    </p>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                        Cancelar
                                    </button>
                                    <form asp-action="Delete" asp-route-id="@item.GradeLevelId" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-danger">
                                            <i class="fas fa-trash me-2"></i>Eliminar
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>