@using SchoolManager.Areas.Grades.ViewModels.Breadcrumbs
@using SchoolManager.Areas.Grades.ViewModels.GradeLevels
@model List<GradeLevelViewModel>

@{
    ViewData["Title"] = "Niveles Escolares";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";

    var breadcrumbs = new BreadcrumbViewModel();
    breadcrumbs.AddItem("Panel Administrativo", "/PanelAdministrativo");
    breadcrumbs.AddItem("Niveles Escolares");
}
<partial name="_Breadcrumb" model="breadcrumbs" />

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="users-title mb-1">
                <i class="bi bi-layers me-2"></i>Niveles Escolares
            </h1>
            <p class="text-muted mb-0">Administración de semestres y períodos</p>
        </div>
        <a asp-action="Create" class="btn btn-calificaciones" style="padding: 10px 25px;">
            <i class="bi bi-plus-circle me-2"></i>Nuevo Nivel
        </a>
    </div>

    @if (Model.Any())
    {
        <!-- Filtro por estado -->
        <div class="d-flex flex-wrap gap-3 mb-3 align-items-center">
            <div class="btn-group" role="group" id="estadoFilter">
                <input type="radio" class="btn-check" name="estadoOpt" id="optTodos" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="optTodos">Todos</label>

                <input type="radio" class="btn-check" name="estadoOpt" id="optAbiertos" autocomplete="off" checked>
                <label class="btn btn-outline-secondary btn-sm" for="optAbiertos">
                    <i class="bi bi-unlock me-1"></i>Abiertos
                </label>

                <input type="radio" class="btn-check" name="estadoOpt" id="optCerrados" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="optCerrados">
                    <i class="bi bi-lock me-1"></i>Cerrados
                </label>
            </div>
        </div>

        <div class="sistema-card">
            <div class="table-responsive">
                <table id="gradeLevelsTable" class="table table-hover align-middle mb-0" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th class="text-center">Fecha Inicio</th>
                            <th class="text-center">Fecha Fin</th>
                            <th class="text-center">Mínima</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Grupos</th>
                            <th class="text-center">Materias</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var level in Model)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    <i class="bi bi-layers me-1" style="color: #8C1B1B;"></i>
                                    @level.Name
                                </td>
                                <td class="text-center">@level.StartDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">@level.EndDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">
                                    <span class="badge" style="background-color: #B1A596; padding: 6px 12px; border-radius: 20px;">
                                        @level.MinPassingGrade
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (level.IsOpen)
                                    {
                                        <span class="badge" style="background-color: #28a745; padding: 6px 12px; border-radius: 20px;">
                                            <i class="bi bi-unlock me-1"></i>Abierto
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary" style="padding: 6px 12px; border-radius: 20px;">
                                            <i class="bi bi-lock me-1"></i>Cerrado
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge" style="background-color: #8C1B1B; padding: 6px 12px; border-radius: 20px;">
                                        @level.GroupsCount
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge" style="background-color: #D42D2D; padding: 6px 12px; border-radius: 20px;">
                                        @level.SubjectsCount
                                    </span>
                                </td>
                                <td class="text-end">

                                    <a asp-action="Edit" asp-route-id="@level.GradeLevelId"
                                       class="btn btn-sm btn-outline-secondary" title="Editar"
                                       style="border-radius: 8px;">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@level.GradeLevelId" method="post"
                                          style="display: inline;"
                                          onsubmit="return confirm('¿Estás seguro de eliminar este nivel?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                title="Eliminar" style="border-radius: 8px;">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="sistema-card text-center py-5">
            <i class="bi bi-layers" style="font-size: 3rem; color: #B1A596;"></i>
            <p class="text-muted mt-3">No hay niveles escolares registrados</p>
            <a asp-action="Create" class="btn btn-calificaciones mt-2" style="padding: 10px 25px;">
                <i class="bi bi-plus-circle me-2"></i>Crear Primer Nivel
            </a>
        </div>
    }
</div>

@if (Model.Any())
{
    @section Scripts {
        <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

        <script>
            $(document).ready(function () {
                var table = $('#gradeLevelsTable').DataTable({
                    language: {
                        search: "",
                        searchPlaceholder: "Buscar nivel...",
                        lengthMenu: "Mostrar _MENU_ niveles",
                        info: "Mostrando _START_ a _END_ de _TOTAL_ niveles",
                        infoEmpty: "Sin niveles",
                        infoFiltered: "(filtrado de _MAX_ totales)",
                        zeroRecords: "No se encontraron niveles",
                        paginate: {
                            first: "Primero",
                            last: "Último",
                            next: "<i class='bi bi-chevron-right'></i>",
                            previous: "<i class='bi bi-chevron-left'></i>"
                        }
                    },
                    pageLength: 10,
                    lengthMenu: [5, 10, 25, 50],
                    order: [[4, 'desc'], [0, 'asc']],
                    columnDefs: [
                        { orderable: false, targets: 7 }
                    ],
                    dom: '<"d-flex justify-content-between align-items-center mb-3"lf>t<"d-flex justify-content-between align-items-center mt-3"ip>'
                });

                // Filtro por estado (Abierto/Cerrado)
                // Aplicar filtro inicial "Abiertos"
                table.column(4).search('Abierto').draw();

                $('input[name="estadoOpt"]').on('change', function () {
                    var val = '';
                    if ($('#optAbiertos').is(':checked')) val = 'Abierto';
                    if ($('#optCerrados').is(':checked')) val = 'Cerrado';
                    table.column(4).search(val).draw();
                });
            });
        </script>

        <style>
            /* Select "Mostrar X" más ancho */
            .dataTables_length select {
                border-radius: 10px !important;
                border: 1px solid #dee2e6 !important;
                padding: 4px 30px 4px 10px !important; /* ✅ Más espacio a la derecha */
                min-width: 70px !important; /* ✅ Ancho mínimo */
            }

            /* Search input */
            .dataTables_filter input {
                border-radius: 10px !important;
                border: 1px solid #dee2e6 !important;
                padding: 6px 12px !important;
                margin-left: 8px !important;
            }

                .dataTables_filter input:focus {
                    border-color: #8C1B1B !important;
                    box-shadow: 0 0 0 0.2rem rgba(140, 27, 27, 0.15) !important;
                }

            /* Paginación - página activa */
            .page-item.active .page-link {
                background-color: #8C1B1B !important;
                border-color: #8C1B1B !important;
                color: white !important; /* ✅ Texto blanco */
                border-radius: 8px !important; /* ✅ Bordes redondeados */
            }

            /* Paginación - botones normales */
            .page-link {
                color: #8C1B1B !important;
                border-radius: 8px !important;
                margin: 0 2px;
                border: 1px solid #dee2e6 !important; /* ✅ Borde visible */
            }

                .page-link:hover {
                    background-color: rgba(140, 27, 27, 0.1) !important;
                }

            /* Paginación - botones deshabilitados (< >) */
            .page-item.disabled .page-link {
                color: #adb5bd !important;
                background-color: #f8f9fa !important;
                border-color: #dee2e6 !important;
            }

            /* Info text */
            .dataTables_info {
                color: #6c757d !important;
                font-size: 0.875rem;
            }
        </style>
    }
}