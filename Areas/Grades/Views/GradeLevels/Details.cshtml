@model SchoolManager.Models.grades_grade_level

@{
    ViewData["Title"] = $"Detalles - {Model.Name}";
    Layout = "~/Pages/Shared/_Layout.cshtml";

}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Niveles</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle me-2 text-primary"></i>
                        Información General
                    </h5>
                </div>
                <div class="card-body">
                    <h6 class="fw-bold mb-3">@Model.Name</h6>

                    <div class="mb-3">
                        <small class="text-muted d-block">Período</small>
                        <span>@Model.StartDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy")</span>
                    </div>

                    <div class="mb-3">
                        <small class="text-muted d-block">Estado</small>
                        <span class="badge @(Model.IsOpen ? "bg-success" : "bg-secondary")">
                            @(Model.IsOpen ? "Abierto" : "Cerrado")
                        </span>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-6">
                            <div class="border rounded p-3 text-center">
                                <h4 class="mb-1 fw-bold">@Model.Groups?.Count() ?? 0</h4>
                                <small class="text-muted">Grupos</small>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3 text-center">
                                <h4 class="mb-1 fw-bold">@Model.Subjects?.Count() ?? 0</h4>
                                <small class="text-muted">Materias</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 pb-3">
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.GradeLevelId" class="btn btn-primary flex-fill">
                            <i class="fas fa-edit me-2"></i>Editar
                        </a>
                        <a asp-action="Index" class="btn btn-secondary flex-fill">
                            <i class="fas fa-arrow-left me-2"></i>Volver
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <!-- Grupos -->
            <div class="card shadow mb-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-users me-2 text-primary"></i>
                        Grupos (@(Model.Groups?.Count() ?? 0))
                    </h5>
                    <a asp-controller="Groups" asp-action="Create" asp-route-gradeLevelId="@Model.GradeLevelId"
                       class="btn btn-sm btn-primary">
                        <i class="fas fa-plus me-2"></i>Nuevo Grupo
                    </a>
                </div>
                <div class="card-body">
                    @if (Model.Groups != null && Model.Groups.Any())
                    {
                        <div class="row">
                            @foreach (var group in Model.Groups.OrderBy(g => g.Name))
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="border rounded p-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="mb-1 fw-bold">@group.Name</h6>
                                                <small class="text-muted">
                                                    <i class="fas fa-users me-1"></i>
                                                    @group.TeacherSubjectGroups?.Count() ?? 0 materias asignadas
                                                </small>
                                            </div>
                                            <a asp-controller="Groups" asp-action="Details" asp-route-id="@group.GroupId"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-users fa-3x text-muted mb-3"></i>
                            <p class="text-muted mb-0">No hay grupos en este nivel</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Materias -->
            <div class="card shadow">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-book me-2 text-primary"></i>
                        Materias (@(Model.Subjects?.Count() ?? 0))
                    </h5>
                    <a asp-controller="Subjects" asp-action="Create" asp-route-gradeLevelId="@Model.GradeLevelId"
                       class="btn btn-sm btn-primary">
                        <i class="fas fa-plus me-2"></i>Nueva Materia
                    </a>
                </div>
                <div class="card-body">
                    @if (Model.Subjects != null && Model.Subjects.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Materia</th>
                                        <th class="text-center">Unidades</th>
                                        <th class="text-end">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var subject in Model.Subjects.OrderBy(s => s.Name))
                                    {
                                        <tr>
                                            <td class="fw-semibold">@subject.Name</td>
                                            <td class="text-center">
                                                <span class="badge bg-info">@(subject.Units?.Count() ?? 0)</span>
                                            </td>
                                            <td class="text-end">
                                                <a asp-controller="Subjects" asp-action="Details" asp-route-id="@subject.SubjectId"
                                                   class="btn btn-sm btn-outline-info" title="Ver detalles">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a asp-controller="Subjects" asp-action="ManageUnits" asp-route-subjectId="@subject.SubjectId"
                                                   class="btn btn-sm btn-outline-success" title="Gestionar unidades">
                                                    <i class="fas fa-puzzle-piece"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-book fa-3x text-muted mb-3"></i>
                            <p class="text-muted mb-0">No hay materias en este nivel</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>