@using SchoolManager.Areas.Grades.ViewModels.GradeLevels
@model GradeLevelViewModel

@{
    ViewData["Title"] = "Editar Nivel Escolar";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";

}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="fas fa-edit me-2 text-primary"></i>
                        Editar Nivel: @Model.Name
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="GradeLevelId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Nombre del Nivel</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label fw-semibold">Fecha de Inicio</label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label fw-semibold">Fecha de Fin</label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="IsOpen" class="form-check-input" role="switch" />
                                <label asp-for="IsOpen" class="form-check-label fw-semibold">
                                    Nivel Abierto
                                </label>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label asp-for="MinPassingGrade" class="form-label fw-semibold">Calificación mínima aprobatoria</label>
                            <input asp-for="MinPassingGrade" class="form-control" type="number" step="0.5" min="0" max="10" value="6.0" />
                            <span asp-validation-for="MinPassingGrade" class="text-danger"></span>
                            <small class="form-text text-muted">Calificación mínima para aprobar en este nivel (ej: 6.0, 7.0, 8.0)</small>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}