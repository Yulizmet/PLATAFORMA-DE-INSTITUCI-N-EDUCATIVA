@model SchoolManager.Areas.Grades.ViewModels.FinalGrades.FinalGradeListViewModel

@{
    ViewData["Title"] = $"Finales - {Model.SubjectName}";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Calificaciones Finales</a></li>
            <li class="breadcrumb-item active">@Model.SubjectName - @Model.GroupName</li>
        </ol>
    </nav>

    <div class="sistema-card mb-4">
        <div class="row align-items-center">
            <div class="col-md-4">
                <h4 class="fw-bold mb-1">@Model.SubjectName</h4>
                <p class="text-muted">
                    <i class="bi bi-people me-2"></i>@Model.GroupName
                    <span class="mx-2">|</span>
                    <i class="bi bi-layers me-2"></i>@Model.GradeLevelName
                </p>
            </div>
            <div class="col-md-4 text-center">
                <h6 class="mb-1">Calificación mínima</h6>
                <h3 style="color: #D42D2D;">@Model.MinPassingGradeUsed.ToString("F1")</h3>
            </div>
            <div class="col-md-4">
                <div class="d-flex gap-3">
                    <div class="text-center flex-fill p-2" style="background-color: #d4edda; border-radius: 10px;">
                        <span class="fw-bold" style="color: #28a745;">@Model.Students.Count(s => s.Passed)</span>
                        <small class="d-block">Aprobados</small>
                    </div>
                    <div class="text-center flex-fill p-2" style="background-color: #f8d7da; border-radius: 10px;">
                        <span class="fw-bold" style="color: #D42D2D;">@Model.Students.Count(s => !s.Passed)</span>
                        <small class="d-block">Reprobados</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="sistema-card">
        <div class="d-flex justify-content-end mb-3">
            <form asp-action="Calculate" method="post"
                  onsubmit="return confirm('¿Calcular calificaciones finales? Esto actualizará los promedios.');">
                <input type="hidden" name="groupId" value="@Model.GroupId" />
                <input type="hidden" name="subjectId" value="@Model.SubjectId" />
                <button type="submit" class="btn btn-calificaciones">
                    <i class="bi bi-calculator me-2"></i>Calcular Finales
                </button>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Matrícula</th>
                        <th>Estudiante</th>
                        <th class="text-center">Calificación Final</th>
                        <th class="text-center">Extraordinario</th>
                        <th class="text-center">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model.Students)
                    {
                        <tr>
                            <td class="fw-semibold">@student.Matricula</td>
                            <td>@student.StudentName</td>
                            <td class="text-center">
                                @if (student.FinalGrade.HasValue)
                                {
                                    <span class="fw-bold">@student.FinalGrade.Value.ToString("F2")</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (student.HasExtraordinary)
                                {
                                    <span class="text-warning fw-bold">@student.ExtraordinaryGrade?.ToString("F2")</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (student.Passed)
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle me-1"></i>Aprobado
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-x-circle me-1"></i>Reprobado
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>