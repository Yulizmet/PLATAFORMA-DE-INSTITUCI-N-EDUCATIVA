@using SchoolManager.Areas.Grades.ViewModels.Breadcrumbs;
@{
    ViewData["Title"] = "Calificaciones Finales";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    var breadcrumbs = new BreadcrumbViewModel();
    breadcrumbs.AddItem("Calificaciones", "/CalificacionesDocente");
    breadcrumbs.AddItem("Calificaciones Finales");

    var classes = Model as IEnumerable<dynamic>;
    var list = classes?.ToList() ?? new List<dynamic>();
}
<partial name="_Breadcrumb" model="breadcrumbs" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="users-title mb-1">
                <i class="bi bi-clipboard-data me-2"></i>Calificaciones Finales
            </h1>
            <p class="text-muted mb-0">Selecciona una clase para ver o calcular calificaciones finales</p>
        </div>
    </div>

    @if (list.Any())
    {
        <!-- Filtros -->
        <div class="d-flex flex-wrap gap-3 mb-3 align-items-center">
            <div style="min-width: 200px;">
                <select id="filterGradeLevel" class="form-select">
                    <option value="">Todos los niveles</option>
                    @foreach (var level in list.Select(c => (string)c.GradeLevelName).Distinct().OrderBy(x => x))
                    {
                        <option value="@level">@level</option>
                    }
                </select>
            </div>
            <div style="min-width: 200px;">
                <select id="filterGroup" class="form-select">
                    <option value="">Todos los grupos</option>
                    @foreach (var grp in list.Select(c => (string)c.GroupName).Distinct().OrderBy(x => x))
                    {
                        <option value="@grp">@grp</option>
                    }
                </select>
            </div>
        </div>

        <div class="sistema-card">
            <div class="table-responsive">
                <table id="finalsTable" class="table table-hover align-middle mb-0" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th>Materia</th>
                            <th>Grupo</th>
                            <th>Nivel Escolar</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in list)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    <i class="bi bi-clipboard-check me-1" style="color: #8C1B1B;"></i>
                                    @item.SubjectName
                                </td>
                                <td>
                                    <span class="badge" style="background-color: #8C1B1B; padding: 6px 12px; border-radius: 20px;">
                                        <i class="bi bi-people me-1"></i>@item.GroupName
                                    </span>
                                </td>
                                <td>
                                    <span class="badge" style="background-color: #B1A596; color: white; padding: 6px 12px; border-radius: 20px;">
                                        <i class="bi bi-layers me-1"></i>@item.GradeLevelName
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details"
                                       asp-route-groupId="@item.GroupId"
                                       asp-route-subjectId="@item.SubjectId"
                                       class="btn btn-sm btn-calificaciones" style="border-radius: 8px;">
                                        <i class="bi bi-eye me-1"></i>Ver Finales
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="sistema-card text-center py-5">
            <i class="bi bi-clipboard-data" style="font-size: 3rem; color: #B1A596;"></i>
            <p class="text-muted mt-3">No tienes clases asignadas</p>
            <p class="text-muted">Contacta al administrador para asignarte materias</p>
        </div>
    }
</div>

@if (list.Any())
{
    @section Scripts {
        <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

        <script>
            $(document).ready(function () {
                var table = $('#finalsTable').DataTable({
                    language: {
                        search: "",
                        searchPlaceholder: "Buscar materia...",
                        lengthMenu: "Mostrar _MENU_ clases",
                        info: "Mostrando _START_ a _END_ de _TOTAL_ clases",
                        infoEmpty: "Sin clases",
                        infoFiltered: "(filtrado de _MAX_ totales)",
                        zeroRecords: "No se encontraron clases",
                        paginate: {
                            next: "<i class='bi bi-chevron-right'></i>",
                            previous: "<i class='bi bi-chevron-left'></i>"
                        }
                    },
                    pageLength: 10,
                    lengthMenu: [5, 10, 25, 50],
                    order: [[2, 'asc'], [1, 'asc'], [0, 'asc']],
                    columnDefs: [
                        { orderable: false, targets: 3 }
                    ],
                    dom: '<"d-flex justify-content-between align-items-center mb-3"lf>t<"d-flex justify-content-between align-items-center mt-3"ip>'
                });

                $('#filterGradeLevel').on('change', function () {
                    table.column(2).search($(this).val()).draw();
                });

                $('#filterGroup').on('change', function () {
                    table.column(1).search($(this).val()).draw();
                });
            });
        </script>

        <style>
            .dataTables_length select {
                border-radius: 10px !important;
                border: 1px solid #dee2e6 !important;
                padding: 4px 30px 4px 10px !important;
                min-width: 70px !important;
            }

            .dataTables_filter input {
                border-radius: 10px !important;
                border: 1px solid #dee2e6 !important;
                padding: 6px 12px !important;
                margin-left: 8px !important;
            }

                .dataTables_filter input:focus {
                    border-color: #8C1B1B !important;
                    box-shadow: 0 0 0 0.2rem rgba(140, 27, 27, 0.15) !important;
                }

            .page-item.active .page-link {
                background-color: #8C1B1B !important;
                border-color: #8C1B1B !important;
                color: white !important;
                border-radius: 8px !important;
            }

            .page-link {
                color: #8C1B1B !important;
                border-radius: 8px !important;
                margin: 0 2px;
                border: 1px solid #dee2e6 !important;
            }

                .page-link:hover {
                    background-color: rgba(140, 27, 27, 0.1) !important;
                }

            .page-item.disabled .page-link {
                color: #adb5bd !important;
                background-color: #f8f9fa !important;
                border-color: #dee2e6 !important;
            }

            .dataTables_info {
                color: #6c757d !important;
                font-size: 0.875rem;
            }
        </style>
    }
}