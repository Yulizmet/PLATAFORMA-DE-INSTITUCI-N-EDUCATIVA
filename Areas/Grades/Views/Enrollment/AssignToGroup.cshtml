@model SchoolManager.Areas.Grades.ViewModels.Enrollment.EnrollmentCreateViewModel

@{
    ViewData["Title"] = $"Asignar Estudiantes - {Model.GroupName}";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";

    var gradeLevels = ViewBag.GradeLevels as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var allGroups = ViewBag.AllGroups as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/PanelAdministrativo">Panel Administrativo</a></li>
            <li class="breadcrumb-item">
                <a asp-controller="Groups" asp-action="Details" asp-route-id="@Model.GroupId">@Model.GroupName</a>
            </li>
            <li class="breadcrumb-item active">Asignar Estudiantes</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="users-title mb-1">
                <i class="bi bi-person-plus me-2"></i>Asignar Estudiantes
            </h1>
            <p class="text-muted mb-0">
                <i class="bi bi-people me-1" style="color: #8C1B1B;"></i>
                <strong>@Model.GroupName</strong>
                <span class="mx-2">·</span>
                <i class="bi bi-layers me-1" style="color: #8C1B1B;"></i>
                @Model.GradeLevelName
            </p>
        </div>
        <div id="selectionBadge" class="badge fs-6 px-3 py-2" style="background-color: #8C1B1B;">
            0 seleccionados
        </div>
    </div>

    <div class="sistema-card">

        <!-- Filtros principales -->
        <div class="d-flex flex-wrap gap-3 mb-3 align-items-center">

            <!-- Buscador -->
            <div style="min-width: 260px; flex-grow: 1; max-width: 350px;">
                <div class="input-group">
                    <span class="input-group-text" style="background: #f8f9fa; border-right: none;">
                        <i class="bi bi-search" style="color: #8C1B1B;"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control"
                           placeholder="Buscar por nombre o matrícula..."
                           style="border-left: none;">
                </div>
            </div>

            <!-- Toggle inscripción -->
            <div class="btn-group" role="group" id="enrollFilter">
                <input type="radio" class="btn-check" name="enrollOpt" id="optAll" autocomplete="off" checked>
                <label class="btn btn-outline-secondary btn-sm" for="optAll">Todos</label>

                <input type="radio" class="btn-check" name="enrollOpt" id="optEnrolled" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="optEnrolled">
                    <i class="bi bi-check-circle me-1"></i>Inscritos aquí
                </label>

                <input type="radio" class="btn-check" name="enrollOpt" id="optAvailable" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="optAvailable">
                    <i class="bi bi-person-plus me-1"></i>No inscritos
                </label>
            </div>

            <span id="filterCount" class="text-muted small"></span>
        </div>

        <!-- Filtros secundarios (solo visibles en modo "no inscritos") -->
        <div id="extraFilters" class="d-flex flex-wrap gap-3 mb-4 align-items-center d-none">
            <div style="min-width: 200px;">
                <select id="filterGradeLevel" class="form-select form-select-sm">
                    <option value="">Todos los semestres</option>
                    @foreach (var gl in gradeLevels)
                    {
                        <option value="@gl.GradeLevelId">@gl.Name</option>
                    }
                </select>
            </div>
            <div style="min-width: 200px;">
                <select id="filterGroup" class="form-select form-select-sm">
                    <option value="">Todos los grupos</option>
                    @foreach (var g in allGroups)
                    {
                        <option value="@g.GroupId" data-gradelevel="@g.GradeLevelId">
                            @g.Name — @g.GradeLevelName
                        </option>
                    }
                </select>
            </div>
            <button type="button" id="btnClearExtra" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-x-circle me-1"></i>Limpiar
            </button>
        </div>

        <form asp-action="SaveAssignments" method="post" id="assignForm">
            <input type="hidden" name="groupId" value="@Model.GroupId" />

            <div class="table-responsive">
                <table class="table table-hover align-middle" id="studentsTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px;">
                                <input type="checkbox" class="form-check-input" id="selectAll"
                                       title="Seleccionar todos los visibles" />
                            </th>
                            <th>Matrícula</th>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th class="text-center">Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model.AvailableStudents)
                        {
                            <tr class="student-row @(student.IsSelected ? "table-success" : "")"
                                data-name="@student.FullName.ToLower()"
                                data-matricula="@(student.Matricula?.ToLower() ?? "")"
                                data-enrolled="@(student.IsSelected ? "here" : (student.CurrentGroupName != null ? "other" : "none"))"
                                data-groupid="@(student.CurrentGroupName != null ? "has" : "")"
                                data-gradelevelname="@(student.CurrentGradeLevelName ?? "")"
                                data-currentgroup="@(student.CurrentGroupName ?? "")">
                                <td>
                                    <input type="checkbox"
                                           name="selectedStudentIds"
                                           value="@student.StudentId"
                                           class="form-check-input student-checkbox"
                                           @(student.IsSelected ? "checked" : "") />
                                </td>
                                <td class="fw-semibold">@student.Matricula</td>
                                <td>@student.FullName</td>
                                <td class="text-muted small">@student.Email</td>
                                <td class="text-center status-cell">
                                    @if (student.IsSelected)
                                    {
                                        <span class="badge" style="background-color: #28a745;">
                                            <i class="bi bi-check-circle me-1"></i>Inscrito aquí
                                        </span>
                                    }
                                    else if (student.CurrentGroupName != null)
                                    {
                                        <span class="badge" style="background-color: #fd7e14;"
                                              title="@student.CurrentGradeLevelName">
                                            <i class="bi bi-arrow-left-right me-1"></i>@student.CurrentGroupName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="bi bi-dash-circle me-1"></i>Sin inscribir
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div id="noResults" class="text-center py-4 d-none">
                <i class="bi bi-search" style="font-size: 2.5rem; color: #B1A596;"></i>
                <p class="text-muted mt-2">Sin resultados para los filtros aplicados</p>
            </div>

            <div class="d-flex gap-2 justify-content-end mt-4">
                <a asp-controller="Groups" asp-action="Details" asp-route-id="@Model.GroupId"
                   class="btn btn-secondary" style="border-radius: 10px; padding: 10px 25px;">
                    <i class="bi bi-x-circle me-2"></i>Cancelar
                </a>
                <button type="submit" class="btn btn-calificaciones" style="padding: 10px 25px;">
                    <i class="bi bi-save me-2"></i>Guardar Asignaciones
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const rows        = document.querySelectorAll('.student-row');
        const checkboxes  = document.querySelectorAll('.student-checkbox');
        const selectAll   = document.getElementById('selectAll');
        const searchInput = document.getElementById('searchInput');
        const badge       = document.getElementById('selectionBadge');
        const countSpan   = document.getElementById('filterCount');
        const noResults   = document.getElementById('noResults');
        const extraFilters = document.getElementById('extraFilters');
        const filterGL    = document.getElementById('filterGradeLevel');
        const filterGrp   = document.getElementById('filterGroup');

        // Grupos disponibles en el select (para filtrar por semestre)
        const allGroupOptions = [...document.querySelectorAll('#filterGroup option')].filter(o => o.value);

        function getEnrollOpt() {
            if (document.getElementById('optEnrolled').checked)  return 'enrolled';
            if (document.getElementById('optAvailable').checked) return 'available';
            return 'all';
        }

        function updateBadge() {
            const n = [...checkboxes].filter(c => c.checked).length;
            badge.textContent = `${n} seleccionado${n !== 1 ? 's' : ''}`;
        }

        function updateRowStyle(cb) {
            const row = cb.closest('tr');
            row.classList.toggle('table-success', cb.checked);
            const cell = row.querySelector('.status-cell');
            const enrolled = row.dataset.enrolled;
            if (cb.checked) {
                cell.innerHTML = `<span class="badge" style="background-color:#28a745;"><i class="bi bi-check-circle me-1"></i>Inscrito aquí</span>`;
            } else if (enrolled === 'other') {
                const grp = row.dataset.currentgroup;
                const lvl = row.dataset.gradelevelname;
                cell.innerHTML = `<span class="badge" style="background-color:#fd7e14;" title="${lvl}"><i class="bi bi-arrow-left-right me-1"></i>${grp}</span>`;
            } else {
                cell.innerHTML = `<span class="badge bg-secondary"><i class="bi bi-dash-circle me-1"></i>Sin inscribir</span>`;
            }
        }

        function applyFilters() {
            const query    = searchInput.value.toLowerCase().trim();
            const opt      = getEnrollOpt();
            const selGL    = filterGL.value;
            const selGrp   = filterGrp.value;
            let visible    = 0;

            rows.forEach(row => {
                const name      = row.dataset.name || '';
                const matricula = row.dataset.matricula || '';
                const enrolled  = row.dataset.enrolled; // 'here' | 'other' | 'none'
                const glName    = row.dataset.gradelevelname || '';
                const grpName   = row.dataset.currentgroup || '';

                // Filtro toggle inscripción
                let matchEnroll = true;
                if (opt === 'enrolled')  matchEnroll = enrolled === 'here';
                if (opt === 'available') matchEnroll = enrolled !== 'here';

                // Filtros extra (semestre/grupo — solo aplican sobre los "no inscritos aquí")
                let matchGL  = true;
                let matchGrp = true;
                if (opt === 'available' && enrolled === 'other') {
                    if (selGL) {
                        // Comparamos por nombre de nivel porque el data-attribute tiene el nombre
                        const selGLName = filterGL.options[filterGL.selectedIndex]?.text || '';
                        matchGL = glName === selGLName;
                    }
                    if (selGrp) {
                        const selGrpName = filterGrp.options[filterGrp.selectedIndex]?.text.split(' — ')[0].trim() || '';
                        matchGrp = grpName === selGrpName;
                    }
                }

                const matchSearch = !query || name.includes(query) || matricula.includes(query);
                const show = matchEnroll && matchGL && matchGrp && matchSearch;

                row.classList.toggle('d-none', !show);
                if (show) visible++;
            });

            countSpan.textContent = visible < rows.length ? `${visible} de ${rows.length} estudiantes` : '';
            noResults.classList.toggle('d-none', visible > 0);

            // Sincronizar selectAll
            const visibleChecks = [...rows]
                .filter(r => !r.classList.contains('d-none'))
                .map(r => r.querySelector('.student-checkbox'));
            selectAll.checked = visibleChecks.length > 0 && visibleChecks.every(c => c.checked);
            selectAll.indeterminate = !selectAll.checked && visibleChecks.some(c => c.checked);
        }

        // Mostrar/ocultar filtros extra según el toggle
        document.querySelectorAll('input[name="enrollOpt"]').forEach(radio => {
            radio.addEventListener('change', () => {
                const isAvailable = document.getElementById('optAvailable').checked;
                extraFilters.classList.toggle('d-none', !isAvailable);
                if (!isAvailable) {
                    filterGL.value  = '';
                    filterGrp.value = '';
                    // Restaurar todas las opciones de grupo
                    allGroupOptions.forEach(o => o.hidden = false);
                }
                applyFilters();
            });
        });

        // Filtrar opciones de grupo según semestre seleccionado
        filterGL.addEventListener('change', function () {
            const selId = this.value;
            allGroupOptions.forEach(o => {
                o.hidden = selId ? o.dataset.gradelevel !== selId : false;
            });
            if (filterGrp.value && filterGrp.options[filterGrp.selectedIndex]?.hidden) {
                filterGrp.value = '';
            }
            applyFilters();
        });

        filterGrp.addEventListener('change', applyFilters);

        document.getElementById('btnClearExtra').addEventListener('click', () => {
            filterGL.value  = '';
            filterGrp.value = '';
            allGroupOptions.forEach(o => o.hidden = false);
            applyFilters();
        });

        // Select all (solo filas visibles)
        selectAll.addEventListener('change', function () {
            rows.forEach(row => {
                if (!row.classList.contains('d-none')) {
                    const cb = row.querySelector('.student-checkbox');
                    cb.checked = this.checked;
                    updateRowStyle(cb);
                }
            });
            updateBadge();
        });

        // Individual checkbox
        checkboxes.forEach(cb => {
            cb.addEventListener('change', function () {
                updateRowStyle(this);
                updateBadge();
                applyFilters();
            });
        });

        searchInput.addEventListener('input', applyFilters);

        // Init
        updateBadge();
        applyFilters();
    </script>
}