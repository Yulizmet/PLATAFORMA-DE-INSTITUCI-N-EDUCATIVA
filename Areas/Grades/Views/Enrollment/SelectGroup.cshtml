@using SchoolManager.Areas.Grades.ViewModels.Breadcrumbs
@model IEnumerable<SchoolManager.Areas.MainScreen.ViewModels.GrupoResumenViewModel>

@{
    ViewData["Title"] = ViewBag.Titulo;
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    var breadcrumbs = new BreadcrumbViewModel();
    breadcrumbs.AddItem("Panel Administrativo", "/PanelAdministrativo");
    breadcrumbs.AddItem(ViewBag.Titulo);
    var list = Model.ToList();
}
<partial name="_Breadcrumb" model="breadcrumbs" />

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="users-title">
            <i class="bi bi-people me-2"></i>@ViewBag.Titulo
        </h1>
    </div>

    @if (!list.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-people" style="font-size: 4rem; color: #B1A596;"></i>
            <h5 class="text-muted mt-3">No hay grupos disponibles</h5>
        </div>
    }
    else
    {
        <div class="d-flex flex-wrap gap-3 mb-4 align-items-center">
            <div style="min-width: 200px;">
                <select id="filterGradeLevel" class="form-select">
                    <option value="">Todos los niveles</option>
                    @foreach (var level in list.Select(g => g.GradeLevelName).Distinct().OrderBy(x => x))
                    {
                        <option value="@level">@level</option>
                    }
                </select>
            </div>
            <span id="filterCount" class="text-muted small"></span>
            <button type="button" id="btnClearFilters" class="btn btn-outline-secondary btn-sm d-none">
                <i class="bi bi-x-circle me-1"></i>Limpiar filtros
            </button>
        </div>

        <div class="row" id="groupsGrid">
            @foreach (var grupo in list)
            {
                <div class="col-md-6 col-lg-4 mb-4 group-card"
                     data-gradelevel="@grupo.GradeLevelName">
                    <div class="sistema-card border-calificaciones h-100">
                        <div class="sistema-icon icon-calificaciones mb-4">
                            <i class="bi bi-people"></i>
                        </div>
                        <h4 class="fw-bold mb-2" style="color: #1f2937;">@grupo.Name</h4>
                        <p class="text-muted mb-3">
                            <i class="bi bi-layers me-1"></i>@grupo.GradeLevelName
                        </p>
                        <div class="mt-3">
                            <a asp-action="@ViewBag.Accion"
                               asp-route-groupId="@grupo.GroupId"
                               class="btn btn-calificaciones w-100">
                                @ViewBag.Boton <i class="bi bi-chevron-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div id="noResults" class="text-center py-5 d-none">
            <i class="bi bi-search" style="font-size: 3rem; color: #B1A596;"></i>
            <h5 class="text-muted mt-3">Sin resultados</h5>
        </div>
    }
</div>

@section Scripts {
    <script>
        const cards    = document.querySelectorAll('.group-card');
        const selLevel = document.getElementById('filterGradeLevel');
        const count    = document.getElementById('filterCount');
        const noRes    = document.getElementById('noResults');
        const btnClear = document.getElementById('btnClearFilters');

        function applyFilters() {
            const level = selLevel.value;
            let visible = 0;
            cards.forEach(card => {
                const match = !level || card.dataset.gradelevel === level;
                card.classList.toggle('d-none', !match);
                if (match) visible++;
            });
            count.textContent = visible < cards.length ? `${visible} de ${cards.length} grupos` : '';
            noRes.classList.toggle('d-none', visible > 0);
            btnClear.classList.toggle('d-none', !level);
        }

        selLevel.addEventListener('change', applyFilters);
        btnClear.addEventListener('click', () => { selLevel.value = ''; applyFilters(); });
    </script>
}