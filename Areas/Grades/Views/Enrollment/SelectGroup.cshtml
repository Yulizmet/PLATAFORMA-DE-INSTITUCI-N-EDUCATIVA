@using SchoolManager.Areas.Grades.ViewModels.Breadcrumbs
@model IEnumerable<SchoolManager.Areas.MainScreen.ViewModels.GrupoResumenViewModel>

@{
    ViewData["Title"] = ViewBag.Titulo;
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    var breadcrumbs = new BreadcrumbViewModel();
    breadcrumbs.AddItem("Panel Administrativo", "/PanelAdministrativo");
    breadcrumbs.AddItem(ViewBag.Titulo);
}
<partial name="_Breadcrumb" model="breadcrumbs" />

<section class="sistema-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="sistema-card">
                    <div class="sistema-icon icon-calificaciones mb-4">
                        <i class="bi bi-people"></i>
                    </div>

                    <h2 class="sistema-title mb-3">@ViewBag.Titulo</h2>

                    <p class="text-muted mb-4">
                        Selecciona un grupo de la lista para continuar
                    </p>

                    <div class="list-group">
                        @foreach (var grupo in Model)
                        {
                            <a asp-action="@ViewBag.Accion"
                               asp-route-groupId="@grupo.GroupId"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3 mb-2 border rounded">
                                <div>
                                    <h5 class="mb-1 fw-semibold">@grupo.Name</h5>
                                    <small class="text-muted">@grupo.GradeLevelName</small>
                                </div>
                                <i class="bi bi-chevron-right fs-5" style="color: #8C1B1B;"></i>
                            </a>
                        }
                    </div>

                    <div class="mt-4">
                        <a href="/PanelAdministrativo" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Volver al Panel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>