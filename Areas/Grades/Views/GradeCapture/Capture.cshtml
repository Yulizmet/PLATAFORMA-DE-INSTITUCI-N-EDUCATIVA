@using static SchoolManager.Areas.Grades.Controllers.GradeCaptureController
@using SchoolManager.Areas.Grades.ViewModels.Breadcrumbs;
@model SchoolManager.Areas.Grades.ViewModels.GradeCapture.GradeCaptureViewModel

@{
    ViewData["Title"] = $"Capturar Calificaciones - {Model.SubjectName}";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    var breadcrumbs = new BreadcrumbViewModel();
    breadcrumbs.AddItem("Calificaciones", "/CalificacionesDocente");
    breadcrumbs.AddItem("Mis Clases", "/Grades/GradeCapture/MyClasses");
    breadcrumbs.AddItem(
        @Model.SubjectName + " - " + @Model.GroupName,
        $"/Grades/GradeCapture/SelectUnit?teacherSubjectGroupId={Model.TeacherSubjectGroupId}"
    ); breadcrumbs.AddItem("Unidad " + @Model.UnitNumber);
}
<partial name="_Breadcrumb" model="breadcrumbs" />

<div class="container-fluid py-4">
@*     <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="MyClasses">Mis Clases</a></li>
            <li class="breadcrumb-item"><a asp-action="SelectUnit" asp-route-teacherSubjectGroupId="@Model.TeacherSubjectGroupId">@Model.SubjectName</a></li>
            <li class="breadcrumb-item active">Unidad @Model.UnitNumber</li>
        </ol>
    </nav> *@

    <div class="sistema-card">
        <!-- Botón de importación -->
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h4 class="fw-bold mb-2" style="color: #1f2937;">@Model.SubjectName - Unidad @Model.UnitNumber</h4>
                <p class="text-muted mb-0">
                    <i class="bi bi-people me-2"></i>Grupo @Model.GroupName
                </p>
            </div>
            <div class="d-flex align-items-center">
                <span class="badge bg-success me-3" style="font-size: 1rem; padding: 8px 15px;">
                    <i class="bi bi-pencil me-2"></i>Capturando
                </span>
                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#importModal">
                    <i class="bi bi-file-earmark-excel me-2"></i>Cargar Excel
                </button>
            </div>
        </div>

        <!-- Mensajes de importación -->
        @if (TempData["ImportSuccess"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["ImportSuccess"]
                @if (TempData["ImportErrors"] != null)
                {
                    var errores = System.Text.Json.JsonSerializer.Deserialize<List<string>>((string)TempData["ImportErrors"]);
                    if (errores.Any())
                    {
                        <ul class="mb-0 mt-2">
                            @foreach (var error in errores)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    }
                }
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }


        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form asp-action="SaveGrades" method="post" id="gradeForm">
            <input type="hidden" name="TeacherSubjectGroupId" value="@Model.TeacherSubjectGroupId" />
            <input type="hidden" name="UnitId" value="@Model.UnitId" />
            <input type="hidden" name="GroupId" value="@Model.GroupId" />
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 100px;">Matrícula</th>
                            <th>Estudiante</th>
                            <th style="width: 150px;">Calificación</th>
                            <th style="width: 200px;">Recuperación</th>
                            <th style="width: 100px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Students.Count; i++)
                        {
                            <tr>
                                <td class="fw-semibold">@Model.Students[i].Matricula</td>
                                <td>@Model.Students[i].StudentName</td>
                                <td>
                                    <input type="hidden" name="Grades[@i].StudentId" value="@Model.Students[i].StudentId" />
                                    <input type="number" name="Grades[@i].GradeValue"
                                           class="form-control grade-input"
                                           value="@(Model.Students[i].GradeValue?.ToString("F2") ?? "")"
                                           step="0.01" min="0" max="10"
                                           style="width: 100px; @(Model.Students[i].HasRecovery ? "background-color: #fff3cd;" : "")" />
                                </td>
                                <td>
                                    @if (Model.Students[i].GradeId.HasValue)
                                    {
                                        @if (Model.Students[i].RecoveryValue.HasValue)
                                        {
                                            <span class="text-success">
                                                <i class="bi bi-check-circle me-1"></i>@Model.Students[i].RecoveryValue?.ToString("F2")
                                            </span>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-warning"
                                                    onclick="openRecoveryModal(@Model.Students[i].GradeId, '@Model.Students[i].StudentName')">
                                                <i class="bi bi-plus-circle me-1"></i>Agregar Recuperación
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">Primero captura calificación</span>
                                    }
                                </td>
                                <td>
                                    @if (Model.Students[i].RecoveryId.HasValue)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                onclick="openDeleteRecoveryModal(@Model.Students[i].RecoveryId, '@Model.Students[i].StudentName')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex gap-2 justify-content-end mt-4">
                <a asp-action="SelectUnit" asp-route-teacherSubjectGroupId="@Model.TeacherSubjectGroupId"
                   class="btn btn-secondary" style="border-radius: 10px; background-color: #6c757d; color: white; padding: 10px 25px;">
                    <i class="bi bi-x-circle me-2"></i>Cancelar
                </a>
                <button type="submit" class="btn btn-calificaciones" style="padding: 10px 25px;">
                    <i class="bi bi-save me-2"></i>Guardar Calificaciones
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal para recuperación -->
<div class="modal fade" id="recoveryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius: 20px; border: none;">
            <div class="modal-header" style="background-color: #8C1B1B; color: white; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title">
                    <i class="bi bi-arrow-repeat me-2"></i>
                    Agregar Recuperación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="SaveRecovery" method="post" id="recoveryForm">
                <div class="modal-body p-4">
                    <input type="hidden" name="gradeId" id="recoveryGradeId" />
                    <input type="hidden" name="teacherSubjectGroupId" value="@Model.TeacherSubjectGroupId" />
                    <input type="hidden" name="unitId" value="@Model.UnitId" />

                    <p>Estudiante: <strong id="recoveryStudentName"></strong></p>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Calificación de Recuperación</label>
                        <input type="number" name="recoveryValue" class="form-control"
                               step="0.01" min="0" max="10" required />
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn" style="background-color: #D42D2D; color: white;">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal para eliminar recuperación -->
<div class="modal fade" id="deleteRecoveryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius: 20px; border: none;">
            <div class="modal-header" style="background-color: #8C1B1B; color: white; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="DeleteRecovery" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="recoveryId" id="deleteRecoveryId" value="" />

                    <input type="hidden" name="teacherSubjectGroupId" value="@Model.TeacherSubjectGroupId" />
                    <input type="hidden" name="unitId" value="@Model.UnitId" />

                    <p>¿Estás seguro de eliminar esta recuperación?</p>
                    <p class="text-danger mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Esta acción no se puede deshacer.
                    </p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn" style="background-color: #D42D2D; color: white;">Eliminar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Importación Excel — paso único con 2 estados -->
<div class="modal fade" id="importModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="border-radius: 20px; border: none;">
            <div class="modal-header" style="background-color: #8C1B1B; color: white; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title">
                    <i class="bi bi-file-earmark-excel me-2"></i>
                    <span id="importModalTitle">Cargar Calificaciones desde Excel</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">

                <!-- PASO 1: Subir archivo -->
                <div id="stepUpload">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Selecciona tu archivo Excel</label>
                        <input type="file" id="excelFileInput" class="form-control" accept=".xlsx,.xls,.csv" />
                        <small class="text-muted">Formatos aceptados: .xlsx, .xls, .csv</small>
                    </div>
                    <div id="uploadError" class="alert alert-danger d-none"></div>
                    <button type="button" id="btnUpload" class="btn btn-primary">
                        <i class="bi bi-upload me-2"></i>Subir y analizar
                    </button>
                </div>

                <!-- PASO 2: Mapeo simplificado (oculto hasta subir) -->
                <div id="stepMapping" class="d-none">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <p class="mb-0">
                            <i class="bi bi-file-earmark-spreadsheet me-2 text-success"></i>
                            <strong id="uploadedFileName"></strong>
                            <span class="text-muted ms-2" id="uploadedRowCount"></span>
                        </p>
                    </div>

                    <div id="mappingError" class="alert alert-danger d-none"></div>

                    <!-- Checkbox primera fila -->
                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" id="hasHeaderRow">
                        <label class="form-check-label" for="hasHeaderRow">
                            La primera fila contiene encabezados
                            <small class="text-muted d-block">
                                Marca esto si tu Excel tiene títulos como "Nombre", "Calificación" en la primera fila
                            </small>
                        </label>
                    </div>

                    <!-- Tabla de vista previa -->
                    <div class="table-responsive mb-3" style="max-height: 200px; overflow-y: auto;">
                        <table class="table table-sm table-bordered mb-0" id="previewTable">
                            <thead class="table-light" id="previewHead"></thead>
                            <tbody id="previewBody"></tbody>
                        </table>
                    </div>

                    <!-- Dropdowns de mapeo -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-person me-1"></i>Columna de Nombres
                            </label>
                            <select id="nombreColumnSelect" class="form-select">
                                <!-- Se llena dinámicamente -->
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-123 me-1"></i>Columna de Calificaciones
                            </label>
                            <select id="califColumnSelect" class="form-select">
                                <!-- Se llena dinámicamente -->
                            </select>
                        </div>
                    </div>

                    <!-- Info de la unidad destino -->
                    <div class="alert alert-info py-2 mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        Las calificaciones se importarán a la <strong>Unidad @Model.UnitNumber</strong>
                        de <strong>@Model.SubjectName</strong>
                    </div>

                    <div class="d-flex justify-content-between">
                        <button type="button" id="btnBackToUpload" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Volver
                        </button>
                        <button type="button" id="btnApplyMapping" class="btn btn-calificaciones">
                            <i class="bi bi-check-circle me-2"></i>Importar Calificaciones
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        // ── Recuperaciones ──────────────────────────────────────────────
        let currentRecoveryId = null;

        function openRecoveryModal(gradeId, studentName) {
            document.getElementById('recoveryGradeId').value = gradeId;
            document.getElementById('recoveryStudentName').innerText = studentName;
            new bootstrap.Modal(document.getElementById('recoveryModal')).show();
        }

        function openDeleteRecoveryModal(recoveryId, studentName) {
            currentRecoveryId = recoveryId;
            document.getElementById('deleteRecoveryId').value = recoveryId;
            new bootstrap.Modal(document.getElementById('deleteRecoveryModal')).show();
        }

        document.addEventListener('click', function (e) {
            if (e.target && e.target.id === 'confirmDeleteRecovery' && currentRecoveryId) {
                bootstrap.Modal.getInstance(document.getElementById('deleteRecoveryModal')).hide();
                Swal.fire({ icon: 'success', title: 'Eliminado', text: 'Recuperación eliminada correctamente', timer: 1500, showConfirmButton: false })
                    .then(() => location.reload());
            }
        });

        // ── Validación inputs calificación ──────────────────────────────
        document.querySelectorAll('.grade-input').forEach(input => {
            input.addEventListener('change', function () {
                let value = parseFloat(this.value);
                if (isNaN(value)) { this.value = ''; return; }
                this.value = Math.min(10, Math.max(0, value));
            });
        });

        // ── Importación Excel (AJAX) ─────────────────────────────────────
        const teacherSubjectGroupId = @Model.TeacherSubjectGroupId;
        const unitId                = @Model.UnitId;
        const groupId               = @Model.GroupId;
        const subjectId             = @Model.SubjectId;

        // Mapa: studentId → índice de fila en la tabla del formulario
        const studentIndexMap = {
            @for (int i = 0; i < Model.Students.Count; i++)
            {
                    <text>@Model.Students[i].StudentId: @i,</text>
            }
        };

        // Variables del flujo de importación
        let uploadedFileId = null;
        let uploadedHeaders = [];
        let uploadedPreview = [];

        // ── PASO 1: Subir archivo ────────────────────────────────────
        document.getElementById('btnUpload').addEventListener('click', async function () {
            const file = document.getElementById('excelFileInput').files[0];
            const errorDiv = document.getElementById('uploadError');
            errorDiv.classList.add('d-none');

            if (!file) {
                errorDiv.textContent = 'Selecciona un archivo';
                errorDiv.classList.remove('d-none');
                return;
            }

            const formData = new FormData();
            formData.append('excelFile', file);
            formData.append('teacherSubjectGroupId', teacherSubjectGroupId);
            formData.append('unitId', unitId);

            this.disabled = true;
            this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Analizando...';

            try {
                const response = await fetch('/Grades/GradeCapture/UploadExcel', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();

                if (!response.ok) {
                    errorDiv.textContent = data.error;
                    errorDiv.classList.remove('d-none');
                    return;
                }

                // Guardar datos para el paso 2
                uploadedFileId = data.fileId;
                uploadedHeaders = data.headers;
                uploadedPreview = data.preview;

                // Construir UI de mapeo
                buildMappingUI(data.headers, data.preview, data.fileName, data.totalRows);

                // Cambiar a paso 2
                document.getElementById('stepUpload').classList.add('d-none');
                document.getElementById('stepMapping').classList.remove('d-none');
                document.getElementById('importModalTitle').textContent = 'Mapear Columnas';

            } catch (err) {
                errorDiv.textContent = 'Error al conectar con el servidor';
                errorDiv.classList.remove('d-none');
            } finally {
                this.disabled = false;
                this.innerHTML = '<i class="bi bi-upload me-2"></i>Subir y analizar';
            }
        });

        // ── Construir UI de mapeo ────────────────────────────────────
        function buildMappingUI(headers, preview, fileName, totalRows) {
            // Info del archivo
            document.getElementById('uploadedFileName').textContent = fileName;
            document.getElementById('uploadedRowCount').textContent = `(${totalRows} fila${totalRows !== 1 ? 's' : ''})`;

            // Tabla de vista previa
            const thead = document.getElementById('previewHead');
            const tbody = document.getElementById('previewBody');

            // Encabezados: # + columnas
            thead.innerHTML = '<tr><th style="width:40px">#</th>' +
                headers.map(h => `<th>${h}</th>`).join('') + '</tr>';

            // Filas de datos
            tbody.innerHTML = '';
            preview.forEach((row, idx) => {
                const cells = headers.map(h => {
                    const val = row[h];
                    return `<td>${val !== null && val !== undefined ? val : ''}</td>`;
                }).join('');
                tbody.innerHTML += `<tr data-row-index="${idx}"><td class="text-muted">${idx + 1}</td>${cells}</tr>`;
            });

            // Llenar dropdowns de columnas
            const nombreSelect = document.getElementById('nombreColumnSelect');
            const califSelect = document.getElementById('califColumnSelect');

            nombreSelect.innerHTML = '<option value="-1">-- Seleccionar --</option>';
            califSelect.innerHTML = '<option value="-1">-- Seleccionar --</option>';

            let suggestedNombre = -1;
            let suggestedCalif = -1;

            headers.forEach((header, i) => {
                // Obtener valor de vista previa para auto-detectar tipo
                const sampleValue = preview[0] ? preview[0][header] : null;
                let hint = '';

                if (sampleValue !== null && sampleValue !== undefined) {
                    if (typeof sampleValue === 'number' || !isNaN(Number(sampleValue))) {
                        hint = ' (numérica)';
                        if (suggestedCalif === -1) suggestedCalif = i;
                    } else {
                        hint = ' (texto)';
                        if (suggestedNombre === -1) suggestedNombre = i;
                    }
                }

                const label = `Columna ${header}${hint}`;
                nombreSelect.innerHTML += `<option value="${i}">${label}</option>`;
                califSelect.innerHTML += `<option value="${i}">${label}</option>`;
            });

            // Auto-seleccionar basado en detección de tipo
            if (suggestedNombre >= 0) nombreSelect.value = suggestedNombre;
            if (suggestedCalif >= 0) califSelect.value = suggestedCalif;
        }

        // ── Checkbox "primera fila es encabezado" ────────────────────
        document.getElementById('hasHeaderRow').addEventListener('change', function () {
            const firstRow = document.querySelector('#previewBody tr[data-row-index="0"]');
            if (firstRow) {
                if (this.checked) {
                    firstRow.style.opacity = '0.4';
                    firstRow.style.textDecoration = 'line-through';
                    firstRow.title = 'Esta fila se tratará como encabezado y se omitirá';
                } else {
                    firstRow.style.opacity = '1';
                    firstRow.style.textDecoration = 'none';
                    firstRow.title = '';
                }
            }
        });

        // ── Volver al paso 1 ─────────────────────────────────────────
        document.getElementById('btnBackToUpload').addEventListener('click', function () {
            document.getElementById('stepMapping').classList.add('d-none');
            document.getElementById('stepUpload').classList.remove('d-none');
            document.getElementById('importModalTitle').textContent = 'Cargar Calificaciones desde Excel';
            document.getElementById('mappingError').classList.add('d-none');
        });

        // ── PASO 2: Aplicar mapeo ────────────────────────────────────
        document.getElementById('btnApplyMapping').addEventListener('click', async function () {
            const errorDiv = document.getElementById('mappingError');
            errorDiv.classList.add('d-none');

            const nombreIdx = parseInt(document.getElementById('nombreColumnSelect').value);
            const califIdx = parseInt(document.getElementById('califColumnSelect').value);
            const hasHeaderRow = document.getElementById('hasHeaderRow').checked;

            // Validaciones frontend
            if (nombreIdx < 0) {
                errorDiv.textContent = 'Selecciona la columna de nombres';
                errorDiv.classList.remove('d-none');
                return;
            }
            if (califIdx < 0) {
                errorDiv.textContent = 'Selecciona la columna de calificaciones';
                errorDiv.classList.remove('d-none');
                return;
            }
            if (nombreIdx === califIdx) {
                errorDiv.textContent = 'Las columnas de nombre y calificación deben ser diferentes';
                errorDiv.classList.remove('d-none');
                return;
            }

            const payload = {
                teacherSubjectGroupId,
                unitId,
                groupId,
                fileId: uploadedFileId,
                nombreColumnIndex: nombreIdx,
                calificacionColumnIndex: califIdx,
                hasHeaderRow: hasHeaderRow
            };

            this.disabled = true;
            this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Procesando...';

            try {
                const response = await fetch('/Grades/GradeCapture/ApplyExcelMapping', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await response.json();

                if (!response.ok) {
                    errorDiv.textContent = data.error;
                    errorDiv.classList.remove('d-none');
                    return;
                }

                // Cerrar modal
                bootstrap.Modal.getInstance(document.getElementById('importModal')).hide();

                // Rellenar inputs de calificación en la tabla principal
                let actualizados = 0;
                data.grades.forEach(item => {
                    const rowIndex = studentIndexMap[item.studentId];
                    if (rowIndex !== undefined) {
                        const input = document.querySelector(`input[name='Grades[${rowIndex}].GradeValue']`);
                        if (input) {
                            input.value = parseFloat(item.grade).toFixed(2);
                            input.style.backgroundColor = '#d4edda';
                            input.style.transition = 'background-color 0.3s';
                            actualizados++;
                        }
                    }
                });

                // Mostrar resultado con alerta
                let alertType = data.errores.length > 0 ? 'warning' : 'success';
                let iconClass = data.errores.length > 0 ? 'exclamation-triangle-fill' : 'check-circle-fill';

                const alertHtml = `
                    <div class="alert alert-${alertType} alert-dismissible fade show" role="alert">
                        <i class="bi bi-${iconClass} me-2"></i>
                        Se cargaron <strong>${actualizados}</strong> calificaciones desde el Excel.
                        ${actualizados > 0 ? '<strong>Recuerda dar clic en "Guardar Calificaciones" para confirmar.</strong>' : ''}
                        ${data.errores.length > 0 ? `
                            <hr class="my-2">
                            <details>
                                <summary class="fw-semibold" style="cursor:pointer">
                                    ${data.errores.length} observación${data.errores.length !== 1 ? 'es' : ''}</summary>
                                <ul class="mb-0 mt-1">
                                    ${data.errores.map(e => `<li>${e}</li>`).join('')}
                                </ul>
                            </details>` : ''}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>`;

                document.getElementById('gradeForm').insertAdjacentHTML('beforebegin', alertHtml);

            } catch (err) {
                errorDiv.textContent = 'Error al conectar con el servidor';
                errorDiv.classList.remove('d-none');
            } finally {
                this.disabled = false;
                this.innerHTML = '<i class="bi bi-check-circle me-2"></i>Importar Calificaciones';
            }
        });

        // ── Resetear modal al cerrarse ───────────────────────────────
        document.getElementById('importModal').addEventListener('hidden.bs.modal', function () {
            document.getElementById('stepUpload').classList.remove('d-none');
            document.getElementById('stepMapping').classList.add('d-none');
            document.getElementById('uploadError').classList.add('d-none');
            document.getElementById('mappingError').classList.add('d-none');
            document.getElementById('excelFileInput').value = '';
            document.getElementById('hasHeaderRow').checked = false;
            document.getElementById('importModalTitle').textContent = 'Cargar Calificaciones desde Excel';
            uploadedFileId = null;
        });
    </script>
}
