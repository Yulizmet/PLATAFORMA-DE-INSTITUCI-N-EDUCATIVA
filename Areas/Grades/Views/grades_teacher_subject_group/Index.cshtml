@model IEnumerable<SchoolManager.Models.grades_teacher_subject_group>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TeacherSubject)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.grades_group)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TeacherSubject.TeacherSubjectId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.grades_group.Name)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.TeacherSubjectGroupId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.TeacherSubjectGroupId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.TeacherSubjectGroupId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
