@using SchoolManager.Areas.Grades.ViewModels.Wizard
@* /Areas/Grades/Views/SchoolCycleWizard/Step5.cshtml *@
@model SchoolCycleWizardViewModel

@{
    ViewData["Title"] = "Paso 5: Resumen Final";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="sistema-card">
                <!-- Barra de progreso -->
                <div class="progress mb-4" style="height: 10px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: 100%;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                </div>

                <div class="text-center mb-4">
                    <div class="sistema-icon icon-calificaciones mx-auto mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-check-circle-fill" style="font-size: 2.5rem; color: #28a745;"></i>
                    </div>
                    <h2 class="fw-bold">¡Configuración Completada!</h2>
                    <p class="text-muted">Revisa el resumen antes de finalizar</p>
                </div>

                <!-- Tarjeta de resumen del nivel -->
                <div class="card mb-4 border-success">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="bi bi-layers me-2"></i>Nivel Escolar</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <strong>Nombre:</strong> @Model.LevelName
                            </div>
                            <div class="col-md-4">
                                <strong>Período:</strong> @Model.StartDate?.ToString("dd/MM/yyyy") - @Model.EndDate?.ToString("dd/MM/yyyy")
                            </div>
                            <div class="col-md-4">
                                <strong>Calificación mínima:</strong> <span class="badge bg-danger">@Model.MinPassingGrade</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tarjeta de materias y unidades -->
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-book me-2"></i>Materias y Unidades</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.Subjects.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Materia</th>
                                            <th class="text-center">Unidades</th>
                                            <th>Detalle</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var subject in Model.Subjects)
                                        {
                                            <tr>
                                                <td class="fw-semibold">@subject.Name</td>
                                                <td class="text-center">@subject.Units.Count</td>
                                                <td>
                                                    @foreach (var unit in subject.Units)
                                                    {
                                                        <span class="badge @(unit.IsOpen ? "bg-success" : "bg-secondary") me-1">
                                                            U@(unit.Number) @(unit.IsOpen ? "✓" : "✗")
                                                        </span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No se crearon materias</p>
                        }
                    </div>
                </div>

                <!-- Tarjeta de grupos -->
                <div class="card mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="bi bi-people me-2"></i>Grupos</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.Groups.Any())
                        {
                            foreach (var group in Model.Groups)
                            {
                                <span class="badge bg-secondary me-2 mb-2 p-2">@group.Name</span>
                            }
                        }
                        else
                        {
                            <p class="text-muted mb-0">No se crearon grupos</p>
                        }
                    </div>
                </div>

                <!-- Tarjeta de asignaciones -->
                <div class="card mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Asignaciones de Profesores</h5>
                    </div>
                    <div class="card-body">
                        @{
                            var asignacionesConProfesor = Model.Assignments.Where(a => a.TeacherId.HasValue).ToList();
                        }
                        @if (asignacionesConProfesor.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Materia</th>
                                            <th>Profesor</th>
                                            <th>Grupos</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var assignment in asignacionesConProfesor)
                                        {
                                            var gruposAsignados = Model.Groups
                                            .Where(g => assignment.SelectedGroupIds.Contains(g.TempId))
                                            .Select(g => g.Name)
                                            .ToList();
                                            <tr>
                                                <td class="fw-semibold">@assignment.SubjectName</td>
                                                <td>@assignment.TeacherName</td>
                                                <td>
                                                    @if (gruposAsignados.Any())
                                                    {
                                                        foreach (var group in gruposAsignados)
                                                        {
                                                            <span class="badge bg-secondary me-1">@group</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Sin grupos</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No se asignaron profesores</p>
                        }
                    </div>
                </div>

                <!-- Estadísticas rápidas -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card text-center bg-light">
                            <div class="card-body">
                                <h3 class="fw-bold text-primary">@Model.Subjects.Count</h3>
                                <small>Materias</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card text-center bg-light">
                            <div class="card-body">
                                <h3 class="fw-bold text-success">@Model.Subjects.Sum(s => s.Units.Count)</h3>
                                <small>Unidades</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card text-center bg-light">
                            <div class="card-body">
                                <h3 class="fw-bold text-info">@Model.Groups.Count</h3>
                                <small>Grupos</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card text-center bg-light">
                            <div class="card-body">
                                <h3 class="fw-bold text-warning">@asignacionesConProfesor.Count</h3>
                                <small>Asignaciones</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Botones de acción final -->
                <form asp-action="Step4" method="post" class="d-inline">
                    <div class="d-flex justify-content-between">
                        <a asp-action="Step4" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Regresar
                        </a>
                        <div>
                            <button type="submit" name="saveType" value="draft" formaction="@Url.Action("Step4")" class="btn btn-outline-secondary me-2">
                                <i class="bi bi-pencil me-2"></i>Editar
                            </button>
                            <button type="submit" formaction="@Url.Action("Step4")" formmethod="post" class="btn btn-success" id="btnFinalizar">
                                <i class="bi bi-check-circle me-2"></i>Guardar y Finalizar
                            </button>
                        </div>
                    </div>
                </form>

                <p class="text-muted small text-center mt-4 mb-0">
                    <i class="bi bi-info-circle me-2"></i>
                    Al finalizar, se creará todo en la base de datos y podrás comenzar a trabajar.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Confirmación antes de guardar
            document.getElementById('btnFinalizar').addEventListener('click', function(e) {
                if (!confirm('¿Estás seguro de guardar toda la configuración? Esta acción no se puede deshacer.')) {
                    e.preventDefault();
                }
            });
        });
    </script>
}