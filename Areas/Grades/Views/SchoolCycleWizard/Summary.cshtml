@* /Areas/Grades/Views/SchoolCycleWizard/Summary.cshtml *@
@model SchoolManager.Models.grades_grade_level

@{
    ViewData["Title"] = "Ciclo Configurado";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-9">

                <div class="sistema-card border-calificaciones">

                    <!-- Éxito -->
                    <div class="text-center mb-5">
                        <div class="sistema-icon icon-calificaciones mx-auto mb-3"
                             style="width: 90px; height: 90px;">
                            <i class="bi bi-check-circle-fill" style="font-size: 2.8rem;"></i>
                        </div>
                        <h2 class="sistema-title">¡Ciclo Escolar Creado!</h2>
                        <p class="text-muted">Todo se guardó correctamente en la base de datos</p>
                    </div>

                    <!-- Nivel -->
                    <div class="p-3 rounded mb-4"
                         style="background-color: rgba(212,45,45,0.08); border: 1px solid rgba(212,45,45,0.25);">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-layers" style="color: var(--rojo-principal);"></i>
                            <span class="fw-bold">Nivel Escolar</span>
                        </div>
                        <div class="row text-muted small">
                            <div class="col-md-4">
                                <strong class="text-dark">Nombre:</strong> @Model.Name
                            </div>
                            <div class="col-md-4">
                                <strong class="text-dark">Período:</strong>
                                @Model.StartDate.ToString("dd/MM/yyyy") – @Model.EndDate.ToString("dd/MM/yyyy")
                            </div>
                            <div class="col-md-4">
                                <strong class="text-dark">Mínimo:</strong>
                                <span class="badge ms-1" style="background-color: var(--rojo-principal);">
                                    @Model.MinPassingGrade.ToString("F1")
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Materias -->
                    <div class="mb-4">
                        <h6 class="fw-bold mb-3">
                            <i class="bi bi-book me-2" style="color: var(--rojo-principal);"></i>
                            Materias Creadas <span class="badge ms-1" style="background-color: var(--rojo-principal);">@Model.Subjects.Count</span>
                        </h6>
                        @if (Model.Subjects.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr style="border-bottom: 2px solid rgba(212,45,45,0.3);">
                                            <th>Materia</th>
                                            <th class="text-center">Unidades</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var subject in Model.Subjects)
                                        {
                                            <tr>
                                                <td>@subject.Name</td>
                                                <td class="text-center">
                                                    <span class="badge" style="background-color: var(--rojo-principal);">
                                                        @subject.Units.Count
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small">No se crearon materias</p>
                        }
                    </div>

                    <!-- Grupos -->
                    <div class="mb-5">
                        <h6 class="fw-bold mb-3">
                            <i class="bi bi-people me-2" style="color: var(--rojo-principal);"></i>
                            Grupos Creados <span class="badge ms-1" style="background-color: var(--rojo-principal);">@Model.Groups.Count</span>
                        </h6>
                        @if (Model.Groups.Any())
                        {
                            foreach (var group in Model.Groups)
                            {
                                <span class="badge me-2 mb-2 p-2" style="background-color: var(--rojo-principal);">@group.Name</span>
                            }
                        }
                        else
                        {
                            <p class="text-muted small">No se crearon grupos</p>
                        }
                    </div>

                    <!-- Acciones -->
                    <div class="d-flex justify-content-center gap-3 pt-3 border-top">
                        <a asp-area="MainScreen" asp-controller="MainScreen" asp-action="PanelAdministrativo"
                           class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Volver al Panel
                        </a>
                        <a asp-area="Grades" asp-controller="Enrollment" asp-action="SelectGroupForAssignment"
                           class="btn btn-calificaciones">
                            <i class="bi bi-person-plus me-2"></i>Inscribir Estudiantes
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
