@* /Areas/Grades/Views/SchoolCycleWizard/Step4.cshtml *@
@using SchoolManager.Areas.Grades.ViewModels.Wizard
@model SchoolCycleWizardViewModel

@{
    ViewData["Title"] = "Nuevo Ciclo Escolar";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-11">

                <div class="sistema-card border-calificaciones">

                    <!-- Indicador de pasos -->
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">Paso 4 de 4</span>
                        <span class="badge" style="background-color: var(--rojo-principal); font-size: 0.85rem;">
                            @Model.LevelName
                        </span>
                    </div>
                    <div class="progress mb-4" style="height: 6px; border-radius: 4px;">
                        <div class="progress-bar" role="progressbar"
                             style="width: 100%; background-color: var(--rojo-principal);">
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div class="sistema-icon icon-calificaciones mb-0" style="flex-shrink:0;">
                            <i class="bi bi-person-badge"></i>
                        </div>
                        <div>
                            <h3 class="sistema-title mb-0" style="font-size: 1.5rem;">Asignar Profesores</h3>
                            <p class="text-muted mb-0 small">Cada grupo solo puede tener un profesor por materia</p>
                        </div>
                    </div>

                    <!-- Leyenda -->
                    <div class="alert mb-4" style="background-color: rgba(212,45,45,0.07); border: 1px solid rgba(212,45,45,0.2); border-radius: 10px;">
                        <i class="bi bi-info-circle me-2" style="color: var(--rojo-principal);"></i>
                        <span class="small">Varios profesores pueden compartir una materia, pero <strong>cada grupo solo puede asignarse a un profesor</strong> por materia. Los grupos ya tomados aparecen bloqueados en las otras filas.</span>
                    </div>

                    <form asp-action="Step4" method="post" id="assignmentsForm">
                        @Html.AntiForgeryToken()

                        <!-- Datos ocultos: nivel -->
                        <input type="hidden" name="LevelName" value="@(Model.LevelName ?? "")" />
                        <input type="hidden" name="StartDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd") ?? "")" />
                        <input type="hidden" name="EndDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd") ?? "")" />
                        <input type="hidden" name="MinPassingGrade" value="@(Model.MinPassingGrade?.ToString() ?? "")" />

                        <!-- Datos ocultos: materias -->
                        @for (int i = 0; i < Model.Subjects.Count; i++)
                        {
                            <input type="hidden" name="Subjects[@i].TempId" value="@Model.Subjects[i].TempId" />
                            <input type="hidden" name="Subjects[@i].Name" value="@(Model.Subjects[i].Name ?? "")" />
                            @for (int j = 0; j < Model.Subjects[i].Units.Count; j++)
                            {
                                <input type="hidden" name="Subjects[@i].Units[@j].Number" value="@Model.Subjects[i].Units[j].Number" />
                                <input type="hidden" name="Subjects[@i].Units[@j].IsOpen" value="@Model.Subjects[i].Units[j].IsOpen" />
                            }
                        }

                        <!-- Datos ocultos: grupos -->
                        @for (int i = 0; i < Model.Groups.Count; i++)
                        {
                            <input type="hidden" name="Groups[@i].TempId" value="@Model.Groups[i].TempId" />
                            <input type="hidden" name="Groups[@i].Name" value="@(Model.Groups[i].Name ?? "")" />
                        }

                        <!-- Asignaciones por materia -->
                        <div id="assignmentsContainer">
                            @for (int i = 0; i < Model.Assignments.Count; i++)
                            {
                                <div class="card mb-4 border-0 shadow-sm" data-subject-card="@i">
                                    <div class="card-header d-flex justify-content-between align-items-center"
                                         style="background-color: rgba(212,45,45,0.08); border-bottom: 2px solid rgba(212,45,45,0.2);">
                                        <h6 class="fw-bold mb-0">
                                            <i class="bi bi-book me-2" style="color: var(--rojo-principal);"></i>
                                            @Model.Assignments[i].SubjectName
                                        </h6>
                                        <input type="hidden" name="Assignments[@i].SubjectTempId" value="@Model.Assignments[i].SubjectTempId" />
                                        <input type="hidden" name="Assignments[@i].SubjectName" value="@Model.Assignments[i].SubjectName" />
                                    </div>
                                    <div class="card-body">
                                        <div class="teacher-assignments-list" data-subject-index="@i">
                                            @for (int t = 0; t < Model.Assignments[i].TeacherAssignments.Count; t++)
                                            {
                                                <div class="teacher-row border rounded p-3 mb-2">
                                                    <div class="row align-items-start">
                                                        <div class="col-md-5 mb-2">
                                                            <label class="form-label fw-semibold small">Profesor</label>
                                                            <select name="Assignments[@i].TeacherAssignments[@t].TeacherId"
                                                                    class="form-select teacher-select">
                                                                <option value="">-- Seleccionar --</option>
                                                                @foreach (var teacher in ViewBag.Teachers)
                                                                {
                                                                    if (teacher.Value == Model.Assignments[i].TeacherAssignments[t].TeacherId?.ToString())
                                                                    {
                                                                        <option value="@teacher.Value" selected>@teacher.Text</option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option value="@teacher.Value">@teacher.Text</option>
                                                                    }
                                                                }
                                                            </select>
                                                        </div>
                                                        <div class="col-md-6 mb-2">
                                                            <label class="form-label fw-semibold small">
                                                                Grupos
                                                                <span class="text-muted fw-normal">(selecciona los que impartirá)</span>
                                                            </label>
                                                            <div class="groups-panel border rounded p-2 d-flex flex-wrap gap-2">
                                                                @for (int g = 0; g < Model.Groups.Count; g++)
                                                                {
                                                                    var isChecked = Model.Assignments[i].TeacherAssignments[t].SelectedGroupIds.Contains(Model.Groups[g].TempId);
                                                                    <div class="form-check form-check-inline m-0">
                                                                        <input type="checkbox"
                                                                               class="form-check-input group-checkbox"
                                                                               name="Assignments[@i].TeacherAssignments[@t].SelectedGroupIds"
                                                                               value="@Model.Groups[g].TempId"
                                                                               id="g_@(i)_@(t)_@(g)"
                                                                               data-group-id="@Model.Groups[g].TempId"
                                                                               @(isChecked ? "checked" : "") />
                                                                        <label class="form-check-label small" for="g_@(i)_@(t)_@(g)">
                                                                            @Model.Groups[g].Name
                                                                        </label>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                        <div class="col-md-1 d-flex align-items-center justify-content-end mb-2 pt-4">
                                                            <button type="button" class="btn btn-outline-danger btn-sm btn-remove-teacher"
                                                                    title="Eliminar fila">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-secondary btn-add-teacher mt-1"
                                                data-subject-index="@i">
                                            <i class="bi bi-plus-circle me-1"></i>Agregar otro profesor
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Navegación -->
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top mt-2">
                            <button type="submit" formaction="@Url.Action("Step4Back")"
                                    class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Regresar
                            </button>
                            <button type="submit" class="btn btn-calificaciones" id="btnFinalizar">
                                <i class="bi bi-check-circle me-2"></i>Guardar Ciclo Escolar
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // ─── Plantillas para filas dinámicas ───────────────────────────────────

        const teacherOptions = `@foreach (var t in ViewBag.Teachers) {
            <text><option value="@t.Value">@t.Text</option></text>
    }
`;

    // Grupos disponibles como array de objetos {id, name}
    const allGroups = [
        @for (int g = 0; g < Model.Groups.Count; g++)
        {
                <text>{ id: @Model.Groups[g].TempId, name: "@Model.Groups[g].Name" },</text>
        }
    ];

    // ─── Lógica de exclusividad de grupos ─────────────────────────────────
    // Dentro de cada materia (card), un grupo solo puede estar marcado en UNA fila.
    // Al marcar un grupo en la fila A, se deshabilita en todas las demás filas de esa materia.
    // Al desmarcarlo, se vuelve a habilitar en las otras filas.

    function syncGroupsInSubject(subjectCard) {
        const lists = subjectCard.querySelectorAll('.teacher-assignments-list');
        if (!lists.length) return;

        const list = lists[0];
        const allRows = list.querySelectorAll('.teacher-row');

        // Construir set de grupos tomados por cada fila
        allRows.forEach(row => {
            const checkedInThisRow = new Set(
                [...row.querySelectorAll('.group-checkbox:checked')]
                    .map(cb => cb.dataset.groupId)
            );

            // Para cada fila, deshabilitar los grupos que están marcados en OTRAS filas
            allRows.forEach(otherRow => {
                if (otherRow === row) return;
                otherRow.querySelectorAll('.group-checkbox').forEach(cb => {
                    const gid = cb.dataset.groupId;
                    if (checkedInThisRow.has(gid)) {
                        // Está tomado por otra fila → deshabilitar y desmarcar
                        cb.disabled = true;
                        cb.checked  = false;
                        cb.closest('.form-check').style.opacity = '0.4';
                    }
                });
            });
        });

        // Segunda pasada: rehabilitar los que ya no están tomados por nadie
        const allCheckedGroupIds = new Set(
            [...list.querySelectorAll('.group-checkbox:checked')]
                .map(cb => cb.dataset.groupId)
        );

        list.querySelectorAll('.group-checkbox').forEach(cb => {
            const gid = cb.dataset.groupId;
            if (!cb.checked && !allCheckedGroupIds.has(gid)) {
                cb.disabled = false;
                cb.closest('.form-check').style.opacity = '1';
            }
        });
    }

    // Escuchar cambios en checkboxes de grupos
    document.addEventListener('change', function (e) {
        if (e.target.classList.contains('group-checkbox')) {
            const subjectCard = e.target.closest('[data-subject-card]');
            if (subjectCard) syncGroupsInSubject(subjectCard);
        }
    });

    // Inicializar al cargar (por si hay datos previos)
    document.querySelectorAll('[data-subject-card]').forEach(syncGroupsInSubject);


    // ─── Construir HTML de una nueva fila de profesor ──────────────────────

    function buildTeacherRow(subjectIndex, teacherIndex) {
        const groupsHtml = allGroups.map((g, gi) => `
            <div class="form-check form-check-inline m-0">
                <input type="checkbox"
                       class="form-check-input group-checkbox"
                       name="Assignments[${subjectIndex}].TeacherAssignments[${teacherIndex}].SelectedGroupIds"
                       value="${g.id}"
                       id="g_${subjectIndex}_${teacherIndex}_${gi}"
                       data-group-id="${g.id}" />
                <label class="form-check-label small" for="g_${subjectIndex}_${teacherIndex}_${gi}">
                    ${g.name}
                </label>
            </div>`).join('');

        return `
            <div class="teacher-row border rounded p-3 mb-2">
                <div class="row align-items-start">
                    <div class="col-md-5 mb-2">
                        <label class="form-label fw-semibold small">Profesor</label>
                        <select name="Assignments[${subjectIndex}].TeacherAssignments[${teacherIndex}].TeacherId"
                                class="form-select teacher-select">
                            <option value="">-- Seleccionar --</option>
                            ${teacherOptions}
                        </select>
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-semibold small">
                            Grupos
                            <span class="text-muted fw-normal">(selecciona los que impartirá)</span>
                        </label>
                        <div class="groups-panel border rounded p-2 d-flex flex-wrap gap-2">
                            ${groupsHtml}
                        </div>
                    </div>
                    <div class="col-md-1 d-flex align-items-center justify-content-end mb-2 pt-4">
                        <button type="button" class="btn btn-outline-danger btn-sm btn-remove-teacher" title="Eliminar fila">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            </div>`;
    }


    // ─── Agregar fila de profesor ──────────────────────────────────────────

    document.querySelectorAll('.btn-add-teacher').forEach(btn => {
        btn.addEventListener('click', function () {
            const si   = parseInt(this.dataset.subjectIndex);
            const list = this.previousElementSibling; // .teacher-assignments-list
            const ti   = list.querySelectorAll('.teacher-row').length;
            list.insertAdjacentHTML('beforeend', buildTeacherRow(si, ti));

            // Sincronizar grupos para reflejar los ya tomados
            const subjectCard = this.closest('[data-subject-card]');
            syncGroupsInSubject(subjectCard);
        });
    });


    // ─── Eliminar fila de profesor ─────────────────────────────────────────

    document.addEventListener('click', function (e) {
        if (e.target.closest('.btn-remove-teacher')) {
            const row         = e.target.closest('.teacher-row');
            const list        = row.closest('.teacher-assignments-list');
            const subjectCard = row.closest('[data-subject-card]');

            if (list.querySelectorAll('.teacher-row').length > 1) {
                row.remove();
                reindexTeacherRows(list);
                syncGroupsInSubject(subjectCard); // liberar grupos de la fila eliminada
            } else {
                alert('Debe haber al menos una fila de profesor por materia.');
            }
        }
    });


    // ─── Re-indexar nombres al eliminar ────────────────────────────────────

    function reindexTeacherRows(list) {
        const si = list.dataset.subjectIndex;
        list.querySelectorAll('.teacher-row').forEach((row, t) => {
            row.querySelectorAll('[name]').forEach(el => {
                el.name = el.name.replace(/TeacherAssignments\[\d+\]/, `TeacherAssignments[${t}]`);
            });
            row.querySelectorAll('[id]').forEach(el => {
                el.id = el.id.replace(/g_\d+_\d+_/, `g_${si}_${t}_`);
            });
            row.querySelectorAll('[for]').forEach(el => {
                el.htmlFor = el.htmlFor.replace(/g_\d+_\d+_/, `g_${si}_${t}_`);
            });
        });
    }


    // ─── Validación al guardar ─────────────────────────────────────────────

    document.getElementById('btnFinalizar').addEventListener('click', function (e) {
        let errors = [];

        document.querySelectorAll('[data-subject-card]').forEach(card => {
            const subjectName = card.querySelector('.card-header h6').innerText.trim();
            card.querySelectorAll('.teacher-row').forEach(row => {
                const teacher = row.querySelector('.teacher-select').value;
                const groups  = row.querySelectorAll('.group-checkbox:checked').length;
                if (teacher && groups === 0)
                    errors.push(`• ${subjectName}: Profesor seleccionado sin grupos asignados.`);
                if (!teacher && groups > 0)
                    errors.push(`• ${subjectName}: Grupos seleccionados sin elegir profesor.`);
            });
        });

        if (errors.length) {
            e.preventDefault();
            alert('Corrige los siguientes errores:\n\n' + errors.join('\n'));
            return;
        }

        if (!confirm('¿Confirmas guardar la configuración del ciclo escolar?')) {
            e.preventDefault();
        }
    });
</script>
}
