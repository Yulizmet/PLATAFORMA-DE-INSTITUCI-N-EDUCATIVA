@* /Areas/Grades/Views/SchoolCycleWizard/Step1.cshtml *@
@model SchoolManager.Areas.Grades.ViewModels.Wizard.SchoolCycleWizardViewModel

@{
    ViewData["Title"] = "Paso 1: Configurar Nivel";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="sistema-card">
                <div class="progress mb-4" style="height: 10px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: 20%;" aria-valuenow="20" aria-valuemin="0" aria-valuemax="100"></div>
                </div>

                <h3 class="fw-bold mb-4">Paso 1/5: Crear Nivel Escolar</h3>

                <form asp-action="Step1" method="post">
                    <div class="mb-3">
                        <label asp-for="LevelName" class="form-label fw-semibold">Nombre de Nivel</label>
                        <input asp-for="LevelName" class="form-control" placeholder="Ej. 1er Semestre 2026" />
                        <span asp-validation-for="LevelName" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label fw-semibold">Fecha de Inicio</label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label fw-semibold">Fecha de fin</label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="MinPassingGrade" class="form-label fw-semibold">Calificación mínima requerida</label>
                        <input asp-for="MinPassingGrade" class="form-control" type="number" step="0.1" min="0" max="10" />
                        <span asp-validation-for="MinPassingGrade" class="text-danger"></span>
                        <small class="text-muted">Calificación mínima para aprobar (ej. 6.0)</small>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-calificaciones">
                            Continuar <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}