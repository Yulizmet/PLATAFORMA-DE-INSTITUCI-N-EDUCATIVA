@* /Areas/Grades/Views/SchoolCycleWizard/Step1.cshtml *@
@model SchoolManager.Areas.Grades.ViewModels.Wizard.SchoolCycleWizardViewModel

@{
    ViewData["Title"] = "Nuevo Ciclo Escolar";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7">

                <div class="sistema-card border-calificaciones">

                    <!-- Indicador de pasos -->
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">Paso 1 de 4</span>
                        <span class="text-muted small">Configuración del Nivel</span>
                    </div>
                    <div class="progress mb-4" style="height: 6px; border-radius: 4px;">
                        <div class="progress-bar" role="progressbar"
                             style="width: 25%; background-color: var(--rojo-principal);">
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="sistema-icon icon-calificaciones mb-0" style="flex-shrink:0;">
                            <i class="bi bi-layers"></i>
                        </div>
                        <div>
                            <h3 class="sistema-title mb-0" style="font-size: 1.5rem;">Crear Nivel Escolar</h3>
                            <p class="text-muted mb-0 small">Define el nombre, fechas y calificación mínima del ciclo</p>
                        </div>
                    </div>

                    <form asp-action="Step1" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="LevelName" class="form-label fw-semibold">Nombre del Nivel</label>
                            <input asp-for="LevelName" class="form-control"
                                   placeholder="Ej. 1er Semestre 2026" />
                            <span asp-validation-for="LevelName" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label fw-semibold">Fecha de Inicio</label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label fw-semibold">Fecha de Fin</label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                                <span asp-validation-for="EndDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="MinPassingGrade" class="form-label fw-semibold">Calificación Mínima para Aprobar</label>
                            <input asp-for="MinPassingGrade" class="form-control"
                                   type="number" step="0.1" min="0" max="10"
                                   placeholder="Ej. 6.0" />
                            <span asp-validation-for="MinPassingGrade" class="text-danger small"></span>
                            <div class="text-muted small mt-1">
                                <i class="bi bi-info-circle me-1"></i>Calificación mínima para aprobar una materia
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-2">
                            <a asp-area="MainScreen" asp-controller="MainScreen" asp-action="PanelAdministrativo"
                               class="btn btn-outline-secondary">
                                <i class="bi bi-x me-1"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-calificaciones">
                                Siguiente <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
