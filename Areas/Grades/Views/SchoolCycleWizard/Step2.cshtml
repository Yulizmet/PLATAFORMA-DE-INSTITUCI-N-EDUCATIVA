@* /Areas/Grades/Views/SchoolCycleWizard/Step2.cshtml *@
@model SchoolManager.Areas.Grades.ViewModels.Wizard.SchoolCycleWizardViewModel

@{
    ViewData["Title"] = "Nuevo Ciclo Escolar";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<section class="sistema-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-9">

                <div class="sistema-card border-calificaciones">

                    <!-- Indicador de pasos -->
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">Paso 2 de 4</span>
                        <span class="badge" style="background-color: var(--rojo-principal); font-size: 0.85rem;">
                            @Model.LevelName
                        </span>
                    </div>
                    <div class="progress mb-4" style="height: 6px; border-radius: 4px;">
                        <div class="progress-bar" role="progressbar"
                             style="width: 50%; background-color: var(--rojo-principal);">
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="sistema-icon icon-calificaciones mb-0" style="flex-shrink:0;">
                            <i class="bi bi-book"></i>
                        </div>
                        <div>
                            <h3 class="sistema-title mb-0" style="font-size: 1.5rem;">Crear Materias</h3>
                            <p class="text-muted mb-0 small">Agrega las materias del ciclo y configura sus unidades</p>
                        </div>
                    </div>

                    <!-- Un solo form que maneja tanto Regresar como Continuar -->
                    <form asp-action="Step2" method="post" id="subjectsForm">
                        @Html.AntiForgeryToken()

                        <!-- Datos del nivel ocultos -->
                        <input type="hidden" name="LevelName" value="@(Model.LevelName ?? "")" />
                        <input type="hidden" name="StartDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd") ?? "")" />
                        <input type="hidden" name="EndDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd") ?? "")" />
                        <input type="hidden" name="MinPassingGrade" value="@(Model.MinPassingGrade?.ToString() ?? "")" />

                        <!-- Lista de materias -->
                        <div id="subjectsContainer">
                            @for (int i = 0; i < Model.Subjects.Count; i++)
                            {
                                <div class="subject-item card mb-3 border-0 shadow-sm" data-index="@i">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div class="flex-grow-1 me-3">
                                                <input type="hidden" name="Subjects[@i].TempId" value="@Model.Subjects[i].TempId" />
                                                <input type="text" name="Subjects[@i].Name" value="@Model.Subjects[i].Name"
                                                       class="form-control subject-name"
                                                       placeholder="Nombre de la materia (ej. Matemáticas I)" required />
                                            </div>
                                            <div class="d-flex gap-2">
                                                <button type="button" class="btn btn-sm btn-outline-secondary toggle-units" data-index="@i">
                                                    <i class="bi @(Model.Subjects[i].ShowUnits ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                                    Unidades
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger remove-subject">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Panel de unidades -->
                                        <div class="units-panel @(Model.Subjects[i].ShowUnits ? "" : "d-none")" id="units-panel-@i">
                                            <div class="border-top pt-3">
                                                <div class="d-flex justify-content-between align-items-center mb-3">
                                                    <h6 class="fw-semibold mb-0 text-muted">Unidades</h6>
                                                    <button type="button" class="btn btn-sm btn-calificaciones add-unit" data-subject-index="@i">
                                                        <i class="bi bi-plus-circle me-1"></i>Agregar Unidad
                                                    </button>
                                                </div>
                                                <div class="units-container" id="units-container-@i">
                                                    @for (int j = 0; j < Model.Subjects[i].Units.Count; j++)
                                                    {
                                                        <div class="unit-item d-flex align-items-center mb-2">
                                                            <input type="hidden" name="Subjects[@i].Units[@j].Number" value="@Model.Subjects[i].Units[j].Number" />
                                                            <span class="badge me-2" style="background-color: var(--rojo-principal); width: 40px;">U@(Model.Subjects[i].Units[j].Number)</span>
                                                            <span class="me-3 text-muted small">Unidad @(Model.Subjects[i].Units[j].Number)</span>
                                                            <div class="form-check form-switch ms-auto">
                                                                <input type="checkbox" class="form-check-input"
                                                                       name="Subjects[@i].Units[@j].IsOpen" value="true"
                                                                       @(Model.Subjects[i].Units[j].IsOpen ? "checked" : "") />
                                                                <input type="hidden" name="Subjects[@i].Units[@j].IsOpen" value="false" />
                                                                <label class="form-check-label small">Abierta</label>
                                                            </div>
                                                            <button type="button" class="btn btn-sm btn-outline-danger ms-2 remove-unit">
                                                                <i class="bi bi-x"></i>
                                                            </button>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Botón agregar materia -->
                        <div class="text-center my-4">
                            <button type="button" id="addSubjectBtn"
                                    class="btn btn-outline-secondary">
                                <i class="bi bi-plus-circle me-2"></i>Agregar Materia
                            </button>
                        </div>

                        <!-- Navegación: Regresar usa formaction diferente -->
                        <div class="d-flex justify-content-between align-items-center pt-2 border-top mt-2">
                            <button type="submit" formaction="@Url.Action("Step2Back")"
                                    class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Regresar
                            </button>
                            <button type="submit" class="btn btn-calificaciones">
                                Siguiente <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

<!-- Template materia -->
<template id="subject-template">
    <div class="subject-item card mb-3 border-0 shadow-sm" data-index="__INDEX__">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="flex-grow-1 me-3">
                    <input type="hidden" name="Subjects[__INDEX__].TempId" value="__TEMPID__" />
                    <input type="text" name="Subjects[__INDEX__].Name"
                           class="form-control subject-name"
                           placeholder="Nombre de la materia (ej. Matemáticas I)" required />
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary toggle-units" data-index="__INDEX__">
                        <i class="bi bi-chevron-down"></i> Unidades
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-danger remove-subject">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
            <div class="units-panel d-none" id="units-panel-__INDEX__">
                <div class="border-top pt-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-semibold mb-0 text-muted">Unidades</h6>
                        <button type="button" class="btn btn-sm btn-calificaciones add-unit" data-subject-index="__INDEX__">
                            <i class="bi bi-plus-circle me-1"></i>Agregar Unidad
                        </button>
                    </div>
                    <div class="units-container" id="units-container-__INDEX__"></div>
                </div>
            </div>
        </div>
    </div>
</template>

<!-- Template unidad -->
<template id="unit-template">
    <div class="unit-item d-flex align-items-center mb-2">
        <input type="hidden" name="Subjects[__SUBJECTINDEX__].Units[__UNITINDEX__].Number" value="__UNITNUMBER__" />
        <span class="badge me-2" style="background-color: var(--rojo-principal); width: 40px;">U__UNITNUMBER__</span>
        <span class="me-3 text-muted small">Unidad __UNITNUMBER__</span>
        <div class="form-check form-switch ms-auto">
            <input type="checkbox" class="form-check-input"
                   name="Subjects[__SUBJECTINDEX__].Units[__UNITINDEX__].IsOpen" value="true" checked />
            <input type="hidden" name="Subjects[__SUBJECTINDEX__].Units[__UNITINDEX__].IsOpen" value="false" />
            <label class="form-check-label small">Abierta</label>
        </div>
        <button type="button" class="btn btn-sm btn-outline-danger ms-2 remove-unit">
            <i class="bi bi-x"></i>
        </button>
    </div>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let subjectCount = @(Model.Subjects?.Count ?? 0);

            // Toggle unidades
            document.addEventListener('click', function (e) {
                if (e.target.closest('.toggle-units')) {
                    const btn   = e.target.closest('.toggle-units');
                    const index = btn.dataset.index;
                    const panel = document.getElementById(`units-panel-${index}`);
                    const icon  = btn.querySelector('i');
                    panel.classList.toggle('d-none');
                    icon.classList.toggle('bi-chevron-down');
                    icon.classList.toggle('bi-chevron-up');
                }
            });

            // Agregar materia
            document.getElementById('addSubjectBtn').addEventListener('click', function () {
                const template = document.getElementById('subject-template');
                const newIndex = subjectCount++;
                const tempId   = -(newIndex + 100);
                let html = template.innerHTML
                    .replace(/__INDEX__/g, newIndex)
                    .replace(/__TEMPID__/g, tempId);
                const div = document.createElement('div');
                div.innerHTML = html;
                const node = div.firstElementChild;
                document.getElementById('subjectsContainer').appendChild(node);
                node.querySelector('.toggle-units').dataset.index     = newIndex;
                node.querySelector('.add-unit').dataset.subjectIndex  = newIndex;
            });

            // Eliminar materia
            document.addEventListener('click', function (e) {
                if (e.target.closest('.remove-subject')) {
                    const item = e.target.closest('.subject-item');
                    if (item && confirm('¿Eliminar esta materia?')) item.remove();
                }
            });

            // Agregar unidad
            document.addEventListener('click', function (e) {
                if (e.target.closest('.add-unit')) {
                    const btn            = e.target.closest('.add-unit');
                    const subjectIndex   = btn.dataset.subjectIndex;
                    const container      = document.getElementById(`units-container-${subjectIndex}`);
                    if (!container) return;
                    const unitIndex  = container.children.length;
                    const unitNumber = unitIndex + 1;
                    const template   = document.getElementById('unit-template');
                    let html = template.innerHTML
                        .replace(/__SUBJECTINDEX__/g, subjectIndex)
                        .replace(/__UNITINDEX__/g, unitIndex)
                        .replace(/__UNITNUMBER__/g, unitNumber);
                    const div  = document.createElement('div');
                    div.innerHTML = html;
                    container.appendChild(div.firstElementChild);
                }
            });

            // Eliminar unidad
            document.addEventListener('click', function (e) {
                if (e.target.closest('.remove-unit')) {
                    const unitItem  = e.target.closest('.unit-item');
                    const container = unitItem.closest('.units-container');
                    if (unitItem && confirm('¿Eliminar esta unidad?')) {
                        unitItem.remove();
                        // Renumerar
                        [...container.children].forEach((u, i) => {
                            const num = i + 1;
                            u.querySelector('.badge').textContent = 'U' + num;
                            u.querySelector('span.me-3').textContent = 'Unidad ' + num;
                            const hidNum = u.querySelector('input[type="hidden"][name$=".Number"]');
                            if (hidNum) { hidNum.name = hidNum.name.replace(/Units\[\d+\]\.Number/, `Units[${i}].Number`); hidNum.value = num; }
                            const chk = u.querySelector('input[type="checkbox"]');
                            if (chk) chk.name = chk.name.replace(/Units\[\d+\]\.IsOpen/, `Units[${i}].IsOpen`);
                            const hidChk = u.querySelector('input[type="hidden"][name$=".IsOpen"]');
                            if (hidChk) hidChk.name = hidChk.name.replace(/Units\[\d+\]\.IsOpen/, `Units[${i}].IsOpen`);
                        });
                    }
                }
            });
        });
    </script>
}
