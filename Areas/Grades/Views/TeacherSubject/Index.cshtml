@model IEnumerable<SchoolManager.Areas.Grades.ViewModels.TeacherSubject.TeacherSubjectViewModel>

@{
    ViewData["Title"] = "Asignación Profesor-Materia";
    var selectedTeacher = ViewBag.SelectedTeacher as int?;
    var selectedSubject = ViewBag.SelectedSubject as int?;
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="users-title">
            <i class="bi bi-person-workspace me-2"></i>Asignación Profesor-Materia
        </h1>
        <a asp-action="Create" class="btn btn-calificaciones">
            <i class="bi bi-plus-circle me-2"></i>Nueva Asignación
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="background-color: #d4edda; color: #155724; border-left: 5px solid #28a745;">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background-color: #f8d7da; color: #721c24; border-left: 5px solid #D42D2D;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtros -->
    <div class="card shadow-sm mb-4" style="border-radius: 20px; border: none;">
        <div class="card-body" style="padding: 30px;">
            <form method="get" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label fw-semibold" style="color: #1f2937;">Filtrar por Profesor</label>
                    <select name="teacherId" class="form-select" style="border-radius: 10px; border: 1px solid #e0e0e0;">
                        <option value="">Todos los profesores</option>
                        @foreach (var teacher in ViewBag.Teachers)
                        {
                            <option value="@teacher.UserId" selected="@(teacher.UserId == selectedTeacher)">
                                @teacher.FullName
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-semibold" style="color: #1f2937;">Filtrar por Materia</label>
                    <select name="subjectId" class="form-select" style="border-radius: 10px; border: 1px solid #e0e0e0;">
                        <option value="">Todas las materias</option>
                        @foreach (var subject in ViewBag.Subjects)
                        {
                            <option value="@subject.SubjectId" selected="@(subject.SubjectId == selectedSubject)">
                                @subject.Name
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn w-100" style="background-color: #8C1B1B; color: white; border-radius: 10px;">
                        <i class="bi bi-search me-2"></i>Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="bi bi-person-workspace" style="font-size: 4rem; color: #B1A596;"></i>
            </div>
            <h5 class="text-muted">No hay asignaciones de profesores</h5>
            <p class="text-muted mb-4">Comienza asignando materias a los profesores</p>
            <a asp-action="Create" class="btn btn-calificaciones">
                <i class="bi bi-plus-circle me-2"></i>Nueva Asignación
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="sistema-card border-calificaciones">
                        <div class="sistema-icon icon-calificaciones mb-4">
                            <i class="bi bi-person-badge"></i>
                        </div>

                        <div class="mb-3">
                            <h5 class="fw-bold mb-1" style="color: #1f2937;">@item.TeacherName</h5>
                            <p class="text-muted mb-0">
                                <i class="bi bi-book me-1"></i>@item.SubjectName
                            </p>
                            <small class="text-muted">
                                <i class="bi bi-layers me-1"></i>@item.GradeLevelName
                            </small>
                        </div>

                        <div class="mb-4">
                            <span class="badge" style="background-color: #B1A596; color: white; padding: 8px 15px; border-radius: 20px;">
                                <i class="bi bi-people me-1"></i>@item.GroupsCount grupos
                            </span>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="AssignGroups" asp-route-id="@item.TeacherSubjectId"
                               class="btn btn-sm" style="background-color: #28a745; color: white; border-radius: 10px; padding: 8px 15px;"
                               title="Asignar grupos">
                                <i class="bi bi-people"></i>
                            </a>
                            <button type="button" class="btn btn-sm"
                                    style="background-color: #D42D2D; color: white; border-radius: 10px; padding: 8px 15px;"
                                    data-bs-toggle="modal" data-bs-target="#deleteModal-@item.TeacherSubjectId"
                                    title="Eliminar asignación">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Modal de eliminación -->
                    <div class="modal fade" id="deleteModal-@item.TeacherSubjectId" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content" style="border-radius: 20px; border: none;">
                                <div class="modal-header" style="background-color: #8C1B1B; color: white; border-radius: 20px 20px 0 0;">
                                    <h5 class="modal-title">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        Confirmar Eliminación
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body p-4">
                                    <p>¿Estás seguro de eliminar esta asignación?</p>
                                    <p class="fw-semibold" style="color: #8C1B1B;">@item.TeacherName</p>
                                    <p>@item.SubjectName - @item.GradeLevelName</p>
                                    @if (item.GroupsCount > 0)
                                    {
                                        <p class="mt-3 p-3" style="background-color: #fff3cd; color: #856404; border-radius: 10px;">
                                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                            Esta asignación tiene @item.GroupsCount grupo(s) asignado(s).
                                        </p>
                                    }
                                    <p class="text-danger mb-0">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        Esta acción no se puede deshacer.
                                    </p>
                                </div>
                                <div class="modal-footer border-0">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius: 10px; background-color: #6c757d;">
                                        <i class="bi bi-x-circle me-2"></i>Cancelar
                                    </button>
                                    <form asp-action="Delete" asp-route-id="@item.TeacherSubjectId" method="post">
                                        <button type="submit" class="btn" style="background-color: #D42D2D; color: white; border-radius: 10px;">
                                            <i class="bi bi-trash me-2"></i>Eliminar
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>