@model SchoolManager.Areas.Grades.ViewModels.TeacherSubject.TeacherSubjectViewModel

@{
    ViewData["Title"] = "Nueva Asignación";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="sistema-card">
                <div class="sistema-icon icon-calificaciones mb-4">
                    <i class="bi bi-plus-circle"></i>
                </div>

                <h2 class="users-title mb-4">Nueva Asignación</h2>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="border-left: 5px solid #D42D2D;"></div>

                    <div class="mb-4">
                        <label asp-for="TeacherId" class="form-label fw-semibold" style="color: #1f2937;">Profesor</label>
                        <select asp-for="TeacherId" class="form-select"
                                asp-items="@(new SelectList(ViewBag.Teachers, "UserId", "FullName"))"
                                style="border-radius: 10px; border: 1px solid #e0e0e0; padding: 12px;">
                            <option value="">-- Selecciona un profesor --</option>
                        </select>
                        <span asp-validation-for="TeacherId" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="SubjectId" class="form-label fw-semibold" style="color: #1f2937;">Materia</label>
                        <select asp-for="SubjectId" class="form-select"
                                asp-items="@(new SelectList(ViewBag.Subjects, "SubjectId", "DisplayName"))"
                                style="border-radius: 10px; border: 1px solid #e0e0e0; padding: 12px;">
                            <option value="">-- Selecciona una materia --</option>
                        </select>
                        <span asp-validation-for="SubjectId" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-secondary"
                           style="border-radius: 10px; background-color: #6c757d; color: white; padding: 10px 25px;">
                            <i class="bi bi-x-circle me-2"></i>Cancelar
                        </a>
                        <button type="submit" class="btn btn-calificaciones" style="padding: 10px 25px;">
                            <i class="bi bi-save me-2"></i>Guardar Asignación
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}