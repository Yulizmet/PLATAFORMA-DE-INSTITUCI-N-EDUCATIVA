@model SchoolManager.Areas.Grades.ViewModels.Groups.GroupViewModel

@{
    ViewData["Title"] = "Nuevo Grupo";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="sistema-card">
                <div class="sistema-icon icon-calificaciones mb-4">
                    <i class="bi bi-plus-circle"></i>
                </div>

                <h2 class="users-title mb-4">Nuevo Grupo</h2>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="border-left: 5px solid #D42D2D;"></div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-semibold" style="color: #1f2937;">Nombre del Grupo</label>
                        <input asp-for="Name" class="form-control" placeholder="Ej: 101, 102, A, B, etc."
                               style="border-radius: 10px; border: 1px solid #e0e0e0; padding: 12px;" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                        <small class="form-text text-muted">Ejemplo: "101", "A", "B", "Único"</small>
                    </div>

                    <div class="mb-4">
                        <label asp-for="GradeLevelId" class="form-label fw-semibold" style="color: #1f2937;">Nivel Escolar</label>
                        <select asp-for="GradeLevelId" class="form-select"
                                asp-items="@(new SelectList(ViewBag.GradeLevels, "GradeLevelId", "Name", Model.GradeLevelId))"
                                style="border-radius: 10px; border: 1px solid #e0e0e0; padding: 12px;">
                            <option value="">-- Selecciona un nivel --</option>
                        </select>
                        <span asp-validation-for="GradeLevelId" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" asp-route-gradeLevelId="@Model.GradeLevelId" class="btn btn-secondary"
                           style="border-radius: 10px; background-color: #6c757d; color: white; padding: 10px 25px;">
                            <i class="bi bi-x-circle me-2"></i>Cancelar
                        </a>
                        <button type="submit" class="btn btn-calificaciones" style="padding: 10px 25px;">
                            <i class="bi bi-save me-2"></i>Guardar Grupo
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}