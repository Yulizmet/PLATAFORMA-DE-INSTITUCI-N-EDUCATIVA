@model SchoolManager.Models.grades_subjects

@{
    ViewData["Title"] = "Nueva Materia";
    Layout = "~/Pages/Shared/_Layout.cshtml";

}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="fas fa-plus-circle me-2 text-primary"></i>
                        Nueva Materia
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Nombre de la Materia</label>
                            <input asp-for="Name" class="form-control" placeholder="Ej: Matemáticas I, Física, etc." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="GradeLevelId" class="form-label fw-semibold">Nivel Escolar</label>
                            <select asp-for="GradeLevelId" class="form-select" asp-items="@(new SelectList(ViewBag.GradeLevels, "GradeLevelId", "Name", ViewBag.SelectedGradeLevel))">
                                <option value="">-- Selecciona un nivel --</option>
                            </select>
                            <span asp-validation-for="GradeLevelId" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" asp-route-gradeLevelId="@ViewBag.SelectedGradeLevel" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Guardar Materia
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}