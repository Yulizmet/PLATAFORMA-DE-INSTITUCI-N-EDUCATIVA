@model SchoolManager.Models.grades_subjects

@{
    ViewData["Title"] = $"Unidades - {Model.Name}";
    Layout = "~/Pages/Shared/_Layout.cshtml";

}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Materias</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="fas fa-plus-circle me-2 text-success"></i>
                        Agregar Unidad
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="AddUnit" method="post">
                        <input type="hidden" name="subjectId" value="@Model.SubjectId" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Número de Unidad</label>
                            <input type="number" name="unitNumber" class="form-control"
                                   min="1" max="20" required
                                   placeholder="Ej: 1, 2, 3..." />
                            <small class="form-text text-muted">
                                Las unidades se ordenarán automáticamente
                            </small>
                        </div>
                        <button type="submit" class="btn btn-success w-100">
                            <i class="fas fa-plus me-2"></i>Agregar Unidad
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="fas fa-list me-2 text-primary"></i>
                        Unidades de @Model.Name
                    </h5>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (Model.Units != null && Model.Units.Any())
                    {
                        <div class="list-group">
                            @foreach (var unit in Model.Units.OrderBy(u => u.UnitNumber))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-primary me-3" style="width: 40px;">
                                            U@(unit.UnitNumber)
                                        </span>
                                        <span class="@(unit.IsOpen ? "text-success" : "text-secondary")">
                                            <i class="fas @(unit.IsOpen ? "fa-lock-open" : "fa-lock") me-2"></i>
                                            @(unit.IsOpen ? "Abierta" : "Cerrada")
                                        </span>
                                    </div>
                                    <div class="btn-group" role="group">
                                        <form asp-action="ToggleUnit" method="post" class="d-inline">
                                            <input type="hidden" name="unitId" value="@unit.UnitId" />
                                            <button type="submit"
                                                    class="btn btn-sm @(unit.IsOpen ? "btn-warning" : "btn-success")"
                                                    title="@(unit.IsOpen ? "Cerrar unidad" : "Abrir unidad")">
                                                <i class="fas @(unit.IsOpen ? "fa-lock" : "fa-lock-open")"></i>
                                            </button>
                                        </form>
                                        <form asp-action="DeleteUnit" method="post" class="d-inline"
                                              onsubmit="return confirm('¿Estás seguro de eliminar la unidad @(unit.UnitNumber)?')">
                                            <input type="hidden" name="unitId" value="@unit.UnitId" />
                                            <button type="submit" class="btn btn-sm btn-danger"
                                                    title="Eliminar unidad">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-puzzle-piece fa-3x text-muted mb-3"></i>
                            <p class="text-muted mb-0">No hay unidades registradas</p>
                            <p class="text-muted">Agrega la primera unidad usando el formulario</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>