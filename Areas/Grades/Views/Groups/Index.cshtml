@using SchoolManager.Areas.Grades.ViewModels.Breadcrumbs
@model IEnumerable<SchoolManager.Areas.Grades.ViewModels.Groups.GroupViewModel>

@{
    ViewData["Title"] = "Grupos";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    var selectedGradeLevel = ViewBag.SelectedGradeLevel as int?;
    var breadcrumbs = new BreadcrumbViewModel();
    breadcrumbs.AddItem("Panel Administrativo", "/PanelAdministrativo");
    breadcrumbs.AddItem("Grupos");
}
<partial name="_Breadcrumb" model="breadcrumbs" />

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="users-title">
            <i class="bi bi-people me-2"></i>Grupos
        </h1>
        <a asp-action="Create" asp-route-gradeLevelId="@selectedGradeLevel" class="btn btn-calificaciones">
            <i class="bi bi-plus-circle me-2"></i>Nuevo Grupo
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="background-color: #d4edda; color: #155724; border-left: 5px solid #28a745;">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background-color: #f8d7da; color: #721c24; border-left: 5px solid #D42D2D;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtro por Nivel -->
    <div class="card shadow-sm mb-4" style="border-radius: 20px; border: none;">
        <div class="card-body" style="padding: 30px;">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold" style="color: #1f2937;">Filtrar por Nivel</label>
                    <select name="gradeLevelId" class="form-select" onchange="this.form.submit()" style="border-radius: 10px; border: 1px solid #e0e0e0;">
                        <option value="">Todos los niveles</option>
                        @foreach (var level in ViewBag.GradeLevels)
                        {
                            <option value="@level.GradeLevelId" selected="@(level.GradeLevelId == selectedGradeLevel)">
                                @level.Name
                            </option>
                        }
                    </select>
                </div>
                @if (selectedGradeLevel.HasValue)
                {
                    <div class="col-md-2">
                        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 10px;">
                            <i class="bi bi-x-circle me-2"></i>Limpiar
                        </a>
                    </div>
                }
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="bi bi-people" style="font-size: 4rem; color: #B1A596;"></i>
            </div>
            <h5 class="text-muted">No hay grupos registrados</h5>
            <p class="text-muted mb-4">Comienza creando el primer grupo</p>
            <a asp-action="Create" class="btn btn-calificaciones">
                <i class="bi bi-plus-circle me-2"></i>Crear Grupo
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="sistema-card border-calificaciones">
                        <div class="sistema-icon icon-calificaciones mb-4">
                            <i class="bi bi-people"></i>
                        </div>

                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h4 class="fw-bold" style="color: #1f2937;">@item.Name</h4>
                        </div>

                        <p class="text-muted mb-3">
                            <i class="bi bi-layers me-1"></i>@item.GradeLevelName
                        </p>

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <div class="p-2 text-center" style="background-color: #f8f9fa; border-radius: 10px;">
                                    <span class="h5 mb-0 fw-bold" style="color: #D42D2D;">@item.SubjectsCount</span>
                                    <small class="text-muted d-block">Materias</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-2 text-center" style="background-color: #f8f9fa; border-radius: 10px;">
                                    <span class="h5 mb-0 fw-bold" style="color: #8C1B1B;">@item.StudentsCount</span>
                                    <small class="text-muted d-block">Estudiantes</small>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Details" asp-route-id="@item.GroupId"
                               class="btn btn-sm" style="background-color: #f0f0f0; color: #4a5568; border-radius: 10px; padding: 8px 12px;"
                               title="Ver detalles">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.GroupId"
                               class="btn btn-sm" style="background-color: #8C1B1B; color: white; border-radius: 10px; padding: 8px 12px;"
                               title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button" class="btn btn-sm"
                                    style="background-color: #620900; color: white; border-radius: 10px; padding: 8px 12px;"
                                    data-bs-toggle="modal" data-bs-target="#deleteModal-@item.GroupId"
                                    title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Modal de eliminación -->
                    <div class="modal fade" id="deleteModal-@item.GroupId" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content" style="border-radius: 20px; border: none;">
                                <div class="modal-header" style="background-color: #8C1B1B; color: white; border-radius: 20px 20px 0 0;">
                                    <h5 class="modal-title">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        Confirmar Eliminación
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body p-4">
                                    <p>¿Estás seguro de eliminar el grupo <strong style="color: #8C1B1B;">@item.Name</strong>?</p>
                                    @if (item.SubjectsCount > 0)
                                    {
                                        <p class="mt-3 p-3" style="background-color: #fff3cd; color: #856404; border-radius: 10px;">
                                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                            Este grupo tiene @item.SubjectsCount materias asignadas.
                                        </p>
                                    }
                                    <p class="text-danger mb-0">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        Esta acción no se puede deshacer.
                                    </p>
                                </div>
                                <div class="modal-footer border-0">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius: 10px; background-color: #6c757d;">
                                        <i class="bi bi-x-circle me-2"></i>Cancelar
                                    </button>
                                    <form asp-action="Delete" asp-route-id="@item.GroupId" method="post">
                                        <button type="submit" class="btn" style="background-color: #D42D2D; color: white; border-radius: 10px;">
                                            <i class="bi bi-trash me-2"></i>Eliminar
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>