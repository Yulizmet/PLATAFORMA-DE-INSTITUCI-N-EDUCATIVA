@using SchoolManager.Areas.Grades.ViewModels.Breadcrumbs
@using SchoolManager.Areas.Grades.ViewModels.Groups
@model List<GroupViewModel>

@{
    ViewData["Title"] = "Grupos";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";

    var gradeLevels = ViewBag.GradeLevels as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();

    var breadcrumbs = new BreadcrumbViewModel();
    breadcrumbs.AddItem("Panel Administrativo", "/PanelAdministrativo");
    breadcrumbs.AddItem("Grupos");
}
<partial name="_Breadcrumb" model="breadcrumbs" />

<!-- DataTables CSS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="users-title mb-1">
                <i class="bi bi-people me-2"></i>Grupos
            </h1>
            <p class="text-muted mb-0">Administración de grupos por nivel escolar</p>
        </div>
        <a asp-action="Create" class="btn btn-calificaciones" style="padding: 10px 25px;">
            <i class="bi bi-plus-circle me-2"></i>Nuevo Grupo
        </a>
    </div>

    @if (Model.Any())
    {
        <!-- Filtro por nivel (se integra con DataTables) -->
        <div class="d-flex flex-wrap gap-3 mb-3 align-items-center">
            <div style="min-width: 200px;">
                <select id="filterGradeLevel" class="form-select">
                    <option value="">Todos los niveles</option>
                    @foreach (var gl in gradeLevels)
                    {
                        <option value="@gl.Name">@gl.Name</option>
                    }
                </select>
            </div>
        </div>

        <div class="sistema-card">
            <div class="table-responsive">
                <table id="groupsTable" class="table table-hover align-middle mb-0" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th>Grupo</th>
                            <th>Nivel Escolar</th>
                            <th class="text-center">Materias</th>
                            <th class="text-center">Estudiantes</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in Model)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    <i class="bi bi-people me-1" style="color: #8C1B1B;"></i>
                                    @group.Name
                                </td>
                                <td>
                                    <span class="badge" style="background-color: #B1A596; color: white; padding: 6px 12px; border-radius: 20px;">
                                        <i class="bi bi-layers me-1"></i>@group.GradeLevelName
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge" style="background-color: #8C1B1B; padding: 6px 12px; border-radius: 20px;">
                                        @group.SubjectsCount
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge" style="background-color: #D42D2D; padding: 6px 12px; border-radius: 20px;">
                                        @group.StudentsCount
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@group.GroupId"
                                       class="btn btn-sm btn-outline-secondary" title="Ver detalles"
                                       style="border-radius: 8px;">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@group.GroupId"
                                       class="btn btn-sm btn-outline-secondary" title="Editar"
                                       style="border-radius: 8px;">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@group.GroupId" method="post"
                                          style="display: inline;"
                                          onsubmit="return confirm('¿Estás seguro de eliminar este grupo?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                title="Eliminar" style="border-radius: 8px;">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="sistema-card text-center py-5">
            <i class="bi bi-people" style="font-size: 3rem; color: #B1A596;"></i>
            <p class="text-muted mt-3">No hay grupos registrados en niveles abiertos</p>
            <a asp-action="Create" class="btn btn-calificaciones mt-2" style="padding: 10px 25px;">
                <i class="bi bi-plus-circle me-2"></i>Crear Primer Grupo
            </a>
        </div>
    }
</div>

@if (Model.Any())
{
    @section Scripts {
        <!-- DataTables JS -->
        <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

        <script>
            $(document).ready(function () {
                var table = $('#groupsTable').DataTable({
                    language: {
                        search: "",
                        searchPlaceholder: "Buscar grupo...",
                        lengthMenu: "Mostrar _MENU_ grupos",
                        info: "Mostrando _START_ a _END_ de _TOTAL_ grupos",
                        infoEmpty: "Sin grupos",
                        infoFiltered: "(filtrado de _MAX_ totales)",
                        zeroRecords: "No se encontraron grupos",
                        paginate: {
                            first: "Primero",
                            last: "Último",
                            next: "<i class='bi bi-chevron-right'></i>",
                            previous: "<i class='bi bi-chevron-left'></i>"
                        }
                    },
                    pageLength: 10,
                    lengthMenu: [5, 10, 25, 50],
                    order: [[1, 'asc'], [0, 'asc']],  // Ordenar por nivel, luego nombre
                    columnDefs: [
                        { orderable: false, targets: 4 }  // Columna acciones sin ordenar
                    ],
                    dom: '<"d-flex justify-content-between align-items-center mb-3"lf>t<"d-flex justify-content-between align-items-center mt-3"ip>'
                });

                // Filtro por nivel escolar
                $('#filterGradeLevel').on('change', function () {
                    var val = $(this).val();
                    table.column(1).search(val).draw();
                });
            });
        </script>

        <style>
            /* Select "Mostrar X" más ancho */
            .dataTables_length select {
                border-radius: 10px !important;
                border: 1px solid #dee2e6 !important;
                padding: 4px 30px 4px 10px !important; /* ✅ Más espacio a la derecha */
                min-width: 70px !important; /* ✅ Ancho mínimo */
            }

            /* Search input */
            .dataTables_filter input {
                border-radius: 10px !important;
                border: 1px solid #dee2e6 !important;
                padding: 6px 12px !important;
                margin-left: 8px !important;
            }

                .dataTables_filter input:focus {
                    border-color: #8C1B1B !important;
                    box-shadow: 0 0 0 0.2rem rgba(140, 27, 27, 0.15) !important;
                }

            /* Paginación - página activa */
            .page-item.active .page-link {
                background-color: #8C1B1B !important;
                border-color: #8C1B1B !important;
                color: white !important; /* ✅ Texto blanco */
                border-radius: 8px !important; /* ✅ Bordes redondeados */
            }

            /* Paginación - botones normales */
            .page-link {
                color: #8C1B1B !important;
                border-radius: 8px !important;
                margin: 0 2px;
                border: 1px solid #dee2e6 !important; /* ✅ Borde visible */
            }

                .page-link:hover {
                    background-color: rgba(140, 27, 27, 0.1) !important;
                }

            /* Paginación - botones deshabilitados (< >) */
            .page-item.disabled .page-link {
                color: #adb5bd !important;
                background-color: #f8f9fa !important;
                border-color: #dee2e6 !important;
            }

            /* Info text */
            .dataTables_info {
                color: #6c757d !important;
                font-size: 0.875rem;
            }
        </style>
    }
}