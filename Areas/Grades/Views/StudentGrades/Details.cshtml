@model SchoolManager.Areas.Grades.ViewModels.StudentGrades.StudentDashboardViewModel

@{
    ViewData["Title"] = "Mis Calificaciones";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <!-- Header con información del estudiante -->
    <div class="sistema-card mb-4">
        <div class="row">
            <div class="col-md-8">
                <h1 class="users-title mb-3">
                    <i class="bi bi-person-video3 me-2" style="color: #8C1B1B;"></i>
                    @Model.StudentName
                </h1>
                <p class="text-muted mb-1">
                    <i class="bi bi-qr-code me-2"></i>Matrícula: @Model.Matricula
                </p>
                <p class="text-muted mb-1">
                    <i class="bi bi-layers me-2"></i>@Model.GradeLevel
                </p>
                <p class="text-muted">
                    <i class="bi bi-people me-2"></i>Grupo: @Model.GroupName
                </p>
            </div>
            <div class="col-md-4">
                <div class="card h-100" style="background-color: #f8f9fa; border: none; border-radius: 15px;">
                    <div class="card-body text-center">
                        <h5 class="card-title">Promedio General</h5>
                        <h2 style="color: #8C1B1B; font-size: 3rem;">@Model.Resumen.PromedioGeneral?.ToString("F2")</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tarjetas de resumen -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center h-100" style="border: none; border-radius: 15px; background-color: #e3f2fd;">
                <div class="card-body">
                    <h3>@Model.Resumen.TotalMaterias</h3>
                    <p class="mb-0">Materias</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center h-100" style="border: none; border-radius: 15px; background-color: #e8f5e8;">
                <div class="card-body">
                    <h3 style="color: #28a745;">@Model.Resumen.Aprobadas</h3>
                    <p class="mb-0">Aprobadas</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center h-100" style="border: none; border-radius: 15px; background-color: #ffebee;">
                <div class="card-body">
                    <h3 style="color: #D42D2D;">@Model.Resumen.Reprobadas</h3>
                    <p class="mb-0">Reprobadas</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center h-100" style="border: none; border-radius: 15px; background-color: #fff3e0;">
                <div class="card-body">
                    <h3 style="color: #ff9800;">@Model.Resumen.Extraordinarios</h3>
                    <p class="mb-0">Extraordinarios</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Detalle por materia -->
    @foreach (var subject in Model.Subjects)
    {
        <div class="sistema-card mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold" style="color: #1f2937;">@subject.SubjectName</h4>
                <div>
                    @if (subject.HasExtraordinary)
                    {
                        <span class="badge bg-warning text-dark me-2">Extra: @subject.ExtraordinaryGrade?.ToString("F2")</span>
                    }
                    <span class="badge @(subject.Passed ? "bg-success" : "bg-danger")" style="font-size: 1rem;">
                        @subject.Status - @subject.FinalGrade?.ToString("F2")
                    </span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 100px;">Unidad</th>
                            <th>Calificación</th>
                            <th>Recuperación</th>
                            <th>Nota Final</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unit in subject.Units)
                        {
                            <tr>
                                <td class="fw-semibold">Unidad @unit.UnitNumber</td>
                                <td>@unit.Grade?.ToString("F2")</td>
                                <td>@unit.Recovery?.ToString("F2")</td>
                                <td class="fw-bold @(unit.FinalGrade >= 6 ? "text-success" : "text-danger")">
                                    @unit.DisplayGrade
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>