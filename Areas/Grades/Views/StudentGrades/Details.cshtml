@model SchoolManager.Areas.Grades.ViewModels.StudentGrades.StudentDashboardViewModel

@{
    ViewData["Title"] = "Mis Calificaciones";
    Layout = "~/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-3">
    <!-- Header compacto: info + stats en una sola fila -->
    <div class="sistema-card mb-3">
        <div class="row align-items-center">
            <!-- Info del estudiante -->
            <div class="col-lg-4 col-md-6 mb-2 mb-lg-0">
                <h5 class="fw-bold mb-1" style="color: #1f2937;">
                    <i class="bi bi-person-video3 me-2" style="color: #8C1B1B;"></i>
                    @Model.StudentName
                </h5>
                <div class="d-flex flex-wrap gap-3 text-muted" style="font-size: 0.85rem;">
                    <span><i class="bi bi-qr-code me-1"></i>@Model.Matricula</span>
                    <span><i class="bi bi-layers me-1"></i>@Model.GradeLevel</span>
                    <span><i class="bi bi-people me-1"></i>@Model.GroupName</span>
                </div>
            </div>

            <!-- Stats en línea -->
            <div class="col-lg-8 col-md-6">
                <div class="row g-2 text-center">
                    <div class="col">
                        <div class="rounded-3 py-2" style="background-color: #f8f9fa;">
                            <div class="fw-bold fs-4" style="color: #8C1B1B;">
                                @(Model.Resumen.PromedioGeneral?.ToString("F2") ?? "—")
                            </div>
                            <small class="text-muted">Promedio</small>
                        </div>
                    </div>
                    <div class="col">
                        <div class="rounded-3 py-2" style="background-color: #e3f2fd;">
                            <div class="fw-bold fs-4">@Model.Resumen.TotalMaterias</div>
                            <small class="text-muted">Materias</small>
                        </div>
                    </div>
                    <div class="col">
                        <div class="rounded-3 py-2" style="background-color: #e8f5e8;">
                            <div class="fw-bold fs-4" style="color: #28a745;">@Model.Resumen.Aprobadas</div>
                            <small class="text-muted">Aprobadas</small>
                        </div>
                    </div>
                    <div class="col">
                        <div class="rounded-3 py-2" style="background-color: #ffebee;">
                            <div class="fw-bold fs-4" style="color: #D42D2D;">@Model.Resumen.Reprobadas</div>
                            <small class="text-muted">Reprobadas</small>
                        </div>
                    </div>
                    <div class="col">
                        <div class="rounded-3 py-2" style="background-color: #fff3e0;">
                            <div class="fw-bold fs-4" style="color: #ff9800;">@Model.Resumen.Extraordinarios</div>
                            <small class="text-muted">Extra</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Detalle por materia -->
    @foreach (var subject in Model.Subjects)
    {
        <div class="sistema-card mb-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="fw-bold mb-0" style="color: #1f2937;">@subject.SubjectName</h6>
                <div>
                    @if (subject.HasExtraordinary)
                    {
                        <span class="badge bg-warning text-dark me-1" style="font-size: 0.75rem;">
                            Extra: @subject.ExtraordinaryGrade?.ToString("F2")
                        </span>
                    }
                    <span class="badge @(subject.Passed ? "bg-success" : "bg-danger")">
                        @subject.Status — @(subject.FinalGrade?.ToString("F2") ?? "Sin final")
                    </span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 90px;">Unidad</th>
                            <th>Calificación</th>
                            <th>Recuperación</th>
                            <th>Nota Final</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unit in subject.Units)
                        {
                            <tr>
                                <td class="fw-semibold">U@(unit.UnitNumber)</td>
                                <td>@(unit.Grade?.ToString("F2") ?? "—")</td>
                                <td>@(unit.Recovery?.ToString("F2") ?? "—")</td>
                                <td class="fw-bold @(unit.FinalGrade >= 6 ? "text-success" : "text-danger")">
                                    @unit.DisplayGrade
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>