@model IEnumerable<SchoolManager.Models.procedure_areas>

@{
    ViewData["Title"] = "Gestión de Áreas";
    ViewBag.EntityName = "areas";
}

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <partial name="_DataTableConfig" />

    <script>
        window.loadModal = async function(url) {
            try {
                const response = await fetch(url);
                if (!response.ok) throw new Error(`Error: ${response.status}`);
                const html = await response.text();
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;

                const modalElement = container.querySelector('.modal');
                if (modalElement) {
                    const myModal = new bootstrap.Modal(modalElement);
                    myModal.show();
                }
            } catch (error) {
                Swal.fire('Error', 'No se pudo cargar la ventana: ' + error.message, 'error');
            }
        };

        $(document).off("submit", ".modal form").on("submit", ".modal form", async function (e) {
            e.preventDefault();
            const form = e.target;

            try {
                const response = await fetch(form.action, {
                    method: form.method,
                    body: new FormData(form)
                });

                const result = await response.json();

                if (result.success) {
                    location.reload(); // Recarga tras éxito para ver cambios
                } else {
                    Swal.fire('Atención', result.errors ? result.errors.join("\n") : "Error al procesar", 'warning');
                }
            } catch (error) {
                Swal.fire('Error', 'Error al procesar la solicitud', 'error');
            }
        });
    </script>
}

<div id="modalContainer"></div>

<div class="container-fluid px-4 pt-5">

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-diagram-3"></i> Áreas
            </h2>
            <p class="text-muted small mb-0">Configura las áreas o departamentos responsables de los trámites.</p>
        </div>

        <button class="btn btn-burgundy shadow-sm" onclick="loadModal('/Procedures/ProcedureAreas/Create')">
            <i class="bi bi-plus-circle me-2"></i> Agregar área
        </button>
    </div>

    <partial name="_TableTools" />

    <div class="card border-0 overflow-hidden">
        <div class="card-body p-0">
            <table id="mainTable" class="table table-hover align-middle mb-0">
                <thead class="burgundy-header text-white">
                    <tr>
                        <th class="no-sort text-center" style="width: 5%;">
                            <input type="checkbox" id="checkAll" class="form-check-input">
                        </th>
                        <th class="ps-4" style="width: 25%;">Nombre</th>
                        <th style="width: 40%;">Descripción</th>
                        <th style="width: 20%;">Última modificación</th>
                        <th class="no-sort text-center pe-4" style="width: 10%;">Acciones</th>
                    </tr>
                </thead>
                <tbody class="table-white">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">
                                <input type="checkbox" class="form-check-input row-checkbox" value="@item.Id" />
                            </td>
                            <td class="ps-4 fw-bold text-dark">@item.Name</td>
                            <td class="text-muted">@(string.IsNullOrEmpty(item.Description) ? "Sin descripción" : item.Description)</td>
                            <td class="text-muted small">
                                <i class="bi bi-clock-history me-1"></i> @item.DateUpdated.ToString("dd/MM/yyyy hh:mm tt")
                            </td>
                            <td class="actions text-center pe-4">
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-light border shadow-sm me-2"
                                            style="width:32px; height:32px; padding:0;"
                                            onclick="loadModal('/Procedures/ProcedureAreas/Edit/@item.Id')"
                                            title="Editar">
                                        <i class="bi bi-pencil-square text-warning"></i>
                                    </button>
                                    <button class="btn btn-sm btn-light border shadow-sm"
                                            style="width:32px; height:32px; padding:0;"
                                            onclick="loadModal('/Procedures/ProcedureAreas/Delete/@item.Id')"
                                            title="Eliminar">
                                        <i class="bi bi-trash-fill text-danger"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>