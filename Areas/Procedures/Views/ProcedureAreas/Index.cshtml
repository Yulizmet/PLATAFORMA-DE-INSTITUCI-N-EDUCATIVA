@model IEnumerable<SchoolManager.Models.procedure_areas>

@{
    ViewData["Title"] = "Gestión de Áreas";
    ViewBag.EntityName = "areas";

    bool HasPermission(string buttonName) =>
        ViewBag.UserPermissions != null && ((List<string>)ViewBag.UserPermissions).Contains(buttonName);
}

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <partial name="_DataTableConfig" />

    <script>
        window.loadModal = async function(url) {
            try {
                const response = await fetch(url);
                if (!response.ok) throw new Error(`Error: ${response.status}`);
                const html = await response.text();
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;

                const modalElement = container.querySelector('.modal');
                if (modalElement) {
                    const myModal = new bootstrap.Modal(modalElement);
                    myModal.show();
                }
            } catch (error) {
                showToast('error', 'No se pudo cargar la ventana');
            }
        };

        $(document).off("submit", ".modal form").on("submit", ".modal form", async function (e) {
            e.preventDefault();
            const form = e.target;

            try {
                const response = await fetch(form.action, {
                    method: form.method,
                    body: new FormData(form)
                });

                const result = await response.json();

                if (result.success) {
                    const modalInstance = bootstrap.Modal.getInstance(form.closest('.modal'));
                    if(modalInstance) modalInstance.hide();

                    showToast('success', result.message || '¡Cambios guardados!');

                    setTimeout(() => { location.reload(); }, 1500);
                } else {
                    showToast('warning', 'No se puede eliminar porque está en uso.');
                }
            } catch (error) {
                Swal.fire('Error', r.message, 'error');
            }
        });

        $(document).ready(function () {
            $(document).on('change', '#checkAll', function () {
                const isChecked = $(this).is(':checked');
                $('.row-checkbox').prop('checked', isChecked);
                $('.row-checkbox').closest('tr').toggleClass('table-active', isChecked);
                updateBulkBar();
            });

            $(document).on('change', '.row-checkbox', function () {
                const total = $('.row-checkbox').length;
                const selected = $('.row-checkbox:checked').length;
                $('#checkAll').prop('checked', total === selected);
                $(this).closest('tr').toggleClass('table-active', $(this).is(':checked'));
                updateBulkBar();
            });
        });

        function updateBulkBar() {
            const count = $('.row-checkbox:checked').length;
            const bar = $('#bulkActionsBar');

            if (count > 0) {
                const text = count === 1 ? '1 seleccionado' : count + ' seleccionados';
                $('#selectedCount').text(text);
                bar.removeClass('d-none').fadeIn('fast');
            } else {
                bar.fadeOut('fast', function() {
                    $(this).addClass('d-none');
                });
                $('#checkAll').prop('checked', false);
            }
        }

        function deselectAll() {
            $('.row-checkbox, #checkAll').prop('checked', false).closest('tr').removeClass('table-active');
            updateBulkBar();
        }

        function bulkDelete() {
            const selectedIds = $('.row-checkbox:checked').map(function() {
                return parseInt($(this).val());
            }).get();

            Swal.fire({
                title: '¿Eliminar seleccionadas?',
                html: `Estás por eliminar <b>${selectedIds.length}</b> áreas de forma permanente.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#620900',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Procedures/ProcedureAreas/BulkDelete',
                        type: 'POST',
                        data: {
                            ids: selectedIds,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (r) {
                            if (r.success) {
                                showToast('success', r.message);
                                setTimeout(() => { location.reload(); }, 1500);
                            } else {
                                Swal.fire('Error', r.message, 'error');
                            }
                        }
                    });
                }
            });
        }
    </script>
}

<div id="modalContainer"></div>

<div class="container-fluid px-4 pt-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-end align-items-md-center gap-3 mb-4">
        <div class="w-100">
            <h2 class="fw-bold mb-0 merriweather-font">
                <i class="bi bi-diagram-3 me-2 text-dark"></i>Áreas
            </h2>
            <p class="text-muted small mb-0">Configura las áreas o departamentos responsables de los trámites.</p>
        </div>
        <div class="flex-shrink-0">
            <button class="btn btn-burgundy btn-sm px-4 shadow-sm"
                    onclick="@(HasPermission("btn-agregar") ? "loadModal('/Procedures/ProcedureAreas/Create')" : "")"
                    @(HasPermission("btn-agregar") ? "" : "disabled")
                    title="@(HasPermission("btn-agregar") ? "Agregar área" : "Sin permiso para agregar")">
                <i class="bi bi-plus-circle me-1"></i> Agregar área
            </button>
        </div>
    </div>

    <partial name="_TableTools" />

    <div class="border-0 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="mainTable" class="table mt-2 mb-2 table-hover table-container-rounded dataTable no-footer">
                    <thead class="burgundy-header text-white">
                        <tr>
                            <th class="no-sort text-center" style="width: 5%;">
                                <input type="checkbox" id="checkAll" class="form-check-input">
                            </th>
                            <th class="ps-4" style="width: 25%;">Nombre</th>
                            <th style="width: 40%;">Descripción</th>
                            <th style="width: 20%;">Última modificación</th>
                            <th class="no-sort text-center pe-4" style="width: 10%;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="table-white">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input row-checkbox" value="@item.Id" />
                                </td>
                                <td class="ps-4 fw-bold text-dark text-nowrap">@item.Name</td>
                                <td class="text-muted text-nowrap">@(string.IsNullOrEmpty(item.Description) ? "Sin descripción" : item.Description)</td>
                                <td class="text-muted small">
                                    <i class="bi bi-clock-history me-1"></i> @item.DateUpdated.ToString("dd/MM/yyyy hh:mm tt")
                                </td>
                                <td class="actions text-center pe-4">
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-light border shadow-sm me-2"
                                                style="width:32px; height:32px; padding:0;"
                                                onclick="@(HasPermission("btn-editar") ? $"loadModal('/Procedures/ProcedureAreas/Edit/{item.Id}')" : "")"
                                                @(HasPermission("btn-editar") ? "" : "disabled")
                                                title="@(HasPermission("btn-editar") ? "Editar" : "Sin permiso para editar")">
                                            <i class="bi bi-pencil-square text-warning"></i>
                                        </button>
                                        <button class="btn btn-sm btn-light border shadow-sm"
                                                style="width:32px; height:32px; padding:0;"
                                                onclick="@(HasPermission("btn-eliminar") ? $"loadModal('/Procedures/ProcedureAreas/Delete/{item.Id}')" : "")"
                                                @(HasPermission("btn-eliminar") ? "" : "disabled")
                                                title="@(HasPermission("btn-eliminar") ? "Eliminar" : "Sin permiso para eliminar")">
                                            <i class="bi bi-trash-fill text-danger"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <div id="bulkActionsBar" class="position-fixed bottom-0 start-50 translate-middle-x mb-4 shadow-lg bg-dark text-white p-3 rounded-pill d-none animate__animated animate__fadeInUp" style="z-index: 1050; min-width: 300px;">
        <div class="d-flex align-items-center justify-content-between px-3">
            <span id="selectedCount" class="fw-bold me-4">0 seleccionados</span>
            <div class="btn-group">
                @if (HasPermission("btn-multiple-eliminar"))
                {
                    <button class="btn btn-sm btn-danger px-3 fw-bold rounded-pill" onclick="bulkDelete()">
                        <i class="bi bi-trash3-fill me-1"></i> Eliminar
                    </button>
                }
            </div>
            <button type="button" class="btn-close btn-close-white ms-3" onclick="deselectAll()"></button>
        </div>
    </div>
</div>