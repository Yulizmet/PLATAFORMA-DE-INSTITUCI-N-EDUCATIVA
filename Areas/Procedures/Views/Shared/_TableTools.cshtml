<div class="table-tools mb-3">
    <div id="tools-container" class="d-flex flex-wrap align-items-center justify-content-between gap-2 w-100">

        <div id="entries-container" class="d-flex align-items-center">
            
        </div>

        <div class="btn-group shadow-sm rounded-3 overflow-hidden" role="group">
            <button class="btn btn-export" onclick="copyTableToClipboard()" title="Copiar">
                <i class="bi bi-clipboard"></i> <span class="d-none d-md-inline ms-1">Copiar</span>
            </button>
            <button class="btn btn-export" onclick="window.location.href='/Procedures/Report/ExportCsv?entity=@ViewBag.EntityName'" title="CSV">
                <i class="bi bi-filetype-csv"></i> <span class="d-none d-md-inline ms-1">CSV</span>
            </button>
            <button class="btn btn-export" onclick="window.location.href='/Procedures/Report/ExportExcel?entity=@ViewBag.EntityName'" title="Excel">
                <i class="bi bi-file-earmark-excel"></i> <span class="d-none d-md-inline ms-1">Excel</span>
            </button>
            <button class="btn btn-export" onclick="window.open('/Procedures/Report/ExportPdf?entity=@ViewBag.EntityName', '_blank')" title="PDF">
                <i class="bi bi-file-earmark-pdf"></i> <span class="d-none d-md-inline ms-1">PDF</span>
            </button>
            <button class="btn btn-export" onclick="window.print()" title="Imprimir">
                <i class="bi bi-printer"></i> <span class="d-none d-md-inline ms-1">Imprimir</span>
            </button>
        </div>

        <div class="d-flex gap-3 align-items-center">
            <div id="staffCounter" class="d-none d-lg-block">
                <span class="badge rounded-pill bg-burgundy-subtle text-burgundy border py-2 px-3" style="font-size: 0.75rem;">
                    <i class="bi bi-layers-fill me-1"></i> <span id="countNumber">@Model.Count</span> REGISTROS
                </span>
            </div>
            <div class="position-relative">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-2 text-muted me-3" style="font-size: 0.8rem;"></i>
                <input type="text" id="tableSearch"
                       class="form-control form-control-sm ps-5 border shadow-none"
                       placeholder="Buscar..."
                       style="width: 180px; border-radius: 20px; height: 35px;">
            </div>
        </div>
    </div>
</div>