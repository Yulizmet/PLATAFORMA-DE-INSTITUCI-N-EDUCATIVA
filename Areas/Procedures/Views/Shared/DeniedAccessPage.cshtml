@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = null;
    var statusCode = Context.Response.StatusCode;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Inter', sans-serif;
        }

        .text-burgundy {
            color: #620900;
        }

        .btn-burgundy {
            background-color: #620900;
            color: white;
            border: none;
            transition: all 0.3s ease;
        }

            .btn-burgundy:hover {
                background-color: #8c0d00;
                color: white;
                transform: translateY(-2px);
            }

        .card-denied {
            max-width: 800px;
            border: none;
            border-left: 8px solid #620900;
            border-radius: 15px;
            overflow: hidden;
        }

        .status-code {
            font-size: 4rem;
            font-weight: 800;
            line-height: 1;
            opacity: 0.15;
            position: absolute;
            right: 20px;
            top: 15px;
            z-index: 1;
        }

        .icon-rect-background {
            background-color: #f1f3f5;
            height: 100%;
            min-height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>
    <div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">

        <div class="card card-denied shadow-lg bg-white position-relative">
            <div class="status-code text-burgundy">@statusCode</div>

            <div class="row g-0 align-items-stretch">
                <div class="col-md-4 p-0">
                    <div class="icon-rect-background">
                        <i class="bi bi-shield-lock-fill text-burgundy" style="font-size: 7rem;"></i>
                    </div>
                </div>

                <div class="col-md-8 p-5">
                    <h2 class="fw-extrabold text-dark mb-2">Acceso Restringido</h2>
                    <h5 class="text-secondary mb-4">Módulo de Seguridad Institucional</h5>

                    <p class="text-muted mb-4">
                        Lo sentimos, <span class="fw-bold text-dark">@User.Identity?.Name</span>, tu perfil actual no cuenta con los privilegios necesarios para visualizar esta ruta.
                        <br><br>
                        <small class="text-muted italic">Si consideras que esto es un error administrativo, por favor levanta un ticket con el equipo de TI.</small>
                    </p>

                    <div class="d-flex gap-3 mt-2">
                        <a asp-area="Procedures" asp-controller="Dashboard" asp-action="Index"
                           class="btn btn-burgundy px-4 py-2 rounded-3 shadow-sm">
                            <i class="bi bi-house-door me-2"></i>Ir al Dashboard
                        </a>
                        <button onclick="history.back()" class="btn btn-outline-secondary px-4 py-2 rounded-3">
                            <i class="bi bi-arrow-left me-2"></i>Volver
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</body>
</html>