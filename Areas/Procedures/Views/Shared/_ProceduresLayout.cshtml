@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/tramites.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SchoolManager.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

</head>
<body>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
      $(document).ready(function () {
            const savedState = localStorage.getItem("sidebar-collapsed");
            if (savedState === "true") {
                $(".sidebar").addClass("collapsed");
            }
            syncMainMargin();
            $("#sidebarToggle").on("click", function () {
                $(".sidebar").toggleClass("collapsed");
                const isCollapsed = $(".sidebar").hasClass("collapsed");
                localStorage.setItem("sidebar-collapsed", isCollapsed);
                syncMainMargin();
            });
            function syncMainMargin() {
                if ($(window).width() >= 768) {
                    const isCollapsed = $(".sidebar").hasClass("collapsed");
                    $(".main-content").css(
                        "margin-left",
                        isCollapsed ? "75px" : "260px"
                    );
                } else {
                    $(".main-content").css("margin-left", "0");
                }
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <div class="container-fluid p-0">
        <div class="d-flex">
            <nav class="sidebar shadow-lg">
                <div class="sidebar-header d-flex align-items-center px-3 py-3">
                    <button id="sidebarToggle" class="btn p-0 text-white">
                        <i class="bi bi-list fs-3"></i>
                    </button>
                </div>
                <div class="sidebar-scroll-container">
                    <div class="text-center mb-4 px-2 logo-container">
                        <i class="bi bi-person-badge fs-2 text-white opacity-50"></i>
                        <div class="text-white fw-bold mt-2 sidebar-text">Sistema Escolar</div>
                    </div>

                    <h5 class="mb-3 text-center">Gestión de Trámites</h5>

                    <div class="sidebar-group">
                        <small class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-uppercase opacity-50">
                            <span>Análisis</span>
                        </small>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Dashboard" ? "active-item" : "")"
                                   asp-area="Procedures" asp-controller="Dashboard" asp-action="Index">
                                        <i class="bi bi-clipboard-data"></i>
                                    <span>Panel de control</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="sidebar-group">
                        <small class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-uppercase opacity-50">
                            <span>Atención Escolar</span>
                        </small>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "ProcedureManagement" ? "active-item" : "")"
                                   asp-area="Procedures" asp-controller="ProcedureManagement" asp-action="Index">
                                        <i class="bi bi-speedometer2"></i>
                                    <span>Seguimiento</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Proceeding" ? "active-item" : "")"
                                   asp-area="Procedures" asp-controller="Proceeding" asp-action="Index">
                                    <i class="bi bi-folder2-open"></i>
                                    <span>Expedientes</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="sidebar-group">
                        <small class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-uppercase opacity-50">
                            <span>Administración</span>
                        </small>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                    <a class="nav-link @(currentController == "AdministrativeStaff" ? "active-item" : "")"
                                       asp-area="Procedures" asp-controller="AdministrativeStaff" asp-action="Index">
                                    <i class="bi bi-people"></i>
                                    <span>Gestión de Personal</span>
                                </a>
                            </li>
                                <li class="nav-item">
                                    <a class="nav-link @(currentController == "Permissions" ? "active-item" : "")"
                                       asp-area="Procedures" asp-controller="Permissions" asp-action="Index">
                                        <i class="bi bi-shield-lock"></i>
                                        <span>Gestión de Permisos</span>
                                    </a>
                                </li>
                        </ul>
                    </div>

                    <div class="sidebar-group">
                        <small class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-uppercase opacity-50">
                            <span>Configuración</span>
                        </small>
                        <ul class="nav flex-column mb-5">
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "ProcedureAreas" ? "active-item" : "")"
                                   asp-area="Procedures" asp-controller="ProcedureAreas" asp-action="Index">
                                    <i class="bi bi-diagram-3"></i>
                                    <span>Áreas</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "DocumentsCatalog" ? "active-item" : "")"
                                   asp-area="Procedures" asp-controller="DocumentsCatalog" asp-action="Index">
                                    <i class="bi bi-file-earmark-medical"></i>
                                    <span>Documentos</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "ProcedureStatus" ? "active-item" : "")"
                                   asp-area="Procedures" asp-controller="ProcedureStatus" asp-action="Index">
                                    <i class="bi bi-check-circle"></i>
                                    <span>Estatus</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "ProcedureConfiguration" ? "active-item" : "")"
                                   asp-area="Procedures" asp-controller="ProcedureConfiguration" asp-action="Index">
                                    <i class="bi bi-gear"></i>
                                    <span>Trámites</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="user-profile">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-person-circle fs-3 text-white-50"></i>
                        <div class="ms-2 user-info-text overflow-hidden">
                            <p class="user-name text-truncate mb-0 text-white">Nicolle Guerrero</p>
                            <small class="text-white last-connection">
                                @* <i class="bi bi-circle-fill me-1" style="font-size: 0.6rem;"></i>*@ Administrador
                            </small>
                        </div>
                    </div>
                    <a asp-action="Logout" asp-controller="Account" class="btn btn-sm text-white-50 p-0  align-items-center border-0">
                        <i class="bi bi-box-arrow-right me-2"></i>
                        <span class="sidebar-text" style="font-size: 0.75rem;">Salir</span>
                    </a>
                </div>
            </nav>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 main-content area-tramites">
                <div class="print-only-header d-none d-print-block text-center mb-4">
                    <h1 class="fw-bold" style="color: #620900; text-transform: uppercase;">SCHOOL MANAGER</h1>
                    <h3>Reporte de @(ViewData["Title"] ?? "SISTEMA GENERAL")</h3>
                    <hr style="border: 2px solid #8C1B1B;" />
                </div>

                @RenderBody()
            </main>
        </div>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="copyToast" class="toast align-items-center text-white bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle-fill me-2"></i> ¡Tabla copiada con éxito!
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
</body>
</html>