@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SchoolManager.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

    <style>
        @@media print {
            .table-tools, nav, .sidebar, .btn, .toast-container, header, footer {
                display: none !important;
            }

            .actions, th:last-child, td:last-child {
                display: none !important;
            }

            tr {
                page-break-inside: avoid;
            }
        }

        body {
            background-color: #f8f9fa;
        }

        .sidebar {
            background-color: #620900 !important;
            min-height: 100vh;
            color: white;
            padding-top: 2rem;
            z-index: 1000;
        }

        .burgundy-header {
            background-color: #620900 !important;
        }

        .burgundy-color {
            color: #620900 !important;
        }

        .sidebar h5 {
            color: rgba(255, 255, 255, 0.6) !important;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding-left: 1.5rem;
        }

        .sidebar .nav-link {
            color: rgba(255, 255, 255, 0.8) !important;
            border-left: 4px solid transparent;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0.8rem 1.5rem;
        }

            .sidebar .nav-link:hover {
                background-color: rgba(255, 255, 255, 0.1);
                color: white !important;
            }

            .sidebar .nav-link.active-item {
                background-color: rgba(255, 255, 255, 0.15) !important;
                border-left: 4px solid #ffffff !important;
                font-weight: bold;
                color: white !important;
            }

        .main-content {
            margin-left: 16.666667%;
        }

        @@media (max-width: 767.98px) {
            .sidebar {
                position: relative;
                min-height: auto;
                width: 100%;
            }

            .main-content {
                margin-left: 0;
            }
        }

        .sidebar {
            background-color: #620900 !important;
            min-height: 100vh;
            color: white;
            padding-top: 2rem;
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }

            .sidebar .position-sticky {
                display: flex;
                flex-direction: column;
                height: calc(100vh - 2rem);
                width: 100%;
            }

            .sidebar .nav.flex-column {
                flex-grow: 1;
                overflow-y: auto; 
            }

        .user-profile {
            margin-top: auto;
            margin-left: 1rem;
            margin-right: 1rem;
            margin-bottom: 1.5rem;
            padding: 1rem;
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            transition: all 0.3s ease;
        }

            .user-profile:hover {
                background-color: rgba(255, 255, 255, 0.15);
            }

            .user-profile .user-name {
                font-size: 0.85rem;
                font-weight: 700;
                color: #ffffff;
                margin-bottom: 0;
            }

            .user-profile .last-connection {
                font-size: 0.7rem;
                color: rgba(255, 255, 255, 0.5);
            }
    </style>
</head>
<body>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 d-md-block sidebar shadow-lg position-fixed">
                <div class="position-sticky">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-badge fs-1 text-white opacity-50"></i>
                        <div class="text-white fw-bold mt-2">Sistema Integral Escolar</div>
                    </div>

                    <h5 class="mb-3">Gestión de Trámites</h5>

                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Dashboard" ? "active-item" : "")"
                               asp-area="Procedures" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-speedometer2"></i>
                                <span>Panel de control</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "ProcedureManagement" ? "active-item" : "")"
                               asp-area="Procedures" asp-controller="ProcedureManagement" asp-action="Index">
                                <i class="bi bi-folder2-open"></i>
                                <span>Seguimiento</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "ProcedureAreas" ? "active-item" : "")"
                               asp-area="Procedures" asp-controller="ProcedureAreas" asp-action="Index">
                                <i class="bi bi-diagram-3"></i>
                                <span>Áreas</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "DocumentsCatalog" ? "active-item" : "")"
                               asp-area="Procedures" asp-controller="DocumentsCatalog" asp-action="Index">
                                <i class="bi bi-file-earmark-medical"></i>
                                <span>Documentos</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "ProcedureStatus" ? "active-item" : "")"
                               asp-area="Procedures" asp-controller="ProcedureStatus" asp-action="Index">
                                <i class="bi bi-check-circle"></i>
                                <span>Estados</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "ProcedureConfiguration" ? "active-item" : "")"
                               asp-area="Procedures" asp-controller="ProcedureConfiguration" asp-action="Index">
                                <i class="bi bi-gear"></i>
                                <span>Trámites</span>
                            </a>
                        </li>
                    </ul>

                    <div class="user-profile">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <i class="bi bi-person-circle fs-3 text-white-50"></i>
                            </div>
                            <div class="flex-grow-1 ms-3 overflow-hidden">
                                <p class="user-name text-truncate mb-0">Nicolle Guerrero</p>
                                <div class="d-flex align-items-center" style="margin-top: -5px;">
                                    <i class="bi bi-dot text-success fs-3 lh-1" style="margin-left: -8px;"></i>
                                    <small class="last-connection text-truncate opacity-75" style="margin-left: -6px;">
                                        @DateTime.Now.ToString("dd/MM/yy hh:mm tt")
                                    </small>
                                </div>
                            </div>
                        </div>
                        <a href="#" class="btn btn-sm btn-link text-white-50 p-0 mt-2 text-decoration-none border-0">
                            <i class="bi bi-box-arrow-right me-1"></i> Cerrar sesión
                        </a>
                    </div>
                </div>
            </nav>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 main-content">
                <div class="print-only-header d-none d-print-block text-center mb-4">
                    <h1 class="fw-bold" style="color: #620900; text-transform: uppercase;">SCHOOL MANAGER</h1>
                    <h3>Reporte de @(ViewData["Title"] ?? "SISTEMA GENERAL")</h3>
                    <hr style="border: 2px solid #8C1B1B;" />
                </div>

                @RenderBody()
            </main>
        </div>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="copyToast" class="toast align-items-center text-white bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle-fill me-2"></i> ¡Tabla copiada con éxito!
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
</body>
</html>