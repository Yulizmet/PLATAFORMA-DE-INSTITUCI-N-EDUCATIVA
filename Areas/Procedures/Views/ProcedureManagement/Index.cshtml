@model IEnumerable<SchoolManager.Models.procedure_request>
@{
    ViewData["Title"] = "Historial de Solicitudes";

    bool HasPermission(string buttonName) =>
        ViewBag.UserPermissions != null && ((List<string>)ViewBag.UserPermissions).Contains(buttonName);
}

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <partial name="_DataTableConfig" />

    <script>
        function openMonitoring(id) {
                $('#dynamicModalContent').html('');

                Swal.fire({
                    title: 'Cargando expediente...',
                    text: 'Espere un momento por favor.',
                    allowOutsideClick: false,
                    showConfirmButton: false,
                    didOpen: () => { Swal.showLoading(); }
                });

                $.get(`/Procedures/ProcedureManagement/Monitoring/${id}`, function (data) {
                    Swal.close();

                    $('#dynamicModalContent').html(data);

                    const modalEl = document.getElementById('dynamicModal');
                    const myModal = new bootstrap.Modal(modalEl);
                    myModal.show();

                }).fail(function(xhr) {
                    Swal.close();
                    showToast('error', 'No se pudo cargar el seguimiento. Verifique la conexión.');
                });
            }

        function submitStep() {
                const formData = $('#formUpdateStatus').serialize();

                $.post('/Procedures/ProcedureManagement/UpdateStatus', formData, function (response) {
                    if (response.success) {
                        showToast('success', '¡Estatus actualizado!');
                    
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast('error', response.message || 'Fallo en la actualización');
                    }
                }).fail(function() {
                    showToast('error', 'Error de red al actualizar');
                });
            }

        function setComment(text) {
            const textarea = document.getElementById('adminComment');
            textarea.value = text;
            textarea.classList.add('is-valid');
            setTimeout(() => textarea.classList.remove('is-valid'), 1000);
        }

        $(document).on('change', 'select[name="newFlowId"]', function() {
            const selectedText = $(this).find("option:selected").text().toLowerCase();
            let autoComment = "";

            if (selectedText.includes("aprobado")) {
                autoComment = "Su solicitud ha sido aprobada satisfactoriamente.";
            } else if (selectedText.includes("finalizado")) {
                autoComment = "El trámite ha concluido con éxito.";
            } else if (selectedText.includes("validación")) {
                autoComment = "Estamos validando la información proporcionada.";
            } else if (selectedText.includes("pago")) {
                autoComment = "En espera de la confirmación de pago institucional.";
            } else {
                autoComment = "Se ha actualizado el estatus del trámite.";
            }

            $('#adminComment').val(autoComment);
        });

        $(document).ready(function () {
            $(document).on('change', '#checkAll', function () {
                const isChecked = $(this).is(':checked');
                $('.row-checkbox').prop('checked', isChecked);
                $('.row-checkbox').closest('tr').toggleClass('table-active', isChecked);
                updateBulkBar();
            });

            $(document).on('change', '.row-checkbox', function () {
                const total = $('.row-checkbox').length;
                const selected = $('.row-checkbox:checked').length;
                $('#checkAll').prop('checked', total === selected);
                $(this).closest('tr').toggleClass('table-active', $(this).is(':checked'));
                updateBulkBar();
            });
        });

        function updateBulkBar() {
            const count = $('.row-checkbox:checked').length;
            const bar = $('#bulkActionsBar');

            if (count > 0) {
                const text = count === 1 ? '1 seleccionado' : count + ' seleccionados';
                $('#selectedCount').text(text);

                bar.removeClass('d-none').fadeIn('fast');
            } else {
                bar.fadeOut('fast', function() {
                    $(this).addClass('d-none');
                });
                $('#checkAll').prop('checked', false);
            }
        }

        function deselectAll() {
            $('.row-checkbox, #checkAll').prop('checked', false).closest('tr').removeClass('table-active');
            updateBulkBar();
        }

        function bulkDeleteRequests() {
            const selectedIds = $('.row-checkbox:checked').map(function() {
                return parseInt($(this).val());
            }).get();

            Swal.fire({
                title: '¿Eliminar trámites?',
                html: `Se eliminarán <b>${selectedIds.length}</b> solicitudes permanentemente.<br>
                       <span class="text-danger small fw-bold">Esto borrará historial de seguimiento y documentos adjuntos.</span>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#620900',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, eliminar todo',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Procesando...', didOpen: () => { Swal.showLoading(); } });

                    $.ajax({
                        url: '/Procedures/ProcedureManagement/BulkDelete',
                        type: 'POST',
                        data: {
                            ids: selectedIds,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (r) {
                            if (r.success) {
                                showToast('success', 'Trámites eliminados correctamente');
                                setTimeout(() => location.reload(), 1000);
                            } else {
                                showToast('error', r.message || 'Error al eliminar');
                            }
                        },
                        error: function() {
                            showToast('error', 'Error de comunicación con el servidor');
                        }
                    });
                }
            });
        }
    </script>
}

<div class="container-fluid px-4 pt-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-end align-items-md-center gap-3 mb-4">
        <div class="w-100">
            <h2 class="fw-bold mb-0 merriweather-font">
                <i class="bi bi-speedometer2 me-2 text-dark"></i>Historial de Solicitudes
            </h2>
            <p class="text-muted small mb-0">Administración y seguimiento de trámites emitidos.</p>
        </div>

        <div class="flex-shrink-0">
            <button class="btn btn-outline-secondary btn-sm shadow-sm px-4 py-2 py-md-1" onclick="location.reload()">
                <i class="bi bi-arrow-clockwise me-1"></i> Actualizar
            </button>
        </div>
    </div>

    <partial name="_TableTools" />

    <div class="border-0 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="mainTable" class="table mt-2 mb-2 table-hover table-container-rounded dataTable no-footer">
                    <thead class="small burgundy-header text-white">
                        <tr>
                            <th class="no-sort text-center"> <input type="checkbox" id="checkAll" class="form-check-input"> </th>
                            <th class="ps-4">Folio / Fecha</th>
                            <th>Alumno / Remitente</th>
                            <th>Trámite / Asunto</th>
                            <th class="text-center">Docs</th>
                            <th>Estado Actual</th>
                            <th class="no-sort actions text-center pe-4"> Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="table-white">
                        @foreach (var item in Model)
                        {
                            var student = item.Preenrollments?.FirstOrDefault();

                            <tr>
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input row-checkbox" value="@item.Id" />
                                </td>
                                <td class="ps-4">
                                    <div class="fw-bold burgundy-color">@item.Folio</div>
                                    <small class="text-muted d-block">@item.DateCreated.ToString("dd/MM/yyyy hh:mm tt")</small>
                                    @{
                                        var maxDays = item.ProcedureType?.MaxResolutionDays ?? 0;
                                        if (maxDays > 0 && item.DateTerminated == null)
                                        {
                                            var daysActive = (DateTime.Now - item.DateCreated).Days;
                                            var remainingDays = maxDays - daysActive;

                                            if (remainingDays < 0)
                                            {
                                                <span class="badge bg-danger mt-1 animate__animated animate__pulse animate__infinite"
                                                      title="Trámite fuera de tiempo">
                                                    <i class="bi bi-exclamation-triangle-fill"></i> @Math.Abs(remainingDays) días de retraso
                                                </span>
                                            }
                                            else if (remainingDays <= 2)
                                            {
                                                <span class="badge bg-warning text-dark mt-1">
                                                    <i class="bi bi-clock-fill"></i> vence en @remainingDays días
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-muted border mt-1">
                                                    <i class="bi bi-calendar-check"></i> @remainingDays días restantes
                                                </span>
                                            }
                                        }
                                    }
                                </td>
                                <td>
                                    <div class="fw-bold">
                                        @if (student?.User?.Person != null)
                                        {
                                            @($"{student.User.Person.FirstName} {student.User.Person.LastNamePaternal}")
                                        }
                                        else if (item.User?.Person != null)
                                        {
                                            @($"{item.User.Person.FirstName} {item.User.Person.LastNamePaternal}")
                                        }
                                        else if (student != null)
                                        {
                                            <span class="text-dark">Aspirante: <i class="text-muted fw-normal fst-italic">Sin expediente</i></span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Usuario: @(item.User?.Username ?? "Desconocido")</span>
                                        }
                                    </div>

                                    <small class="text-muted">
                                        @{
                                            bool isRealStudent = (student?.User?.Person != null || item.User?.Person != null);
                                            string matriculaVal = student?.Matricula ?? "";

                                            if (isRealStudent && !string.IsNullOrWhiteSpace(matriculaVal) && matriculaVal != "0" && matriculaVal != "S/M")
                                            {
                                                <i class="fst-italic opacity-75">Matrícula:</i> 
                                                @matriculaVal
                                            }
                                            else if (!isRealStudent && !string.IsNullOrWhiteSpace(student?.Folio))
                                            {
                                                <i class="fst-italic opacity-75">Folio:</i> 
                                                @student.Folio
                                            }
                                            else if (!string.IsNullOrWhiteSpace(student?.Matricula) && student.Matricula != "0")
                                            {
                                                <i class="fst-italic opacity-75">Folio:</i> 
                                                @student.Matricula
                                            }
                                            else
                                            {
                                                <i class="fst-italic opacity-75">Sin Matrícula / Folio</i>
                                            }
                                        }
                                    </small>
                                </td>

                                <td>
                                    <div class="fw-bold text-dark">@item.ProcedureType?.Name</div>
                                    <div class="small text-truncate text-muted" style="max-width: 200px;">
                                        @item.Subject
                                    </div>
                                </td>

                                <td class="text-center">
                                    @{
                                        var docsCount = item.ProcedureDocuments?.Count ?? 0;
                                    }

                                    @if (docsCount > 0)
                                    {
                                        <span class="badge bg-info text-white rounded-pill">
                                            <i class="bi bi-paperclip"></i> @docsCount
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">0</span>
                                    }
                                </td>

                                @{
                                    bool isCancelled = item.ProcedureFlow?.ProcedureStatus?.Name == "Cancelado";
                                }

                                <td>
                                    <span class="badge rounded-pill shadow-sm"
                                          style="background-color: @(item.ProcedureFlow?.ProcedureStatus?.BackgroundColor ?? "#6c757d");
                                                 color: @(item.ProcedureFlow?.ProcedureStatus?.TextColor ?? "#fff");
                                                 padding: 0.5em 1em;">
                                        @item.ProcedureFlow?.ProcedureStatus?.Name
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        @if (HasPermission("btn-gestionar"))
                                        {
                                            <button class="btn btn-sm btn-light border text-dark shadow-sm px-3 rounded-pill"
                                                    onclick="openMonitoring(@item.Id)"
                                                    title="@(isCancelled ? "No se puede gestionar" : "Gestionar Trámite")"
                                                    @(isCancelled ? "disabled" : "")>
                                                <i class="bi bi-gear-fill me-1 @(isCancelled ? "text-muted" : "text-dark")"></i>Gestionar
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted small"><i>Sin acceso</i></span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="bulkActionsBar" class="position-fixed bottom-0 start-50 translate-middle-x mb-4 shadow-lg bg-dark text-white p-3 rounded-pill d-none animate__animated animate__fadeInUp" style="z-index: 1050; min-width: 300px;">
        <div class="d-flex align-items-center justify-content-between px-3">
            <span id="selectedCount" class="fw-bold me-4">0 seleccionados</span>
            <div class="btn-group">
                @if (HasPermission("btn-multiple-eliminar"))
                {
                    <button class="btn btn-sm btn-danger px-3 fw-bold rounded-pill" onclick="bulkDeleteRequests()">
                        <i class="bi bi-trash-fill me-1"></i> Eliminar
                    </button>
                }
            </div>
            <button type="button" class="btn-close btn-close-white ms-3" onclick="deselectAll()"></button>
        </div>
    </div>
</div>

<div class="modal fade" id="dynamicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" id="dynamicModalContent">

        </div>
    </div>
</div>