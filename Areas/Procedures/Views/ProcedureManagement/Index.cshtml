@model IEnumerable<SchoolManager.Models.procedure_request>
@{
    ViewData["Title"] = "Historial de Solicitudes";
}

<div class="container-fluid px-4 pt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"><i class="bi bi-folder2-open me-2 text-dark"></i>Historial de Solicitudes</h2>
            <p class="text-muted small">Administración y seguimiento de trámites emitidos.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm shadow-sm" onclick="location.reload()">
                <i class="bi bi-arrow-clockwise"></i> Actualizar
            </button>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="tableToCopy" class="table table-hover align-middle mb-0">
                    <thead class="small burgundy-header text-white">
                        <tr>
                            <th class="ps-4">Folio / Fecha</th>
                            <th>Alumno / Remitente</th>
                            <th>Trámite / Asunto</th>
                            <th class="text-center">Docs</th>
                            <th>Estado Actual</th>
                            <th class="actions text-center pe-4"> Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var student = item.Preenrollments?.FirstOrDefault();

                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold burgundy-color">@item.Folio</div>
                                    <small class="text-muted">@item.DateUpdated.ToString("dd/MM/yyyy hh:mm tt")</small>
                                </td>

                                <td>
                                    <div class="fw-bold">
                                        @if (student?.User?.Person != null)
                                        {
                                            @($"{student.User.Person.FirstName} {student.User.Person.LastNamePaternal}")
                                        }
                                        else if (item.User?.Person != null)
                                        {
                                            @($"{item.User.Person.FirstName} {item.User.Person.LastNamePaternal}")
                                        }
                                        else if (student != null)
                                        {
                                            <span>Aspirante: <i>Sin expediente</i></span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Usuario: @(item.User?.Username ?? "Desconocido")</span>
                                        }
                                    </div>

                                    <small class="text-muted">
                                        @{
                                            string label = "Usuario Registrado";

                                            if (!string.IsNullOrWhiteSpace(student?.Matricula) && student.Matricula != "0")
                                            {
                                                label = $"Matrícula: {student.Matricula}";
                                            }
                                            else if (item.User?.Preenrollments?.Any(p => !string.IsNullOrEmpty(p.Matricula) && p.Matricula != "0") == true)
                                            {
                                                var m = item.User.Preenrollments.First(p => !string.IsNullOrEmpty(p.Matricula) && p.Matricula != "0").Matricula;
                                                label = $"Matrícula: {m}";
                                            }
                                            else if (!string.IsNullOrWhiteSpace(student?.Folio) && student.Folio != "0")
                                            {
                                                label = $"Folio: {student.Folio}";
                                            }
                                        }
                                        @label
                                    </small>
                                </td>

                                <td>
                                    <div class="fw-bold text-dark">@item.ProcedureType?.Name</div>
                                    <div class="small text-truncate text-muted" style="max-width: 200px;">
                                        @item.Subject
                                    </div>
                                </td>

                                <td class="text-center">
                                    @{
                                        var docsCount = item.ProcedureDocuments?.Count ?? 0;
                                    }

                                    @if (docsCount > 0)
                                    {
                                        <span class="badge bg-info text-white rounded-pill">
                                            <i class="bi bi-paperclip"></i> @docsCount
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">0</span>
                                    }
                                </td>

                                <td>
                                    <span class="badge rounded-pill shadow-sm"
                                          style="background-color: @(item.ProcedureFlow?.ProcedureStatus?.BackgroundColor ?? "#6c757d");
                             color: @(item.ProcedureFlow?.ProcedureStatus?.TextColor ?? "#fff");
                             padding: 0.5em 1em;">
                                        @item.ProcedureFlow?.ProcedureStatus?.Name
                                    </span>
                                </td>

                                <td class="text-center pe-4">
                                    <button class="btn btn-sm btn-secondary px-3 shadow-sm rounded-pill"
                                            onclick="openMonitoring(@item.Id)">
                                        <i class="bi bi-gear-fill me-1"></i> Gestionar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="dynamicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" id="dynamicModalContent">

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openMonitoring(id) {
            $('#dynamicModalContent').html('');

            Swal.fire({
                title: 'Cargando expediente...',
                text: 'Espere un momento por favor.',
                allowOutsideClick: false,
                showConfirmButton: false,
                didOpen: () => { Swal.showLoading(); }
            });

            $.get(`/Procedures/ProcedureManagement/Monitoring/${id}`, function (data) {
                Swal.close();

                $('#dynamicModalContent').html(data);

                const modalEl = document.getElementById('dynamicModal');
                const myModal = new bootstrap.Modal(modalEl);
                myModal.show();

            }).fail(function(xhr) {
                Swal.close();
                console.error("Error al cargar:", xhr.responseText);
                Swal.fire('Error', 'No se pudo cargar el seguimiento. Verifique que la ruta sea correcta.', 'error');
            });
        }
    function submitStep() {
            const formData = $('#formUpdateStatus').serialize();

            $.post('/Procedures/ProcedureManagement/UpdateStatus', formData, function (response) {
                if (response.success) {
                    Swal.fire('¡Éxito!', response.message, 'success').then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error', response.message, 'error');
                }
            });
        }
    </script>
}