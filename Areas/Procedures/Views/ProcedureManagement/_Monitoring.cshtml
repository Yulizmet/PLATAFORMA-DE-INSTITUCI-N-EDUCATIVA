@model SchoolManager.Models.procedure_request

<div class="modal-header burgundy-header text-white">
    <h5 class="modal-title">Gestión de Folio: <strong>@Model.Folio</strong></h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body bg-light">
    <div class="row">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted small text-uppercase fw-bold">Detalles de la Solicitud</h6>
                    <p class="mb-1"><strong>Asunto:</strong> @Model.Subject</p>
                    <p class="mb-0"><strong>Mensaje del Alumno:</strong> @Model.Message</p>
                </div>
            </div>

            <h6 class="mb-3 fw-bold burgundy-color"><i class="bi bi-clock-history"></i> Historial de Seguimiento</h6>
            <div class="timeline-container" style="max-height: 300px; overflow-y: auto;">
                @if (Model.ProcedureMonitorings != null && Model.ProcedureMonitorings.Any())
                {
                    @foreach (var log in Model.ProcedureMonitorings.OrderByDescending(l => l.DateUpdated))
                    {
                        <div class="p-3 bg-white border rounded mb-2 shadow-sm">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="badge" style="background-color:@log.ProcedureStatus?.BackgroundColor; color:@log.ProcedureStatus?.TextColor">
                                    @log.ProcedureStatus?.Name
                                </span>
                                <small class="text-muted">@log.DateUpdated.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <p class="small mb-0">@log.Comment</p>
                            <small class="text-muted font-italic">- Atendido por: @log.IdUser</small>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No hay actividad previa registrada.</p>
                }
            </div>
        </div>

        <div class="col-md-5">
            <h6 class="fw-bold mb-3">Documentación</h6>
            <div class="list-group mb-4">
                @foreach (var doc in Model.ProcedureDocuments)
                {
                    <a href="@doc.FilePath" target="_blank" class="list-group-item list-group-item-action small d-flex align-items-center gap-2">
                        <i class="bi bi-file-earmark-pdf text-danger fs-5"></i>
                        @doc.Name
                    </a>
                }
            </div>

            <div class="card border-primary">
                <div class="card-header bg-primary text-white py-2 small fw-bold">ACTUALIZAR ESTATUS</div>
                <div class="card-body p-3">
                    <form id="formUpdateStatus">
                        <input type="hidden" name="requestId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label small">Nuevo Estado:</label>
                            <select name="newStatusId" class="form-select form-select-sm" asp-items="ViewBag.Statuses"></select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Comentario / Respuesta:</label>
                            <textarea name="adminComment" class="form-control form-control-sm" rows="3" required placeholder="Escribe la respuesta para el alumno..."></textarea>
                        </div>
                        <button type="button" onclick="submitStep()" class="btn btn-primary btn-sm w-100">
                            Guardar y Notificar
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>