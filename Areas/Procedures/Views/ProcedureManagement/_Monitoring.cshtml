@model SchoolManager.Models.procedure_request

<style>

    :root {
        --burgundy: #620900;
        --burgundy-light: #8C1B1B;
    }

    .burgundy-border {
        border: 2px solid var(--burgundy) !important;
    }

    .timeline-burgundy {
        border-left: 3px solid var(--burgundy);
        margin-left: 10px;
        position: relative;
    }

        .timeline-burgundy::before {
            content: "";
            position: absolute;
            left: -8px;
            top: 15px;
            width: 13px;
            height: 13px;
            border-radius: 50%;
            background: var(--burgundy);
            border: 2px solid white;
        }

    .doc-card-custom {
        border: 1px solid #dee2e6;
        transition: all 0.3s ease;
    }

        .doc-card-custom:hover {
            border-color: var(--burgundy) !important;
            background-color: rgba(98, 9, 0, 0.03) !important;
            transform: translateX(5px);
        }

    .header-burgundy-solid {
        background-color: var(--burgundy);
        border-bottom: 3px solid var(--burgundy-light);
    }
</style>

<div class="modal-header header-burgundy-solid text-white py-3">
    <div class="d-flex align-items-center">
        <i class="bi bi-person-badge fs-3 me-3"></i>
        <div>
            <h5 class="modal-title mb-0 fw-bold">Gestión de Trámite</h5>
            <small>Folio: <strong class="text-white">@Model.Folio</strong></small>
        </div>
    </div>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body bg-white px-4 py-4">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card burgundy-border shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-uppercase mb-3" style="color: var(--burgundy);">Resumen del Requerimiento</h6>
                    <div class="row">
                        <div class="col-12 mb-2">
                            <span class="small text-muted d-block">Asunto:</span>
                            <span class="fw-bold text-dark">@Model.Subject</span>
                        </div>
                        <div class="col-12">
                            <span class="small text-muted d-block">Mensaje del Usuario:</span>
                            <p class="text-secondary small mb-0 border-start ps-2 py-1">@Model.Message</p>
                        </div>
                    </div>
                </div>
            </div>

            <h6 class="fw-bold mb-3" style="color: var(--burgundy);">
                <i class="bi bi-clock-history me-2"></i> Historial de Seguimiento
            </h6>

            <div class="ps-2" style="max-height: 350px; overflow-y: auto;">
                @if (Model.ProcedureMonitorings != null && Model.ProcedureMonitorings.Any())
                {
                    @foreach (var log in Model.ProcedureMonitorings.OrderByDescending(l => l.DateUpdated))
                    {
                        <div class="timeline-burgundy p-3 bg-light rounded-4 mb-3 ms-3 border shadow-sm">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="badge" style="background-color:@log.ProcedureStatus?.BackgroundColor; color:@log.ProcedureStatus?.TextColor">
                                    @log.ProcedureStatus?.Name
                                </span>
                                <small class="text-muted fw-bold">@log.DateUpdated.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <p class="small text-dark mb-2">@log.Comment</p>
                            <div class="pt-2 border-top text-end">
                                <small class="text-muted italic">- Atendido por: @log.User?.Username</small>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-lg-5">
            <h6 class="fw-bold mb-3" style="color: var(--burgundy);">
                <i class="bi bi-files me-2"></i> Documentación Adjunta
            </h6>
            <div class="mb-4">
                @if (Model.ProcedureDocuments != null && Model.ProcedureDocuments.Any())
                {
                    @foreach (var doc in Model.ProcedureDocuments)
                    {
                        var isPdf = doc.Name.ToLower().EndsWith(".pdf");
                        <a href="@doc.FilePath" target="_blank" class="doc-card-custom list-group-item list-group-item-action rounded-4 mb-2 p-3 d-flex align-items-center">
                            <div class="rounded p-2 me-3">
                                @if (isPdf)
                                {
                                    <i class="bi bi-file-earmark-pdf-fill text-danger fs-3"></i>
                                }
                                else
                                {
                                    <i class="bi bi-file-earmark-image-fill text-primary fs-3"></i>
                                }
                            </div>
                            <div class="overflow-hidden">
                                <div class="text-dark fw-bold small text-truncate">@doc.Name</div>
                                <small class="text-muted">Ver archivo @(isPdf ? "PDF" : "Imagen")</small>
                            </div>
                        </a>
                    }
                }
            </div>

            <div class="card burgundy-border rounded-4 overflow-hidden shadow-sm">
                <div class="card-header text-white py-2 fw-bold" style="background-color: var(--burgundy);">
                    <i class="bi bi-arrow-repeat me-2"></i>ACTUALIZAR ESTATUS
                </div>
                <div class="card-body p-4 bg-white">
                    <form id="formUpdateStatus">
                        <input type="hidden" name="requestId" value="@Model.Id" />

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Nuevo Estado:</label>
                            <select name="newStatusId" class="form-select border-1" asp-items="ViewBag.Statuses"></select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Comentario Administrativo:</label>
                            <textarea name="adminComment" class="form-control border-1" rows="4" required placeholder="Escriba la respuesta..."></textarea>
                        </div>

                        <button type="button" onclick="submitStep()" class="btn btn-burgundy w-100 py-2 shadow-sm">
                            Guardar y Notificar
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>