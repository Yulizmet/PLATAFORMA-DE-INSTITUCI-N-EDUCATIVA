@model SchoolManager.Areas.Procedures.ViewModels.ExtraInfoViewModel

@{
    bool HasPermission(string buttonKey)
    {
        var permissions = ViewBag.UserPermissions as List<string>;
        return permissions != null && permissions.Contains(buttonKey);
    }
}

<style>
    :root {
        --burgundy: #620900;
        --burgundy-light: #8C1B1B;
    }

    .burgundy-border {
        border: 2px solid var(--burgundy) !important;
    }

    .timeline-burgundy {
        border-left: 3px solid var(--burgundy);
        margin-left: 10px;
        position: relative;
    }

        .timeline-burgundy::before {
            content: "";
            position: absolute;
            left: -8px;
            top: 15px;
            width: 13px;
            height: 13px;
            border-radius: 50%;
            background: var(--burgundy);
            border: 2px solid white;
        }

    .doc-card-custom {
        border: 1px solid #dee2e6;
        transition: all 0.3s ease;
    }

        .doc-card-custom:hover {
            border-color: var(--burgundy) !important;
            background-color: rgba(98, 9, 0, 0.03) !important;
            transform: translateX(5px);
        }

    .header-burgundy-solid {
        background-color: var(--burgundy);
        border-bottom: 3px solid var(--burgundy-light);
    }

    .burgundy-color {
        color: var(--burgundy);
    }

    .btn-burgundy {
        background-color: var(--burgundy);
        color: white;
        border: none;
        padding: 10px;
        border-radius: 8px;
        transition: 0.3s;
    }

        .btn-burgundy:hover {
            background-color: var(--burgundy-light);
            color: white;
        }
</style>

<div class="modal-header header-burgundy-solid text-white py-3">
    <div class="d-flex align-items-center">
        <i class="bi bi-person-badge fs-3 me-3"></i>
        <div>
            <h5 class="modal-title mb-0 fw-bold">Gestión de Trámite</h5>
            <small class="text-uppercase text-white-50">Folio: <strong>@Model.Folio</strong></small>
        </div>
    </div>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body bg-white px-4 py-4 area-tramites">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card burgundy-border shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h6 class="fw-bold text-uppercase mb-0 burgundy-color">Datos del Remitente</h6>
                        @if (Model.IsAspirante)
                        {
                            <span class="badge bg-warning text-dark"><i class="bi bi-star-fill me-1"></i>Aspirante</span>
                        }
                        else
                        {
                            <span class="badge bg-success"><i class="bi bi-person-check-fill me-1"></i>Alumno</span>
                        }
                    </div>
                    <div class="row g-3">
                        <div class="col-md-7">
                            <span class="small text-muted d-block">Nombre Completo:</span>
                            <span class="fw-bold text-dark fs-5">@Model.StudentFullName</span>
                        </div>
                        <div class="col-md-5">
                            <span class="small text-muted d-block">
                                @((Model.Matricula != "S/M" && Model.Matricula != "0") ? "Matrícula:" : "Folio Aspirante:")
                            </span>
                            <span class="badge bg-light text-dark border p-2">
                                <i class="bi bi-hash me-1"></i>
                                @((Model.Matricula != "S/M" && Model.Matricula != "0") ? Model.Matricula : Model.ApplicantFolio)
                            </span>
                        </div>

                        <div class="col-12 mt-2 pt-3 border-top">
                            <span class="small text-muted d-block fw-bold text-uppercase">Asunto del Trámite:</span>
                            <p class="mb-2 text-dark"><strong>@Model.ProcedureName</strong> - @Model.UserMessage</p>
                            <span class="small text-muted"><i class="bi bi-envelope me-1"></i>@Model.Email</span>
                        </div>
                    </div>
                    <div class="row g-2 mt-2 pt-2 border-top">
                        <div class="col-md-4">
                            <span class="small text-muted d-block">Fecha de Solicitud:</span>
                            <span class="small fw-bold"><i class="bi bi-calendar-plus me-1"></i>@Model.CreationDate.ToString("dd/MM/yyyy")</span>
                        </div>

                        @if (Model.LastUpdate.HasValue)
                        {
                            <div class="col-md-4">
                                <span class="small text-muted d-block">Último Movimiento:</span>
                                <span class="small fw-bold burgundy-color"><i class="bi bi-clock-history me-1"></i>@Model.LastUpdate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        }

                        @if (Model.TerminatedDate.HasValue)
                        {
                            <div class="col-md-4">
                                <span class="small text-muted d-block">Fecha de Finalización:</span>
                                <span class="small fw-bold text-success"><i class="bi bi-check-circle-fill me-1"></i>@Model.TerminatedDate.Value.ToString("dd/MM/yyyy")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <h6 class="fw-bold mb-3 burgundy-color"><i class="bi bi-clock-history me-2"></i> Historial de Seguimiento</h6>
            <div class="ps-2 timeline-detail" style="max-height: 400px; overflow-y: auto;">
                @foreach (var log in Model.History)
                {
                    <div class="timeline-burgundy p-3 bg-light rounded-4 mb-3 ms-3 border shadow-sm">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge shadow-sm" style="background-color:@(log.BackgroundColor ?? "#6c757d"); color:@(log.TextColor ?? "#ffffff");">
                                @log.StatusName
                            </span>
                            <small class="text-muted fw-bold">@log.Date.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        <p class="small text-dark mb-2">@log.AdminComment</p>
                        <div class="pt-2 border-top text-end">
                            <small class="text-muted italic">- @log.UpdatedBy</small>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* COLUMNA DERECHA: ACCIONES Y DOCUMENTOS *@
        <div class="col-lg-5">
            <h6 class="fw-bold mb-3 burgundy-color"><i class="bi bi-files me-2"></i> Documentación</h6>
            <div class="mb-4">
                @if (Model.Documents != null && Model.Documents.Any())
                {
                    foreach (var doc in Model.Documents)
                    {
                        string ext = System.IO.Path.GetExtension(doc.FileName).ToLower();
                        string iconClass = ext switch
                        {
                            ".pdf" => "bi-file-earmark-pdf-fill text-danger",
                            ".jpg" or ".jpeg" or ".png" => "bi-file-earmark-image-fill text-primary",
                            ".docx" or ".doc" => "bi-file-earmark-word-fill text-info",
                            _ => "bi-file-earmark-fill text-secondary"
                        };

                        <a href="@doc.FilePath" target="_blank" class="doc-card-custom list-group-item list-group-item-action rounded-4 mb-2 p-3 d-flex align-items-center border shadow-sm">
                            <i class="bi @iconClass fs-3 me-3"></i>
                            <div class="overflow-hidden">
                                <div class="text-dark fw-bold small text-truncate">@doc.FileName</div>
                                <small class="text-muted">Abrir documento</small>
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="p-3 bg-light rounded-4 border border-dashed text-center">
                        <p class="text-muted small mb-0">No hay documentos adjuntos.</p>
                    </div>
                }
            </div>

            <div class="card burgundy-border rounded-4 overflow-hidden shadow-sm">
                <div class="card-header text-white py-2 fw-bold bg-burgundy text-uppercase">
                    <i class="bi bi-arrow-repeat me-2"></i>Actualizar Estatus
                </div>
                <div class="card-body p-4 bg-white">
                    @if (Model.ProcedureFlow?.ProcedureStatus?.IsTerminalState == true && !Model.ProcedureFlow.ProcedureStatus.Name.Contains("Rechazado"))
                    {
                        <div class="alert alert-success border-0 shadow-sm text-center">
                            <i class="bi bi-check-all fs-4"></i><br>
                            <strong>¡Trámite Concluido!</strong><br>
                            Este registro se encuentra en un estado terminal de éxito.
                        </div>
                    }
                    else
                    {
                        @if (ViewBag.Statuses != null && ((SelectList)ViewBag.Statuses).Any())
                        {
                            <form id="formUpdateStatus">
                                <input type="hidden" name="requestId" value="@Model.RequestId" />

                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Nuevo Estado:</label>
                                    <select name="newFlowId" class="form-select shadow-sm" asp-items="ViewBag.Statuses"></select>
                                </div>

                                <div class="mb-3">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <label class="form-label small fw-bold mb-0">Comentario:</label>
                                        <span class="badge rounded-pill bg-warning text-dark" style="font-size: 0.65rem;">
                                            <i class="bi bi-info-circle-fill"></i> Se requiere registrar un motivo
                                        </span>
                                    </div>

                                    <div id="commentSuggestions" class="mb-2">
                                        <span class="badge bg-light text-dark border p-1 px-2" style="cursor:pointer; font-size: 0.75rem;" onclick="setComment('Trámite revisado y aprobado.')">✅ Aprobado</span>
                                        <span class="badge bg-light text-dark border p-1 px-2" style="cursor:pointer; font-size: 0.75rem;" onclick="setComment('Documentación completa, en espera de validación.')">📄 Documentos OK</span>
                                        <span class="badge bg-light text-dark border p-1 px-2" style="cursor:pointer; font-size: 0.75rem;" onclick="setComment('Se ha avanzado al siguiente paso del proceso.')">🚀 Continuar</span>
                                        <span class="badge bg-light text-dark border p-1 px-2" style="cursor:pointer; font-size: 0.75rem;" onclick="setComment('El pago ha sido aprobado.')">💵 Verificado</span>
                                    </div>

                                    <textarea id="adminComment" name="adminComment" class="form-control shadow-sm" rows="3"
                                      placeholder="Escriba instrucciones para el alumno..."></textarea>
                                </div>
                                <div class="mt-3">
                                    @if (HasPermission("btn-guardar"))
                                    {
                                        <button type="button" onclick="submitStep()" class="btn btn-burgundy w-100 fw-bold shadow-sm text-white">
                                            <i class="bi bi-save me-1"></i> Guardar Cambios
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="alert alert-warning py-2 small text-center">
                                            <i class="bi bi-exclamation-triangle me-2"></i> No tienes permiso para realizar cambios.
                                        </div>
                                    }
                                </div>
                            </form>
                        }
                        else
                        {
                            <div class="alert alert-light border shadow-sm text-center text-muted">
                                <i class="bi bi-info-circle me-2"></i> No hay más acciones disponibles para este trámite.
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>