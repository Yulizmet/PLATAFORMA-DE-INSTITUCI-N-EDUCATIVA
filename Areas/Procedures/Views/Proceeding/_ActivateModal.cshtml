@model SchoolManager.Models.users_person

<div class="modal fade" id="activateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-person-check me-2"></i>Reactivar Expediente</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <i class="bi bi-person-plus-fill text-success" style="font-size: 4rem;"></i>
                <h4 class="fw-bold mt-3">¿Reactivar a este alumno?</h4>
                <p class="mb-1">Se restaurará el acceso al sistema y el expediente de:</p>
                <p class="fs-5 fw-bold text-success">@Model.FirstName @Model.LastNamePaternal @Model.LastNameMaternal</p>

                <div class="alert alert-success small mx-3 mt-3">
                    <i class="bi bi-check-circle me-1"></i>
                    El alumno podrá iniciar sesión nuevamente** y aparecerá de nuevo en las listas y procesos de trámites.
                </div>
            </div>
            <div class="modal-footer bg-light">
                <form id="formActivateStudent">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.PersonId" />
                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" onclick="confirmActivateLogic()" class="btn btn-success px-4">Confirmar Reactivación</button>
                </form>
            </div>
        </div>
    </div>
</div>