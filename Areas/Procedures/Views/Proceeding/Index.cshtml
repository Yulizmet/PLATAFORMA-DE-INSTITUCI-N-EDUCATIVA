@model IEnumerable<SchoolManager.Areas.Procedures.ViewModels.StudentExpedienteViewModel>

@{
    ViewData["Title"] = "Expedientes de Alumnos";
    Layout = "_ProceduresLayout";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-folder2-open me-2"></i>Expedientes Escolares</h2>
        <button class="btn btn-burgundy shadow-sm"><i class="bi bi-person-plus me-1"></i> Nuevo Alumno</button>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Alumno</th>
                            <th>Identificador</th>
                            <th>Usuario</th>
                            <th>Estado</th>
                            <th>Fecha Registro</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@item.FullName</div>
                                    <small class="text-muted">@item.Email</small>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Matricula) && item.Matricula != "0")
                                    {
                                        <span class="badge bg-light text-dark border"><i class="bi bi-hash me-1"></i>@item.Matricula</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-secondary border">Folio: @item.Folio</span>
                                    }
                                </td>
                                <td><code class="text-burgundy">@item.Username</code></td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success rounded-pill">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger rounded-pill">Inactivo</span>
                                    }
                                </td>
                                <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-pencil-square"></i></button>
                                    <button class="btn btn-sm btn-outline-burgundy border-0"><i class="bi bi-eye"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>