@model IEnumerable<SchoolManager.Areas.Procedures.ViewModels.StudentExpedienteViewModel>

@{
    ViewData["Title"] = "Expedientes de Alumnos";
    Layout = "_ProceduresLayout";

    bool HasPermission(string buttonName) =>
        ViewBag.UserPermissions != null && ((List<string>)ViewBag.UserPermissions).Contains(buttonName);
}

@section Scripts
{
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <partial name="_DataTableConfig" />

    <script>
        function loadDeactivateModal(id) {
            $('#modalContainer').html('');

            $.get('/Procedures/Proceeding/Deactivate/' + id, function (data) {
                $('#modalContainer').html(data);
                const modalElement = document.getElementById('deactivateModal');
                const myModal = new bootstrap.Modal(modalElement);
                myModal.show();
            }).fail(function() {
                 showToast('error', 'No se pudo cargar el formulario de baja.');
            });
        }

        function confirmDeactivateLogic() {
            const form = document.getElementById('formDeleteStudent');
            const formData = new FormData(form);

            fetch('/Procedures/Proceeding/DeactivateConfirmed', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('success', '¡Baja exitosa!');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast('error', 'Error: ' + (data.message || 'No se pudo procesar'));
                }
            })
            .catch(error => {
                showToast('error', 'Fallo de comunicación con el servidor.');
            });
        }

        function loadActivateModal(id) {
            $('#modalContainer').html('');

            $.get('/Procedures/Proceeding/Activate/' + id, function (data) {
                $('#modalContainer').html(data);
                const modalElement = document.getElementById('activateModal');
                const myModal = new bootstrap.Modal(modalElement);
                myModal.show();
            }).fail(function() {
                showToast('error', 'No se pudo cargar el formulario de reactivación.');
            });
        }

        function confirmActivateLogic() {
            const form = document.getElementById('formActivateStudent');
            const formData = new FormData(form);

            fetch('/Procedures/Proceeding/ActivateConfirmed', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('success', data.message || '¡Expediente Reactivado!');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast('error', data.message || 'Error al activar');
                }
            })
            .catch(error => {
                showToast('error', 'Ocurrió un error en la comunicación con el servidor.');
            });
        }

        window.loadQuickStudentModal = function() {
            $.get('/Procedures/Proceeding/QuickAddStudent', function (data) {
                $('#modalContainer').html(data);
                const modalElement = document.getElementById('quickStudentModal');
                const myModal = new bootstrap.Modal(modalElement);
                myModal.show();

                $('#formQuickStudent').on('submit', function(e) {
                    e.preventDefault();
                    $.post($(this).attr('action'), $(this).serialize(), function(r) {
                        if(r.success) {
                            myModal.hide();
                            showToast('success', r.message || '¡Alumno registrado!');
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            showToast('error', r.message || 'Error al guardar');
                        }
                    });
                });
            });
        };

        function fillStudentData() {
            const r = Math.floor(Math.random() * 900) + 100;
            $('input[name="FirstName"]').val("Alumno");
            $('input[name="LastNamePaternal"]').val("Prueba");
            $('input[name="Curp"]').val("CURP" + r + r + "XTSXXX00");
            $('input[name="Email"]').val("alumno" + r + "@@email.com");
            $('input[name="Username"]').val("alum." + r);
            $('input[name="Matricula"]').val("2616" + r + "99");
        }

        $(document).on('input', 'input[name="Curp"]', function() {
            this.value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
        });

        $(document).on('input', 'input[name="ZipCode"]', function() {
            this.value = this.value.replace(/[^0-9]/g, '').substring(0, 5);
        });

        $(document).ready(function() {
            const dtToday = new Date();
            let month = dtToday.getMonth() + 1;
            let day = dtToday.getDate();
            const year = dtToday.getFullYear();

            if(month < 10) month = '0' + month.toString();
            if(day < 10) day = '0' + day.toString();

            const maxDate = year + '-' + month + '-' + day;
            $('input[name="BirthDate"]').attr('max', maxDate);
        });

        window.editStudent = function(personId) {
            window.location.href = '/Procedures/Proceeding/Edit/' + personId;
        };

        $(document).ready(function () {
            $('#checkAll').on('change', function () {
                $('.row-checkbox').prop('checked', $(this).is(':checked'));
                updateBulkBar();
            });

            $(document).on('change', '.row-checkbox', function () {
                updateBulkBar();
                $('#checkAll').prop('checked', $('.row-checkbox:checked').length === $('.row-checkbox').length);
            });
        });

        function updateBulkBar() {
             const count = $('.row-checkbox:checked').length;
             const bar = $('#bulkActionsBar');

             if (count > 0) {
                 const text = count === 1 ? '1 seleccionado' : count + ' seleccionados';
                 $('#selectedCount').text(text);
                 bar.removeClass('d-none').fadeIn('fast');
             } else {
                 bar.fadeOut('fast', function() {
                     $(this).addClass('d-none');
                 });
                 $('#checkAll').prop('checked', false);
             }
        }

        function deselectAll() {
            $('.row-checkbox, #checkAll').prop('checked', false).closest('tr').removeClass('table-active');
            updateBulkBar();
        }

        function uncheckAll() {
            $('.row-checkbox, #checkAll').prop('checked', false);
            updateBulkBar();
        }

        function bulkDeleteExpedientes() {
            const selectedIds = $('.row-checkbox:checked').map(function() {
                return parseInt($(this).val());
            }).get();

            Swal.fire({
                title: '¿Eliminar permanentemente?',
                html: `<div class="text-danger fw-bold mb-2">¡AVISO CRÍTICO!</div>
                       Se borrarán <b>${selectedIds.length}</b> expedientes con TODA su información (usuarios, trámites y documentos). Esta acción no se puede deshacer.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#620900',
                confirmButtonText: 'Sí, borrar todo',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Eliminando...',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); }
                    });

                    $.ajax({
                        url: '/Procedures/Proceeding/BulkDelete',
                        type: 'POST',
                        data: {
                            ids: selectedIds,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (r) {
                            if (r.success) {
                                showToast('success', r.message || 'Eliminación masiva exitosa');
                                setTimeout(() => location.reload(), 1000);
                            } else {
                                showToast('error', r.message || 'Error en el proceso');
                            }
                        },
                        error: function () {
                            showToast('error', 'No se pudo procesar la comunicación con el servidor.');
                        }
                    });
                }
            });
        }
    </script>
}

<div id="modalContainer"></div>

<div class="container-fluid  px-4 py-4 pt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-folder2-open me-2"></i>Expedientes Escolares</h2>
        <button class="btn btn-burgundy shadow-sm"
                onclick="@(HasPermission("btn-agregar") ? "loadQuickStudentModal()" : "")"
                @(HasPermission("btn-agregar") ? "" : "disabled")
                title="@(HasPermission("btn-agregar") ? "Añadir Alumno" : "Sin permiso para añadir alumnos")">
            <i class="bi bi-plus-circle me-1"></i> Añadir Alumno
        </button>
    </div>

    <partial name="_TableTools" />

    <div class="border-0 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="mainTable" class="table table-hover align-middle mb-0">
                    <thead class="small bg-burgundy text-white">
                        <tr>
                            <th class="no-sort text-center"> <input type="checkbox" id="checkAll" class="form-check-input"> </th>
                            <th class="ps-4">Alumno / Contacto</th>
                            <th>Identificador</th>
                            <th>Carrera</th>
                            <th>Estado</th>
                            <th>Fecha Registro</th>
                            <th class="no-sort text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="table-white">
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.IsActive ? "" : "opacity-50 bg-light")">
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input row-checkbox" value="@item.PersonId" />
                                </td>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle bg-burgundy-light text-white me-3">
                                            @item.Initials
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.FullName</div>
                                            <small class="text-muted"><i class="bi bi-envelope me-1"></i>@item.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Matricula) && item.Matricula != "0")
                                    {
                                        <span class="badge bg-light text-dark border"><i class="bi bi-hash me-1"></i>@item.Matricula</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-secondary border">Folio: @item.Folio</span>
                                    }
                                </td>
                                <td>
                                    <span class="small fw-bold">@item.CareerName</span>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success rounded-pill border border-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger rounded-pill border border-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <div class="small">@item.CreatedDate.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">@item.CreatedDate.ToString("hh:mm tt")</div>
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group">
                                        @if (item.IsActive)
                                        {
                                            <a asp-area="Procedures" asp-controller="Proceeding" asp-action="Details" asp-route-id="@item.PersonId"
                                               class="btn btn-sm btn-light border shadow-sm me-2 @(HasPermission("btn-detalles") ? "" : "disabled")"
                                               title="@(HasPermission("btn-detalles") ? "Ver Detalles" : "Sin permiso para ver detalles")">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-light border shadow-sm me-2"
                                                    onclick="@(HasPermission("btn-editar") ? $"window.editStudent({item.PersonId})" : "")"
                                                    @(HasPermission("btn-editar") ? "" : "disabled")
                                                    title="@(HasPermission("btn-editar") ? "Editar Alumno" : "Sin permiso para editar")">
                                                <i class="bi bi-pencil-square text-warning"></i>
                                            </button>
                                            <button class="btn btn-sm btn-light border shadow-sm"
                                                    onclick="@(HasPermission("btn-desactivar") ? $"loadDeactivateModal({item.PersonId})" : "")"
                                                    @(HasPermission("btn-desactivar") ? "" : "disabled")
                                                    title="@(HasPermission("btn-desactivar") ? "Dar de Baja" : "Sin permiso para dar de baja")">
                                                <i class="bi bi-person-x-fill text-danger"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-light border shadow-sm me-2 opacity-50" disabled title="Activa el expediente para ver detalles">
                                                <i class="bi bi-eye text-muted"></i>
                                            </button>

                                            <button class="btn btn-sm btn-light border shadow-sm me-2 opacity-50" disabled title="Activa el expediente para editar">
                                                <i class="bi bi-pencil-square text-muted"></i>
                                            </button>

                                            <button class="btn btn-sm btn-light border shadow-sm"
                                                    onclick="@(HasPermission("btn-activar") ? $"loadActivateModal({item.PersonId})" : "")"
                                                    @(HasPermission("btn-activar") ? "" : "disabled")
                                                    title="@(HasPermission("btn-activar") ? "Reactivar Expediente" : "Sin permiso para reactivar")">
                                                <i class="bi bi-person-check-fill text-success"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="bulkActionsBar" class="position-fixed bottom-0 start-50 translate-middle-x mb-4 shadow-lg bg-dark text-white p-3 rounded-pill d-none animate__animated animate__fadeInUp" style="z-index: 1050; min-width: 300px;">
        <div class="d-flex align-items-center justify-content-between px-3">
            <span id="selectedCount" class="fw-bold me-4">0 seleccionados</span>
            <div class="btn-group">
               @if (HasPermission("btn-multiple-eliminar"))
                    {
                        <button class="btn btn-sm btn-danger px-3 fw-bold rounded-pill" onclick="bulkDeleteExpedientes()">
                            <i class="bi bi-trash3-fill me-1"></i> Eliminar
                        </button>
                    }
            </div>
            <button type="button" class="btn-close btn-close-white ms-3" onclick="deselectAll()"></button>
        </div>
    </div>
</div>
