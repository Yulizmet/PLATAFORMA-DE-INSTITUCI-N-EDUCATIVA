@model IEnumerable<SchoolManager.Models.procedure_request>
@{
    ViewData["Title"] = "Registro de pago";
    Layout = "/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    var tramitesPago = ViewBag.TramitesPago as List<SchoolManager.Models.procedure_types> ?? new List<SchoolManager.Models.procedure_types>();
}

<link rel="stylesheet" href="~/css/tramites.css" asp-append-version="true" />

<div class="container py-5 area-tramites">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="card-header-burgundy p-4">
            <h4 class="mb-0"><i class="bi bi-patch-check-fill me-2"></i>Validación de Pago Institucional</h4>
        </div>
        <div class="card-body p-4 bg-light">
            <form id="paymentForm" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark">Folio o Matrícula:</label>
                        <input type="text" name="identifier" class="form-control" placeholder="Ej. PRE-12345" required>
                        <small class="text-muted">Ingresa tu folio de preinscripción o matrícula.</small>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark">Concepto de Pago:</label>
                        <select name="procedureTypeId" class="form-select" required>
                            <option value="">Seleccione concepto...</option>
                            @foreach (var item in tramitesPago)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-12" id="upload-section" style="display: none;">
                        <label class="form-label fw-bold text-dark">Comprobante de Pago (Boucher):</label>
                        <div class="drop-zone" onclick="document.getElementById('fileInput').click()">
                            <input type="file" name="formFiles" id="fileInput" class="d-none" accept=".pdf,.jpg,.png" onchange="handleFileSelect(this)">

                            <div id="upload-prompt">
                                <i class="bi bi-cloud-arrow-up-fill fs-1 text-muted"></i>
                                <h5 class="mt-2">Haz clic para buscar tu comprobante</h5>
                                <p class="small text-muted mb-0">PDF, JPG o PNG (Máximo 2MB)</p>
                            </div>

                            <div id="file-preview" class="animate__animated animate__fadeIn">
                                <div class="file-icon"><i id="type-icon" class="bi bi-file-earmark-text"></i></div>
                                <div class="text-start">
                                    <div id="file-name" class="fw-bold text-dark text-truncate" style="max-width: 250px;"></div>
                                    <div id="file-size" class="small text-muted"></div>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-danger ms-auto" onclick="removeFile(event)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div id="no-requirements-msg" class="col-12" style="display: none;">
                        <div class="alert alert-warning border-0 shadow-sm">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> Este concepto no requiere boucher de pago actualmente.
                        </div>
                    </div>

                    <div class="col-12 text-center mt-4">
                        <button type="button" onclick="submitPayment()" class="btn btn-burgundy btn-lg shadow-sm">
                            <i class="bi bi-send-check me-2"></i>Registrar Pago
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function handleFileSelect(input) {
            const file = input.files[0];
            if (file) {
                const preview = document.getElementById('file-preview');
                const prompt = document.getElementById('upload-prompt');
                document.getElementById('file-name').innerText = file.name;
                document.getElementById('file-size').innerText = (file.size / 1024).toFixed(2) + ' KB';
                const icon = document.getElementById('type-icon');
                const ext = file.name.split('.').pop().toLowerCase();
                icon.className = ext === 'pdf' ? 'bi bi-file-earmark-pdf-fill text-danger' : 'bi bi-file-earmark-image-fill text-primary';
                prompt.style.display = 'none';
                preview.style.display = 'flex';
            }
        }

        function removeFile(e) {
            e.stopPropagation();
            document.getElementById('fileInput').value = '';
            document.getElementById('file-preview').style.display = 'none';
            document.getElementById('upload-prompt').style.display = 'block';
        }

        document.addEventListener('DOMContentLoaded', function() {
            var checkjQuery = setInterval(function() {
                if (window.jQuery) {
                    clearInterval(checkjQuery);
                    initPageLogic();
                }
            }, 100);
        });

        function initPageLogic() {
            console.log("jQuery detectado correctamente. Inicializando...");

            $('select[name="procedureTypeId"]').on('change', function() {
                const id = $(this).val();
                if (!id) {
                    $('#upload-section').hide();
                    $('#no-requirements-msg').hide();
                    return;
                }

                $.get(`/Procedures/Request/GetPaymentRequirements?procedureTypeId=${id}`, function(data) {
                    const hasPaymentReq = data && data.length > 0 && data.some(r => r.isPaymentDoc === true);
                    if (hasPaymentReq) {
                        $('#upload-section').fadeIn();
                        $('#no-requirements-msg').hide();
                    } else {
                        $('#upload-section').hide();
                        $('#no-requirements-msg').fadeIn();
                    }
                });
            });
        }

        function submitPayment() {
            const form = document.getElementById('paymentForm');

            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            const fileInput = document.getElementById('fileInput');
            if (fileInput.files.length === 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Falta el comprobante',
                    text: 'Por favor, adjunta tu boucher o comprobante de pago para continuar.',
                    confirmButtonColor: '#620900'
                });
                return;
            }

            const formData = new FormData(form);

            Swal.fire({
                title: 'Registrando Pago',
                html: 'Estamos procesando tu comprobante y subiéndolo a la nube.<br><b>Por favor, no cierres esta ventana.</b>',
                allowOutsideClick: false,
                showConfirmButton: false,
                color: '#620900',
                didOpen: () => { Swal.showLoading(); }
            });

            $.ajax({
                url: '/Procedures/Request/CreatePaymentValidation',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    Swal.close();
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: '<span style="color:#620900">¡Registro Exitoso!</span>',
                            html: `
                                <div class="mt-3">
                                    <p>Tu comprobante ha sido enviado correctamente.</p>
                                    <div class="p-3 mb-3" style="background-color:#f8f9fa; border-radius:10px; border: 1px solid #dee2e6">
                                        <small class="text-muted d-block">TU FOLIO DE SEGUIMIENTO:</small>
                                        <strong style="font-size: 1.5rem; color:#620900;">${response.folio}</strong>
                                    </div>
                                    <p class="small text-muted">Conserva este folio para consultar el estatus de tu validación en la sección de seguimiento.</p>
                                </div>
                            `,
                            confirmButtonText: '<i class="bi bi-house-door me-2"></i>Ir a Mis Trámites',
                            confirmButtonColor: '#620900',
                            allowOutsideClick: false
                        }).then((result) => {
                            if (result.isConfirmed) {
                                window.location.href = '/Procedures/Request/Tracking';
                            }
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Hubo un problema',
                            html: response.errors.join('<br>'),
                            confirmButtonColor: '#8C1B1B'
                        });
                    }
                },
                error: function() {
                    Swal.close();
                    Swal.fire({
                        icon: 'error',
                        title: 'Error de conexión',
                        text: 'No se pudo contactar con el servidor. Inténtalo más tarde.',
                        confirmButtonColor: '#8C1B1B'
                    });
                }
            });
        }
    </script>
}