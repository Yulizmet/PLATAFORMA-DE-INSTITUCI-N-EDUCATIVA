@model IEnumerable<SchoolManager.Models.procedure_request>
@{
    ViewData["Title"] = "Nueva solicitud";
    Layout = "/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    var newRequest = new SchoolManager.Models.procedure_request();
}

<link rel="stylesheet" href="~/css/tramites.css" asp-append-version="true" />


<div class="form-container area-tramites">
    <div class="container">
        <div class="row justify-content-center p-4">
            <div class="col-lg-12">

                @if (ViewBag.Errors != null)
                {
                    <div class="alert alert-danger shadow-sm border-0 mb-4" style="border-radius: 15px;">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                            <ul class="mb-0">
                                @foreach (var error in ViewBag.Errors)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                @if (ViewBag.UpcomingProcedures != null && ((List<SchoolManager.Models.procedure_types>)ViewBag.UpcomingProcedures).Any())
                {
                    <div class="alert alert-info border-0 shadow-sm mb-4 animate__animated animate__fadeIn" style="border-radius: 15px; background-color: rgba(56, 182, 255, 0.1);">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-calendar-event-fill fs-4 me-3 text-primary"></i>
                            <div>
                                <strong class="d-block text-primary">Próximas aperturas:</strong>
                                <ul class="mb-0 small text-dark">
                                    @foreach (var p in (List<SchoolManager.Models.procedure_types>)ViewBag.UpcomingProcedures)
                                    {
                                        <li><strong>@p.Name:</strong> Disponible a partir del @p.StartDate?.ToString("dd/MM/yyyy hh:mm tt")</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }

                <div class="card card-request">
                    <div class="card-header-burgundy">
                        <div class="d-flex align-items-center">
                            <div class="bg-white rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                <i class="bi bi-file-earmark-plus-fill fs-4" style="color: var(--burgundy);"></i>
                            </div>
                            <h4 class="mb-0 fw-bold merriweather-font">Nueva Solicitud de Trámite</h4>
                        </div>
                    </div>

                    <div class="card-body p-4 p-md-5">
                        <form id="formNewRequest" method="post" enctype="multipart/form-data" asp-action="CreateRequest">
                            @Html.AntiForgeryToken()

                            <div class="row g-4">
                                <div class="col-12">
                                    <h5 class="section-title merriweather-font"><i class="bi bi-info-circle me-2"></i>Información General</h5>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Tipo de Trámite</label>
                                    <select asp-for="@newRequest.IdTypeProcedure" name="IdTypeProcedure" id="ProcedureSelect" class="form-select shadow-sm" asp-items="ViewBag.Procedures" required>
                                        <option value="">-- Selecciona el trámite a realizar --</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Asunto / Título</label>
                                    <input asp-for="@newRequest.Subject" name="Subject" class="form-control shadow-sm" placeholder="Ej: Solicitud de certificado parcial" required />
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Mensaje o Detalles adicionales</label>
                                    <textarea asp-for="@newRequest.Message" name="Message" class="form-control shadow-sm" rows="3" placeholder="Describe brevemente el motivo de tu solicitud..."></textarea>
                                </div>

                                <div id="requirementsContainer" class="col-12 mt-5" style="display: none;">
                                    <h5 class="section-title"><i class="bi bi-cloud-upload me-2"></i>Documentación Requerida</h5>
                                    <div class="requirement-box">
                                        <div id="fileInputsList" class="row g-3">
                                        </div>
                                        <div class="mt-3 text-muted small">
                                            <i class="bi bi-info-circle me-1"></i> Formatos permitidos: PDF, JPG, PNG. Tamaño máximo: 100MB.
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-5 text-center text-md-end border-top pt-4">
                                <a href="/Procedures/Request" class="btn btn-link text-decoration-none text-muted me-md-3 merriweather-font">Cancelar</a>
                                <button type="submit" class="btn btn-send shadow-sm merriweather-font">
                                    <i class="bi bi-send-check me-2"></i>Enviar Solicitud
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $('#ProcedureSelect').on('change', async function() {
            const procedureId = $(this).val();
            const container = $('#requirementsContainer');
            const list = $('#fileInputsList');

            if (!procedureId) {
                container.fadeOut();
                return;
            }

            try {
                const response = await fetch(`/Procedures/Request/GetRequirements?procedureId=${procedureId}`);
                const requirements = await response.json();

                list.empty();

                if (requirements && requirements.length > 0) {
                    requirements.forEach(req => {
                        const inputHtml = `
                            <div class="col-md-6 mb-3">
                                <div class="p-3 border rounded bg-light shadow-sm">
                                    <label class="form-label small fw-bold d-block mb-2">
                                        ${req.documentName} ${req.isRequired ? '<span class="text-danger">*</span>' : '<span class="text-muted fw-normal">(Opcional)</span>'}
                                    </label>
                                    <input type="file" name="formFiles"
                                           class="form-control form-control-sm"
                                           ${req.isRequired ? 'required' : ''}
                                           accept=".pdf,.jpg,.png" />
                                </div>
                            </div>`;
                        list.append(inputHtml);
                    });
                    container.fadeIn();
                    showToast('info', 'Requisitos cargados');
                } else {
                    list.append('<div class="col-12 text-muted p-3"><i class="bi bi-info-circle me-2"></i>Este trámite no requiere adjuntar documentos adicionales.</div>');
                    container.fadeIn();
                }
            } catch (error) {
                console.error("Error al cargar requisitos:", error);
                showToast('error', 'No se pudieron cargar los requisitos');
            }
        });

        function copyFolio(text) {
            navigator.clipboard.writeText(text).then(() => {
                const btn = document.getElementById('btnCopy');
                if (btn) {
                    btn.innerHTML = '<i class="bi bi-check-all"></i> ¡Copiado!';
                    btn.classList.replace('btn-outline-secondary', 'btn-success');
                    btn.classList.add('text-white');
                }
                showToast('success', 'Folio copiado al portapapeles');
            });
        }

        document.getElementById('formNewRequest').addEventListener('submit', async function (e) {
            e.preventDefault();
            const form = e.target;
            const files = form.querySelectorAll('input[type="file"]');
            const maxSize = 50 * 1024 * 1024; // 50MB
            const allowedExtensions = /(\.pdf|\.jpg|\.jpeg|\.png)$/i;

            for (let fileInput of files) {
                if (fileInput.files.length > 0) {
                    const file = fileInput.files[0];
                    if (!allowedExtensions.exec(file.name)) {
                        showToast('error', `Formato no permitido: ${file.name}`);
                        fileInput.classList.add('is-invalid');
                        return;
                    }
                    if (file.size > maxSize) {
                        showToast('warning', `El archivo es demasiado grande (>50MB)`);
                        fileInput.classList.add('is-invalid');
                        return;
                    }
                    fileInput.classList.remove('is-invalid');
                }
            }

            const formData = new FormData(form);

            Swal.fire({
                title: 'Enviando Solicitud',
                text: 'Estamos registrando tu información, por favor espera...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    await Swal.fire({
                        title: '¡Solicitud enviada!',
                        icon: 'success',
                        confirmButtonColor: '#620900',
                        html: `
                            <div class="p-3 border rounded bg-light mb-3 text-center">
                                <p class="mb-1 small text-muted">Tu número de folio es:</p>
                                <h4 style="color: #620900;" class="mb-3 fw-bold">${data.folio}</h4>
                                <button type="button" id="btnCopy" class="btn btn-sm btn-outline-secondary" onclick="copyFolio('${data.folio}')">
                                    <i class="bi bi-clipboard"></i> Copiar Folio
                                </button>
                            </div>
                            <p class="small text-muted text-start">Puedes consultar el avance en la sección de "Seguimiento".</p>
                        `,
                        confirmButtonText: 'Ver mis trámites'
                    });
                    window.location.href = '/Procedures/Request/Tracking';
                } else {
                    Swal.close();
                    showToast('error', data.errors?.join(' ') || 'Error al procesar');
                }
            } catch (error) {
                Swal.close();
                showToast('error', 'Error de conexión con el servidor');
            }
        });
    </script>
}