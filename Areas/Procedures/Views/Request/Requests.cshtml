@model IEnumerable<SchoolManager.Models.procedure_request>
@{
    ViewData["Title"] = "Nueva solicitud";
    Layout = "/Pages/Shared/_Layout.cshtml";
    //Layout = "/MainScreen/Views/Shared/_Layout.cshtml";
    var newRequest = new SchoolManager.Models.procedure_request();
}

<style>
    :root {
        --burgundy: #620900;
        --burgundy-light: #8C1B1B;
    }

    .form-container {
        /*background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);*/
        min-height: 90vh;
        padding-top: 2rem;
        padding-bottom: 2rem;
    }

    .card-request {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    }

    .card-header-burgundy {
        background-color: var(--burgundy);
        color: white;
        padding: 1.5rem;
        border: none;
    }

    .form-label {
        color: var(--burgundy);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 0.75rem;
        border: 1px solid #dee2e6;
        transition: all 0.3s;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--burgundy-light);
            box-shadow: 0 0 0 0.25 core-rgba(77, 2, 23, 0.1);
        }

    .btn-send {
        background-color: var(--burgundy);
        color: white;
        border-radius: 50px;
        padding: 0.8rem 2.5rem;
        font-weight: 600;
        transition: all 0.3s;
        border: none;
    }

        .btn-send:hover {
            background-color: var(--burgundy-light);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(77, 2, 23, 0.3);
        }

    .requirement-box {
        background-color: #fff;
        border-radius: 15px;
        padding: 1.5rem;
        border: 1px dashed #ced4da;
    }

    .section-title {
        color: var(--burgundy);
        border-bottom: 2px solid #f1f1f1;
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
        font-weight: 700;
    }
</style>

<div class="form-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-12">

                @if (ViewBag.Errors != null)
                {
                    <div class="alert alert-danger shadow-sm border-0 mb-4" style="border-radius: 15px;">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                            <ul class="mb-0">
                                @foreach (var error in ViewBag.Errors)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <div class="card card-request">
                    <div class="card-header-burgundy">
                        <div class="d-flex align-items-center">
                            <div class="bg-white rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                <i class="bi bi-file-earmark-plus-fill fs-4" style="color: var(--burgundy);"></i>
                            </div>
                            <h4 class="mb-0 fw-bold">Nueva Solicitud de Trámite</h4>
                        </div>
                    </div>

                    <div class="card-body p-4 p-md-5">
                        <form id="formNewRequest" method="post" enctype="multipart/form-data" asp-action="CreateRequest">
                            @Html.AntiForgeryToken()

                            <div class="row g-4">
                                <div class="col-12">
                                    <h5 class="section-title"><i class="bi bi-info-circle me-2"></i>Información General</h5>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Tipo de Trámite</label>
                                    <select asp-for="@newRequest.IdTypeProcedure" name="IdTypeProcedure" id="ProcedureSelect" class="form-select shadow-sm" asp-items="ViewBag.Procedures" required>
                                        <option value="">-- Selecciona el trámite a realizar --</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Asunto / Título</label>
                                    <input asp-for="@newRequest.Subject" name="Subject" class="form-control shadow-sm" placeholder="Ej: Solicitud de certificado parcial" required />
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Mensaje o Detalles adicionales</label>
                                    <textarea asp-for="@newRequest.Message" name="Message" class="form-control shadow-sm" rows="3" placeholder="Describe brevemente el motivo de tu solicitud..."></textarea>
                                </div>

                                <div id="requirementsContainer" class="col-12 mt-5" style="display: none;">
                                    <h5 class="section-title"><i class="bi bi-cloud-upload me-2"></i>Documentación Requerida</h5>
                                    <div class="requirement-box">
                                        <div id="fileInputsList" class="row g-3">
                                        </div>
                                        <div class="mt-3 text-muted small">
                                            <i class="bi bi-info-circle me-1"></i> Formatos permitidos: PDF, JPG, PNG. Tamaño máximo: 100MB.
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-5 text-center text-md-end border-top pt-4">
                                <a href="/Procedures/Request" class="btn btn-link text-decoration-none text-muted me-md-3">Cancelar</a>
                                <button type="submit" class="btn btn-send shadow-sm">
                                    <i class="bi bi-send-check me-2"></i>Enviar Solicitud
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('#ProcedureSelect').on('change', async function() {
            const procedureId = $(this).val();
            const container = $('#requirementsContainer');
            const list = $('#fileInputsList');

            if (!procedureId) {
                container.fadeOut();
                return;
            }

            try {
                const response = await fetch(`/Procedures/Request/GetRequirements?procedureId=${procedureId}`);
                const requirements = await response.json();

                list.empty();
                if (requirements.length > 0) {
                    requirements.forEach(req => {
                        const inputHtml = `
                            <div class="col-md-6">
                                <div class="p-3 border rounded bg-light shadow-sm">
                                    <label class="form-label small fw-bold d-block mb-2">
                                        ${req.documentName} ${req.isRequired ? '<span class="text-danger">*</span>' : '<span class="text-muted fw-normal">(Opcional)</span>'}
                                    </label>
                                    <input type="file" name="files_${req.documentId}"
                                           class="form-control form-control-sm"
                                           ${req.isRequired ? 'required' : ''}
                                           accept=".pdf,.jpg,.png" />
                                </div>
                            </div>`;
                        list.append(inputHtml);
                    });
                    container.fadeIn();
                } else {
                    list.append('<div class="col-12 text-muted p-3"><i class="bi bi-check-circle-fill text-success me-2"></i>Este trámite no requiere documentos adicionales.</div>');
                    container.fadeIn();
                }
            } catch (error) {
                console.error("Error al cargar requisitos:", error);
            }
        });

        function copyFolio(text) {
            navigator.clipboard.writeText(text).then(() => {
                const btn = document.getElementById('btnCopy');
                if (btn) {
                    btn.innerHTML = '<i class="bi bi-check-all"></i> ¡Copiado!';
                    btn.classList.replace('btn-outline-primary', 'btn-success');
                }
            });
        }

        document.getElementById('formNewRequest').addEventListener('submit', async function (e) {
            e.preventDefault();
            const form = e.target;
            const files = form.querySelectorAll('input[type="file"]');
            const maxSize = 100 * 1024 * 1024;
            const allowedExtensions = /(\.pdf|\.jpg|\.jpeg|\.png|\.txt|\.xml)$/i;

            for (let fileInput of files) {
                if (fileInput.files.length > 0) {
                    const file = fileInput.files[0];
                    if (!allowedExtensions.exec(file.name)) {
                        Swal.fire({ title: 'Archivo no permitido', text: `El archivo "${file.name}" no es válido.`, icon: 'error' });
                        return;
                    }
                    if (file.size > maxSize) {
                        Swal.fire({ title: 'Archivo muy pesado', text: `"${file.name}" supera los 100MB.`, icon: 'error' });
                        return;
                    }
                }
            }

            const formData = new FormData(form);
            Swal.fire({
                title: 'Procesando...',
                text: 'Estamos registrando tu solicitud.',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            try {
                const response = await fetch(form.action, { method: 'POST', body: formData });
                const data = await response.json();

                if (data.success) {
                    await Swal.fire({
                        title: '¡Solicitud enviada!',
                        icon: 'success',
                        confirmButtonColor: '#4D0217',
                        html: `
                            <div class="p-3 border rounded bg-light mb-3 text-center">
                                <p class="mb-1 small text-muted">Tu número de folio es:</p>
                                <h4 style="color: #4D0217;" class="mb-3 fw-bold" id="folioText">${data.folio}</h4>
                                <button type="button" id="btnCopy" class="btn btn-sm btn-outline-secondary" onclick="copyFolio('${data.folio}')">
                                    <i class="bi bi-clipboard"></i> Copiar Folio
                                </button>
                            </div>
                            <p class="small text-muted text-start">Recibirás actualizaciones en tu correo institucional.</p>
                        `,
                        confirmButtonText: 'Ir a Mis Trámites'
                    });
                    window.location.href = '/Procedures/Request/Tracking';
                } else {
                    Swal.fire('Error', data.errors?.join('<br>') || 'Error desconocido', 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'No se pudo conectar con el servidor.', 'error');
            }
        });
    </script>
}