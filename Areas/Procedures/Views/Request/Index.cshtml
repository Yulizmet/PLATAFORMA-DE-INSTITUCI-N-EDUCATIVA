@{
    ViewData["Title"] = "Solicitudes";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="row g-4 w-100 justify-content-center">
        <div class="col-md-5 col-lg-4">
            <a asp-action="Requests" class="card h-100 text-center shadow-sm text-decoration-none transition-hover border-success border-top border-4">
                <div class="card-body py-5">
                    <i class="bi bi-file-earmark-plus text-success" style="font-size: 4rem;"></i>
                    <h4 class="card-title mt-3 text-dark">Solicitar Documento</h4>
                    <p class="text-muted">Inicia un nuevo trámite y sube tus requisitos.</p>
                </div>
            </a>
        </div>

        <div class="col-md-5 col-lg-4">
            <a asp-action="Tracking" class="card h-100 text-center shadow-sm text-decoration-none transition-hover border-primary border-top border-4">
                <div class="card-body py-5">
                    <i class="bi bi-search text-primary" style="font-size: 4rem;"></i>
                    <h4 class="card-title mt-3 text-dark">Consultar Trámite</h4>
                    <p class="text-muted">Revisa el folio y el estado actual de tus solicitudes.</p>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .transition-hover:hover {
        transform: translateY(-10px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }        
</style>