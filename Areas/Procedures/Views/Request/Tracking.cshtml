@model IEnumerable<SchoolManager.Models.procedure_request>
@{
    ViewData["Title"] = "Mis trámites";
    Layout = "/Pages/Shared/_Layout.cshtml";
}


<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold">Mis Trámites</h2>
        <a asp-action="Requests" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Nueva Solicitud
        </a>
    </div>
    @Html.AntiForgeryToken()
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Folio</th>
                            <th>Fecha</th>
                            <th>Trámite</th>
                            <th>Asunto</th>
                            <th>Estado</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-primary">@item.Folio</td>
                                <td class="small">@item.DateUpdated.ToString("dd/MM/yyyy")</td>
                                <td>@item.ProcedureType?.Name</td>
                                <td class="text-truncate" style="max-width: 200px;" title="@item.Message">
                                    <strong>@item.Subject</strong>
                                </td>
                                <td>
                                    @if (item.ProcedureStatus != null)
                                    {
                                        <span class="badge" 
                                              style="background-color: @item.ProcedureStatus.BackgroundColor; 
                                                     color: @item.ProcedureStatus.TextColor;
                                                     padding: 0.5em 1em;
                                                     border-radius: 50px;
                                                     font-weight: 600;
                                                     border: 1px solid rgba(0,0,0,0.1);">
                                            @item.ProcedureStatus.Name
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border">N/A</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <button class="btn btn-sm btn-info text-white shadow-sm"
                                                title="Ver Detalles"
                                                onclick="loadModal('/Procedures/Request/TrackingDetails/@item.Id')">
                                            <i class="bi bi-info-circle-fill"></i>
                                        </button>

                                        @{
                                            var tieneDocs = item.ProcedureDocuments != null && item.ProcedureDocuments.Any();
                                            var primerDoc = tieneDocs ? item.ProcedureDocuments!.First() : null;
                                        }

                                        <a href="@(tieneDocs && primerDoc != null ? primerDoc.FilePath : "#")"
                                           download="@(tieneDocs && primerDoc != null ? primerDoc.Name : "")"
                                           target="_blank"
                                           class="btn btn-sm @(tieneDocs ? "btn-warning text-white" : "btn-light text-muted opacity-50") shadow-sm"
                                           title="@(tieneDocs && primerDoc != null ? "Descargar: " + primerDoc.Name : "Sin archivos adjuntos")"
                                           style="@(tieneDocs ? "" : "pointer-events: none; cursor: default;")">
                                            <i class="bi bi-file-earmark-arrow-down-fill"></i>
                                        </a>

                                        @if (item.IdStatus != 3 && item.IdStatus != 5)
                                        {
                                            <button type="button" class="btn btn-sm btn-danger shadow-sm"
                                                    onclick="confirmCancel(@item.Id, '@item.Folio')"
                                                    title="Cancelar Trámite">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function loadModal(url) {
            $.get(url, function (data) {
                $('#dynamicModal').remove();
                const modalHtml = `
                    <div class="modal fade" id="dynamicModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-lg modal-dialog-centered">
                            <div class="modal-content border-0 shadow-lg">${data}</div>
                        </div>
                    </div>`;
                $('body').append(modalHtml);
                const myModal = new bootstrap.Modal(document.getElementById('dynamicModal'));
                myModal.show();
            }).fail(function() {
                Swal.fire('Error', 'No se pudo cargar el detalle.', 'error');
            });
        }

        function previewFile(url, fileName) {
            const ext = url.split('.').pop().toLowerCase();
            let content = '';

            if (ext === 'pdf') {
                content = `<embed src="${url}" type="application/pdf" width="100%" height="600px" />`;
            } else if (['jpg', 'jpeg', 'png'].includes(ext)) {
                content = `<img src="${url}" class="img-fluid" />`;
            } else {
                content = `<iframe src="${url}" width="100%" height="500px"></iframe>`;
            }

            Swal.fire({
                title: fileName,
                html: content,
                width: '80%',
                showCloseButton: true,
                showConfirmButton: false
            });
        }

        async function confirmCancel(id, folio) {
            const result = await Swal.fire({
                title: '¿Cancelar trámite?',
                text: `Se cancelará la solicitud con folio ${folio}.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Sí, cancelar'
            });

            if (result.isConfirmed) {
                const token = $('input[name="__RequestVerificationToken"]').val();
                const response = await fetch(`/Procedures/Request/CancelRequest/${id}`, {
                    method: 'POST',
                    headers: { "RequestVerificationToken": token }
                });
                const data = await response.json();
                if (data.success) {
                    Swal.fire('Cancelado', 'Trámite cancelado.', 'success').then(() => location.reload());
                } else {
                    Swal.fire('Error', 'No se pudo procesar.', 'error');
                }
            }
        }

        const formRequest = document.getElementById('formNewRequest');
        if (formRequest) {
            formRequest.addEventListener('submit', function (e) {
                const files = this.querySelectorAll('input[type="file"]');
                const maxSize = 100 * 1024 * 1024; // 100MB
                const allowedExtensions = /(\.pdf|\.jpg|\.jpeg|\.png|\.txt|\.xml)$/i;

                for (let fileInput of files) {
                    if (fileInput.files.length > 0) {
                        const file = fileInput.files[0];
                        if (!allowedExtensions.exec(file.name)) {
                            e.preventDefault();
                            Swal.fire('Error', `Extensión no válida: ${file.name}`, 'error');
                            return;
                        }
                        if (file.size > maxSize) {
                            e.preventDefault();
                            Swal.fire('Error', `El archivo ${file.name} supera los 100MB`, 'error');
                            return;
                        }
                    }
                }
            });
        }
    </script>
}