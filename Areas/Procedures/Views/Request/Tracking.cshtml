@model IEnumerable<SchoolManager.Models.procedure_request>
@{
    ViewData["Title"] = "Mis trámites";
    Layout = "/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/tramites.css" asp-append-version="true" />

<div class="tracking-container area-tramites">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="burgundy-color fw-bolder mb-1">
                    <i class="bi bi-journal-text me-2"></i>Mis Trámites
                </h2>
                <p class="text-muted small mb-0">Consulta el historial y estado de tus solicitudes vigentes.</p>
            </div>
            <a asp-action="Requests" class="btn btn-burgundy px-4 shadow-sm" style="background-color: var(--burgundy); color: white; border-radius: 50px; font-weight: 600;">
                <i class="bi bi-plus-lg me-2"></i>Nueva Solicitud
            </a>
        </div>

        @Html.AntiForgeryToken()

        <div class="card table-custom border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="custom-table-header">
                            <tr>
                                <th class="ps-4">Folio</th>
                                <th>Fecha Registro</th>
                                <th>Tipo de Trámite</th>
                                <th>Asunto</th>
                                <th>Estado</th>
                                <th class="text-center pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                                        Aún no has realizado ninguna solicitud.
                                    </td>
                                </tr>
                            }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold text-dark">@item.Folio</span>
                                    </td>
                                    <td class="text-muted small">
                                        <i class="bi bi-calendar3 me-1"></i> @item.DateUpdated.ToString("dd/MM/yyyy")
                                    </td>
                                    <td>
                                        <div class="fw-bold small text-dark">@item.ProcedureType?.Name</div>
                                    </td>
                                    <td>
                                        <div class="text-truncate small" style="max-width: 180px;" title="@item.Subject">
                                            @item.Subject
                                        </div>
                                    </td>
                                    <td>
                                        @if (item.ProcedureFlow?.ProcedureStatus != null)
                                        {
                                            <span class="status-badge shadow-sm"
                                                  style="background-color: @(item.ProcedureFlow.ProcedureStatus.BackgroundColor ?? "#6c757d");
                                     color: @(item.ProcedureFlow.ProcedureStatus.TextColor ?? "#ffffff");">
                                                @item.ProcedureFlow.ProcedureStatus.Name
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="d-flex justify-content-center gap-2">
                                            <button class="btn btn-action btn-info text-white"
                                                    title="Ver Detalles"
                                                    onclick="loadModal('/Procedures/Request/TrackingDetails/@item.Id')">
                                                <i class="bi bi-eye-fill"></i>
                                            </button>

                                            @{
                                                var tieneDocs = item.ProcedureDocuments != null && item.ProcedureDocuments.Any();
                                                var ultimoDoc = tieneDocs ? item.ProcedureDocuments!.Last() : null;
                                            }

                                            <a href="@(tieneDocs? ultimoDoc!.FilePath : "javascript:void(0)")"
                                               target="@(tieneDocs ? "_blank" : "")"
                                               class="btn btn-action @(tieneDocs ? "btn-warning text-white" : "btn-light text-muted opacity-50")"
                                               title="@(tieneDocs ? "Descargar respuesta/archivo" : "No hay archivos adjuntos")"
                                               style="@(tieneDocs ? "" : "cursor: not-allowed;")"
                                               @(tieneDocs ? "" : "disabled")>
                                                <i class="bi bi-cloud-download-fill"></i>
                                            </a>

                                            @if (item.ProcedureFlow?.ProcedureStatus?.Name != "Finalizado" &&
                                                                                    item.ProcedureFlow?.ProcedureStatus?.Name != "Cancelado")
                                            {
                                                <button type="button" class="btn btn-action btn-danger"
                                                        onclick="confirmCancel(@item.Id, '@item.Folio')"
                                                        title="Cancelar Trámite">
                                                    <i class="bi bi-x-circle-fill"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function loadModal(url) {
            $.get(url, function (data) {
                $('#dynamicModal').remove();
                const modalHtml = `
                    <div class="modal fade" id="dynamicModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-lg modal-dialog-centered">
                            <div class="modal-content border-0 shadow-lg">${data}</div>
                        </div>
                    </div>`;
                $('body').append(modalHtml);
                const myModal = new bootstrap.Modal(document.getElementById('dynamicModal'));
                myModal.show();
            }).fail(function() {
                Swal.fire('Error', 'No se pudo cargar el detalle.', 'error');
            });
        }

        function previewFile(url, fileName) {
            const ext = url.split('.').pop().toLowerCase();
            let content = '';

            if (ext === 'pdf') {
                content = `<embed src="${url}" type="application/pdf" width="100%" height="600px" />`;
            } else if (['jpg', 'jpeg', 'png'].includes(ext)) {
                content = `<img src="${url}" class="img-fluid" />`;
            } else {
                content = `<iframe src="${url}" width="100%" height="500px"></iframe>`;
            }

            Swal.fire({
                title: fileName,
                html: content,
                width: '80%',
                showCloseButton: true,
                showConfirmButton: false
            });
        }

        async function confirmCancel(id, folio) {
            const result = await Swal.fire({
                title: '¿Cancelar trámite?',
                text: `Se cancelará la solicitud con folio ${folio}.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Sí, cancelar',
                cancelButtonText: 'Salir'
            });

            if (result.isConfirmed) {
                const token = $('input[name="__RequestVerificationToken"]').val();
                const response = await fetch(`/Procedures/Request/CancelRequest/${id}`, {
                    method: 'POST',
                    headers: { "RequestVerificationToken": token }
                });
                const data = await response.json();
                if (data.success) {
                    Swal.fire('Cancelado', 'Trámite cancelado.', 'success').then(() => location.reload());
                } else {
                    Swal.fire('Error', 'No se pudo procesar.', 'error');
                }
            }
        }

        const formRequest = document.getElementById('formNewRequest');
        if (formRequest) {
            formRequest.addEventListener('submit', function (e) {
                const files = this.querySelectorAll('input[type="file"]');
                const maxSize = 100 * 1024 * 1024; // 100MB
                const allowedExtensions = /(\.pdf|\.jpg|\.jpeg|\.png|\.txt|\.xml)$/i;

                for (let fileInput of files) {
                    if (fileInput.files.length > 0) {
                        const file = fileInput.files[0];
                        if (!allowedExtensions.exec(file.name)) {
                            e.preventDefault();
                            Swal.fire('Error', `Extensión no válida: ${file.name}`, 'error');
                            return;
                        }
                        if (file.size > maxSize) {
                            e.preventDefault();
                            Swal.fire('Error', `El archivo ${file.name} supera los 100MB`, 'error');
                            return;
                        }
                    }
                }
            });
        }
    </script>
}