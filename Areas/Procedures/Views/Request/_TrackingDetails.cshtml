@model SchoolManager.Models.procedure_request

<div class="modal-header burgundy-header text-white border-0 py-3 area-tramites">
    <div class="d-flex align-items-center">
        <div class="bg-white rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
            <i class="bi bi-search burgundy-color fs-5"></i>
        </div>
        <div>
            <h5 class="modal-title fw-bold mb-0">Detalles de Seguimiento</h5>
            <small class="opacity-75">Folio: @Model.Folio</small>
        </div>
    </div>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body px-4 bg-light">
    <div class="row mb-4 mt-2">
        <div class="col-md-7">
            <label class="text-muted small d-block text-uppercase fw-bold">Trámite</label>
            <span class="fw-bold text-dark fs-5">@Model.ProcedureType?.Name</span>
            <p class="text-muted small mb-0">@Model.Subject</p>
        </div>
        <div class="col-md-5 text-md-end">
            <label class="text-muted small d-block text-uppercase fw-bold">Fecha de Registro</label>
            <span class="text-secondary">@Model.DateUpdated.ToString("dd MMMM yyyy, hh:mm tt")</span>
        </div>
    </div>

    <div class="alert d-flex align-items-center border-0 shadow-sm mb-4"
         style="background-color: @Model.ProcedureFlow?.ProcedureStatus?.BackgroundColor; color: @Model.ProcedureFlow?.ProcedureStatus?.TextColor; border-radius: 15px;">
        <i class="bi bi-info-circle-fill me-3 fs-4"></i>
        <div>
            <small class="d-block opacity-75 fw-bold text-uppercase" style="font-size: 0.65rem;">Estatus del proceso</small>
            <span class="fw-bold fs-5">@Model.ProcedureFlow?.ProcedureStatus?.Name</span>
        </div>
    </div>

    <div class="mb-4">
        <h6 class="fw-bold burgundy-color border-bottom pb-2 mb-3">
            <i class="bi bi-chat-left-text-fill me-2"></i>Historial de Respuestas
        </h6>
        <div class="timeline-detail p-1" style="max-height: 250px; overflow-y: auto;">

            <div class="p-3 bg-white rounded shadow-sm border-start border-4 border-primary mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <small class="fw-bold text-primary text-uppercase">Tú (Remitente)</small>
                    <small class="text-muted italic">Mensaje inicial</small>
                </div>
                <p class="mb-0 text-dark small">@(string.IsNullOrEmpty(Model.Message) ? "Sin mensaje adicional." : Model.Message)</p>
            </div>

            @if (Model.ProcedureMonitorings != null && Model.ProcedureMonitorings.Any())
            {
                @foreach (var step in Model.ProcedureMonitorings.OrderByDescending(s => s.DateUpdated))
                {
                    <div class="p-3 bg-white rounded shadow-sm border-start border-4 mb-2"
                         style="border-color: @step.ProcedureFlow?.ProcedureStatus?.BackgroundColor !important;">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <small class="fw-bold burgundy-color text-uppercase">Respuesta Administrativa</small>
                            <small class="text-muted" style="font-size: 0.7rem;">@step.DateUpdated.ToString("g")</small>
                        </div>
                        <p class="mb-1 text-dark small">@step.Comment</p>
                        <span class="badge rounded-pill" style="font-size: 0.6rem; background-color: @step.ProcedureFlow?.ProcedureStatus?.BackgroundColor; color: @step.ProcedureFlow?.ProcedureStatus?.TextColor">
                            Cambió a: @step.ProcedureFlow?.ProcedureStatus?.Name
                        </span>
                    </div>
                }
            }
        </div>
    </div>

    <div class="mb-2">
        <h6 class="fw-bold burgundy-color border-bottom pb-2 mb-3">
            <i class="bi bi-file-earmark-arrow-down-fill me-2"></i>Documentación del Trámite
        </h6>
        <div class="row g-2">
            @if (Model.ProcedureDocuments != null && Model.ProcedureDocuments.Any())
            {
                @foreach (var doc in Model.ProcedureDocuments)
                {
                    string ext = System.IO.Path.GetExtension(doc.Name).ToLower();
                    string iconClass = ext switch
                    {
                        ".pdf" => "bi-filetype-pdf text-danger",
                        ".jpg" or ".jpeg" or ".png" => "bi-file-earmark-image text-primary",
                        _ => "bi-file-earmark-text text-muted"
                    };

                    <div class="col-12">
                        <a href="@doc.FilePath" target="_blank" class="text-decoration-none">
                            <div class="d-flex align-items-center p-2 bg-white border rounded shadow-sm hover-bg-light transition-all">
                                <i class="bi @iconClass fs-3 me-3"></i>
                                <div class="flex-grow-1">
                                    <span class="d-block text-dark fw-bold small">@doc.Name</span>
                                    <small class="text-muted" style="font-size: 0.7rem;">Haga clic para previsualizar</small>
                                </div>
                                <i class="bi bi-chevron-right text-muted px-2"></i>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-3 bg-white rounded border">
                    <p class="text-muted small mb-0 italic">No hay documentos adjuntos en este trámite.</p>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal-footer border-0 bg-light rounded-bottom">
    <button type="button" class="btn btn-burgundy text-white px-5 rounded-pill shadow-sm" data-bs-dismiss="modal">Entendido</button>
</div>