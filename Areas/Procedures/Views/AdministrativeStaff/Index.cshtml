@model IEnumerable<SchoolManager.Areas.Procedures.ViewModels.StaffViewModel>

@{
    ViewData["Title"] = "Gestión de Personal";
    Layout = "_ProceduresLayout";

    bool HasPermission(string buttonName) =>
        ViewBag.UserPermissions != null && ((List<string>)ViewBag.UserPermissions).Contains(buttonName);

}

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <partial name="_DataTableConfig" />

    <script>
        function editStaff(id) {
            window.location.href = '/Procedures/AdministrativeStaff/EditAdministrativeStaff/' + id;
        }

        function loadEditStaffModal(id) {
            $.get('/Procedures/AdministrativeStaff/Edit/' + id, function (data) {
                $('#modalContainer').html(data);
                const modalElement = document.getElementById('editStaffModal');
                const myModal = new bootstrap.Modal(modalElement);
                myModal.show();

                $('#formEditStaff').on('submit', function(e) {
                    e.preventDefault();
                    const form = $(this);
                    $.post(form.attr('action'), form.serialize(), function(response) {
                        if(response.success) {
                            myModal.hide();
                            showToast('success', response.message || '¡Actualizado!');
                            setTimeout(() => { location.reload(); }, 1000);
                        } else {
                            showToast('error', response.message || 'Error al actualizar');
                        }
                    });
                });
            });
        }

        function loadDeactivateModal(id) {
            $.get('/Procedures/AdministrativeStaff/Deactivate/' + id, function (data) {
                $('#modalContainer').html(data);
                const modalElement = document.getElementById('deactivateModal');
                const myModal = new bootstrap.Modal(modalElement);
                myModal.show();
            });
        }

        function loadActivateModal(id) {
            $.get('/Procedures/AdministrativeStaff/Activate/' + id, function (data) {
                $('#modalContainer').html(data);
                const modalElement = document.getElementById('activateModal');
                const myModal = new bootstrap.Modal(modalElement);
                myModal.show();
            });
        }

        function loadCreateStaffModal() {
            $.get('/Procedures/AdministrativeStaff/Create', function (data) {
                $('#modalContainer').html(data);
                const modalElement = document.getElementById('createStaffModal');
                const myModal = new bootstrap.Modal(modalElement);
                myModal.show();
                $(modalElement).on('shown.bs.modal', function () {
                    $('#UserSearch').select2({
                        dropdownParent: $(modalElement),
                        theme: 'bootstrap-5',
                        ajax: {
                            url: '/Procedures/AdministrativeStaff/SearchUsers',
                            dataType: 'json',
                            delay: 250,
                            data: function (params) { return { term: params.term }; },
                            processResults: function (data) { return { results: data }; }
                        },
                        minimumInputLength: 3
                    });
                });
                $('#formCreateStaff').on('submit', function (e) {
                    e.preventDefault();
                    const form = $(this);
                    $.post(form.attr('action'), form.serialize(), function (response) {
                        if (response.success) {
                            myModal.hide();
                            showToast('success', response.message || '¡Éxito!');
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            showToast('error', response.message || 'Error al crear');
                        }
                    });
                });
            });
        }

        function loadQuickUserModal() {
            $.get('/Procedures/AdministrativeStaff/QuickAddUser', function (data) {
                $('#modalContainer').html(data);
                const modalElement = document.getElementById('quickUserModal');
                const myModal = new bootstrap.Modal(modalElement);
                myModal.show();

                $('#QuickCreateStaff').on('submit', function (e) {
                    e.preventDefault();
                    const form = $(this);

                    $.post(form.attr('action'), form.serialize(), function (response) {
                        if (response.success) {
                            myModal.hide();
                            showToast('success', response.message || '¡Éxito!');
                            setTimeout(() => { location.reload(); }, 1000);
                        } else {
                            showToast('error', response.message || 'Error en la creación rápida');
                        }
                    }).fail(function() {
                        showToast('error', 'No se pudo conectar con el servidor');
                    });
                });
            });
        }

        function confirmDeactivateLogic() {
            const form = $('#formDeactivateStaff');
            $.post('/Procedures/AdministrativeStaff/DeactivateStaff', form.serialize(), function (response) {
                if (response.success) {
                    showToast('success', response.message || '¡Éxito!');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast('error', response.message || 'Error al desactivar');
                }
            });
        }

        function confirmActivateLogic() {
            const form = $('#formActivateStaff');
            $.post('/Procedures/AdministrativeStaff/ActivateStaff', form.serialize(), function (response) {
                if (response.success) {
                    showToast('success', 'Personal reactivado');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast('error', response.message || 'Error al activar');
                }
            });
        }

        $(document).ready(function () {
            $(document).on('change', '#checkAll', function () {
                const isChecked = $(this).is(':checked');
                $('.row-checkbox').prop('checked', isChecked);
                $('.row-checkbox').closest('tr').toggleClass('table-active', isChecked);
                updateBulkBar();
            });

            $(document).on('change', '.row-checkbox', function () {
                const total = $('.row-checkbox').length;
                const selected = $('.row-checkbox:checked').length;
                $('#checkAll').prop('checked', total === selected);
                $(this).closest('tr').toggleClass('table-active', $(this).is(':checked'));
                updateBulkBar();
            });
        });

        function updateBulkBar() {
            const count = $('.row-checkbox:checked').length;
            const bar = $('#bulkActionsBar');

            if (count > 0) {
                const text = count === 1 ? '1 seleccionado' : count + ' seleccionados';
                $('#selectedCount').text(text);
                bar.removeClass('d-none').fadeIn('fast');
            } else {
                bar.fadeOut('fast', function() {
                    $(this).addClass('d-none');
                });
                $('#checkAll').prop('checked', false);
            }
        }

        function deselectAll() {
            $('.row-checkbox, #checkAll').prop('checked', false).closest('tr').removeClass('table-active');
            updateBulkBar();
        }

        function bulkDeleteStaff() {
            const selectedIds = $('.row-checkbox:checked').map(function() {
                return parseInt($(this).val());
            }).get();

            Swal.fire({
                title: '¿Retirar personal seleccionado?',
                html: `Se eliminarán <b>${selectedIds.length}</b> registros de la plantilla administrativa. <br><small class="text-muted">El acceso al módulo de trámites será revocado para estos usuarios.</small>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#620900',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Procesando...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

                    $.ajax({
                        url: '/Procedures/AdministrativeStaff/BulkDelete',
                        type: 'POST',
                        data: {
                            ids: selectedIds,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (r) {
                            Swal.close();
                            if (r.success) {
                                showToast('success', r.message || '¡Éxito!');
                                setTimeout(() => location.reload(), 1000);
                            } else {
                                showToast('error', r.message || 'Error al eliminar');
                            }
                        }
                    });
                }
            });
        }

        function fillTestData() {
            const random = Math.floor(Math.random() * 1000);
            $('input[name="FirstName"]').val("Usuario");
            $('input[name="LastNamePaternal"]').val("Prueba");
            $('input[name="LastNameMaternal"]').val("Staff");
            $('input[name="Curp"]').val("CURP" + random + random + "XXXXXX00");
            $('input[name="Email"]').val("test" + random + "@@email.com");
            $('input[name="Username"]').val("user.test" + random);
        }
    </script>
}

<div id="modalContainer"></div>

<div class="container-fluid px-4 py-4 pt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0 merriweather-font">
                <i class="bi bi-people"></i> Gestión de Personal
            </h2>
            <p class="text-muted mb-0">Administra a los responsables de cada área y sus permisos.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-burgundy shadow-sm"
                    onclick="@(HasPermission("btn-agregar") ? "loadQuickUserModal()" : "")"
                    @(HasPermission("btn-agregar") ? "" : "disabled")
                    title="@(HasPermission("btn-agregar") ? "Añadir Personal" : "Sin permiso para añadir")">
                <i class="bi bi-plus-circle me-1"></i> Añadir Personal
            </button>

            <button class="btn btn-burgundy shadow-sm"
                    onclick="@(HasPermission("btn-asignar") ? "loadCreateStaffModal()" : "")"
                    @(HasPermission("btn-asignar") ? "" : "disabled")
                    title="@(HasPermission("btn-asignar") ? "Asignar Personal" : "Sin permiso para asignar")">
                <i class="bi bi-person-plus-fill me-2"></i> Asignar Personal
            </button>
        </div>
    </div>

    <partial name="_TableTools" />

    <div class="border-0 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="mainTable" class="table table-hover align-middle mb-0 table-container-rounded">
                    <thead class="bg-burgundy text-white">
                        <tr>
                            <th class="no-sort text-center"> <input type="checkbox" id="checkAll" class="form-check-input"> </th>
                            <th class="ps-4">Personal</th>
                            <th>Área Responsable</th>
                            <th>Puesto</th>
                            <th>Roles</th>
                            <th class="text-center">Estatus</th>
                            <th class="no-sort text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="table-white">
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.IsActive ? "" : "opacity-50 bg-light")">
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input row-checkbox" value="@item.Id" />
                                </td>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle bg-burgundy text-white me-3">
                                            @item.Initials
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.FullName</div>
                                            <div class="small text-muted">@item.Username</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-info-subtle text-info border border-info-subtle rounded-pill px-3">
                                        @item.AreaName
                                    </span>
                                </td>
                                <td>
                                    <span class="text-dark fw-medium">
                                        @item.JobPositionName
                                    </span>
                                </td>
                                <td>
                                    @foreach (var role in item.Roles)
                                    {
                                        <small class="d-block text-muted text-uppercase" style="font-size: 0.7rem;">
                                            <i class="bi bi-shield-check me-1"></i>@role
                                        </small>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.IsSuperAdmin)
                                    {
                                        <span class="status-badge bg-superadmin text-warning border border-warning">
                                            <i class="bi bi-star-fill me-1"></i>SuperAdmin
                                        </span>
                                    }
                                    else if (item.IsActive)
                                    {
                                        <span class="status-badge bg-active text-success border border-sucess">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge bg-inactive text-danger border border-danger">
                                            Baja
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        @if (item.IsActive)
                                        {
                                            <a asp-controller="AdministrativeStaff" asp-action="DetailsStaff" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-light border shadow-sm me-2 @(HasPermission("btn-detalles") ? "" : "disabled")"
                                               title="@(HasPermission("btn-detalles") ? "Ver Detalles" : "Sin acceso a detalles")">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                            <a asp-controller="AdministrativeStaff" asp-action="EditAdministrativeStaff" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-light border shadow-sm me-2 @(HasPermission("btn-editar") ? "" : "disabled")"
                                               title="@(HasPermission("btn-editar") ? "Editar Persona" : "Sin permiso para editar")">
                                                <i class="bi bi-pencil-square text-warning"></i>
                                            </a>

                                            <button class="btn btn-sm btn-light border shadow-sm me-2"
                                                    onclick="@(HasPermission("btn-editar-asignacion") ? $"loadEditStaffModal({item.Id})" : "")"
                                                    @(HasPermission("btn-editar-asignacion") ? "" : "disabled")
                                                    title="@(HasPermission("btn-editar-asignacion") ? "Asignar Área" : "Sin permiso de asignación")">
                                                <i class="bi bi-plus-circle text-success"></i>
                                            </button>

                                            <button class="btn btn-sm btn-light border shadow-sm"
                                                    onclick="@(HasPermission("btn-desactivar") ? $"loadDeactivateModal({item.Id})" : "")"
                                                    @(HasPermission("btn-desactivar") ? "" : "disabled")
                                                    title="@(HasPermission("btn-desactivar") ? "Dar de Baja" : "Sin permiso para dar de baja")">
                                                <i class="bi bi-person-x-fill text-danger"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-light border shadow-sm me-2 opacity-50" disabled><i class="bi bi-eye-slash text-muted"></i></button>
                                            <button class="btn btn-sm btn-light border shadow-sm me-2 opacity-50" disabled><i class="bi bi-pencil text-muted"></i></button>
                                            <button class="btn btn-sm btn-light border shadow-sm me-2 opacity-50" disabled><i class="bi bi-plus-square text-muted"></i></button>

                                            <button class="btn btn-sm btn-light border shadow-sm"
                                                    onclick="@(HasPermission("btn-activar") ? $"loadActivateModal({item.Id})" : "")"
                                                    @(HasPermission("btn-activar") ? "" : "disabled")
                                                    title="@(HasPermission("btn-activar") ? "Reactivar" : "Sin permiso para activar")">
                                                <i class="bi bi-person-check-fill text-success"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="bulkActionsBar" class="position-fixed bottom-0 start-50 translate-middle-x mb-4 shadow-lg bg-dark text-white p-3 rounded-pill d-none animate__animated animate__fadeInUp" style="z-index: 1050; min-width: 300px;">
        <div class="d-flex align-items-center justify-content-between px-3">
            <span id="selectedCount" class="fw-bold me-4">0 seleccionados</span>
            <div class="btn-group">
                @if (HasPermission("btn-multiple-eliminar"))
                    {
                        <button class="btn btn-danger btn-sm rounded-pill" onclick="bulkDeleteStaff()">
                            <i class="bi bi-trash-fill me-1"></i> Eliminar
                        </button>
                    }
            </div>
            <button type="button" class="btn-close btn-close-white ms-3" onclick="deselectAll()"></button>
        </div>
    </div>
</div>