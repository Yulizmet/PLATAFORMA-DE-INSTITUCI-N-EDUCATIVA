@model SchoolManager.Areas.Procedures.ViewModels.StaffViewModel

<div class="modal fade" id="deactivateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-person-dash me-2"></i>Revocar Permisos Administrativos</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <i class="bi bi-shield-slash text-danger" style="font-size: 4rem;"></i>
                <h4 class="fw-bold mt-3">¿Inactivar este perfil?</h4>
                <p class="mb-1">Se removerán las facultades administrativas de:</p>
                <p class="fs-5 fw-bold text-burgundy">@Model.FullName</p>

                <div class="badge fw-bold text-info border border-danger-subtle p-2 mb-3">
                    <span class="text-dark">Área a desactivar:</span> @Model.AreaName
                </div>

                <div class="alert alert-danger small mx-3 mt-2">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                    El usuario <strong>NO podrá gestionar trámites</strong> de esta área, pero su cuenta de sistema general permanecerá intacta.
                </div>
            </div>
            <div class="modal-footer bg-light">
                <form id="formDeactivateStaff">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" onclick="confirmDeactivateLogic()" class="btn btn-danger rounded-pill px-4">Confirmar Inactivación</button>
                </form>
            </div>
        </div>
    </div>
</div>