@model SchoolManager.Areas.Procedures.ViewModels.DashboardViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Panel de Control";
    Layout = "_ProceduresLayout";
    var espanol = new CultureInfo("es-MX");
}

<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Panel de Control Institucional</h2>
        <span class="text-muted">
            @DateTime.Now.ToString("dddd dd 'de' MMMM 'de' yyyy", espanol)
        </span>
    </div>

    <!-- TARJETAS -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card shadow border-0 h-100"
                 style="border-left:6px solid #8C1B1B;">
                <div class="card-body">
                    <h6 class="text-muted">Total de Solicitudes</h6>
                    <h2 class="fw-bold">@Model.TotalRequests</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 h-100"
                 style="border-left:6px solid #B1A596;">
                <div class="card-body">
                    <h6 class="text-muted">Acción Requerida</h6>
                    <h2 class="fw-bold">@Model.ActionRequired</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 h-100"
                 style="border-left:6px solid #620900;">
                <div class="card-body">
                    <h6 class="text-muted">En Curso</h6>
                    <h2 class="fw-bold">@Model.InProgress</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 h-100"
                 style="border-left:6px solid #8C1B1B;">
                <div class="card-body">
                    <h6 class="text-muted">Finalizadas</h6>
                    <h2 class="fw-bold">@Model.Cancelled</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card shadow border-0 p-3 h-100">
                <h5 class="fw-bold mb-3">Distribución de Solicitudes</h5>
                <div class="chart-container">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow border-0 p-3 h-100">
                <h5 class="fw-bold mb-3">Solicitudes por Mes</h5>
                <div class="chart-container">
                    <canvas id="monthChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const commonOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                position: 'bottom'
            }
        }
    };

    const statusChart = new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: ['Acción requerida', 'En curso', 'Finalizadas'],
            datasets: [{
                data: [@Model.ActionRequired, @Model.InProgress, @Model.Cancelled],
                backgroundColor: ['#8C1B1B', '#B1A596', '#620900']
            }]
        },
        options: commonOptions
    });

    const monthChart = new Chart(document.getElementById('monthChart'), {
        type: 'line',
        data: {
            labels: ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'],
            datasets: [{
                label: 'Solicitudes',
                data: @Html.Raw(Json.Serialize(Model.MonthlyRequests)),
                borderColor: '#8C1B1B',
                backgroundColor: 'rgba(140,27,27,0.2)',
                fill: true,
                tension: 0.4
            }]
        },
        options: commonOptions
    });
</script>