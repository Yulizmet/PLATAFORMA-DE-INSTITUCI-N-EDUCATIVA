@model SchoolManager.Areas.Procedures.ViewModels.DashboardViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Panel de Control";
    Layout = "_ProceduresLayout";
    var espanol = new CultureInfo("es-MX");
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-dark merriweather-font">Panel de Control Institucional</h2>
            <p class="text-muted mb-0">
                <i class="bi bi-calendar3 me-2"></i>
                @{
                    var fecha = DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy", espanol);
                    @char.ToUpper(fecha[0])
                    @fecha.Substring(1)
                }
            </p>
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center gap-2">
                <span class="fw-bold small text-uppercase text-muted">Área:</span>
                <form method="get" class="bg-white px-2 py-1 rounded-3 shadow-sm border">
                    <input type="hidden" name="year" value="@Model.SelectedYear" />
                    <select name="areaId" onchange="this.form.submit()" class="form-select form-select-sm border-0 fw-bold" style="min-width:150px; cursor:pointer;">
                        <option value="">Todas las Áreas</option>
                        @foreach (var area in ViewBag.Areas)
                        {
                            <option value="@area.Id" selected="@(area.Id == ViewBag.SelectedArea)">@area.Name</option>
                        }
                    </select>
                </form>
            </div>

            <div class="d-flex align-items-center gap-2">
                <span class="fw-bold small text-uppercase text-muted">Periodo:</span>
                <form method="get" class="bg-white px-2 py-1 rounded-3 shadow-sm border">
                    <input type="hidden" name="areaId" value="@ViewBag.SelectedArea" />
                    <select name="year" onchange="this.form.submit()" class="form-select form-select-sm border-0 fw-bold" style="width:100px; cursor:pointer;">
                        @for (int i = DateTime.Now.Year; i >= 2023; i--)
                        {
                            <option value="@i" selected="@(i == Model.SelectedYear)">@i</option>
                        }
                    </select>
                </form>
            </div>
        </div>
    </div>

    @* --- CARDS DE MÉTRICAS --- *@
    <div class="row g-3 mb-5">
        <div class="col-xl col-md-4">
            <div class="card card-metric shadow-sm h-100 accent-total p-3">
                <i class="bi bi-stack position-absolute end-0 bottom-0 m-2 opacity-25 display-4" style="color: #8C1B1B;"></i>
                <h6 class="text-muted small fw-bold text-uppercase position-relative" style="z-index: 2;">Total Solicitudes</h6>
                <h2 class="fw-bold mb-0 position-relative" style="z-index: 2;">@Model.TotalRequests</h2>
            </div>
        </div>

        <div class="col-xl col-md-4">
            <div class="card card-metric shadow-sm h-100 accent-action p-3">
                <i class="bi bi-exclamation-triangle-fill position-absolute end-0 bottom-0 m-2 opacity-25 display-4" style="color: #ffde59;"></i>
                <h6 class="text-muted small fw-bold text-uppercase position-relative" style="z-index: 2;">Acción Requerida</h6>
                <h2 class="fw-bold mb-0 position-relative" style="z-index: 2;">@Model.ActionRequired</h2>
            </div>
        </div>

        <div class="col-xl col-md-4">
            <div class="card card-metric shadow-sm h-100 accent-course p-3">
                <i class="bi bi-clock-history position-absolute end-0 bottom-0 m-2 opacity-25 display-4" style="color: #38b6ff;"></i>
                <h6 class="text-muted small fw-bold text-uppercase position-relative" style="z-index: 2;">En Curso</h6>
                <h2 class="fw-bold mb-0 position-relative" style="z-index: 2;">@Model.InProgress</h2>
            </div>
        </div>

        <div class="col-xl col-md-6">
            <div class="card card-metric shadow-sm h-100 accent-done p-3">
                <i class="bi bi-check-circle-fill position-absolute end-0 bottom-0 m-2 opacity-25 display-4" style="color: #7ed957;"></i>
                <h6 class="text-muted small fw-bold text-uppercase position-relative" style="z-index: 2;">Finalizadas</h6>
                <h2 class="fw-bold mb-0 position-relative" style="z-index: 2;">@Model.Done</h2>
            </div>
        </div>

        <div class="col-xl col-md-6">
            <div class="card card-metric shadow-sm h-100 accent-cancel p-3">
                <i class="bi bi-x-circle-fill position-absolute end-0 bottom-0 m-2 opacity-25 display-4" style="color: #ff3131;"></i>
                <h6 class="text-muted small fw-bold text-uppercase position-relative" style="z-index: 2;">Canceladas</h6>
                <h2 class="fw-bold mb-0 position-relative" style="z-index: 2;">@Model.Cancelled</h2>
            </div>
        </div>
    </div>

    @* --- FILA 1 DE GRÁFICAS --- *@
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 p-4 h-100">
                <h5 class="fw-bold mb-4"><i class="bi bi-graph-up me-2"></i>Tendencia Mensual</h5>
                <div style="height: 300px;"><canvas id="monthChart"></canvas></div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="card shadow-sm border-0 p-4 h-100">
                <h5 class="fw-bold mb-4"><i class="bi bi-pie-chart me-2"></i>Estatus</h5>
                <div style="height: 300px;"><canvas id="statusChart"></canvas></div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="card shadow-sm border-0 p-4 h-100">
                <h5 class="fw-bold mb-4 text-center"><i class="bi bi-clock-history me-2"></i>Eficiencia</h5>
                <div style="height: 200px;"><canvas id="efficiencyChart"></canvas></div>
                <div class="mt-3 small text-center">
                    <div class="text-muted">Resolución: <strong>@Model.AvgResolutionTime</strong></div>
                    <div class="text-muted">Espera (Abiertos): <strong>@Model.AvgWaitTime</strong></div>
                </div>
            </div>
        </div>
    </div>

    @* --- FILA 2 DE GRÁFICAS --- *@
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 p-4 h-100">
                <h5 class="fw-bold mb-4"><i class="bi bi-building me-2"></i>Por Área</h5>
                <div style="height: 300px;"><canvas id="areaChart"></canvas></div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 p-4 h-100">
                <h5 class="fw-bold mb-4"><i class="bi bi-list-stars me-2"></i>Top 5 Trámites</h5>
                <div style="height: 300px;"><canvas id="typeChart"></canvas></div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 p-4 h-100">
                <h5 class="fw-bold mb-4"><i class="bi bi-bar-chart-steps me-2"></i>Flujo Acumulado</h5>
                <div style="height: 300px;"><canvas id="flowChart"></canvas></div>
            </div>
        </div>
    </div>
</div>

<script>
    const commonOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                position: 'bottom',
                labels: { boxWidth: 12, padding: 15, font: { size: 11 } }
            },
            tooltip: {
                backgroundColor: 'rgba(0,0,0,0.8)',
                padding: 10,
                cornerRadius: 6
            }
        }
    };

    // Nueva paleta de colores vibrantes
    const variedBarColors = [
        '#7ed957', // Verde Success
        '#38b6ff', // Azul Info
        '#ffde59', // Amarillo Warning
        '#ff3131', // Rojo Danger
        '#620900', // Burgundy Institucional
        '#B1A596'  // Beige Neutro
    ];

    // --- GENERACIÓN DE GRÁFICAS ---

    // 1. Tendencia Mensual (Línea)
    new Chart(document.getElementById('monthChart'), {
        type: 'line',
        data: {
            labels: ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'],
            datasets: [{
                label: 'Solicitudes',
                data: @Html.Raw(Json.Serialize(Model.MonthlyRequests)),
                borderColor: '#7ed957',
                backgroundColor: 'rgba(126, 217, 87, 0.1)',
                fill: true,
                tension: 0.4,
                pointRadius: 3,
                pointBackgroundColor: '#7ed957',
                pointBorderColor: '#fff',
                pointBorderWidth: 2
            }]
        },
        options: {
            ...commonOptions,
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.05)' } },
                x: { grid: { display: false } }
            }
        }
    });

    // 2. Estatus (Doughnut) - Usamos la nueva paleta
    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: ['Acción requerida', 'En curso', 'Finalizadas', 'Canceladas'],
            datasets: [{
                data: [@Model.ActionRequired, @Model.InProgress, @Model.Done, @Model.Cancelled],
                backgroundColor: [variedBarColors[2], variedBarColors[1], variedBarColors[0], '#6c757d']
            }]
        },
        options: commonOptions
    });

    // 3. Eficiencia (Barra comparativa)
    new Chart(document.getElementById('efficiencyChart'), {
        type: 'bar',
        data: {
            labels: ['Resolución (Cerrados)', 'Espera (Abiertos)'],
            datasets: [{
                data: [@Model.AvgResolutionHours, @Model.AvgWaitHours],
                backgroundColor: [variedBarColors[0], variedBarColors[3]],
                borderRadius: 6
            }]
        },
        options: {
            ...commonOptions,
            plugins: { ...commonOptions.plugins, legend: { display: false } },
            scales: {
                y: { beginAtZero: true, title: { display: true, text: 'Horas Totales', font: { weight: 'bold' } } },
                x: { grid: { display: false } }
            }
        }
    });

    // 4. Por Área (Barra Horizontal)
    new Chart(document.getElementById('areaChart'), {
        type: 'bar',
        data: {
            labels: @Html.Raw(Json.Serialize(Model.RequestsByArea.Keys)),
            datasets: [{
                label: 'Solicitudes',
                data: @Html.Raw(Json.Serialize(Model.RequestsByArea.Values)),
                backgroundColor: variedBarColors[1], // Azul Info
                borderRadius: 5
            }]
        },
        options: {
            ...commonOptions,
            indexAxis: 'y',
            plugins: { ...commonOptions.plugins, legend: { display: false } },
            scales: {
                x: { beginAtZero: true, grid: { display: false }, ticks: { stepSize: 1, precision: 0 } },
                y: { grid: { display: false }, ticks: { font: { size: 10 } } }
            }
        }
    });

    // 5. Top 5 Trámites (Barra Vertical) - Colores Variados
    new Chart(document.getElementById('typeChart'), {
        type: 'bar',
        data: {
            labels: @Html.Raw(Json.Serialize(Model.RequestsByType.Keys)),
            datasets: [{
                label: 'Cantidad',
                data: @Html.Raw(Json.Serialize(Model.RequestsByType.Values)),
                backgroundColor: variedBarColors,
                borderRadius: 6
            }]
        },
        options: {
            ...commonOptions,
            plugins: { ...commonOptions.plugins, legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.05)' } },
                x: { grid: { display: false }, ticks: { font: { size: 10 } } }
            }
        }
    });

    // 6. Flujo Acumulado (Stacked)
    new Chart(document.getElementById('flowChart'), {
        type: 'bar',
        data: {
            labels: ['Estado Actual'],
            datasets: [
                { label: 'Acción Requerida', data: [@Model.ActionRequired], backgroundColor: variedBarColors[2] },
                { label: 'En curso', data: [@Model.InProgress], backgroundColor: variedBarColors[1] },
                { label: 'Finalizadas', data: [@Model.Done], backgroundColor: variedBarColors[0] },
                { label: 'Canceladas', data: [@Model.Cancelled], backgroundColor: '#6c757d' }
            ]
        },
        options: {
            ...commonOptions,
            scales: {
                x: { stacked: true, grid: { display: false } },
                y: { stacked: true, beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } }
            }
        }
    });
</script>