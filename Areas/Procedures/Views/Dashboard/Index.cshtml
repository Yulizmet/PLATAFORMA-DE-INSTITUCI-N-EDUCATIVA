@model SchoolManager.Areas.Procedures.ViewModels.DashboardViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Panel de Control";
    Layout = "_ProceduresLayout";
    var espanol = new CultureInfo("es-MX");
}

<style>
    body {
        background: #f4f7f6;
    }

    .card {
        border-radius: 15px;
        transition: 0.3s;
        position: relative;
        overflow: hidden;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .card-icon {
        position: absolute;
        right: 15px;
        top: 15px;
        opacity: 0.15;
        font-size: 2.2rem;
    }

    .chart-container {
        position: relative;
        height: 300px;
        width: 100%;
    }

    .accent-total {
        border-left: 6px solid #8C1B1B !important;
    }

    .accent-action {
        border-left: 6px solid #B1A596 !important;
    }

    .accent-course {
        border-left: 6px solid #620900 !important;
    }

    .accent-done {
        border-left: 6px solid #28a745 !important;
    }

    .accent-cancel {
        border-left: 6px solid #6c757d !important;
    }
</style>

<div class="container-fluid px-4 py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Panel de Control Institucional</h2>
            <p class="text-muted mb-0">
                <i class="bi bi-calendar3 me-2"></i>
                @{
                    var fecha = DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy", espanol);
                    @char.ToUpper(fecha[0])
                    @fecha.Substring(1)
                }
            </p>
        </div>

        <div class="d-flex align-items-center gap-2">
            <span class="fw-bold small text-uppercase text-muted" style="letter-spacing: 1px;">Periodo:</span>
            <form method="get" class="d-flex align-items-center bg-white px-2 py-1 rounded-3 shadow-sm border">
                <select name="year" onchange="this.form.submit()" class="form-select form-select-sm border-0 fw-bold" style="width:100px; cursor:pointer; background-color: transparent;">
                    @for (int i = DateTime.Now.Year; i >= 2023; i--)
                    {
                        <option value="@i" selected="@(i == Model.SelectedYear)">@i</option>
                    }
                </select>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-xl col-md-4">
            <div class="card shadow-sm border-0 h-100 accent-total">
                <div class="card-body">
                    <i class="bi bi-files card-icon"></i>
                    <h6 class="text-muted small fw-bold">TOTAL SOLICITUDES</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalRequests</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4">
            <div class="card shadow-sm border-0 h-100 accent-action">
                <div class="card-body">
                    <i class="bi bi-person-exclamation card-icon"></i>
                    <h6 class="text-muted small fw-bold">ACCIÓN REQUERIDA</h6>
                    <h2 class="fw-bold mb-0">@Model.ActionRequired</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4">
            <div class="card shadow-sm border-0 h-100 accent-course">
                <div class="card-body">
                    <i class="bi bi-gear-wide-connected card-icon"></i>
                    <h6 class="text-muted small fw-bold">EN CURSO</h6>
                    <h2 class="fw-bold mb-0">@Model.InProgress</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-6">
            <div class="card shadow-sm border-0 h-100 accent-done">
                <div class="card-body">
                    <i class="bi bi-check-circle card-icon"></i>
                    <h6 class="text-muted small fw-bold">FINALIZADAS</h6>
                    <h2 class="fw-bold mb-0">@Model.Done</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-6">
            <div class="card shadow-sm border-0 h-100 accent-cancel">
                <div class="card-body">
                    <i class="bi bi-x-octagon card-icon"></i>
                    <h6 class="text-muted small fw-bold">CANCELADAS</h6>
                    <h2 class="fw-bold mb-0">@Model.Cancelled</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 p-4 h-100">
                <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-graph-up me-2"></i>Tendencia Mensual</h5>
                <div class="chart-container"><canvas id="monthChart"></canvas></div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 p-4 h-100">
                <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-pie-chart me-2"></i>Estatus Actual</h5>
                <div class="chart-container"><canvas id="statusChart"></canvas></div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 p-4 h-100">
                <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-building me-2"></i>Solicitudes por Área</h5>
                <div class="chart-container"><canvas id="areaChart"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 p-4 h-100">
                <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-list-stars me-2"></i>Top 5 Trámites</h5>
                <div class="chart-container"><canvas id="typeChart"></canvas></div>
            </div>
        </div>
    </div>
</div>

<script>
        const commonOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { position: 'bottom' }
        }
    };

    const integerScales = {
        y: {
            beginAtZero: true,
            ticks: {
                stepSize: 1,
                precision: 0
            }
        }
    };

    // Gráfica Mensual
       new Chart(document.getElementById('monthChart'), {
        type: 'line',
        data: {
            labels: ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'],
            datasets: [{
                label: 'Solicitudes',
                data: @Html.Raw(Json.Serialize(Model.MonthlyRequests)),
                borderColor: '#8C1B1B',
                backgroundColor: 'rgba(140,27,27,0.1)',
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            ...commonOptions,
            scales: {
                y: { ...integerScales.y, grid: { display: true } },
                x: { grid: { display: false } }
            }
        }
    });

    // Gráfica de Estatus
        new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: ['Acción requerida', 'En curso', 'Finalizadas', 'Canceladas'],
            datasets: [{
                data: [@Model.ActionRequired, @Model.InProgress, @Model.Done, @Model.Cancelled],
                backgroundColor: ['#B1A596', '#620900', '#28a745', '#6c757d']
            }]
        },
        options: {
            ...commonOptions,
            cutout: '50%'
        }
    });

    // Gráfica por Área
        new Chart(document.getElementById('areaChart'), {
        type: 'bar',
        data: {
            labels: @Html.Raw(Json.Serialize(Model.RequestsByArea.Keys)),
            datasets: [{
                label: 'Total',
                data: @Html.Raw(Json.Serialize(Model.RequestsByArea.Values)),
                backgroundColor: '#620900',
                borderRadius: 5
            }]
        },
        options: {
            indexAxis: 'y',
            ...commonOptions,
            scales: {
                x: {
                    beginAtZero: true,
                    ticks: { stepSize: 1, precision: 0 },
                    grid: { display: false }
                },
                y: { grid: { display: false } }
            }
        }
    });

    // Gráfica por Tipo
        new Chart(document.getElementById('typeChart'), {
        type: 'bar', // Cambiado de polarArea a bar para limpieza total
        data: {
            labels: @Html.Raw(Json.Serialize(Model.RequestsByType.Keys)),
            datasets: [{
                label: 'Cantidad',
                data: @Html.Raw(Json.Serialize(Model.RequestsByType.Values)),
                backgroundColor: ['#620900', '#8C1B1B', '#B1A596', '#D4D2D2', '#6c757d'],
                borderRadius: 5
            }]
        },
        options: {
            ...commonOptions,
            scales: {
                y: { ...integerScales.y },
                x: { grid: { display: false } }
            }
        }
    });
</script>