@model SchoolManager.Models.procedure_status
@{
    Layout = null;
}
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <form method="post" action="/Procedures/ProcedureStatus/Edit">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-warning py-3">
                    <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2"></i>Editar Configuración de Estado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Nombre del Estado</label>
                        <input asp-for="Name" id="Name" class="form-control border-2" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="InternalCode" class="form-label fw-bold">Código Interno</label>
                        <input asp-for="InternalCode" class="form-control border-2 bg-light" required readonly />
                        <div class="form-text small text-danger">El código interno no debe cambiarse si ya hay trámites en curso.</div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsTerminalState" id="IsTerminalState">
                                <label class="form-check-label fw-bold" for="IsTerminalState">¿Finalizado?</label>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActionRequiredByUser" id="IsActionRequiredByUser">
                                <label class="form-check-label fw-bold" for="IsActionRequiredByUser">¿Acción Alumno?</label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="BackgroundColor" class="form-label fw-bold">Fondo (Hex)</label>
                            <input type="color" asp-for="BackgroundColor" id="BackgroundColor" class="form-control form-control-color w-100 shadow-sm" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="TextColor" class="form-label fw-bold">Texto (Hex)</label>
                            <input type="color" asp-for="TextColor" id="TextColor" class="form-control form-control-color w-100 shadow-sm" />
                        </div>
                    </div>

                    <div class="mt-3 p-3 border rounded-3 bg-light text-center">
                        <span class="text-muted small d-block mb-2">Vista previa actualizada:</span>
                        <span id="previewBadge" class="badge px-4 py-2 shadow-sm" style="background-color: @Model.BackgroundColor; color: @Model.TextColor; font-size: 0.9rem; border-radius: 20px;">
                            @Model.Name
                        </span>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4 fw-bold" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning px-5 shadow-sm fw-bold">Actualizar Datos</button>
                </div>
            </form>
        </div>
    </div>
</div>