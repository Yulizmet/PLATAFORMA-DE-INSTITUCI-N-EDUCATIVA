@model SchoolManager.Models.procedure_status
@{
    Layout = null;
}
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form method="post" action="/Procedures/ProcedureStatus/Edit">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Editar estado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Nombre del Estado</label>
                        <input asp-for="Name" class="form-control" placeholder="Ej: En Revisión" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="StepOrder" class="form-label fw-bold">Orden en el Proceso</label>
                        <input type="number" asp-for="StepOrder" class="form-control" min="1" />
                        <div class="form-text">Define la secuencia lógica del trámite.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="BackgroundColor" class="form-label fw-bold">Fondo (Hex)</label>
                            <div class="d-flex align-items-center gap-2">
                                <input type="color" asp-for="BackgroundColor" class="form-control form-control-color shadow-sm" />
                                <span class="text-muted small">Fondo</span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="TextColor" class="form-label fw-bold">Texto (Hex)</label>
                            <div class="d-flex align-items-center gap-2">
                                <input type="color" asp-for="TextColor" class="form-control form-control-color shadow-sm" />
                                <span class="text-muted small">Fuente</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3 p-3 border rounded bg-light text-center">
                        <span class="text-muted small d-block mb-2">Vista previa del indicador:</span>
                        <span id="previewBadge" class="badge px-3 py-2" style="background-color: @Model.BackgroundColor; color: @Model.TextColor;">
                            @Model.Name
                        </span>
                    </div>
                </div>
                <div class="modal-footer bg-light border-top-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning px-4 shadow-sm"> Guardar </button>
                </div>
            </form>
        </div>
    </div>
</div>