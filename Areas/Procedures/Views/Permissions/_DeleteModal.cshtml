@model dynamic

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-trash3 me-2"></i>¿Confirmar eliminación?
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body text-center p-4">
                <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
                <h4 class="fw-bold mt-1">¡Atención!</h4>
                <p class="mb-1 text-muted">Estás a punto de borrar:</p>

                <h5 class="text-burgundy fw-bold my-2 p-2 rounded">
                    @ViewBag.ItemName
                </h5>

                <p class="text-dark small mb-1 px-3">
                    Esta acción eliminará <strong>@(ViewBag.IsModuleGroup == true ? "el módulo y todos sus botones asociados" : "el botón seleccionado")</strong>.
                    <span class="text-danger d-block mt-2">No se puede deshacer.</span>
                </p>
            </div>

            <div class="modal-footer border-0 bg-light justify-content-end pb-4">
                <button type="button" class="btn btn-light rounded-pill px-4 me-2" data-bs-dismiss="modal">
                    Cancelar
                </button>

                <form id="formDeleteGeneric" method="post" action="@ViewBag.ActionUrl">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@ViewBag.ItemId" />

                    @if (ViewBag.IsModuleGroup == true)
                    {
                        <input type="hidden" name="moduleName" value="@ViewBag.ItemName" />
                    }

                    <button type="submit" class="btn btn-danger rounded-pill px-4 flex-end">
                        Eliminar permanentemente
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>