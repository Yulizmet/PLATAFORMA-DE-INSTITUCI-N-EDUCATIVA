@model List<SchoolManager.Areas.Procedures.Models.procedure_job_position>

@{
    bool HasPermission(string buttonName) =>
        ViewBag.UserPermissions != null && ((List<string>)ViewBag.UserPermissions).Contains(buttonName);
}

<div class="table-responsive">
    <table id="mainTable" class="table mt-2 mb-2 table-hover table-container-rounded dataTable no-footer">
        <thead class="small bg-burgundy text-white">
            <tr>
                <th class="no-sort text-center"> <input type="checkbox" id="checkAll" class="form-check-input"> </th>
                <th>Nombre del Puesto</th>
                <th>Descrpción del Puesto</th>
                <th>Fecha Registro</th>
                <th class="no-sort text-center pe-4">Acciones</th>
            </tr>
        </thead>
        <tbody class="table-white">
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center">
                        <input type="checkbox" class="form-check-input row-checkbox" value="@item.Id" />
                    </td>
                    <td class="fw-bold">@item.Name</td>
                    <td>@item.Description</td>
                    <td class="text-center small text-muted"><i class="bi bi-clock-history me-1"></i> @item.CreatedAt.ToString("dd/MM/yyyy hh:mm tt")</td>
                    <td class="text-center pe-4">
                        <div class="btn-group">
                            <button class="btn btn-sm btn-light border shadow-sm me-2"
                                    onclick="@(HasPermission("btn-editar-puesto") ? $"loadJobModal({item.Id})" : "")"
                                    @(HasPermission("btn-editar-puesto") ? "" : "disabled")
                                    title="@(HasPermission("btn-editar-puesto") ? "Editar" : "Sin permiso para editar puestos")">
                                <i class="bi bi-pencil-square text-warning"></i>
                            </button>
                            <button class="btn btn-sm btn-light border shadow-sm"
                                    onclick="@(HasPermission("btn-eliminar-puesto") ? $"openDeleteModal({item.Id})" : "")"
                                    @(HasPermission("btn-eliminar-puesto") ? "" : "disabled")
                                    title="@(HasPermission("btn-eliminar-puesto") ? "Eliminar" : "Sin permiso para eliminar puestos")">
                                <i class="bi bi-trash3 text-danger"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="3" class="text-center py-4 text-muted italic">
                        No hay puestos registrados en el catálogo.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
