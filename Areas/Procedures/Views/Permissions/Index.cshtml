@model List<SchoolManager.Areas.Procedures.Models.procedure_permission>

@{
    ViewData["Title"] = "Gestión de Permisos";
    Layout = "_ProceduresLayout";

    bool HasPermission(string buttonName) =>
        ViewBag.UserPermissions != null && ((List<string>)ViewBag.UserPermissions).Contains(buttonName);
}

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <partial name="_DataTableConfig" />

    <script>
        $(document).ready(function() {
            let activeTab = localStorage.getItem('activeGestorTab');
            if (activeTab) {
                $(`#mainGestorTabs button[data-bs-target="${activeTab}"]`).tab('show');
            }

            $('button[data-bs-toggle="pill"]').on('shown.bs.tab', function (e) {
                localStorage.setItem('activeGestorTab', $(e.target).attr('data-bs-target'));
            });

            $(document).on('change', '#checkAll', function () {
                const isChecked = $(this).is(':checked');
                $('.row-checkbox').prop('checked', isChecked);
                $('.row-checkbox').closest('tr').toggleClass('table-active', isChecked);
                updateBulkBar();
            });

            $(document).on('change', '.row-checkbox', function () {
                const total = $('.row-checkbox').length;
                const selected = $('.row-checkbox:checked').length;
                $('#checkAll').prop('checked', total === selected);
                $(this).closest('tr').toggleClass('table-active', $(this).is(':checked'));
                updateBulkBar();
            });

            refreshTables();
        });

        function refreshTables() {
            const catalogUrl = '@Url.Action("GetCatalogTable", "Permissions")';
            const jobsUrl = '@Url.Action("GetJobsTable", "Permissions")';

            $("#catalogTableContainer").load(catalogUrl, function(response, status, xhr) {
                if (status === "error") console.error("Error cargando Catálogo:", xhr.status, xhr.statusText);
            });

            $("#jobsTableContainer").load(jobsUrl, function(response, status, xhr) {
                if (status === "success") {
                    initGlobalDataTable('#mainTable');
                } else {
                    console.error("Error cargando Puestos:", xhr.status, xhr.statusText);
                }
            });
        }

        window.loadModal = async function(url) {
            try {
                const response = await fetch(url);
                if (!response.ok) throw new Error(`Error: ${response.status}`);
                const html = await response.text();
                const container = document.getElementById('modalContainer');
                container.innerHTML = html;

                const modalElement = container.querySelector('.modal');
                if (modalElement) {
                    const myModal = new bootstrap.Modal(modalElement);
                    myModal.show();
                }
            } catch (error) {
                showToast('error', 'No se pudo cargar la ventana');
            }
        };

        window.loadModuleModal = function(id = 0, moduleName = '') {
            const cleanModuleName = encodeURIComponent(moduleName);
            const url = `@Url.Action("GetModuleModal", "Permissions")?id=${id}&moduleName=${cleanModuleName}`;
            loadModal(url);
        };

        window.loadJobModal = function(id = 0) {
            const url = '@Url.Action("GetJobModal", "Permissions")?id=' + id;
            loadModal(url);
        };

        window.loadAssignJobModal = function() {
            const idArea = '@ViewBag.SelectedAreaId';
            if (!idArea || idArea === '0') {
                showToast('warning', 'Por favor, selecciona un área administrativa primero.');
                return;
            }
            const url = '@Url.Action("GetAssignJobModal", "Permissions")?idArea=' + idArea;
            loadModal(url);
        };

        window.openDeleteModal = function(id, type, groupName = '') {
            const url = '@Url.Action("GetDeleteModal", "Permissions")';
            const encodedGroupName = encodeURIComponent(groupName);
            loadModal(`${url}?id=${id}&type=${type}&groupName=${encodedGroupName}`);
        };

        $(document).off("submit", ".modal form").on("submit", ".modal form", async function (e) {
            e.preventDefault();
            const form = e.target;
            try {
                const response = await fetch(form.action, {
                    method: form.method,
                    body: new FormData(form)
                });
                const result = await response.json();
                if (result.success) {
                    const modalInstance = bootstrap.Modal.getInstance(form.closest('.modal'));
                    if(modalInstance) modalInstance.hide();
                    showToast('success', result.message || '¡Cambios guardados!');
                    setTimeout(() => { location.reload(); }, 1500);
                } else {
                    showToast('warning', result.message || 'No se puede procesar la solicitud.');
                }
            } catch (error) {
                showToast('error', 'Error en el servidor');
            }
        });

        function filterByArea(idArea) {
            if (idArea) {
                window.location.href = '@Url.Action("Index", "Permissions")?idArea=' + idArea;
            }
        }

        function initModules(idArea) {
            if (!idArea) {
                showToast('error', 'ID de área no válido.');
                return;
            }
            Swal.fire({
                title: '¿Generar matriz base?',
                text: "Se crearán reglas de acceso para todos los módulos en esta área.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#620900',
                confirmButtonText: 'Sí, generar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("InitModules", "Permissions")', { idArea: idArea }, function (r) {
                        if (r.success) {
                            showToast('success', r.message);
                            setTimeout(() => { location.reload(); }, 1500);
                        } else {
                            showToast('warning', r.message);
                        }
                    });
                }
            });
        }

        $(document).on("submit", "#formPermissions", async function (e) {
            e.preventDefault();
            const form = e.target;

            Swal.fire({
                title: 'Guardando matriz...',
                text: 'Actualizando permisos y accesos, por favor espere.',
                allowOutsideClick: false,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            try {
                const response = await fetch(form.action, {
                    method: form.method,
                    body: new FormData(form)
                });

                const result = await response.json();

                Swal.close();

                if (result.success) {
                    showToast('success', result.message || '¡Matriz de permisos actualizada!');
                    setTimeout(() => { location.reload(); }, 1500);
                } else {
                    showToast('warning', result.message || 'Error al guardar los permisos.');
                }
            } catch (error) {
                Swal.close();
                showToast('error', 'Error de comunicación con el servidor');
            }
        });

        function updateBulkBar() {
            const count = $('.row-checkbox:checked').length;
            const bar = $('#bulkActionsBar');

            if (count > 0) {
                $('#selectedCount').text(count === 1 ? '1 seleccionado' : count + ' seleccionados');
                bar.removeClass('d-none').show();
            } else {
                bar.hide().addClass('d-none');
                $('#checkAll').prop('checked', false);
            }
        }

        function deselectAll() {
            $('.row-checkbox, #checkAll').prop('checked', false).closest('tr').removeClass('table-active');
            updateBulkBar();
        }

        function bulkDelete() {
            const selectedIds = $('.row-checkbox:checked').map(function() {
                return parseInt($(this).val());
            }).get();
            if (selectedIds.length === 0) return;
            Swal.fire({
                title: '¿Eliminar puestos seleccionados?',
                html: `Estás por eliminar <b>${selectedIds.length}</b> registros de forma permanente.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#620900',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("BulkDeleteJobs", "Permissions")',
                        type: 'POST',
                        data: {
                            ids: selectedIds,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (r) {
                            if (r.success) {
                                showToast('success', r.message);
                                setTimeout(() => { location.reload(); }, 1500);
                            } else {
                                showToast('error', r.message);
                            }
                        }
                    });
                }
            });
        }

        $(document).on('change', '.master-check', function () {
            const isChecked = $(this).is(':checked');
            const targetGroup = $(this).data('target-group');
            $(`.child-check-${targetGroup}`).prop('checked', isChecked);
        });

        $(document).on('change', '[class^="child-check-"]', function () {
            if ($(this).is(':checked')) {
                const modId = $(this).attr('class').split('child-check-')[1].split(' ')[0];
                $(`.master-check[data-target-group="${modId}"]`).prop('checked', true);
            }
        });
    </script>
}

<div id="modalContainer"></div>

<div class="container-fluid px-4 pt-5">
    <div class="mb-4">
        <h2 class="fw-bold text-dark mb-1 merriweather-font">
            <i class="bi bi-shield-lock"></i> Matriz de Permisos
        </h2>
        <p class="text-muted small">Configura el catálogo global y asigna accesos específicos por departamento.</p>
    </div>

    <ul class="nav nav-pills nav-pills-burgundy mb-4 p-2 rounded-4" id="mainGestorTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#catalog-pane" type="button" role="tab">
                <i class="bi bi-collection-play me-0 me-md-2"></i>
                <span class="d-none d-md-inline">Módulos y Botones</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#jobs-pane" type="button" role="tab">
                <i class="bi bi-person-vcard me-0 me-md-2"></i>
                <span class="d-none d-md-inline">Puestos de trabajo</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#permissions-pane" type="button" role="tab">
                <i class="bi bi-shield-lock-fill me-0 me-md-2"></i>
                <span class="d-none d-md-inline">Matriz de Permisos</span>
            </button>
        </li>
    </ul>

    <div class="tab-content" id="mainGestorContent">
        @* PESTAÑA 1 *@
        <div class="tab-pane fade show active" id="catalog-pane" role="tabpanel">
            <div class="card border-0 shadow-sm mb-4 rounded-4 overflow-hidden border-start border-4 border-burgundy">
                <div class="card-body bg-light" style="padding: 1.5rem !important">
                    <div class="row align-items-center">
                        <div class="col-md-7 col-12">
                            <h5 class="mb-0 fw-bold text-dark merriweather-font">
                                <i class="bi bi-collection-play me-2 text-burgundy"></i> Catálogo Global de Apartados
                            </h5>
                            <p class="text-muted small mb-0">Gestiona los elementos base que aparecerán en las matrices.</p>
                        </div>

                        <div class="col-md-5 col-12 text-end mt-2 mt-md-0">
                            <button class="btn btn-burgundy btn-sm px-4 shadow-sm"
                                    onclick="@(HasPermission("btn-agregar-modulo") ? "loadModuleModal(0)" : "")"
                                    @(HasPermission("btn-agregar-modulo") ? "" : "disabled")
                                    title="@(HasPermission("btn-agregar-modulo") ? "Agregar Módulo" : "Sin permiso para crear módulos")">
                                <i class="bi bi-plus-circle me-1"></i> Agregar Módulo
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-0" id="catalogTableContainer">
                </div>
            </div>
        </div>

        @* PESTAÑA 2 *@
        <partial name="_TableTools" />
        <div class="tab-pane fade" id="jobs-pane" role="tabpanel">
            <div class="card border-0 shadow-sm mb-4 rounded-4 overflow-hidden border-start border-4 border-burgundy">
                <div class="card-body bg-light" style="padding: 1.5rem !important">
                    <div class="row align-items-center">
                        <div class="col-md-7 col-12">
                            <h5 class="mb-0 fw-bold text-dark merriweather-font">
                                <i class="bi bi-person-vcard me-2 text-burgundy"></i> Puestos Registrados
                            </h5> 
                            <p class="text-muted small mb-0">Define los perfiles laborales para la asignación de accesos.</p>
                        </div>
                        <div class="col-md-5 col-12 text-end mt-2 mt-md-0">
                            <button class="btn btn-burgundy btn-sm px-4 shadow-sm"
                                    onclick="@(HasPermission("btn-agregar-puesto") ? "loadJobModal()" : "")"
                                    @(HasPermission("btn-agregar-puesto") ? "" : "disabled")
                                    title="@(HasPermission("btn-agregar-puesto") ? "Nuevo Puesto" : "Sin permiso para crear puestos")">
                                <i class="bi bi-person-plus me-1"></i> Nuevo Puesto
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="border-0 overflow-hidden">
                <div class="card-body p-0" id="jobsTableContainer">
                </div>
            </div>
        </div>

        @* PESTAÑA 3 *@
        <div class="tab-pane fade" id="permissions-pane" role="tabpanel">
            <div class="card border-0 shadow-sm mb-4 rounded-4 overflow-hidden border-start border-4 border-burgundy">
                <div class="card-body bg-light" style="padding: 1.5rem !important">
                    <div class="row align-items-center">
                        <div class="col-md-7">
                            <div class="input-group">
                                <span class="input-group-text bg-white" style="border-radius: 10px 0px 0px 10px !important"><i class="bi bi-building"></i></span>
                                <select class="form-select fw-bold border-0" asp-items="ViewBag.Areas" onchange="filterByArea(this.value)" style="border: 1px solid #ced4da !important">
                                    <option value="">-- Selecciona área --</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-12 col-md-5 d-flex flex-column flex-md-row justify-content-md-end align-items-end align-items-md-center gap-2 mt-2 mt-md-0">
                            @if (ViewBag.SelectedAreaId != null)
                            {
                                <button type="button" class="btn btn-burgundy btn-sm shadow-sm px-3"
                                        onclick="@(HasPermission("btn-asignar-puesto") ? "loadAssignJobModal()" : "")"
                                        @(HasPermission("btn-asignar-puesto") ? "" : "disabled")
                                        title="@(HasPermission("btn-asignar-puesto") ? "Asignar Puesto" : "Sin permiso para asignar puestos")">
                                    <i class="bi bi-person-add me-1"></i> Asignar Puesto
                                </button>

                                <button type="submit" form="formPermissions"
                                        class="btn btn-burgundy btn-sm shadow-sm px-3"
                                        @(HasPermission("btn-guardar-permisos") ? "" : "disabled")
                                        title="@(HasPermission("btn-guardar-permisos") ? "Guardar Todo" : "Sin permiso para guardar cambios")">
                                    <i class="bi bi-save2 me-1"></i> Guardar Todo
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                var jobGroups = Model.GroupBy(p => p.IdJobPosition).ToList();

                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header bg-white border-bottom-0 pt-3">
                        <ul class="nav nav-tabs nav-tabs-burgundy px-3" id="secondaryGestorTabs" role="tablist">
                            @for (int j = 0; j < jobGroups.Count; j++)
                            {
                                var jobName = jobGroups[j].First().JobPosition?.Name ?? "Puesto";
                                <li class="nav-item">
                                    <button class="nav-link @(j == 0 ? "active" : "") fw-bold px-4"
                                            data-bs-toggle="tab"
                                            data-bs-target="#job-content-@j"
                                            type="button">
                                        @jobName
                                    </button>
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="card-body p-0">
                        <form id="formPermissions" asp-action="SavePermissions" method="post">
                            @Html.AntiForgeryToken()

                            <div class="tab-content">
                                @for (int j = 0; j < jobGroups.Count; j++)
                                {
                                    <div class="tab-pane fade @(j == 0 ? "show active" : "") p-3" id="job-content-@j" role="tabpanel">

                                        <div class="accordion accordion-flush border rounded-3 overflow-hidden shadow-sm" id="accordionModules-@j">
                                            @{
                                                var moduleGroups = jobGroups[j].GroupBy(p => p.ModuleCatalog!.ModuleName).ToList();
                                                for (int m = 0; m < moduleGroups.Count; m++)
                                                {
                                                    var mainModule = moduleGroups[m].FirstOrDefault(x => x.ModuleCatalog!.ButtonName == null);
                                                    var buttons = moduleGroups[m].Where(x => x.ModuleCatalog!.ButtonName != null).ToList();
                                                    string modId = $"mod_{j}_{m}";

                                                    <div class="accordion-item border-bottom">
                                                        <div class="accordion-header d-flex align-items-center bg-white pe-3">
                                                            <button class="accordion-button collapsed fw-bold text-dark bg-transparent shadow-none"
                                                                    type="button" data-bs-toggle="collapse" data-bs-target="#@modId">
                                                                <i class="bi bi-folder2-open me-2 text-burgundy"></i> @moduleGroups[m].Key
                                                            </button>

                                                            @if (mainModule != null)
                                                            {
                                                                int idx = Model.IndexOf(mainModule);
                                                                <div class="ms-auto d-flex gap-3 align-items-center py-2">
                                                                    <input type="hidden" name="permissions[@idx].Id" value="@mainModule.Id" />
                                                                    <div class="text-center small">
                                                                        <span class="text-muted fw-bold" style="font-size: 0.65rem;">ACCESO</span><br />
                                                                        <input type="checkbox" name="permissions[@idx].CanView" value="true"
                                                                               @(mainModule.CanView ? "checked" : "")
                                                                               @(HasPermission("chk-acceso-modulos") ? "" : "disabled")
                                                                               data-target-group="@modId"
                                                                               class="form-check-input custom-check master-check mt-1"
                                                                               title="@(HasPermission("chk-acceso-modulos") ? "" : "No tienes permiso para modificar este acceso")" />
                                                                        <input type="hidden" name="permissions[@idx].CanView" value="false" />
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>

                                                        <div id="@modId" class="accordion-collapse collapse" data-bs-parent="#accordionModules-@j">
                                                            <div class="accordion-body bg-light-subtle p-0">
                                                                <ul class="list-group list-group-flush">
                                                                    @foreach (var btn in buttons)
                                                                    {
                                                                        int bIdx = Model.IndexOf(btn);
                                                                        <li class="list-group-item d-flex align-items-center ps-5 py-2 border-0 border-bottom small">
                                                                            <input type="hidden" name="permissions[@bIdx].Id" value="@btn.Id" />

                                                                            <div class="flex-grow-1 text-secondary">
                                                                                <i class="bi bi-arrow-return-right me-2"></i>
                                                                                @btn.ModuleCatalog!.ButtonName
                                                                            </div>

                                                                            <div class="form-check form-switch">
                                                                                <input type="checkbox" name="permissions[@bIdx].CanView" value="true"
                                                                                       @(btn.CanView ? "checked" : "")
                                                                                       @(HasPermission("chk-acceso-botones") ? "" : "disabled")
                                                                                       class="form-check-input child-check-@modId"
                                                                                       title="@(HasPermission("chk-acceso-botones") ? "" : "Sin permiso para cambiar permisos de botones")" />

                                                                                <input type="hidden" name="permissions[@bIdx].CanView" value="false" />
                                                                            </div>
                                                                        </li>
                                                                        @if (!buttons.Any())
                                                                        {
                                                                            <li class="list-group-item ps-5 py-2 text-muted small italic">
                                                                                Sin botones configurados para este módulo.
                                                                            </li>
                                                                        }
                                                                    }
                                                                </ul>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        </div>

                                    </div>
                                }
                            </div>
                        </form>
                    </div>
                </div>
            }
            else if (ViewBag.SelectedAreaId != null)
            {
                <div class="card text-center py-5 px-3 px-md-5 rounded-4 bg-white shadow-sm">
                    <i class="bi bi-shield-slash display-1 text-muted opacity-25"></i>

                    <h4 class="mt-3 fw-bold fs-5 fs-md-4">Sin configuración de acceso</h4>

                    <p class="text-muted small mx-auto" style="max-width: 400px;">
                        El área seleccionada no tiene reglas de acceso definidas.
                    </p>

                    <button class="btn btn-burgundy mt-2 w-100 w-md-auto"
                            onclick="@(HasPermission("btn-crear-matriz") ? $"initModules({ViewBag.SelectedAreaId})" : "")"
                            @(HasPermission("btn-crear-matriz") ? "" : "disabled")
                            title="@(HasPermission("btn-crear-matriz") ? "Crear matriz admin" : "Sin permiso para inicializar matrices")">
                        <i class="bi bi-plus-circle me-1"></i> Crear matriz admin para esta área
                    </button>
                </div>
            }

            else
            {

                <div class="text-center py-5 opacity-50">
                    <i class="bi bi-building-gear display-1"></i>
                    <h4 class="mt-3">Esperando selección de área...</h4>
                    <p>Selecciona un departamento en el menú superior para gestionar sus permisos.</p>
                </div>
            }
        </div>
        </div>

    <div id="bulkActionsBar" class="position-fixed bottom-0 start-50 translate-middle-x mb-4 shadow-lg bg-dark text-white p-3 rounded-pill d-none animate__animated animate__fadeInUp" style="z-index: 1050; min-width: 300px;">
        <div class="d-flex align-items-center justify-content-between px-3">
            <span id="selectedCount" class="fw-bold me-4">0 seleccionados</span>
            <div class="btn-group">
                @if (HasPermission("btn-multiple-eliminar"))
                {
                    <button class="btn btn-sm btn-danger px-3 fw-bold rounded-pill" onclick="bulkDelete()">
                        <i class="bi bi-trash3-fill me-1"></i> Eliminar
                    </button>
                }
            </div>
            <button type="button" class="btn-close btn-close-white ms-3" onclick="deselectAll()"></button>
        </div>
    </div>
</div>