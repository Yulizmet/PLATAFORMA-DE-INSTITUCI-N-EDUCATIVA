@model SchoolManager.Models.procedure_types
@{
    Layout = null;
}

<div class="modal fade" id="bulkEditModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow-lg border-0 rounded-4">
            <form id="formBulkProcedure" method="post" action="/Procedures/ProcedureConfiguration/SaveBulkUpdate">
                @Html.AntiForgeryToken()

                <div class="modal-header bg-burgundy text-white py-3">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-stack me-2"></i>Edición Masiva de Trámites
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-4">
                    @* Alerta de advertencia *@
                    <div class="alert alert-warning border-0 shadow-sm mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Atención:</strong> Los campos que llenes sobrescribirán la configuración de todos los trámites seleccionados. Los que dejes vacíos se mantendrán sin cambios.
                    </div>

                    @* Datos Básicos *@
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Nuevo nombre común (opcional)</label>
                            <input type="text" name="Name" class="form-control shadow-sm border-0 bg-light" placeholder="Dejar vacío para mantener original" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Área responsable común</label>
                            <select name="IdArea" class="form-select shadow-sm border-0 bg-light" asp-items="ViewBag.IdArea">
                                <option value="0">-- No cambiar área --</option>
                            </select>
                        </div>
                    </div>

                    @* Sección 1: Requisitos *@
                    <div class="card border-0 bg-light rounded-4 mb-4 shadow-sm">
                        <div class="card-body p-3">
                            <h6 class="text-secondary fw-bold mb-3">
                                <i class="bi bi-file-earmark-check-fill me-2"></i>1. Documentos Requeridos Masivos
                            </h6>
                            <div class="row g-2 mb-3 align-items-center">
                                <div class="col-md-6">
                                    <label class="small text-muted fw-bold d-block">Documento:</label>
                                    <select id="tempDocument" class="form-select form-select-sm border-0 shadow-sm" asp-items="ViewBag.IdTypeDocument">
                                        <option value="">-- Seleccionar documento --</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="small text-muted fw-bold d-block">Tipo:</label>
                                    <select id="tempRequired" class="form-select form-select-sm border-0 shadow-sm">
                                        <option value="true">Obligatorio</option>
                                        <option value="false">Opcional</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <button type="button" id="btnAddReq" class="btn btn-success btn-sm w-100 fw-bold shadow-sm mt-3">
                                        <i class="bi bi-plus-lg"></i> Añadir
                                    </button>
                                </div>
                            </div>
                            <div id="pillsContainer" class="d-flex flex-wrap gap-2 p-2 bg-white rounded-3 border-dashed" style="min-height: 50px;">
                            </div>
                            <small class="text-muted mt-2 d-block">Si dejas esta sección vacía, no se modificarán los requisitos actuales.</small>
                        </div>
                    </div>

                    @* Sección 2: Flujo de Estados *@
                    <div class="card border-0 bg-light rounded-4 shadow-sm">
                        <div class="card-body p-3">
                            <h6 class="text-secondary fw-bold mb-3">
                                <i class="bi bi-arrow-right-circle-fill me-2"></i>2. Ruta de Proceso (Flujo Masivo)
                            </h6>
                            <div class="row g-2 align-items-end mb-3">
                                <div class="col-md-9">
                                    <label class="small text-muted fw-bold">Estado:</label>
                                    <select id="tempStatus" class="form-select form-select-sm border-0 shadow-sm" asp-items="ViewBag.IdStatus">
                                        <option value="">-- Seleccionar estado --</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <button type="button" id="btnAddStatus" class="btn btn-success text-white btn-sm w-100 fw-bold shadow-sm">
                                        <i class="bi bi-node-plus"></i> Insertar
                                    </button>
                                </div>
                            </div>

                            <div id="flowContainer" class="d-flex flex-column gap-2 p-2 bg-white rounded-3 border-dashed" style="min-height: 80px;">
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <small class="text-muted">Arrastra <i class="bi bi-grip-vertical"></i> para reordenar.</small>
                                <small class="text-muted">Solo se actualizará si añades al menos un estado.</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer bg-light border-0 py-3">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-burgundy rounded-pill px-5 shadow-sm fw-bold">
                        Confirmar Cambios Masivos
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script id="statusDataJson" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusData))
</script>