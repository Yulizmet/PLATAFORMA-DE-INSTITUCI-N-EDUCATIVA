@model SchoolManager.Models.procedure_types
@{
    Layout = null;
    // int indexReq = 0;
    // int indexFlow = 0;
}

<div class="modal fade" id="bulkEditModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg border-0 rounded-4">
            <form id="formBulkProcedure" method="post" action="/Procedures/ProcedureConfiguration/SaveBulkUpdate">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-dark text-white py-3">
                    <h5 class="modal-title fw-bold"><i class="bi bi-stack me-2"></i>Edición Masiva de Trámite</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="alert alert-warning border-0 shadow-sm mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Atención:</strong> Los cambios aquí definidos sobrescribirán la configuración de todos los trámites seleccionados.
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Nuevo nombre común (opcional)</label>
                            <input type="text" name="Name" class="form-control shadow-sm" placeholder="Dejar vacío para no cambiar" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Área responsable común</label>
                            <select name="IdArea" class="form-select shadow-sm" asp-items="ViewBag.IdArea">
                                <option value="0">-- No cambiar área --</option>
                            </select>
                        </div>
                    </div>

                    <div class="card border-0 bg-light rounded-4 mb-4">
                        <div class="card-body p-3">
                            <h6 class="fw-bold mb-3"><i class="bi bi-file-earmark-check me-2"></i>1. Nuevos Requisitos Masivos</h6>
                            <div class="row g-2 mb-3">
                                <div class="col-md-6">
                                    <select id="tempDocument" class="form-select form-select-sm" asp-items="ViewBag.IdTypeDocument">
                                        <option value="">-- Seleccionar documento --</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <select id="tempRequired" class="form-select form-select-sm">
                                        <option value="true">Obligatorio</option>
                                        <option value="false">Opcional</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <button type="button" id="btnAddReq" class="btn btn-dark btn-sm w-100 fw-bold">Añadir</button>
                                </div>
                            </div>
                            <div id="pillsContainer" class="d-flex flex-wrap gap-2 p-2 bg-white rounded-3 border-dashed" style="min-height: 50px;"></div>
                        </div>
                    </div>

                    <div class="card border-0 bg-light rounded-4">
                        <div class="card-body p-3">
                            <h6 class="fw-bold mb-3"><i class="bi bi-diagram-3-fill me-2"></i>2. Nueva Ruta de Estados Masiva</h6>
                            <div class="row g-2 align-items-end mb-3">
                                <div class="col-md-7">
                                    <label class="small text-muted fw-bold">Estado:</label>
                                    <select id="tempStatus" class="form-select form-select-sm border-0 shadow-sm" asp-items="ViewBag.IdStatus">
                                        <option value="">-- Seleccionar estado --</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="small text-muted fw-bold">Orden:</label>
                                    <input type="number" id="tempOrder" class="form-control form-select-sm border-0 shadow-sm" placeholder="10" />
                                </div>
                                <div class="col-md-3">
                                    <button type="button" id="btnAddStatus" class="btn bg-success text-white btn-sm w-100 fw-bold shadow-sm">
                                        <i class="bi bi-node-plus"></i> Insertar
                                    </button>
                                </div>
                            </div>

                            <div id="flowContainer" class="d-flex flex-column gap-2 p-2 bg-white rounded-3 border-dashed" style="min-height: 80px;">
                                
                            </div>
                            <small class="text-muted mt-2 d-block">El orden de los pasos se define según como los agregues.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-bottom-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-burgundy rounded-pill px-5 shadow-sm">Actualizar Seleccionados</button>
                </div>
            </form>
        </div>
    </div>
</div>