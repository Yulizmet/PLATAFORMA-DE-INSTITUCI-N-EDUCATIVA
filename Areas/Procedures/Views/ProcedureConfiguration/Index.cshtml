@model IEnumerable<SchoolManager.Models.procedure_types>

@{
    ViewData["Title"] = "Gestión de Trámites";
    ViewBag.EntityName = "tramites";

    bool HasPermission(string buttonName) =>
        ViewBag.UserPermissions != null && ((List<string>)ViewBag.UserPermissions).Contains(buttonName);
}

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <partial name="_DataTableConfig" />

    <script>
        let statusColors = [];

        window.updateStatusColors = function(data) {
            if (!data) return;
            statusColors = data;
            console.log("Sincronización de colores:", statusColors);
        };

        window.loadModal = async function(url) {
            try {
                const response = await fetch(url);
                const html = await response.text();
                const container = document.getElementById('modalContainer');
                if (!container) return;

                container.innerHTML = html;

                const dataElement = container.querySelector('#statusDataJson');
                if (dataElement) {
                    const data = JSON.parse(dataElement.textContent);
                    window.updateStatusColors(data);
                }

                const modalElement = container.querySelector('.modal');

                if (modalElement) {
                    const myModal = new bootstrap.Modal(modalElement);
                    myModal.show();

                    const pills = document.getElementById('pillsContainer');
                    reqIndex = pills ? $(pills).find('.badge').length : 0;

                    setTimeout(() => {
                        initSortable();
                        updateStatusDropdown();
                    }, 300);
                }
            } catch (error) {
                showToast('error', 'Fallo en la carga: ' + error.message);
            }
        };

        function initSortable() {
            const el = document.getElementById('flowContainer');
            if (!el) return;

            if (window.sortableInstance) window.sortableInstance.destroy();

            window.sortableInstance = Sortable.create(el, {
                handle: '.handle',
                animation: 150,
                ghostClass: 'bg-light',
                onEnd: function () {
                    reorderAll();
                }
            });
        }

        function updateStatusDropdown() {
            const flowContainer = $('#flowContainer');
            if (flowContainer.length === 0) return;

            const selectedIds = flowContainer.find('input[type="hidden"]')
                .map((_, el) => parseInt(el.value))
                .get();

            $('#tempStatus option').each(function () {
                const val = parseInt($(this).val());
                if (!val) return;
                $(this).prop('disabled', selectedIds.includes(val));
            });
        }

        function reorderAll() {
            const pillsCont = $('#pillsContainer');
            const flowCont = $('#flowContainer');

            if (pillsCont.length > 0) {
                pillsCont.find('.badge').each(function(i) {
                    $(this).find('input[name*="IdTypeDocument"]').attr('name', `requirementsList[${i}].IdTypeDocument`);
                    $(this).find('input[name*="IsRequired"]').attr('name', `requirementsList[${i}].IsRequired`);
                });
                reqIndex = pillsCont.find('.badge').length;
            }

            if (flowCont.length > 0) {
                flowCont.find('.flow-item').each(function(i) {
                    const newOrder = i + 1;
                    $(this).find('.step-order-input').val(newOrder);
                    $(this).find('input.step-order-input').attr('name', `flowList[${i}].StepOrder`);
                    $(this).find('input[type="hidden"]').attr('name', `flowList[${i}].IdStatus`);
                });
            }
        }

        $(document).off('click', '#btnAddReq').on('click', '#btnAddReq', function (e) {
            e.preventDefault();
            const docId = $('#tempDocument').val();
            const docText = $("#tempDocument option:selected").text();
            const isReq = $('#tempRequired').val() === "true";
            if (!docId) return;

            const pill = `<div class="badge border text-dark d-flex align-items-center p-2 bg-light mb-1" style="border-radius:50px;">
                            <i class="bi ${isReq ? 'bi-asterisk text-danger' : 'bi-file-earmark'} me-2"></i>
                            <span class="me-2">${docText}</span>
                            <button type="button" class="btn-close btn-remove-pill" style="font-size:0.5rem;"></button>
                            <input type="hidden" name="requirementsList[${reqIndex}].IdTypeDocument" value="${docId}" />
                            <input type="hidden" name="requirementsList[${reqIndex}].IsRequired" value="${isReq}" />
                         </div>`;
            $('#pillsContainer').append(pill);
            reorderAll();
        });

        $(document).off('click', '#btnAddStatus').on('click', '#btnAddStatus', function (e) {
            e.preventDefault();
            const statusId = parseInt($('#tempStatus').val());

            if (isNaN(statusId)) {
                showToast('warning', 'Selecciona un estado.');
                return;
            }

            const exists = $('#flowContainer input[value="' + statusId + '"]').length > 0;
            if (exists) {
                showToast('info', 'Ese estado ya está agregado.');
                return;
            }

            const data = statusColors.find(x => (x.Id || x.id) == statusId);

            if (!data) {
                showToast('error', 'No se pudieron cargar los estilos. Cierra y abre el modal de nuevo.');
                return;
            }

            const flowRow = `
                <div class="flow-item d-flex align-items-center bg-light border rounded-3 p-2 mb-2 shadow-sm"
                     style="border-left: 5px solid ${data.Bg || data.bg} !important;">
                    <div class="me-3 text-muted handle" style="cursor:grab"><i class="bi bi-grip-vertical fs-5"></i></div>
                    <div class="me-2" style="width: 50px;">
                        <input type="number" class="form-control form-control-sm step-order-input bg-white border-0 text-center fw-bold" readonly />
                    </div>
                    <div class="flex-grow-1">
                        <span class="badge" style="background-color:${data.Bg || data.bg}; color:${data.Txt || data.txt}">${data.Name || data.name}</span>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-danger btn-remove-flow border-0"><i class="bi bi-trash"></i></button>
                    <input type="hidden" value="${statusId}" />
                </div>`;

            $('#flowContainer').append(flowRow);
            reorderAll();
            updateStatusDropdown();
            $('#tempStatus').val("");
        });

        $(document).on('click', '.btn-remove-pill', function() { $(this).closest('.badge').remove(); reorderAll(); });
        $(document).on('click', '.btn-remove-flow', function() { $(this).closest('.flow-item').remove(); reorderAll(); updateStatusDropdown(); });
        $(document).off("submit", "#formProcedureMaster, #formBulkProcedure").on("submit", "#formProcedureMaster, #formBulkProcedure", async function (e) {
            e.preventDefault();
            const form = e.target;
            reorderAll();

            const token = $('input[name="__RequestVerificationToken"]').val();

            const flowsValidation = [];
            $('#flowContainer .flow-item').each(function() {
                flowsValidation.push({
                    IdStatus: parseInt($(this).find('input[type="hidden"]').val()),
                    StepOrder: parseInt($(this).find('.step-order-input').val())
                });
            });

            if (flowsValidation.length > 0) {
                const lastStep = flowsValidation[flowsValidation.length - 1];
                const statusInfo = statusColors.find(x => (x.Id || x.id) == lastStep.IdStatus);
                const isTerminal = statusInfo ? (statusInfo.IsTerminal || statusInfo.isTerminal || statusInfo.IsTerminalState || statusInfo.isTerminalState) : false;

                if (isTerminal !== true && isTerminal !== 1) {
                    showToast('warning', 'El último estado de la ruta debe ser un estado Final/Terminal.');
                    return;
                }
            } else {
                showToast('warning', 'Debes añadir al menos un estado al flujo.');
                return;
            }

            let finalBody;
            let finalHeaders = {
                "RequestVerificationToken": token
            };

            if (form.id === "formBulkProcedure") {
                const ids = $('.row-checkbox:checked').map((_, el) => parseInt(el.value)).get();
                const reqs = [];
                $('#pillsContainer .badge').each(function() {
                    reqs.push({
                        IdTypeDocument: parseInt($(this).find('input[type="hidden"]').eq(0).val()),
                        IsRequired: $(this).find('input[type="hidden"]').eq(1).val() === "true"
                    });
                });

                finalBody = JSON.stringify({
                    Ids: ids,
                    Name: $(form).find('input[name="Name"]').val() || null,
                    IdArea: parseInt($(form).find('select[name="IdArea"]').val()) || 0,
                    RequirementsList: reqs.length > 0 ? reqs : null,
                    FlowList: flowsValidation.length > 0 ? flowsValidation : null
                });
                finalHeaders['Content-Type'] = 'application/json';
            } else {
                finalBody = new FormData(form);
            }

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: finalHeaders,
                    body: finalBody
                });

                if (response.status === 400) {
                    console.error("Error 400: Revisa el binding del modelo.");
                    showToast('error', 'Error en el formato de datos (400).');
                    return;
                }

                const result = await response.json();
                if (result.success) {
                    showToast('success', '¡Cambios guardados!');
                    setTimeout(() => location.reload(), 1200);
                } else {
                    showToast('error', result.errors ? result.errors.join(" | ") : (result.message || "Error al guardar"));
                }
            } catch (e) {
                showToast('error', 'Error de conexión con el servidor');
            }
        });

        $(document).on("submit", "#formDeleteProcedure", async function (e) {
            e.preventDefault();
            const form = e.target;
            try {
                const response = await fetch(form.action, { method: 'POST', body: new FormData(form) });
                const result = await response.json();
                if (result.success) {
                    showToast('success', 'Registro eliminado correctamente');
                    setTimeout(() => { location.reload(); }, 1000);
                } else {
                    showToast('error', result.message || 'No se pudo eliminar el registro.');
                }
            } catch (error) {
                showToast('error', 'Error en el servidor.');
            }
        });

        window.bulkEdit = () => {
            const count = $('.row-checkbox:checked').length;
            if(count === 0) return showToast('info', 'Selecciona trámites');
            loadModal('/Procedures/ProcedureConfiguration/BulkEdit');
        };

        window.bulkDelete = async () => {
            const ids = $('.row-checkbox:checked').map((_, el) => parseInt(el.value)).get();
            if(ids.length === 0) return;
            const result = await Swal.fire({
                title: '¿Eliminar seleccionados?',
                text: `Borrarás ${ids.length} trámites.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#620900',
                confirmButtonText: 'Sí, borrar',
                cancelButtonText: 'Cancelar'
            });
            if (result.isConfirmed) {
                const res = await fetch('/Procedures/ProcedureConfiguration/BulkDelete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(ids)
                });
                const rJson = await res.json();
                if (rJson.success) {
                    showToast('success', 'Eliminado');
                    setTimeout(() => location.reload(), 1000);
                }
            }
        };

        $(document).on('change', '#checkAll', function () {
            const isChecked = $(this).is(':checked');
            $('.row-checkbox').prop('checked', isChecked).closest('tr').toggleClass('table-active', isChecked);
            updateBulkBar();
        });

        $(document).on('change', '.row-checkbox', function () {
            $('#checkAll').prop('checked', $('.row-checkbox').length === $('.row-checkbox:checked').length);
            $(this).closest('tr').toggleClass('table-active', $(this).is(':checked'));
            updateBulkBar();
        });

        function updateBulkBar() {
            const count = $('.row-checkbox:checked').length;
            const bar = $('#bulkActionsBar');
            if (count > 0) {
                $('#selectedCount').text(count + (count === 1 ? ' seleccionado' : ' seleccionados'));
                bar.removeClass('d-none').show();
            } else {
                bar.hide();
            }
        }
    </script>
}

<div id="modalContainer"></div>

<div class="container-fluid px-4 pt-5">

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold mb-1 merriweather-font">
                <i class="bi bi-pencil-square"></i> Trámites
            </h2>
            <p class="text-muted small mb-0">Configura los documentos necesarios, el área responsable y la ruta de estados para cada trámite.</p>
        </div>

        @if (HasPermission("btn-agregar"))
        {
            <button class="btn btn-burgundy shadow-sm" onclick="loadModal('/Procedures/ProcedureConfiguration/Create')">
                <i class="bi bi-plus-circle me-2"></i> Agregar trámite
            </button>
        }
        else
        {
            <button class="btn btn-burgundy shadow-sm" disabled title="No tienes permiso para agregar">
                <i class="bi bi-plus-circle me-2"></i> Agregar trámite
            </button>
        }
    </div>
    
    <partial name="_TableTools" />

    <div id="bulkActionsBar" class="position-fixed bottom-0 start-50 translate-middle-x mb-4 shadow-lg bg-dark text-white p-3 rounded-pill d-none animate__animated animate__fadeInUp" style="z-index: 1050; min-width: 300px;">
        <div class="d-flex align-items-center justify-content-between px-3">
            <span id="selectedCount" class="fw-bold me-4">0 seleccionados</span>
            <div class="btn-group">
                @if (HasPermission("btn-multiple-editar"))
                {
                    <button class="btn btn-sm btn-warning  px-3 fw-bold rounded-pill me-2" onclick="bulkEdit()">
                        <i class="bi bi-pencil-square me-1"></i> Editar
                    </button>
                }               
                @if (HasPermission("btn-multiple-eliminar"))
                {
                    <button class="btn btn-sm btn-danger px-3 fw-bold rounded-pill" onclick="bulkDelete()">
                        <i class="bi bi-trash3-fill me-1"></i> Eliminar
                    </button>
                }
            </div>
            <button type="button" class="btn-close btn-close-white ms-3" onclick="deselectAll()"></button>
        </div>
    </div>

    <div class="border-0 overflow-hidden">
        <div class="card-body p-0">
            <table id="mainTable" class="table table-hover table-container-rounded">
                <thead class="burgundy-header text-white">
                    <tr>
                        <th class="no-sort text-center"> <input type="checkbox" id="checkAll" class="form-check-input"> </th>
                        <th style="width: 20%;">Nombre del Trámite</th>
                        <th style="width: 17%;">Documentos</th>
                        <th style="width: 13%;">Área</th>
                        <th style="width: 25%;">Ruta de Proceso</th>
                        <th style="width: 15%;">Modificación</th>
                        <th class="no-sort text-center" style="width: 10%;">Acciones</th>
                    </tr>
                </thead>
                <tbody class="table-white">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">
                                <input type="checkbox" class="form-check-input row-checkbox" value="@item.Id" />
                            </td>
                            <td class="ps-4 fw-bold text-dark">@item.Name</td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    @if (item.Requirements != null && item.Requirements.Any())
                                    {
                                        foreach (var req in item.Requirements)
                                        {
                                            <span class="badge border text-dark bg-light d-flex align-items-center"
                                                  style="font-size: 0.7rem; font-weight: 500; border-radius: 50px;"
                                                  title="@(req.IsRequired ? "Obligatorio" : "Opcional")">
                                                <i class="bi @(req.IsRequired ? "bi-asterisk text-danger" : "bi-file-earmark text-muted") me-1"></i>
                                                @(req.ProcedureTypeDocument?.Name ?? "Doc")
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small"><em>Sin requisitos</em></span>
                                    }
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-secondary-subtle text-secondary border rounded-pill px-3">
                                    @(item.ProcedureArea?.Name ?? "General")
                                </span>
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-2">
                                    @if (item.ProcedureFlow != null && item.ProcedureFlow.Any())
                                    {
                                        var sortedFlow = item.ProcedureFlow
                                        .Where(f => f.ProcedureStatus?.Name != "Rechazado" && f.ProcedureStatus?.Name != "Cancelado")
                                        .OrderBy(f => f.StepOrder)
                                        .ToList();

                                        if (sortedFlow.Any())
                                        {
                                            <div class="d-flex align-items-center flex-wrap gap-1">
                                                @foreach (var step in sortedFlow.Where(f => f.StepOrder < 90))
                                                {
                                                    <span class="badge rounded-pill"
                                                          style="background-color: @(step.ProcedureStatus?.BackgroundColor ?? "#eee"); color: @(step.ProcedureStatus?.TextColor ?? "#666"); font-size: 0.6rem; opacity: 0.8;">
                                                        <i class="bi bi-check-all me-1"></i>@step.ProcedureStatus?.Name
                                                    </span>
                                                    @if (step != sortedFlow.Where(f => f.StepOrder < 90).LastOrDefault())
                                                    {
                                                        <i class="bi bi-chevron-right text-muted" style="font-size: 0.6rem;"></i>
                                                    }
                                                }
                                            </div>

                                            <div class="d-flex flex-wrap gap-1 mt-1 ps-2 border-start border-2">
                                                @foreach (var step in sortedFlow.Where(f => f.StepOrder >= 90))
                                                {
                                                    <span class="badge rounded-pill"
                                                          style="background-color: @(step.ProcedureStatus?.BackgroundColor ?? "#eee"); color: @(step.ProcedureStatus?.TextColor ?? "#666"); font-size: 0.6rem; opacity: 0.8;">
                                                        <i class="bi bi-signpost-split me-1"></i>@step.ProcedureStatus?.Name
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small"><em>Solo estados por defecto</em></span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small"><em>No configurado</em></span>
                                    }
                                </div>
                            </td>
                            <td class="text-muted small">
                                <i class="bi bi-clock-history me-1"></i> @item.DateUpdated.ToString("dd/MM/yyyy hh:mm tt")
                            </td>
                            <td class="actions text-center pe-4">
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-light border shadow-sm me-2"
                                            style="width:32px; height:32px; padding:0;"
                                            onclick="@(HasPermission("btn-editar") ? $"loadModal('/Procedures/ProcedureConfiguration/Edit/{item.Id}')" : "")"
                                            @(HasPermission("btn-editar") ? "" : "disabled")
                                            title="@(HasPermission("btn-editar") ? "Editar" : "Sin permiso")">
                                        <i class="bi bi-pencil-square text-warning"></i>
                                    </button>

                                    <button class="btn btn-sm btn-light border shadow-sm"
                                            style="width:32px; height:32px; padding:0;"
                                            onclick="@(HasPermission("btn-eliminar") ? $"loadModal('/Procedures/ProcedureConfiguration/Delete/{item.Id}')" : "")"
                                            @(HasPermission("btn-eliminar") ? "" : "disabled")
                                            title="@(HasPermission("btn-eliminar") ? "Eliminar" : "Sin permiso")">
                                        <i class="bi bi-trash-fill text-danger"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>