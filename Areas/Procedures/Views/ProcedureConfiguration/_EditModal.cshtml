@model SchoolManager.Models.procedure_types
@{
    Layout = null;
    int indexReq = 0;
    int indexFlow = 0;
}
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg border-0 rounded-4">
            <form id="formProcedureMaster" method="post" action="/Procedures/ProcedureConfiguration/SaveProcedureMaster">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-burgundy text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-gear-fill me-2"></i>Configuración Maestra de Trámite</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Nombre del trámite</label>
                            <input asp-for="Name" class="form-control shadow-sm border-2" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Área responsable</label>
                            <select asp-for="IdArea" class="form-select shadow-sm border-2" asp-items="ViewBag.IdArea" required>
                                <option value="">-- Seleccione área --</option>
                            </select>
                        </div>
                    </div>

                    <div class="card border-0 bg-light rounded-4 mb-4 shadow-sm">
                        <div class="card-body p-3">
                            <h6 class="text-secondary fw-bold mb-3"><i class="bi bi-file-earmark-pdf me-2"></i>1. Requisitos de Documentación</h6>
                            <div class="row g-2 align-items-end mb-3">
                                <div class="col-md-6">
                                    <select id="tempDocument" class="form-select form-select-sm border-0 shadow-sm" asp-items="ViewBag.IdTypeDocument">
                                        <option value="">-- Seleccionar documento --</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <select id="tempRequired" class="form-select form-select-sm border-0 shadow-sm">
                                        <option value="true">Obligatorio</option>
                                        <option value="false">Opcional</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <button type="button" id="btnAddReq" class="btn bg-success text-white btn-sm w-100 fw-bold shadow-sm">
                                        <i class="bi bi-plus-lg"></i> Añadir
                                    </button>
                                </div>
                            </div>
                            <div id="pillsContainer" class="d-flex flex-wrap gap-2 p-2 bg-white rounded-3 border-dashed" style="min-height: 50px;">
                                @if (Model.Requirements != null)
                                {
                                    foreach (var req in Model.Requirements)
                                    {
                                        <div class="badge border text-dark d-flex align-items-center p-2 shadow-sm bg-light" style="border-radius: 50px; font-weight: normal;">
                                            <i class="bi @(req.IsRequired ? "bi-asterisk text-danger" : "bi-file-earmark text-muted") me-2"></i>
                                            <span class="me-2">@(req.ProcedureTypeDocument?.Name ?? "Documento")</span>
                                            <button type="button" class="btn-close btn-remove-pill" style="font-size: 0.5rem;"></button>
                                            <input type="hidden" name="requirementsList[@indexReq].IdTypeDocument" value="@req.IdTypeDocument" />
                                            <input type="hidden" name="requirementsList[@indexReq].IsRequired" value="@req.IsRequired.ToString().ToLower()" />
                                        </div>
                                        indexReq++;
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 bg-light rounded-4 shadow-sm">
                        <div class="card-body p-3">
                            <h6 class="text-secondary fw-bold mb-3"><i class="bi bi-arrow-right-circle-fill me-2"></i>2. Ruta de Proceso (Flujo de Estados)</h6>
                            <div class="row g-2 align-items-end mb-3">
                            <div class="col-md-9">
                                    <label class="small text-muted fw-bold">Estado:</label>
                                    <select id="tempStatus" class="form-select form-select-sm border-0 shadow-sm" asp-items="ViewBag.IdStatus">
                                        <option value="">-- Seleccionar estado --</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <button type="button" id="btnAddStatus" class="btn bg-success text-white btn-sm w-100 fw-bold shadow-sm">
                                        <i class="bi bi-node-plus"></i> Insertar
                                    </button>
                                </div>
                            </div>

                            <div id="flowContainer" class="d-flex flex-column gap-2 p-2 bg-white rounded-3 border-dashed" style="min-height: 80px;">
                                @if (Model.ProcedureFlow != null && Model.ProcedureFlow.Any())
                                {
                                    var index = 0;
                                    foreach (var flow in Model.ProcedureFlow.OrderBy(f => f.StepOrder))
                                    {
                                        <div class="flow-item d-flex align-items-center bg-light border rounded-3 p-2 shadow-sm mb-2" 
                                             style="border-left: 5px solid @flow.ProcedureStatus?.BackgroundColor !important; cursor: move;">
                
                                            <div class="me-3 text-muted handle">
                                                <i class="bi bi-grip-vertical fs-5"></i> </div>

                                            <div class="me-2" style="width: 50px;">
                                                <input type="number" name="flowList[@index].StepOrder" value="@flow.StepOrder" 
                                                       class="form-control form-control-sm step-order-input bg-white border-0 text-center fw-bold" readonly />
                                            </div>

                                            <div class="flex-grow-1">
                                                <span class="badge" style="background-color:@flow.ProcedureStatus?.BackgroundColor; color:@flow.ProcedureStatus?.TextColor">
                                                    @flow.ProcedureStatus?.Name
                                                </span>
                                            </div>

                                            <button type="button" class="btn btn-sm btn-outline-danger border-0 btn-remove-flow">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                            <input type="hidden" name="flowList[@index].IdStatus" value="@flow.IdStatus" />
                                        </div>
                                        index++;
                                    }
                                }
                            </div>
                            <small class="text-muted mt-2 d-block">El orden de los pasos se define según como los agregues.</small>
                        </div>
                    </div>

                </div>
                <div class="modal-footer bg-light border-top-0 rounded-bottom-4">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn bg-burgundy text-white shadow-sm">Actualizar Trámite</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script id="statusDataJson" type="application/json">
    @Html.Raw(Json.Serialize(ViewData["StatusData"]))
</script>