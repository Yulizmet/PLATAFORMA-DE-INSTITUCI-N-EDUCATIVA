@model List<SchoolManager.Models.social_service_log>

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
    <h3 class="mb-0">Mis Bitácoras</h3>
    <div class="d-flex flex-wrap gap-2">
        <a href="/SocialService/Student/CrearBitacora" class="btn btn-primary">
            <i class="bi bi-plus-circle-fill me-1"></i> Crear nueva bitácora
        </a>
        <a asp-area="SocialService" asp-controller="Student" asp-action="Dashboard" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@{
    var rejections = ViewBag.Rejections as List<SchoolManager.Models.social_service_rejection>;
}

@if (rejections != null && rejections.Count > 0)
{
    foreach (var rejection in rejections)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong><i class="bi bi-x-circle-fill me-1"></i> Tu bitácora de la Semana @rejection.Week ha sido rechazada.</strong>
            @if (!string.IsNullOrEmpty(rejection.RejectionReason))
            {
                <br><span>Motivo: @rejection.RejectionReason</span>
            }
            <br><small class="text-muted">Rechazada el @rejection.RejectedAt.ToString("dd/MM/yyyy HH:mm")</small>
            <br><small>Debes crear una nueva bitácora para esa semana.</small>
            <form method="post" asp-area="SocialService" asp-controller="Student" asp-action="MarcarRechazoLeido" class="d-inline">
                <input type="hidden" name="rejectionId" value="@rejection.RejectionId" />
                <button type="submit" class="btn-close" aria-label="Close"></button>
            </form>
        </div>
    }
}

<div class="text-end mb-3">
    <a asp-area="SocialService" asp-controller="Student" asp-action="Download" asp-route-filename="plantilla_bitacora.pdf" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-file-earmark-pdf me-1"></i> Descargar plantilla PDF
    </a>
</div>

@if (Model != null && Model.Count > 0)
{
    <div class="bitacora-container">
        @foreach (var bitacora in Model)
        {
            <div class="bitacora-item" data-bs-toggle="modal" data-bs-target="#bitacoraModal@(bitacora.LogId)">

                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h6 class="mb-0">Semana @bitacora.Week</h6>
                    @if (bitacora.IsApproved)
                    {
                        <span class="badge bg-success">
                            <i class="bi bi-check-circle-fill"></i> Aprobada
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">
                            <i class="bi bi-clock-fill"></i> Pendiente
                        </span>
                    }
                </div>

                <p><strong>Actividades:</strong></p>
                <p class="bitacora-activities">@bitacora.Activities</p>

                <div class="d-flex justify-content-between mb-2">
                    <span><strong>Prácticas:</strong> @bitacora.HoursPracticas hrs</span>
                    <span><strong>Servicio:</strong> @bitacora.HoursServicioSocial hrs</span>
                </div>

                @if (bitacora.IsApproved)
                {
                    <div class="alert alert-success py-2 px-3 mb-2" style="font-size: 0.875rem;">
                        <strong><i class="bi bi-check-circle"></i> Horas aprobadas:</strong><br>
                        Prácticas: @bitacora.ApprovedHoursPracticas hrs | Servicio: @bitacora.ApprovedHoursServicioSocial hrs
                        @if (bitacora.ApprovedAt.HasValue)
                        {
                            <br><small class="text-muted">Aprobada el @bitacora.ApprovedAt.Value.ToString("dd/MM/yyyy")</small>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(bitacora.TeacherComments))
                    {
                        <div class="alert alert-info py-2 px-3 mb-2" style="font-size: 0.875rem;">
                            <strong><i class="bi bi-chat-square-text"></i> Comentario del maestro:</strong><br>
                            @bitacora.TeacherComments
                        </div>
                    }
                }

                @if (!string.IsNullOrEmpty(bitacora.Observations))
                {
                    <p><strong>Observaciones:</strong></p>
                    <p class="bitacora-observations">@bitacora.Observations</p>
                }

                <p class="text-muted mb-0">
                    <i class="bi bi-calendar3"></i> @bitacora.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </p>

            </div>

            <!-- Modal para ver bitácora completa -->
            <div class="modal fade bitacora-modal" id="bitacoraModal@(bitacora.LogId)" tabindex="-1" aria-labelledby="bitacoraModalLabel@(bitacora.LogId)" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="bitacoraModalLabel@(bitacora.LogId)">
                                <i class="bi bi-journal-text me-2"></i>Bitácora - Semana @bitacora.Week
                                @if (bitacora.IsApproved)
                                {
                                    <span class="badge bg-success ms-2">
                                        <i class="bi bi-check-circle-fill"></i> Aprobada
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark ms-2">
                                        <i class="bi bi-clock-fill"></i> Pendiente de revisión
                                    </span>
                                }
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            @if (bitacora.IsApproved)
                            {
                                <div class="alert alert-success mb-3">
                                    <h6 class="alert-heading"><i class="bi bi-check-circle-fill"></i> Estado: Aprobada</h6>
                                    <hr>
                                    <p class="mb-1"><strong>Horas aprobadas:</strong></p>
                                    <ul class="mb-2">
                                        <li>Prácticas Profesionales: <strong>@bitacora.ApprovedHoursPracticas horas</strong></li>
                                        <li>Servicio Social: <strong>@bitacora.ApprovedHoursServicioSocial horas</strong></li>
                                    </ul>
                                    @if (bitacora.ApprovedAt.HasValue)
                                    {
                                        <small class="text-muted">Fecha de aprobación: @bitacora.ApprovedAt.Value.ToString("dd/MM/yyyy HH:mm")</small>
                                    }
                                    @if (!string.IsNullOrEmpty(bitacora.TeacherComments))
                                    {
                                        <hr>
                                        <p class="mb-1"><strong><i class="bi bi-chat-square-text"></i> Comentario del maestro:</strong></p>
                                        <p class="mb-0">@bitacora.TeacherComments</p>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning mb-3">
                                    <h6 class="alert-heading"><i class="bi bi-clock-fill"></i> Estado: Pendiente de revisión</h6>
                                    <p class="mb-0">Tu maestro asesor aún no ha revisado esta bitácora. Recibirás una notificación cuando sea aprobada.</p>
                                </div>
                            }

                            <div class="detail-section">
                                <h6><i class="bi bi-list-task me-2"></i>Actividades Realizadas</h6>
                                <p>@bitacora.Activities</p>
                            </div>

                            <div class="hours-grid">
                                <div class="hour-badge">
                                    <strong>Horas Prácticas Profesionales</strong>
                                    <h4 class="text-primary mt-2">@bitacora.HoursPracticas</h4>
                                </div>
                                <div class="hour-badge">
                                    <strong>Horas Servicio Social</strong>
                                    <h4 class="text-success mt-2">@bitacora.HoursServicioSocial</h4>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(bitacora.Observations))
                            {
                                <div class="detail-section">
                                    <h6><i class="bi bi-chat-left-text me-2"></i>Observaciones</h6>
                                    <p>@bitacora.Observations</p>
                                </div>
                            }

                            <div class="creation-date">
                                <p>
                                    <i class="bi bi-calendar-check me-2"></i>
                                    <strong>Fecha de creación:</strong> @bitacora.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </p>
                            </div>
                        </div>
                        <div class="modal-footer">
                            @if (!bitacora.IsApproved)
                            {
                                <a href="/SocialService/Student/EditarBitacora/@bitacora.LogId" class="btn btn-warning me-auto">
                                    <i class="bi bi-pencil-square"></i> Editar bitácora
                                </a>
                            }
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                <i class="bi bi-x-circle me-1"></i> Cerrar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center">
        <p>No tienes bitácoras registradas.</p>
    </div>
}