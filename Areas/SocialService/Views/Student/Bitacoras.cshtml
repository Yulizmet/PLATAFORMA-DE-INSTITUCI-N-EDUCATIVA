@model List<SchoolManager.Models.social_service_log>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Mis Bitácoras</h3>
    <div class="d-flex gap-2">
        <a href="/SocialService/Student/CrearBitacora" class="btn btn-primary">
            <i class="bi bi-plus-circle-fill me-1"></i> Crear nueva bitácora
        </a>
        <a asp-area="SocialService" asp-controller="Student" asp-action="Dashboard" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="text-end mb-3">
    <a asp-area="SocialService" asp-controller="Student" asp-action="Download" asp-route-filename="plantilla_bitacora.pdf" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-file-earmark-pdf me-1"></i> Descargar plantilla PDF
    </a>
</div>

@if (Model != null && Model.Count > 0)
{
    <div class="bitacora-container">
        @foreach (var bitacora in Model)
        {
            <div class="bitacora-item" data-bs-toggle="modal" data-bs-target="#bitacoraModal@(bitacora.LogId)">

                <h6>Semana @bitacora.Week</h6>

                <p><strong>Actividades:</strong></p>
                <p class="bitacora-activities">@bitacora.Activities</p>

                <div class="d-flex justify-content-between mb-2">
                    <span><strong>Prácticas:</strong> @bitacora.HoursPracticas</span>
                    <span><strong>Servicio:</strong> @bitacora.HoursServicioSocial</span>
                </div>

                @if (!string.IsNullOrEmpty(bitacora.Observations))
                {
                    <p><strong>Observaciones:</strong></p>
                    <p class="bitacora-observations">@bitacora.Observations</p>
                }

                <p class="text-muted">
                    <i class="bi bi-calendar3"></i> @bitacora.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </p>

            </div>

            <!-- Modal para ver bitácora completa -->
            <div class="modal fade bitacora-modal" id="bitacoraModal@(bitacora.LogId)" tabindex="-1" aria-labelledby="bitacoraModalLabel@(bitacora.LogId)" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="bitacoraModalLabel@(bitacora.LogId)">
                                <i class="bi bi-journal-text me-2"></i>Bitácora - Semana @bitacora.Week
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="detail-section">
                                <h6><i class="bi bi-list-task me-2"></i>Actividades Realizadas</h6>
                                <p>@bitacora.Activities</p>
                            </div>

                            <div class="hours-grid">
                                <div class="hour-badge">
                                    <strong>Horas Prácticas Profesionales</strong>
                                    <h4 class="text-primary mt-2">@bitacora.HoursPracticas</h4>
                                </div>
                                <div class="hour-badge">
                                    <strong>Horas Servicio Social</strong>
                                    <h4 class="text-success mt-2">@bitacora.HoursServicioSocial</h4>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(bitacora.Observations))
                            {
                                <div class="detail-section">
                                    <h6><i class="bi bi-chat-left-text me-2"></i>Observaciones</h6>
                                    <p>@bitacora.Observations</p>
                                </div>
                            }

                            <div class="creation-date">
                                <p>
                                    <i class="bi bi-calendar-check me-2"></i>
                                    <strong>Fecha de creación:</strong> @bitacora.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </p>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                <i class="bi bi-x-circle me-1"></i> Cerrar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center">
        <p>No tienes bitácoras registradas.</p>
    </div>
}