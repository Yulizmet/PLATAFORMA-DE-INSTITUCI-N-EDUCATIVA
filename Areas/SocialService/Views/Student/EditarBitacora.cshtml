@model SchoolManager.Areas.SocialService.ViewModels.BitacoraViewModel

<div class="bitacora-form-container">

    <div class="card">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">
                    <i class="bi bi-pencil-square me-2"></i>Editar Bitácora
                </h4>
                <a href="/SocialService/Student/Bitacoras" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver
                </a>
            </div>

            <div class="alert alert-info mb-4">
                <i class="bi bi-info-circle-fill"></i> 
                Puedes editar esta bitácora porque aún no ha sido aprobada por tu maestro asesor.
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-area="SocialService"
                  asp-controller="Student"
                  asp-action="EditarBitacora"
                  asp-route-id="@ViewBag.LogId"
                  method="post">

                <div class="mb-4 form-group-inline">
                    <label asp-for="Week" class="form-label">Semana</label>
                    <input asp-for="Week" class="form-control input-small" />
                    <span asp-validation-for="Week" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Activities" class="form-label"></label>
                    <textarea asp-for="Activities" class="form-control textarea-large" rows="6"></textarea>
                    <span asp-validation-for="Activities" class="text-danger"></span>
                </div>

                <div class="horas-inputs mb-4">

                    <div>
                        <label asp-for="HoursPracticas"></label>
                        <input asp-for="HoursPracticas" type="number" class="form-control input-small" min="0" max="40" />
                        <span asp-validation-for="HoursPracticas" class="text-danger"></span>
                    </div>

                    <div>
                        <label asp-for="HoursServicioSocial"></label>
                        <input asp-for="HoursServicioSocial" type="number" class="form-control input-small" min="0" max="40" />
                        <span asp-validation-for="HoursServicioSocial" class="text-danger"></span>
                    </div>

                </div>

                <div class="mb-4">
                    <label asp-for="Observations"></label>
                    <textarea asp-for="Observations" class="form-control textarea-large" rows="4"></textarea>
                    <span asp-validation-for="Observations" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-save"></i> Guardar Cambios
                    </button>
                    <a href="/SocialService/Student/Bitacoras" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </a>
                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
