@model SchoolManager.Areas.SocialService.ViewModels.BitacoraViewModel

<div class="bitacora-form-container">

    <div class="card">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">Crear Bitácora Semanal</h4>
                <a asp-area="SocialService" asp-controller="Student" asp-action="Dashboard" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver
                </a>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-area="SocialService"
                  asp-controller="Student"
                  asp-action="CrearBitacora"
                  method="post">

                <div class="mb-4 form-group-inline">
                    <label asp-for="Week" class="form-label">Semana</label>
                    <input asp-for="Week" class="form-control input-small" />
                </div>

                <div class="mb-4">
                    <label asp-for="Activities" class="form-label"></label>
                    <textarea asp-for="Activities" class="form-control textarea-large"></textarea>
                </div>

                <div class="horas-inputs mb-4">

                    <div>
                        <label asp-for="HoursPracticas"></label>
                        <input asp-for="HoursPracticas" type="number" class="form-control input-small" />
                    </div>

                    <div>
                        <label asp-for="HoursServicioSocial"></label>
                        <input asp-for="HoursServicioSocial" type="number" class="form-control input-small" />
                    </div>

                </div>

                <div class="mb-4">
                    <label asp-for="Observations"></label>
                    <textarea asp-for="Observations" class="form-control textarea-large"></textarea>
                </div>

                <button type="submit" class="btn-primary">
                    Guardar Bitácora
                </button>

            </form>

        </div>
    </div>

</div>