@model SchoolManager.Areas.SocialService.ViewModels.BitacoraViewModel

<div class="bitacora-form-container">

    <div class="card">
        <div class="card-body">

            <div class="mb-4 text-start">
                <a asp-area="SocialService" asp-controller="Student" asp-action="Dashboard" class="btn btn-secondary btn-responsive-sm">
                    <i class="bi bi-arrow-left me-1"></i> Volver
                </a>
            </div>

            <div class="mb-3">
                <h4 class="text-center mb-0">Crear Bitácora Semanal</h4>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-area="SocialService"
                  asp-controller="Student"
                  asp-action="CrearBitacora"
                  method="post"
                  enctype="multipart/form-data">

                <div class="mb-4 form-group-inline">
                    <label asp-for="Week" class="form-label">Semana</label>
                    <input asp-for="Week" type="number" min="1" class="form-control input-small" />
                    <span asp-validation-for="Week" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Activities" class="form-label"></label>
                    <textarea asp-for="Activities" class="form-control textarea-large"></textarea>
                </div>

                <div class="horas-inputs mb-4">

                    <div>
                        <label asp-for="HoursPracticas"></label>
                        <input asp-for="HoursPracticas" type="number" min="0" max="40" class="form-control input-small" />
                        <span asp-validation-for="HoursPracticas" class="text-danger"></span>
                        <div class="form-text text-muted">Límite: 0 - 40 horas</div>
                    </div>

                    <div>
                        <label asp-for="HoursServicioSocial"></label>
                        <input asp-for="HoursServicioSocial" type="number" min="0" max="40" class="form-control input-small" />
                        <span asp-validation-for="HoursServicioSocial" class="text-danger"></span>
                        <div class="form-text text-muted">Límite: 0 - 40 horas</div>
                    </div>

                </div>

                <div class="mb-4">
                    <label asp-for="Observations"></label>
                    <textarea asp-for="Observations" class="form-control textarea-large"></textarea>
                </div>

                <div class="mb-4">
                    <label asp-for="PdfFile" class="form-label">
                        <i class="bi bi-file-earmark-pdf me-1"></i> Archivo PDF (opcional, máx. 10 MB)
                    </label>
                    <input asp-for="PdfFile" type="file" class="form-control" accept=".pdf" />
                </div>

                <button type="submit" class="btn-primary">
                    Guardar Bitácora
                </button>

            </form>

        </div>
    </div>

</div>