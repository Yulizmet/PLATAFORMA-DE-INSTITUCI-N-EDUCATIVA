@page
@{
    ViewData["Title"] = "Crear Bitácora";
}

<div class="bitacora-form-container">

    <div class="card">
        <div class="card-body">

            <h4 class="mb-4">Crear Bitácora Semanal</h4>

            <form>

                <!-- SEMANA -->
                <div class="mb-4 form-group-inline">
                    <label class="form-label">Semana</label>
                    <input type="text"
                           class="form-control input-small"
                           placeholder="Ej. Semana 3" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Actividades realizadas</label>
                    <textarea class="form-control textarea-large"
                              placeholder="Describe detalladamente las actividades realizadas durante la semana"></textarea>
                </div>

                <!-- HORAS -->
                <div class="horas-inputs mb-4">
                    <div>
                        <label class="form-label">Horas de Prácticas Profesionales</label>
                        <input type="number"
                               class="form-control input-small"
                               placeholder="Ej. 20" />
                    </div>

                    <div>
                        <label class="form-label">Horas de Servicio Social</label>
                        <input type="number"
                               class="form-control input-small"
                               placeholder="Ej. 10" />
                    </div>
                </div>

                <!-- OBSERVACIONES (ANCHO COMPLETO) -->
                <div class="mb-4">
                    <label class="form-label">Observaciones (opcional)</label>
                    <textarea class="form-control textarea-large"></textarea>
                </div>

                <!-- GUARDAR -->
                <button type="submit" class="btn-primary">
                    Guardar Bitácora
                </button>

            </form>

        </div>
    </div>

</div>
