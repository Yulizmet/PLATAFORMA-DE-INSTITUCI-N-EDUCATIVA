@page
@{
    Layout = "/Areas/MainScreen/Views/Shared/_Layout.cshtml";
}

<h3>Dashboard Alumno</h3>

<div class="dashboard-cards">
    <div class="card dashboard-card">
        <div class="card-body">
            <h5>Horas</h5>
            <p>Prácticas: 120 / 480</p>
            <p>Servicio Social: 80 / 480</p>
            <a href="/SocialService/Student/Horas" class="btn btn-primary">Ver horas</a>
        </div>
    </div>

    <div class="card dashboard-card">
        <div class="card-body">
            <h5>Bitácoras</h5>
            <p>Consulta tus registros semanales</p>
            <a href="/SocialService/Student/Bitacoras" class="btn btn-primary">Ver bitácoras</a>
        </div>
    </div>
</div>
