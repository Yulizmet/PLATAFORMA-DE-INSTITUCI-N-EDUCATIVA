@{
    ViewData["Title"] = "Dashboard Master";
}

<div class="dashboard-cards">
    <div class="card dashboard-card slide-in-left">
        <div class="card-body">
            <div class="icon-box icon-docentes mb-3">
                <i class="bi bi-person-workspace"></i>
            </div>
            <h5><i class="bi bi-person-badge-fill me-2"></i>Maestros</h5>
            <p>Consulta la lista de asesores y sus alumnos asignados</p>
            <a asp-area="SocialService" asp-controller="Coordinator" asp-action="Maestros" class="btn btn-primary">
                <i class="bi bi-eye-fill me-1"></i> Ver Maestros
            </a>
        </div>
    </div>

    <div class="card dashboard-card slide-in-left" style="animation-delay: 0.1s;">
        <div class="card-body">
            <div class="icon-box icon-estudiantes mb-3">
                <i class="bi bi-people-fill"></i>
            </div>
            <h5><i class="bi bi-mortarboard-fill me-2"></i>Alumnos</h5>
            <p>Consulta todos los alumnos, sus bitácoras, asistencias y horas</p>
            <a asp-area="SocialService" asp-controller="Coordinator" asp-action="Alumnos" class="btn btn-primary">
                <i class="bi bi-eye-fill me-1"></i> Ver Alumnos
            </a>
        </div>
    </div>
</div>


