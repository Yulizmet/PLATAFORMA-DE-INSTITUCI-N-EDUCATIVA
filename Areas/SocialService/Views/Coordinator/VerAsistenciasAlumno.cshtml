@model SchoolManager.Areas.SocialService.ViewModels.CoordinatorAttendanceDetailViewModel

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="mb-2">
    @if (ViewBag.TeacherId != null)
    {
        <a asp-area="SocialService" asp-controller="Coordinator" asp-action="VerAlumnosAsesor" asp-route-id="@ViewBag.TeacherId" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver a Alumnos del Asesor
        </a>
    }
    else
    {
        <a asp-area="SocialService" asp-controller="Coordinator" asp-action="Alumnos" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    }
</div>

<!-- Título -->
<div class="mb-4 text-center">
    <h3 class="mb-0">
        Asistencias de @Model.StudentName
    </h3>
</div>

<!-- Resumen -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <h2>@Model.Attendances.Count</h2>
            <p>Total Registros</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <h2 class="text-success">@Model.TotalPresent</h2>
            <p>Asistencias</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <h2 class="text-danger">@Model.TotalAbsent</h2>
            <p>Inasistencias</p>
        </div>
    </div>
</div>

<!-- Tabla de asistencias -->
<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>#</th>
                <th>Fecha</th>
                <th>Día</th>
                <th class="text-center">Estado</th>
                <th>Notas</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Attendances.Count > 0)
            {
                int rowNum = 1;
                @foreach (var attendance in Model.Attendances)
                {
                    <tr>
                        <td>@(rowNum++)</td>
                        <td>@attendance.Date.ToString("dd/MM/yyyy")</td>
                        <td>@attendance.Date.ToString("dddd", new System.Globalization.CultureInfo("es-MX"))</td>
                        <td class="text-center">
                            @if (attendance.IsPresent)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle-fill me-1"></i> Presente
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-x-circle-fill me-1"></i> Ausente
                                </span>
                            }
                        </td>
                        <td>@(attendance.Notes ?? "-")</td>
                        <td class="text-center">
                            @if ((ViewBag.EsCoordinador == true) || (ViewBag.EsMaster == true))
                            {
                                <button type="button" class="btn btn-warning btn-sm" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#editarAsistenciaModal"
                                        data-attendance-id="@attendance.AttendanceId"
                                        data-student-id="@Model.StudentId"
                                        data-is-present="@attendance.IsPresent.ToString().ToLower()"
                                        data-fecha="@attendance.Date.ToString("dd/MM/yyyy")">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No se encontraron registros de asistencia.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal Editar Asistencia -->
<div class="modal fade" id="editarAsistenciaModal" tabindex="-1" aria-labelledby="editarAsistenciaModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-area="SocialService" asp-controller="Coordinator" asp-action="EditarAsistencia">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="editarAsistenciaModalLabel">
                        <i class="bi bi-pencil-square me-1"></i> Editar Asistencia
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="attendanceId" id="modalAttendanceId" />
                    <input type="hidden" name="studentId" id="modalStudentId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Fecha</label>
                        <p id="modalFecha" class="form-control-plaintext"></p>
                    </div>
                    <div class="mb-3">
                        <label for="modalIsPresent" class="form-label fw-bold">Estado</label>
                        <select class="form-select" name="isPresent" id="modalIsPresent">
                            <option value="true">Presente</option>
                            <option value="false">Ausente</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var modal = document.getElementById('editarAsistenciaModal');
            modal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                document.getElementById('modalAttendanceId').value = button.getAttribute('data-attendance-id');
                document.getElementById('modalStudentId').value = button.getAttribute('data-student-id');
                document.getElementById('modalFecha').textContent = button.getAttribute('data-fecha');
                document.getElementById('modalIsPresent').value = button.getAttribute('data-is-present');
            });
        });
    </script>
}
