@model List<SchoolManager.Models.social_service_log>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-0">Bitácoras de @ViewBag.StudentName</h3>
        @if (ViewBag.TeacherName != null)
        {
            <small class="text-muted">Asesor: @ViewBag.TeacherName</small>
        }
    </div>
    <a asp-area="SocialService" asp-controller="Coordinator" asp-action="Alumnos" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

@if (Model != null && Model.Count > 0)
{
    <div class="teacher-bitacora-grid">
        @foreach (var bitacora in Model)
        {
            <div class="teacher-bitacora-card @(bitacora.IsApproved ? "approved" : "pending")">
                <div class="teacher-card-header @(bitacora.IsApproved ? "approved" : "")">
                    <h6>
                        Semana @bitacora.Week
                        @if (bitacora.IsApproved)
                        {
                            <span class="badge bg-light text-success float-end">
                                <i class="bi bi-check-circle-fill"></i> Aprobada
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-warning float-end">
                                <i class="bi bi-clock"></i> Pendiente
                            </span>
                        }
                    </h6>
                </div>

                <div class="teacher-card-body">
                    <div class="mb-2">
                        <strong>Actividades:</strong>
                        <p class="mb-1">@bitacora.Activities</p>
                    </div>

                    @if (!string.IsNullOrEmpty(bitacora.Observations))
                    {
                        <div class="mb-2">
                            <strong>Observaciones:</strong>
                            <p class="mb-1">@bitacora.Observations</p>
                        </div>
                    }

                    <div class="row mb-2">
                        <div class="col-6">
                            <small class="text-muted">Hrs. Prácticas solicitadas:</small>
                            <div><strong>@bitacora.HoursPracticas h</strong></div>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">Hrs. Servicio Social solicitadas:</small>
                            <div><strong>@bitacora.HoursServicioSocial h</strong></div>
                        </div>
                    </div>

                    @if (bitacora.IsApproved)
                    {
                        <div class="row mb-2">
                            <div class="col-6">
                                <small class="text-muted">Hrs. Prácticas aprobadas:</small>
                                <div class="text-success"><strong>@bitacora.ApprovedHoursPracticas h</strong></div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Hrs. Servicio Social aprobadas:</small>
                                <div class="text-success"><strong>@bitacora.ApprovedHoursServicioSocial h</strong></div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(bitacora.TeacherComments))
                        {
                            <div class="mb-2">
                                <strong>Comentarios del asesor:</strong>
                                <p class="mb-1 text-info">@bitacora.TeacherComments</p>
                            </div>
                        }

                        <small class="text-muted">
                            Aprobada el @bitacora.ApprovedAt?.ToString("dd/MM/yyyy HH:mm")
                        </small>
                    }

                    @if (bitacora.PdfFileName != null)
                    {
                        <div class="mt-2">
                            <span class="badge bg-secondary">
                                <i class="bi bi-file-earmark-pdf me-1"></i>@bitacora.PdfFileName
                            </span>
                        </div>
                    }

                    <div class="mt-2">
                        <small class="text-muted">Creada el @bitacora.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info text-center">
        <i class="bi bi-info-circle me-2"></i>
        Este alumno no tiene bitácoras registradas.
    </div>
}
