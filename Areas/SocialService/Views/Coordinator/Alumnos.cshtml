@model List<SchoolManager.Areas.SocialService.ViewModels.CoordinatorStudentViewModel>

@{
    ViewData["Title"] = "Todos los Alumnos";
    string currentSort = ViewBag.CurrentSort ?? "name";
    string currentOrder = ViewBag.CurrentOrder ?? "asc";
    string searchName = ViewBag.SearchName ?? "";
    string teacherFilter = ViewBag.TeacherFilter ?? "";
    string semesterFilter = ViewBag.SemesterFilter ?? "";
    string groupFilter = ViewBag.GroupFilter ?? "";
    int pageSizeVal = ViewBag.PageSize ?? 10;

    string SortUrl(string column)
    {
        string newOrder = (currentSort == column && currentOrder == "asc") ? "desc" : "asc";
        return $"?searchName={searchName}&teacherFilter={teacherFilter}&semesterFilter={semesterFilter}&groupFilter={groupFilter}&sortBy={column}&sortOrder={newOrder}&page=1&pageSize={pageSizeVal}";
    }

    string SortIcon(string column)
    {
        if (currentSort != column) return "bi-arrow-down-up";
        return currentOrder == "asc" ? "bi-sort-up" : "bi-sort-down";
    }
}

<h3><i class="bi bi-mortarboard-fill me-2"></i>Todos los Alumnos</h3>

<div class="mb-3 d-flex gap-2">
    <a asp-area="SocialService" asp-controller="Coordinator" asp-action="Dashboard" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Regresar al Dashboard
    </a>
    <a asp-area="SocialService" asp-controller="Coordinator" asp-action="ExportAlumnosExcel"
       asp-route-searchName="@searchName" asp-route-teacherFilter="@teacherFilter"
       asp-route-semesterFilter="@semesterFilter" asp-route-groupFilter="@groupFilter"
       class="btn btn-success">
        <i class="bi bi-file-earmark-excel me-1"></i> Exportar a Excel
    </a>
    <a asp-area="SocialService" asp-controller="Coordinator" asp-action="ExportAlumnosPdf"
       asp-route-searchName="@searchName" asp-route-teacherFilter="@teacherFilter"
       asp-route-semesterFilter="@semesterFilter" asp-route-groupFilter="@groupFilter"
       class="btn btn-danger">
        <i class="bi bi-file-earmark-pdf me-1"></i> Exportar en PDF
    </a>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-header">
        <i class="bi bi-funnel"></i> Filtros de Búsqueda
    </div>
    <div class="card-body py-4">
        <form method="get" asp-action="Alumnos" id="filterForm">
            <input type="hidden" name="sortBy" value="@currentSort" />
            <input type="hidden" name="sortOrder" value="@currentOrder" />
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label for="searchName" class="form-label mb-2">Buscar por nombre</label>
                    <input type="text" class="form-control" id="searchName" name="searchName"
                           value="@searchName" placeholder="Nombre del alumno...">
                </div>

                <div class="col-md-2">
                    <label for="teacherFilter" class="form-label mb-2">Asesor</label>
                    <select class="form-select" id="teacherFilter" name="teacherFilter" onchange="this.form.submit()">
                        <option value="">Todos</option>
                        @if (ViewBag.Teachers != null)
                        {
                            foreach (var teacher in (List<string>)ViewBag.Teachers)
                            {
                                <option value="@teacher" selected="@(teacherFilter == teacher)">@teacher</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label for="semesterFilter" class="form-label mb-2">Semestre</label>
                    <select class="form-select" id="semesterFilter" name="semesterFilter" onchange="this.form.submit()">
                        <option value="">Todos</option>
                        @if (ViewBag.Semesters != null)
                        {
                            foreach (var semester in (List<string>)ViewBag.Semesters)
                            {
                                <option value="@semester" selected="@(semesterFilter == semester)">@semester</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label for="groupFilter" class="form-label mb-2">Grupo</label>
                    <select class="form-select" id="groupFilter" name="groupFilter" onchange="this.form.submit()">
                        <option value="">Todos</option>
                        @if (ViewBag.Groups != null)
                        {
                            foreach (var group in (List<string>)ViewBag.Groups)
                            {
                                <option value="@group" selected="@(groupFilter == group)">@group</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-1">
                    <label for="pageSize" class="form-label mb-2"><i class="bi bi-list-ol"></i></label>
                    <select class="form-select" id="pageSize" name="pageSize" onchange="this.form.submit()">
                        @foreach (var size in new[] { 10, 25, 50, 100 })
                        {
                            <option value="@size" selected="@(pageSizeVal == size)">@size</option>
                        }
                    </select>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                    <a asp-action="Alumnos" class="btn btn-secondary px-4">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Tabla de alumnos -->
<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>#</th>
                <th>
                    <a href="@SortUrl("name")" class="text-decoration-none">
                        Alumno <i class="bi @SortIcon("name")"></i>
                    </a>
                </th>
                <th>
                    <a href="@SortUrl("semester")" class="text-decoration-none">
                        Semestre <i class="bi @SortIcon("semester")"></i>
                    </a>
                </th>
                <th>
                    <a href="@SortUrl("group")" class="text-decoration-none">
                        Grupo <i class="bi @SortIcon("group")"></i>
                    </a>
                </th>
                <th>
                    <a href="@SortUrl("teacher")" class="text-decoration-none">
                        Asesor <i class="bi @SortIcon("teacher")"></i>
                    </a>
                </th>
                <th class="text-center">
                    <a href="@SortUrl("bitacoras")" class="text-decoration-none">
                        Bitácoras <i class="bi @SortIcon("bitacoras")"></i>
                    </a>
                </th>
                <th class="text-center">
                    <a href="@SortUrl("pendientes")" class="text-decoration-none">
                        Pendientes <i class="bi @SortIcon("pendientes")"></i>
                    </a>
                </th>
                <th class="text-center">
                    <a href="@SortUrl("practicas")" class="text-decoration-none">
                        Hrs Prácticas <i class="bi @SortIcon("practicas")"></i>
                    </a>
                </th>
                <th class="text-center">
                    <a href="@SortUrl("servicio")" class="text-decoration-none">
                        Hrs Servicio <i class="bi @SortIcon("servicio")"></i>
                    </a>
                </th>
                <th class="text-center">Validación</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                int rowNum = ((int)(ViewBag.CurrentPage ?? 1) - 1) * pageSizeVal + 1;
                @foreach (var student in Model)
                {
                    int totalHoras = student.TotalHorasPracticas + student.TotalHorasServicioSocial;
                    double porcentaje = (totalHoras / 720.0) * 100;

                    <tr>
                        <td>@(rowNum++)</td>
                        <td><strong>@student.StudentName</strong></td>
                        <td>@(student.SemesterName ?? "N/A")</td>
                        <td>@(student.GroupName ?? "N/A")</td>
                        <td>@student.TeacherName</td>
                        <td class="text-center">@student.TotalBitacoras</td>
                        <td class="text-center">
                            @if (student.BitacorasPendientes > 0)
                            {
                                <span class="badge bg-warning text-dark">@student.BitacorasPendientes</span>
                            }
                            else
                            {
                                <span class="badge bg-success">0</span>
                            }
                        </td>
                        <td class="text-center">@student.TotalHorasPracticas / 240</td>
                        <td class="text-center">@student.TotalHorasServicioSocial / 480</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-1 flex-nowrap validation-badges">
                                <span class="badge @(porcentaje >= 25 ? "bg-success" : "bg-danger")">25%</span>
                                <span class="badge @(porcentaje >= 50 ? "bg-success" : "bg-danger")">50%</span>
                                <span class="badge @(porcentaje >= 75 ? "bg-success" : "bg-danger")">75%</span>
                                <span class="badge @(porcentaje >= 100 ? "bg-success" : "bg-danger")">100%</span>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10" class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No se encontraron alumnos.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Paginación -->
@if ((int)(ViewBag.TotalPages ?? 0) > 1)
{
    <nav aria-label="Paginación">
        <ul class="pagination justify-content-center">
            <li class="page-item @((int)(ViewBag.CurrentPage ?? 1) <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Alumnos"
                   asp-route-searchName="@searchName"
                   asp-route-teacherFilter="@teacherFilter"
                   asp-route-semesterFilter="@semesterFilter"
                   asp-route-groupFilter="@groupFilter"
                   asp-route-sortBy="@currentSort"
                   asp-route-sortOrder="@currentOrder"
                   asp-route-page="@((int)(ViewBag.CurrentPage ?? 1) - 1)"
                   asp-route-pageSize="@pageSizeVal">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= (int)(ViewBag.TotalPages ?? 0); i++)
            {
                <li class="page-item @(i == (int)(ViewBag.CurrentPage ?? 1) ? "active" : "")">
                    <a class="page-link" asp-action="Alumnos"
                       asp-route-searchName="@searchName"
                       asp-route-teacherFilter="@teacherFilter"
                       asp-route-semesterFilter="@semesterFilter"
                       asp-route-groupFilter="@groupFilter"
                       asp-route-sortBy="@currentSort"
                       asp-route-sortOrder="@currentOrder"
                       asp-route-page="@i"
                       asp-route-pageSize="@pageSizeVal">@i</a>
                </li>
            }
            <li class="page-item @((int)(ViewBag.CurrentPage ?? 1) >= (int)(ViewBag.TotalPages ?? 0) ? "disabled" : "")">
                <a class="page-link" asp-action="Alumnos"
                   asp-route-searchName="@searchName"
                   asp-route-teacherFilter="@teacherFilter"
                   asp-route-semesterFilter="@semesterFilter"
                   asp-route-groupFilter="@groupFilter"
                   asp-route-sortBy="@currentSort"
                   asp-route-sortOrder="@currentOrder"
                   asp-route-page="@((int)(ViewBag.CurrentPage ?? 1) + 1)"
                   asp-route-pageSize="@pageSizeVal">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}

<p class="text-muted text-center">
    Mostrando @Model?.Count de @ViewBag.TotalRecords registros
</p>
