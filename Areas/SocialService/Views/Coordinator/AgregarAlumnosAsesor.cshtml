@model IEnumerable<SchoolManager.Areas.SocialService.ViewModels.AvailableStudentViewModel>

@{
    ViewData["Title"] = "Agregar Alumnos al Asesor";
    int teacherId = ViewBag.TeacherId ?? 0;
}

<div class="mb-3">
    <a asp-area="SocialService" asp-controller="Coordinator" asp-action="Maestros" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Regresar a Maestros
    </a>
</div>

<h3 class="text-center my-3">Agregar Alumnos al Asesor</h3>

<div class="card">
    <div class="card-body">
        <form method="get" class="mb-4" id="filterForm">
            <input type="hidden" name="teacherId" value="@teacherId" />
            <input type="hidden" name="sortBy" value="@ViewBag.CurrentSort" />
            <input type="hidden" name="sortOrder" value="@ViewBag.CurrentOrder" />
            <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />

            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Buscar por nombre</label>
                    <input type="text" class="form-control" id="searchName" name="searchName" value="@ViewBag.SearchName" placeholder="Escribe para buscar..." />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Semestre</label>
                    <select class="form-select" name="semesterFilter" onchange="this.form.submit()">
                        <option value="">Todos los semestres</option>
                        @if (ViewBag.Semesters != null)
                        {
                            foreach (var sem in (List<string>)ViewBag.Semesters)
                            {
                                <option value="@sem" selected="@(ViewBag.SemesterFilter == sem)">@sem</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Grupo</label>
                    <select class="form-select" name="groupFilter" onchange="this.form.submit()">
                        <option value="">Todos los grupos</option>
                        @if (ViewBag.Groups != null)
                        {
                            foreach (var g in (List<string>)ViewBag.Groups)
                            {
                                <option value="@g" selected="@(ViewBag.GroupFilter == g)">@g</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Carrera</label>
                    <select class="form-select" name="careerFilter" onchange="this.form.submit()">
                        <option value="">Todas las carreras</option>
                        @if (ViewBag.Careers != null)
                        {
                            foreach (var c in (List<string>)ViewBag.Careers)
                            {
                                <option value="@c" selected="@(ViewBag.CareerFilter == c)">@c</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                    <a href="@Url.Action("AgregarAlumnosAsesor", new { teacherId = teacherId })" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </a>
                </div>
            </div>
        </form>
        <script src="~/js/SocialServiceAutoSearch.js"></script>

        @if (Model != null && Model.Any())
        {
            <div class="mb-3 text-muted small">
                Mostrando @Model.Count() de @ViewBag.TotalRecords estudiantes
            </div>

            <div class="table-responsive ss-table-scroll-wrapper">
                <table class="table table-hover ss-table-scroll">
                    <thead>
                        <tr>
                            <th>
                                <a href="@Url.Action("AgregarAlumnosAsesor", new { teacherId = teacherId, sortBy = "name", sortOrder = ViewBag.CurrentSort == "name" ? ViewBag.NextOrder : "asc", searchName = ViewBag.SearchName, semesterFilter = ViewBag.SemesterFilter, groupFilter = ViewBag.GroupFilter, careerFilter = ViewBag.CareerFilter, page = 1, pageSize = ViewBag.PageSize })" class="text-decoration-none text-white">
                                    NOMBRE
                                    @if (ViewBag.CurrentSort == "name")
                                    {
                                        <i class="bi bi-@(ViewBag.CurrentOrder == "asc" ? "sort-alpha-down" : "sort-alpha-up")"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-filter text-muted"></i>
                                    }
                                </a>
                            </th>
                            <th class="text-center">
                                <a href="@Url.Action("AgregarAlumnosAsesor", new { teacherId = teacherId, sortBy = "career", sortOrder = ViewBag.CurrentSort == "career" ? ViewBag.NextOrder : "asc", searchName = ViewBag.SearchName, semesterFilter = ViewBag.SemesterFilter, groupFilter = ViewBag.GroupFilter, careerFilter = ViewBag.CareerFilter, page = 1, pageSize = ViewBag.PageSize })" class="text-decoration-none text-white">
                                    CARRERA
                                    @if (ViewBag.CurrentSort == "career")
                                    {
                                        <i class="bi bi-@(ViewBag.CurrentOrder == "asc" ? "sort-down" : "sort-up")"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-filter text-muted"></i>
                                    }
                                </a>
                            </th>
                            <th class="text-center">
                                <a href="@Url.Action("AgregarAlumnosAsesor", new { teacherId = teacherId, sortBy = "semester", sortOrder = ViewBag.CurrentSort == "semester" ? ViewBag.NextOrder : "asc", searchName = ViewBag.SearchName, semesterFilter = ViewBag.SemesterFilter, groupFilter = ViewBag.GroupFilter, careerFilter = ViewBag.CareerFilter, page = 1, pageSize = ViewBag.PageSize })" class="text-decoration-none text-white">
                                    SEMESTRE
                                    @if (ViewBag.CurrentSort == "semester")
                                    {
                                        <i class="bi bi-@(ViewBag.CurrentOrder == "asc" ? "sort-down" : "sort-up")"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-filter text-muted"></i>
                                    }
                                </a>
                            </th>
                            <th class="text-center">
                                <a href="@Url.Action("AgregarAlumnosAsesor", new { teacherId = teacherId, sortBy = "group", sortOrder = ViewBag.CurrentSort == "group" ? ViewBag.NextOrder : "asc", searchName = ViewBag.SearchName, semesterFilter = ViewBag.SemesterFilter, groupFilter = ViewBag.GroupFilter, careerFilter = ViewBag.CareerFilter, page = 1, pageSize = ViewBag.PageSize })" class="text-decoration-none text-white">
                                    GRUPO
                                    @if (ViewBag.CurrentSort == "group")
                                    {
                                        <i class="bi bi-@(ViewBag.CurrentOrder == "asc" ? "sort-down" : "sort-up")"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-filter text-muted"></i>
                                    }
                                </a>
                            </th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td>@s.FullName</td>
                                <td class="text-center">@(s.CareerName ?? "N/A")</td>
                                <td class="text-center">@(s.SemesterName ?? "N/A")</td>
                                <td class="text-center">@(s.GroupName ?? "N/A")</td>
                                <td class="text-center">
                                    <form method="post" asp-area="SocialService" asp-controller="Coordinator" asp-action="AsignarAlumnoAAsesor">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="teacherId" value="@teacherId" />
                                        <input type="hidden" name="studentId" value="@s.UserId" />
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="bi bi-plus-circle"></i> Agregar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">No hay alumnos disponibles para asignar a este asesor.</div>
        }
    </div>
</div>
