<!-- Modal para visualizar PDF de bitácora -->
<div class="modal fade" id="bitacoraPdfModal" tabindex="-1" aria-labelledby="bitacoraPdfModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="bitacoraPdfModalLabel">
                    <i class="bi bi-file-earmark-pdf me-2"></i> PDF Adjunto – <span id="bitacoraPdfModalSemana"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="height: 80vh; min-height: 500px;">
                <iframe id="bitacoraPdfIframe" src="" width="100%" height="700px" style="border: none; min-height: 500px;" allowfullscreen></iframe>
            </div>
            <div class="modal-footer">
                <a id="bitacoraPdfDownload" href="#" class="btn btn-danger" target="_blank">
                    <i class="bi bi-file-earmark-arrow-down me-1"></i> Descargar PDF
                </a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
