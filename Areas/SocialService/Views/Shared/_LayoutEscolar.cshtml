<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Servicio Social</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Fuente Merriweather - Coherente con MainScreen -->
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- CSS del sitio principal -->
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- CSS específico de Social Service -->
    <link rel="stylesheet" href="~/css/SocialService.css" />
</head>
<body>

    <!-- NAVBAR MEJORADA -->
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: var(--rojo-principal);">
        <div class="container">
            <!-- Logo/Brand -->
            <a class="navbar-brand fw-bold" href="#">
                <i class="bi bi-mortarboard-fill me-2"></i>
                Servicio Social
            </a>

            <!-- Botón toggle para móvil -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Menú de navegación -->
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="javascript:history.back()">
                            <i class="bi bi-arrow-left-circle me-1"></i> Volver
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="MainScreen" 
                           asp-controller="MainScreen" 
                           asp-action="Index" 
                           class="nav-link">
                            <i class="bi bi-house-fill me-1"></i> Inicio
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTENIDO PRINCIPAL -->
    <div class="container mt-4 mb-5">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="footer-custom text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">© 2026 UTTN-TI-DYGS 10C - Servicio Social</p>
        </div>
    </footer>

    <!-- Scripts de Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
