<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Servicio Social</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
    <!-- CSS específico de Social Service -->
    <link rel="stylesheet" href="~/css/SocialService.css" />
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: var(--rojo-principal);">
        <div class="container-fluid px-4">
            @if (User.IsInRole("Teacher"))
            {
                <a asp-area="SocialService" 
                   asp-controller="Teacher" 
                   asp-action="Dashboard" 
                   class="navbar-brand fw-bold">
                    <i class="bi bi-mortarboard-fill me-2"></i>
                    Servicio Social
                </a>
            }
            else if (User.IsInRole("Student"))
            {
                <a asp-area="SocialService" 
                   asp-controller="Student" 
                   asp-action="Dashboard" 
                   class="navbar-brand fw-bold">
                    <i class="bi bi-mortarboard-fill me-2"></i>
                    Servicio Social
                </a>
            }
            else
            {
                <a asp-area="SocialService" 
                   asp-controller="Account" 
                   asp-action="Index" 
                   class="navbar-brand fw-bold">
                    <i class="bi bi-mortarboard-fill me-2"></i>
                    Servicio Social
                </a>
            }

            <!-- Botón toggle para móvil -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Menú de navegación -->
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a asp-area="MainScreen"
                           asp-controller="MainScreen"
                           asp-action="Index"
                           class="nav-link">
                            <i class="bi bi-house-fill me-1"></i> Inicio
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container-fluid px-4 mt-4 mb-4 pb-4">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
