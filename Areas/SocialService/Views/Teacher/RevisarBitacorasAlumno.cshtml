@page "{id:int}"
@{
    var idObj = RouteData.Values["id"];
    int id = 1;
    if (idObj != null)
    {
        if (idObj is int ii) id = ii;
        else if (!int.TryParse(idObj.ToString(), out id)) id = 1;
    }

    var students = new[] {
        new { Name = "Andrés Miguel García López", Group = "5° A" },
        new { Name = "Beatriz Elena Ramírez Torres", Group = "5° A" },
        new { Name = "Diana Patricia Flores Medina", Group = "5° B" },
        new { Name = "Emilio Javier Castro Rey", Group = "5° A" },
        new { Name = "Fernanda Lucía Ortega Vega", Group = "5° B" },
        new { Name = "Helena Sofía Núñez Prado", Group = "5° A" },
        new { Name = "Jimena Alejandra Soto Rivas", Group = "5° A" },
        new { Name = "Laura Isabel Peña Gil", Group = "5° B" },
        new { Name = "Natalia Verónica Suárez León", Group = "5° A" },
        new { Name = "Valeria Marcela Quiroz Peña", Group = "5° B" }
    };

    var index = Math.Clamp(id - 1, 0, students.Length - 1);
    var student = students[index];
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h3 class="mb-0">Revisión de Bitácoras</h3>
    <div>
        <strong style="color:var(--color-principal)">@student.Name</strong>
        <div class="text-muted">@student.Group</div>
    </div>
</div>

<div class="bitacora-container">
    <div class="bitacora-item">
        <h6>Bitácora 1 — Registro inicial</h6>
        <p><strong>Actividades:</strong> @((index % 2 == 0) ? "Apoyo en documentación y atención al público" : "Soporte en laboratorio y mantenimiento")</p>
        <p><strong>Descripción:</strong> @((index % 2 == 0) ? "Registro de tareas administrativas, captura de información y atención telefónica." : "Revisión y mantenimiento de equipos, apoyo en prácticas de laboratorio.")</p>

        <div class="row mt-3">
            <div class="col-md-6">
                <p><strong>Horas Prácticas registradas:</strong> @(10 + index)</p>
                <input type="number" class="form-control" placeholder="Horas a aprobar">
            </div>
            <div class="col-md-6">
                <p><strong>Horas Servicio Social registradas:</strong> @(2 + (index % 3))</p>
                <input type="number" class="form-control" placeholder="Horas a aprobar">
            </div>
        </div>

        <div class="mt-4 text-end">
            <button class="btn btn-full" style="max-width:220px;">Aprobar y sumar horas</button>
        </div>
    </div>

    <div class="bitacora-item">
        <h6>Bitácora 2 — Seguimiento</h6>
        <p><strong>Actividades:</strong> @((index % 2 == 0) ? "Apoyo en seguimiento de casos y actualización de registros" : "Implementación de mejoras y pruebas técnicas")</p>
        <p><strong>Descripción:</strong> @((index % 2 == 0) ? "Monitoreo y actualización de expedientes, coordinación con el equipo." : "Ejecución de pruebas, documentación de resultados y reporte de incidencias.")</p>

        <div class="row mt-3">
            <div class="col-md-6">
                <p><strong>Horas Prácticas registradas:</strong> @(8 + (index % 4))</p>
                <input type="number" class="form-control" placeholder="Horas a aprobar">
            </div>
            <div class="col-md-6">
                <p><strong>Horas Servicio Social registradas:</strong> @(1 + (index % 2))</p>
                <input type="number" class="form-control" placeholder="Horas a aprobar">
            </div>
        </div>

        <div class="mt-4 text-end">
            <button class="btn btn-full" style="max-width:220px;">Aprobar y sumar horas</button>
        </div>
    </div>
</div>