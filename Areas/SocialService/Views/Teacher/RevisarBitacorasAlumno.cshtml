@model List<SchoolManager.Models.social_service_log>

<h3 class="mb-4">Revisión de Bitácoras</h3>

<div class="bitacora-container">

    @if (Model != null && Model.Count > 0)
    {
        foreach (var bitacora in Model)
        {
            <div class="bitacora-item">

                <h6>Semana @bitacora.Week</h6>

                <p><strong>Alumno ID:</strong> @bitacora.StudentId</p>

                <p><strong>Actividades:</strong></p>
                <p>@bitacora.Activities</p>

                <p><strong>Horas Prácticas registradas:</strong> @bitacora.HoursPracticas</p>

                <p><strong>Horas Servicio Social registradas:</strong> @bitacora.HoursServicioSocial</p>

                @if (!string.IsNullOrEmpty(bitacora.Observations))
                {
                    <p><strong>Observaciones:</strong> @bitacora.Observations</p>
                }

                <p class="text-muted">
                    Creado el: @bitacora.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </p>

                <div class="mt-3">
                    <label>Horas prácticas a aprobar:</label>
                    <input type="number" class="form-control mb-2">

                    <label>Horas servicio social a aprobar:</label>
                    <input type="number" class="form-control">
                </div>

                <div class="mt-3 text-end">
                    <button class="btn btn-full" style="max-width:220px;">
                        Aprobar y sumar horas
                    </button>
                </div>

            </div>
        }
    }
    else
    {
        <div class="alert alert-info">
            No hay bitácoras registradas.
        </div>
    }

</div>