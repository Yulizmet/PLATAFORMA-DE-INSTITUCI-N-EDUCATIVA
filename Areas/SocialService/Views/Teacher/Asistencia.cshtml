@model SchoolManager.Areas.SocialService.ViewModels.AttendanceListViewModel

<h3>Tomar Lista - Servicio Social</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-3 d-flex justify-content-between align-items-center">
    <a href="/SocialService/Teacher/Dashboard" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Regresar al Dashboard
    </a>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body py-3">
        <form method="get" action="/SocialService/Teacher/Asistencia" id="filterForm">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label for="searchName" class="form-label">
                        <i class="bi bi-search"></i> Buscar Alumno
                    </label>
                    <input type="text" class="form-control" id="searchName" name="searchName"
                           value="@ViewBag.SearchName" placeholder="Escribe para buscar...">
                </div>

                <div class="col-md-2">
                    <label for="groupFilter" class="form-label">
                        <i class="bi bi-funnel"></i> Grupo
                    </label>
                    <select id="groupFilter" name="groupFilter" class="form-select" onchange="this.form.submit()">
                        <option value="">Todos</option>
                        @if (ViewBag.Groups != null)
                        {
                            foreach (var group in ViewBag.Groups)
                            {
                                <option value="@group" selected="@(ViewBag.GroupFilter == group)">@group</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label for="dateFrom" class="form-label">
                        <i class="bi bi-calendar-event"></i> Desde
                    </label>
                    <input type="date" class="form-control" id="dateFrom" name="dateFrom"
                           value="@ViewBag.DateFrom" />
                </div>

                <div class="col-md-2">
                    <label for="dateTo" class="form-label">
                        <i class="bi bi-calendar-event"></i> Hasta
                    </label>
                    <input type="date" class="form-control" id="dateTo" name="dateTo"
                           value="@ViewBag.DateTo" />
                </div>

                <div class="col-md-1">
                    <label for="pageSize" class="form-label">
                        <i class="bi bi-list-ol"></i> Reg.
                    </label>
                    <select id="pageSize" name="pageSize" class="form-select" onchange="this.form.submit()">
                        @foreach (var size in new[] { 10, 25, 50, 100 })
                        {
                            <option value="@size" selected="@(ViewBag.PageSize == size)">@size</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.DateFrom?.ToString()) || !string.IsNullOrEmpty(ViewBag.DateTo?.ToString()))
            {
                <div class="mt-2">
                    <a href="/SocialService/Teacher/Asistencia?sortBy=@ViewBag.CurrentSort&sortOrder=@ViewBag.SortOrder&groupFilter=@ViewBag.GroupFilter&searchName=@ViewBag.SearchName&pageSize=@ViewBag.PageSize&page=1"
                       class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-x-circle"></i> Limpiar filtros de fecha
                    </a>
                </div>
            }

            <input type="hidden" name="sortBy" value="@ViewBag.CurrentSort" />
            <input type="hidden" name="sortOrder" value="@ViewBag.SortOrder" />
            <input type="hidden" name="page" value="1" />
        </form>

        @if (ViewBag.TotalRecords != null)
        {
            <div class="mt-2">
                <small class="text-muted">
                    Mostrando @Model.Students.Count() de @ViewBag.TotalRecords registro(s)
                </small>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="bi bi-calendar-check"></i> 
            Fecha: @Model.Today.ToString("dddd, dd 'de' MMMM 'de' yyyy")
        </h5>
    </div>
    <div class="card-body">
        @if (Model.Students.Any())
        {
            <form method="post" action="/SocialService/Teacher/GuardarAsistencia">
                <input type="hidden" name="sortBy" value="@ViewBag.CurrentSort" />
                <input type="hidden" name="sortOrder" value="@ViewBag.SortOrder" />
                <input type="hidden" name="groupFilter" value="@ViewBag.GroupFilter" />
                <input type="hidden" name="searchName" value="@ViewBag.SearchName" />
                <input type="hidden" name="page" value="@ViewBag.CurrentPage" />
                <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
                <input type="hidden" name="dateFrom" value="@ViewBag.DateFrom" />
                <input type="hidden" name="dateTo" value="@ViewBag.DateTo" />

                @foreach (var student in Model.Students)
                {
                    <input type="hidden" name="allStudentsOnPage" value="@student.Assignment.StudentId" />
                }

                <div class="table-responsive">
                    <table class="table table-hover ss-table-cards">
                        <thead>
                            <tr>
                                @{
                                    string currentSort = ViewBag.CurrentSort ?? "name";
                                    string currentOrder = ViewBag.SortOrder ?? "asc";

                                    string SortUrl(string column)
                                    {
                                        string order = (currentSort == column && currentOrder == "asc") ? "desc" : "asc";
                                        return $"?sortBy={column}&sortOrder={order}&groupFilter={ViewBag.GroupFilter}&searchName={ViewBag.SearchName}&pageSize={ViewBag.PageSize}&page=1&dateFrom={ViewBag.DateFrom}&dateTo={ViewBag.DateTo}";
                                    }

                                    string SortIcon(string column)
                                    {
                                        if (currentSort != column) return "bi bi-arrow-down-up text-muted";
                                        return currentOrder == "asc" ? "bi bi-sort-up" : "bi bi-sort-down";
                                    }
                                }
                                <th>
                                    <a href="@SortUrl("name")">
                                        Alumno <i class="@SortIcon("name")"></i>
                                    </a>
                                </th>
                                <th class="text-center">
                                    <a href="@SortUrl("group")">
                                        Grupo <i class="@SortIcon("group")"></i>
                                    </a>
                                </th>
                                @{
                                    var allDates = Model.Students
                                        .SelectMany(s => s.RecentAttendances.Select(a => a.Date.Date))
                                        .Where(d => d < Model.Today)
                                        .Distinct()
                                        .OrderByDescending(d => d)
                                        .ToList();

                                    foreach (var date in allDates)
                                    {
                                        <th class="text-center">@date.ToString("dd/MM")</th>
                                    }
                                }
                                <th class="text-center" style="background-color: #f8f9fa;">
                                    <strong>Hoy (@Model.Today.ToString("dd/MM"))</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in Model.Students)
                            {
                                var fullName = $"{student.Assignment.Student.Person.LastNamePaternal} {student.Assignment.Student.Person.LastNameMaternal} {student.Assignment.Student.Person.FirstName}";
                                <tr>
                                    <td>@fullName</td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(student.Assignment.GroupName))
                                        {
                                            @student.Assignment.GroupName
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>

                                    @foreach (var date in allDates)
                                    {
                                        var attendance = student.RecentAttendances.FirstOrDefault(a => a.Date.Date == date);
                                        <td class="text-center">
                                            @if (attendance != null)
                                            {
                                                @if (attendance.IsPresent)
                                                {
                                                    <span class="badge-present">P</span>
                                                }
                                                else
                                                {
                                                    <span class="badge-absent">A</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    }

                                    <td class="text-center" style="background-color: #f8f9fa;">
                                        @if (student.HasAttendanceToday)
                                        {
                                            <input type="checkbox" 
                                                   name="presentStudents" 
                                                   value="@student.Assignment.StudentId" 
                                                   checked="@student.IsPresentToday"
                                                   class="form-check-input" 
                                                   style="transform: scale(1.5);" />
                                        }
                                        else
                                        {
                                            <input type="checkbox" 
                                                   name="presentStudents" 
                                                   value="@student.Assignment.StudentId" 
                                                   class="form-check-input" 
                                                   style="transform: scale(1.5);" />
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="text-end mt-3">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Guardar Asistencia
                    </button>
                </div>
            </form>
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> No tienes alumnos asignados. 
                <a href="/SocialService/Teacher/AgregarAlumnos">Haz clic aquí para agregar alumnos.</a>
            </div>
        }
    </div>
</div>

<style>
    .badge-present {
        background-color: #28a745;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
        font-weight: bold;
        display: inline-block;
        min-width: 30px;
    }

    .badge-absent {
        background-color: #dc3545;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
        font-weight: bold;
        display: inline-block;
        min-width: 30px;
    }

    .table th, .table td {
        vertical-align: middle;
    }

    .form-check-input {
        cursor: pointer;
    }

    .form-check-input:checked {
        background-color: #28a745;
        border-color: #28a745;
    }
</style>

<!-- Paginación -->
@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Navegación de páginas" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                   href="?sortBy=@ViewBag.CurrentSort&sortOrder=@ViewBag.SortOrder&groupFilter=@ViewBag.GroupFilter&searchName=@ViewBag.SearchName&pageSize=@ViewBag.PageSize&page=@(ViewBag.CurrentPage - 1)&dateFrom=@ViewBag.DateFrom&dateTo=@ViewBag.DateTo"
                   aria-label="Anterior">
                    <span aria-hidden="true">&laquo; Anterior</span>
                </a>
            </li>

            @{
                int currentPage = ViewBag.CurrentPage;
                int totalPages = ViewBag.TotalPages;
                int startPage = Math.Max(1, currentPage - 2);
                int endPage = Math.Min(totalPages, currentPage + 2);

                if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="?sortBy=@ViewBag.CurrentSort&sortOrder=@ViewBag.SortOrder&groupFilter=@ViewBag.GroupFilter&searchName=@ViewBag.SearchName&pageSize=@ViewBag.PageSize&page=1&dateFrom=@ViewBag.DateFrom&dateTo=@ViewBag.DateTo">1</a>
                    </li>
                    if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link"
                           href="?sortBy=@ViewBag.CurrentSort&sortOrder=@ViewBag.SortOrder&groupFilter=@ViewBag.GroupFilter&searchName=@ViewBag.SearchName&pageSize=@ViewBag.PageSize&page=@i&dateFrom=@ViewBag.DateFrom&dateTo=@ViewBag.DateTo">@i</a>
                    </li>
                }

                if (endPage < totalPages)
                {
                    if (endPage < totalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link"
                           href="?sortBy=@ViewBag.CurrentSort&sortOrder=@ViewBag.SortOrder&groupFilter=@ViewBag.GroupFilter&searchName=@ViewBag.SearchName&pageSize=@ViewBag.PageSize&page=@totalPages&dateFrom=@ViewBag.DateFrom&dateTo=@ViewBag.DateTo">@totalPages</a>
                    </li>
                }
            }

            <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   href="?sortBy=@ViewBag.CurrentSort&sortOrder=@ViewBag.SortOrder&groupFilter=@ViewBag.GroupFilter&searchName=@ViewBag.SearchName&pageSize=@ViewBag.PageSize&page=@(ViewBag.CurrentPage + 1)&dateFrom=@ViewBag.DateFrom&dateTo=@ViewBag.DateTo"
                   aria-label="Siguiente">
                    <span aria-hidden="true">Siguiente &raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
}
