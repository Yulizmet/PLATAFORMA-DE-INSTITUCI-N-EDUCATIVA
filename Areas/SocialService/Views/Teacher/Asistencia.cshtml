@model SchoolManager.Areas.SocialService.ViewModels.AttendanceListViewModel

<h3>Tomar Lista - Servicio Social</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-3">
    <a href="/SocialService/Teacher/Dashboard" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Regresar al Dashboard
    </a>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="bi bi-calendar-check"></i> 
            Fecha: @Model.Today.ToString("dddd, dd 'de' MMMM 'de' yyyy")
        </h5>
    </div>
    <div class="card-body">
        @if (Model.Students.Any())
        {
            <form method="post" action="/SocialService/Teacher/GuardarAsistencia">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th style="width:40%">Alumno</th>
                                <th class="text-center">Grupo</th>
                                @{
                                    // Obtener todas las fechas únicas de asistencias (excluyendo hoy)
                                    var allDates = Model.Students
                                        .SelectMany(s => s.RecentAttendances.Select(a => a.Date.Date))
                                        .Where(d => d < Model.Today)
                                        .Distinct()
                                        .OrderByDescending(d => d)
                                        .Take(3)
                                        .OrderBy(d => d)
                                        .ToList();

                                    foreach (var date in allDates)
                                    {
                                        <th class="text-center">@date.ToString("dd/MM")</th>
                                    }
                                }
                                <th class="text-center" style="background-color: #f8f9fa;">
                                    <strong>Hoy (@Model.Today.ToString("dd/MM"))</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in Model.Students)
                            {
                                var fullName = $"{student.Assignment.Student.Person.FirstName} {student.Assignment.Student.Person.LastNamePaternal} {student.Assignment.Student.Person.LastNameMaternal}";
                                <tr>
                                    <td>@fullName</td>
                                    <td class="text-center">@(student.Assignment.GroupName ?? "N/A")</td>

                                    @foreach (var date in allDates)
                                    {
                                        var attendance = student.RecentAttendances.FirstOrDefault(a => a.Date.Date == date);
                                        <td class="text-center">
                                            @if (attendance != null)
                                            {
                                                @if (attendance.IsPresent)
                                                {
                                                    <span class="badge-present">P</span>
                                                }
                                                else
                                                {
                                                    <span class="badge-absent">A</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    }

                                    <td class="text-center" style="background-color: #f8f9fa;">
                                        @if (student.HasAttendanceToday)
                                        {
                                            <input type="checkbox" 
                                                   name="presentStudents" 
                                                   value="@student.Assignment.StudentId" 
                                                   checked="@student.IsPresentToday"
                                                   class="form-check-input" 
                                                   style="transform: scale(1.5);" />
                                        }
                                        else
                                        {
                                            <input type="checkbox" 
                                                   name="presentStudents" 
                                                   value="@student.Assignment.StudentId" 
                                                   class="form-check-input" 
                                                   style="transform: scale(1.5);" />
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="text-end mt-3">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Guardar Asistencia
                    </button>
                </div>
            </form>
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> No tienes alumnos asignados. 
                <a href="/SocialService/Teacher/AgregarAlumnos">Haz clic aquí para agregar alumnos.</a>
            </div>
        }
    </div>
</div>

<style>
    .badge-present {
        background-color: #28a745;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
        font-weight: bold;
        display: inline-block;
        min-width: 30px;
    }

    .badge-absent {
        background-color: #dc3545;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
        font-weight: bold;
        display: inline-block;
        min-width: 30px;
    }

    .table th, .table td {
        vertical-align: middle;
    }

    .form-check-input {
        cursor: pointer;
    }

    .form-check-input:checked {
        background-color: #28a745;
        border-color: #28a745;
    }
</style>
