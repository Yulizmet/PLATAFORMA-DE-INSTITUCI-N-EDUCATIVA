@model IEnumerable<SchoolManager.Areas.SocialService.ViewModels.AvailableStudentViewModel>

<div class="mb-3">
    <a href="/SocialService/Teacher/Alumnos" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Regresar a Alumnos Asignados
    </a>
</div>

<h3 class="text-center my-3">Agregar Alumnos</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Estudiantes Disponibles</h5>
    </div>

    <div class="card-body">

        <!-- FORMULARIO DE BÚSQUEDA -->
        <form method="get" class="mb-4" id="searchForm">
            <input type="hidden" name="sortBy" value="@ViewBag.CurrentSort" />
            <input type="hidden" name="sortOrder" value="@ViewBag.CurrentOrder" />
            <input type="hidden" name="semesterFilter" value="@ViewBag.SemesterFilter" />
            <input type="hidden" name="groupFilter" value="@ViewBag.GroupFilter" />

            <div class="row align-items-end g-3">
                <div class="col-md-4">
                    <label class="form-label">
                        Buscar por nombre
                    </label>
                    <input type="text"
                           class="form-control"
                           id="searchName"
                           name="searchName"
                           placeholder="Escribe para buscar..."
                           value="@ViewBag.SearchName"
                           autocomplete="off">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Semestre</label>
                    <select class="form-select" name="semesterFilter" onchange="this.form.submit()">
                        <option value="">Todos los semestres</option>
                        @if (ViewBag.Semesters != null)
                        {
                            foreach (var semester in ViewBag.Semesters)
                            {
                                <option value="@semester" selected="@(ViewBag.SemesterFilter == semester)">
                                    @semester
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Grupo</label>
                    <select class="form-select" name="groupFilter" onchange="this.form.submit()">
                        <option value="">Todos los grupos</option>
                        @if (ViewBag.Groups != null)
                        {
                            foreach (var group in ViewBag.Groups)
                            {
                                <option value="@group" selected="@(ViewBag.GroupFilter == group)">
                                    @group
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">
                        <i class="bi bi-list-ol"></i> Registros
                    </label>
                    <select class="form-select" name="pageSize" onchange="this.form.submit()">
                        @foreach (var size in new[] { 10, 25, 50, 100 })
                        {
                            <option value="@size" selected="@(ViewBag.PageSize == size)">
                                @size
                            </option>
                        }
                    </select>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-search"></i> Buscar
                    </button>

                    @if (!string.IsNullOrWhiteSpace(ViewBag.SearchName as string)
                       || !string.IsNullOrWhiteSpace(ViewBag.SemesterFilter as string)
                       || !string.IsNullOrWhiteSpace(ViewBag.GroupFilter as string))
                    {
                        <a href="@Url.Action("AgregarAlumnos")" class="btn btn-secondary px-4">
                            <i class="bi bi-x-circle"></i> Limpiar filtros
                        </a>
                    }
                </div>
            </div>
        </form>

        <!-- TABLA -->
        @if (Model.Any())
        {
            <div class="mb-3 text-muted small">
                Mostrando @Model.Count() de @ViewBag.TotalRecords estudiantes
            </div>

            <div class="table-responsive">
                <table class="table table-hover ss-table-cards">
                    <thead>
                        <tr>
                            <th style="width:40%">Nombre</th>
                            <th class="text-center">Semestre</th>
                            <th class="text-center">Grupo</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model)
                        {
                            <tr>
                                <td>@student.FullName</td>

                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(student.SemesterName))
                                    {
                                        @student.SemesterName
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>

                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(student.GroupName))
                                    {
                                        @student.GroupName
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <form method="post" action="/SocialService/Teacher/AsignarAlumno">
                                        <input type="hidden" name="studentId" value="@student.UserId" />
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="bi bi-plus-circle"></i> Asignar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- PAGINACIÓN -->
            @if (ViewBag.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               href="@Url.Action("AgregarAlumnos", new {
                                   page = ViewBag.CurrentPage - 1,
                                   pageSize = ViewBag.PageSize
                               })">
                                «
                            </a>
                        </li>

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   href="@Url.Action("AgregarAlumnos", new {
                                       page = i,
                                       pageSize = ViewBag.PageSize
                                   })">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               href="@Url.Action("AgregarAlumnos", new {
                                   page = ViewBag.CurrentPage + 1,
                                   pageSize = ViewBag.PageSize
                               })">
                                »
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i>
                No hay estudiantes disponibles para asignar.
            </div>
        }

    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.1);
        cursor: pointer;
    }
</style>

@section Scripts {
    <script src="~/js/SocialServiceAutoSearch.js"></script>
}