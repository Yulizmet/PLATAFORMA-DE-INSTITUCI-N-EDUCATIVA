@model IEnumerable<SchoolManager.Areas.SocialService.ViewModels.AvailableStudentViewModel>

<h3>Agregar Alumnos</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-3">
    <a href="/SocialService/Teacher/Alumnos" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Regresar a Alumnos Asignados
    </a>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Estudiantes Disponibles</h5>
    </div>
    <div class="card-body">
        <form method="get" class="mb-4" id="searchForm">
            <div class="row align-items-end">
                <div class="col-md-8">
                    <label for="searchName" class="form-label">
                        Buscar por nombre
                        <span id="searchingIndicator" class="text-muted small ms-2" style="display:none;">
                            <i class="bi bi-hourglass-split"></i> Buscando...
                        </span>
                    </label>
                    <input type="text" 
                           class="form-control" 
                           id="searchName" 
                           name="searchName" 
                           placeholder="Escribe para buscar..." 
                           value="@ViewBag.SearchName"
                           autocomplete="off">
                </div>
                <div class="col-md-4">
                    @if (!string.IsNullOrWhiteSpace(ViewBag.SearchName as string))
                    {
                        <a href="@Url.Action("AgregarAlumnos")" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Limpiar
                        </a>
                    }
                </div>
            </div>
        </form>
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th style="width:40%">Nombre</th>
                            <th class="text-center">Semestre</th>
                            <th class="text-center">Grupo</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model)
                        {
                            <tr>
                                <td>@student.FullName</td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(student.SemesterName))
                                    {
                                        <span class="badge bg-primary">@student.SemesterName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(student.GroupName))
                                    {
                                        <span class="badge bg-info">@student.GroupName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <form method="post" action="/SocialService/Teacher/AsignarAlumno" style="display:inline;">
                                        <input type="hidden" name="studentId" value="@student.UserId" />
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="bi bi-plus-circle"></i> Asignar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> 
                @if (!string.IsNullOrWhiteSpace(ViewBag.SearchName as string))
                {
                    <text>No se encontraron estudiantes con el nombre "@ViewBag.SearchName".</text>
                }
                else
                {
                    <text>No hay estudiantes disponibles para asignar. Todos los estudiantes ya están asignados.</text>
                }
            </div>
        }
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.1);
        cursor: pointer;
    }
</style>

@section Scripts {
    <script src="~/js/SocialServiceAutoSearch.js"></script>
}
