@page
@{
    Layout = "_LayoutEscolar";
    ViewData["Title"] = "Mis Bitácoras";
}

<h3 class="text-center mb-5">Mis Bitácoras</h3>

<div class="bitacora-container">

    <!-- BITÁCORA 1 -->
    <div class="bitacora-item">
        <h6>Semana 1</h6>

        <p><strong>Actividades realizadas:</strong></p>
        <p>
            Apoyo en el área administrativa, captura de información y
            organización de documentos.
        </p>

        <p><strong>Horas Prácticas:</strong> 20</p>
        <p><strong>Horas Servicio Social:</strong> 10</p>
    </div>

    <!-- BITÁCORA 2 -->
    <div class="bitacora-item">
        <h6>Semana 2</h6>

        <p><strong>Actividades realizadas:</strong></p>
        <p>
            Soporte técnico básico, revisión de equipos y apoyo a usuarios.
        </p>

        <p><strong>Horas Prácticas:</strong> 15</p>
        <p><strong>Horas Servicio Social:</strong> 5</p>
    </div>

    <div class="text-center mt-5">
        <a href="/Alumno/CrearBitacora" class="btn btn-primary">
            Crear nueva bitácora
        </a>
    </div>

</div>
