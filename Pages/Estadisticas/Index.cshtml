@page "/Estadisticas"
@model SchoolManager.Pages.Estadisticas.IndexModel
@{
    ViewData["Title"] = "Estadísticas";
}

<style>
/* Contenedor fijo para las gráficas: evita estirado vertical */
.chart-container {
    height: 300px;
    position: relative;
    width: 100%;
}
.chart-container canvas {
    width: 100% !important;
    height: 100% !important;
    display: block;
}
</style>

<div class="row mb-3">
    <div class="col-12">
        <h2>Estadísticas de estudiantes</h2>
        <p class="text-muted">Control y seguimiento: inscritos, cursando, aprobados y reprobados.</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <input id="filterName" class="form-control" placeholder="Filtrar por nombre..." />
    </div>
    <div class="col-md-3">
        <select id="filterStatus" class="form-select">
            <option value="">Todos los estados</option>
            <option value="Inscrito">Inscrito</option>
            <option value="Cursando">Cursando</option>
            <option value="Aprobado">Aprobado</option>
            <option value="Reprobado">Reprobado</option>
        </select>
    </div>
    <div class="col-md-3">
        <button id="resetFilters" class="btn btn-outline-secondary">Reset filtros</button>
    </div>
</div>

<div class="row mb-4">
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Total alumnos</div>
            <div id="statTotal" class="display-6">@Model.Total</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Inscritos</div>
            <div id="statInscritos" class="display-6">@Model.CountInscrito</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Cursando</div>
            <div id="statCursando" class="display-6">@Model.CountCursando</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Aprobados</div>
            <div id="statAprobados" class="display-6">@Model.CountAprobado</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="table-responsive mb-4">
            <table id="studentsTable" class="table table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Nombre</th>
                        <th>Curso</th>
                        <th>Estado</th>
                        <th>Nota</th>
                        <th>Fecha inscripción</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var s in Model.Students)
                {
                    <tr data-name="@s.Nombre" data-status="@s.Estado">
                        <td>@s.Id</td>
                        <td>@s.Nombre</td>
                        <td>@s.Curso</td>
                        <td>
                            @if (s.Estado == "Aprobado")
                            {
                                <span class="badge bg-success">Aprobado</span>
                            }
                            else if (s.Estado == "Reprobado")
                            {
                                <span class="badge bg-danger">Reprobado</span>
                            }
                            else if (s.Estado == "Cursando")
                            {
                                <span class="badge bg-warning text-dark">Cursando</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inscrito</span>
                            }
                        </td>
                        <td>@s.Nota</td>
                        <td>@s.FechaInscripcion.ToString("yyyy-MM-dd")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card p-3">
            <h5>Distribución por estado</h5>
            <div class="chart-container">
                <canvas id="pieChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card p-3">
            <h5>Promedio de nota por curso</h5>
            <div class="chart-container">
                <canvas id="barChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // datos serializados para JS
        window.__estadisticasData = @Html.Raw(Model.JsonStudents);
    </script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/estadisticas.js" asp-append-version="true"></script>
}