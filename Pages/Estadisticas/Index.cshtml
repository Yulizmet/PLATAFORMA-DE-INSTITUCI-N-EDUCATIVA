@page "/Estadisticas"
@model SchoolManager.Pages.Estadisticas.IndexModel
@{
    Layout = "/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Estadísticas";
}
@section Styles {
    <link rel="stylesheet" href="~/css/escuela.css" asp-append-version="true" />
}

<style>
.chart-container { height: 300px; position: relative; width: 100%; }
.chart-container canvas { width: 100% !important; height: 100% !important; display: block; }
.filter-submenu { border: 1px solid #8c8378; padding: 12px; border-radius: 6px; background: #d5d0cb; }
.excel-filter-popup {
    position: fixed; min-width: 240px; max-width: 320px;
    background: #1f1f1f; color: #fff; border-radius: 6px;
    box-shadow: 0 6px 18px rgba(0,0,0,0.45); padding: 10px;
    z-index: 2000; border: 1px solid rgba(255,255,255,0.06);
}
.excel-filter-popup button {
    background: transparent; color: #fff;
    border: 1px solid rgba(255,255,255,0.15);
    padding: 4px 8px; border-radius: 4px; cursor: pointer;
}
.filter-values {
    max-height: 160px; overflow-y: auto; background: #141414;
    padding: 6px; border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.04); margin-top: 6px;
}
.filter-values label { display: block; font-size: 0.85rem; margin-bottom: 4px; cursor: pointer; }

/* ── Selector de filas por página ── */
.page-size-select {
    font-size: 0.8rem;
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid #ced4da;
    background: #fff;
    color: #333;
    cursor: pointer;
    height: 28px;
}
.page-size-select:focus { outline: none; border-color: #620900; box-shadow: 0 0 0 2px rgba(98,9,0,0.15); }
.pagination-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
}
.pagination-bar-right {
    display: flex;
    align-items: center;
    gap: 8px;
}

#pageTitle {
    font-family: "Merriweather", serif;
}

#pageSubtitle,
.form-control,
.form-select,
small,
.table,
.btn,
.card,
.card p,
.card .h6,
.card h5 {
    font-family: "Inter", sans-serif;
}

.btn-filter-toggle {
    background-color: var(--school-primary) !important;
    border-color: var(--school-accent) !important;
    color: #fff !important;
    font-weight: 600;
    letter-spacing: 0.3px;
    box-shadow: 0 2px 6px rgba(98,9,0,0.35);
}
.btn-filter-toggle:hover, .btn-filter-toggle:focus {
    background-color: var(--school-accent) !important;
    box-shadow: 0 3px 10px rgba(98,9,0,0.5);
}

.btn-action-green {
    background-color: #7ed957 !important;
    border-color: #7ed957 !important;
    color: #111 !important;
}

.btn-action-red {
    background-color: #ff3131 !important;
    border-color: #ff3131 !important;
    color: #fff !important;
}

.btn-action-blue {
    background-color: #38b6ff !important;
    border-color: #38b6ff !important;
    color: #fff !important;
}

.btn-action-yellow {
    background-color: #ffde59 !important;
    border-color: #ffde59 !important;
    color: #111 !important;
}

/* ── Vista General ── */
.general-report-banner {
    background: linear-gradient(90deg, #620900 0%, #8C1B1B 100%);
    color: #fff;
    border: none;
    border-radius: 10px;
}
.general-banner-title {
    font-family: "Merriweather", serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
}
.general-report-banner .general-banner-sub {
    font-family: "Inter", sans-serif;
    font-size: 0.88rem;
    color: #ffffff !important;
}
.general-banner-date {
    font-family: "Inter", sans-serif;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.92);
    font-weight: 600;
}
.general-kpi-card {
    border-radius: 10px;
    transition: transform .15s ease;
    background: #fff;
}
.general-kpi-card:hover { transform: translateY(-3px); }
.general-kpi-card.kpi-blue   { border-left: 5px solid #38b6ff !important; }
.general-kpi-card.kpi-green  { border-left: 5px solid #7ed957 !important; }
.general-kpi-card.kpi-orange { border-left: 5px solid #ffde59 !important; }
.general-kpi-card.kpi-purple { border-left: 5px solid #9b59b6 !important; }
.general-kpi-icon {
    width: 44px; height: 44px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.25rem; background: rgba(98,9,0,0.08); color: #620900;
    flex-shrink: 0;
}
.general-kpi-value {
    font-family: "Merriweather", serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #620900;
    line-height: 1.1;
}
.general-kpi-label {
    font-family: "Inter", sans-serif;
    font-size: 0.76rem;
    color: #666;
    margin-top: 2px;
}
.general-section-divider {
    position: relative;
    border-bottom: 2px solid rgba(98,9,0,0.20);
    margin-bottom: 1rem;
}
.general-section-divider span {
    font-family: "Merriweather", serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: #620900;
    background: #B1A596;
    padding: 0 10px 0 0;
    position: relative;
    top: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.general-summary-table th {
    font-family: "Inter", sans-serif;
    font-size: 0.75rem;
    color: #620900;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    border-bottom: 2px solid rgba(98,9,0,0.2);
}
.general-summary-table td {
    font-family: "Inter", sans-serif;
    font-size: 0.83rem;
    vertical-align: middle;
}
.gen-chart-mini {
    height: 220px; position: relative; width: 100%;
}
.gen-chart-mini canvas { width: 100% !important; height: 100% !important; display: block; }
</style>

<!-- ── Botones de sección ── -->
<div class="row mb-3">
    <div class="col-12">
        <div class="btn-group" role="group">
            <button id="btnGeneral"        class="btn btn-primary view-btn active">General</button>
            <button id="btnCalificaciones" class="btn btn-outline-primary view-btn">Calificaciones</button>
            <button id="btnServicios"      class="btn btn-outline-primary view-btn">Servicio Social</button>
            <button id="btnTramites"       class="btn btn-outline-primary view-btn">Trámites</button>
            <button id="btnBitacoras"      class="btn btn-outline-primary view-btn">Bitácoras</button>
            <button id="btnTutorias"      class="btn btn-outline-primary view-btn">Tutorías</button>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 id="pageTitle">Estadísticas de alumnos</h2>
            <p class="text-muted" id="pageSubtitle">Control y seguimiento: inscritos, cursando, aprobados y reprobados.</p>
        </div>
        <div class="d-flex gap-2">
            <button id="btnExportTable" class="btn btn-action-green">Exportar a Excel</button>
            <button id="btnExportPDF"   class="btn btn-action-red">Exportar a PDF</button>
        </div>
    </div>
</div>

<!-- ── Filtros colapsables ── -->
<div class="row mb-3">
    <div class="col-12">
        <button id="toggleFilters" class="btn btn-sm btn-filter-toggle mb-2" type="button" aria-expanded="false">⚙ Filtros</button>
        <div id="filtersArea" class="filter-submenu collapse">

            <!-- Calificaciones Por Semestre -->
            <div id="filtersStudents">
                <div class="row g-2">
                    <div class="col-md-3"><input id="filterName" class="form-control" placeholder="Filtrar por nombre..." /></div>
                    <div class="col-md-2">
                        <select id="filterStatus" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="Inscrito">Inscrito</option>
                            <option value="Cursando">Cursando</option>
                            <option value="Aprobado">Aprobado</option>
                            <option value="Reprobado">Reprobado</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select id="filterGenero" class="form-select">
                            <option value="">Todos géneros</option>
                            <option value="M">Masculino</option>
                            <option value="F">Femenino</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select id="filterSemestre" class="form-select">
                            <option value="">Todos semestres</option>
                            <option value="1">1</option><option value="2">2</option>
                            <option value="3">3</option><option value="4">4</option>
                            <option value="5">5</option><option value="6">6</option>
                            <option value="7">7</option><option value="8">8</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="applyStudentFilters" class="btn btn-action-blue">Aplicar</button>
                        <button id="resetFilters" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </div>
            </div>

            <!-- Calificaciones Por Grupo -->
            <div id="filtersStudentsGrupo" class="d-none">
                <div class="row g-2">
                    <div class="col-md-3"><input id="filterGrupoName" class="form-control" placeholder="Filtrar por nombre..." /></div>
                    <div class="col-md-2">
                        <select id="filterGrupoStatus" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="Inscrito">Inscrito</option>
                            <option value="Cursando">Cursando</option>
                            <option value="Aprobado">Aprobado</option>
                            <option value="Reprobado">Reprobado</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select id="filterGrupoGenero" class="form-select">
                            <option value="">Todos géneros</option>
                            <option value="M">Masculino</option>
                            <option value="F">Femenino</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input id="filterGrupoGrupo" class="form-control" placeholder="Filtrar por grupo..." />
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="applyGroupFilters" class="btn btn-action-blue">Aplicar</button>
                        <button id="resetGroupFilters" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </div>
            </div>

            <!-- Servicio Social -->
            <div id="filtersSocialServices" class="d-none">
                <div class="row g-2">
                    <div class="col-md-3"><input id="filterSocialName" class="form-control" placeholder="Filtrar por alumno..." /></div>
                    <div class="col-md-2"><input id="filterSocialTeacher" class="form-control" placeholder="Filtrar por maestro..." /></div>
                    <div class="col-md-2">
                        <select id="filterSocialStatus" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="Completado">Completado</option>
                            <option value="En progreso">En progreso</option>
                            <option value="Pendiente">Pendiente</option>
                        </select>
                    </div>
                    <div class="col-md-2"><input id="filterSocialGroup" class="form-control" placeholder="Filtrar por grupo..." /></div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="applySocialFilters" class="btn btn-action-blue">Aplicar</button>
                        <button id="resetSocialFilters" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </div>
            </div>

            <!-- Trámites -->
            <div id="filtersTramites" class="d-none">
                <div class="row g-2">
                    <div class="col-md-3"><input id="filterTramiteUser" class="form-control" placeholder="Filtrar por usuario..." /></div>
                    <div class="col-md-2"><input id="filterTramiteFolio" class="form-control" placeholder="Filtrar por folio..." /></div>
                    <div class="col-md-2">
                        <select id="filterTramiteStatus" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="APPROVED">Pagó inscripción</option>
                            <option value="PENDING">Pendiente</option>
                            <option value="REJECTED">No pagó</option>
                        </select>
                    </div>
                    <div class="col-md-2"><input id="filterTramiteArea" class="form-control" placeholder="Filtrar por área..." /></div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="applyTramiteFilters" class="btn btn-action-blue">Aplicar</button>
                        <button id="resetTramiteFilters" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </div>
            </div>

            <!-- Bitácoras Psicología -->
            <div id="filtersBitacorasPsy" class="d-none">
                <div class="row g-2">
                    <div class="col-md-3"><input id="filterPsyName" class="form-control" placeholder="Filtrar por alumno..." /></div>
                    <div class="col-md-2"><input id="filterPsyFolio" class="form-control" placeholder="Filtrar por folio..." /></div>
                    <div class="col-md-2">
                        <select id="filterPsyStatus" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="Asistió">Asistió</option>
                            <option value="No asistió">No asistió</option>
                            <option value="Justificado">Justificado</option>
                        </select>
                    </div>
                    <div class="col-md-2"><input id="filterPsyMatricula" class="form-control" placeholder="Filtrar por matrícula..." /></div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="applyPsyFilters" class="btn btn-action-blue">Aplicar</button>
                        <button id="resetPsyFilters" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </div>
            </div>

            <!-- Bitácoras Enfermería -->
            <div id="filtersBitacorasMed" class="d-none">
                <div class="row g-2">
                    <div class="col-md-3"><input id="filterMedName" class="form-control" placeholder="Filtrar por alumno..." /></div>
                    <div class="col-md-2"><input id="filterMedFolio" class="form-control" placeholder="Filtrar por folio..." /></div>
                    <div class="col-md-2">
                        <select id="filterMedStatus" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="Estable">Estable</option>
                            <option value="Alta">Alta</option>
                            <option value="Urgente">Urgente</option>
                            <option value="Critico">Crítico</option>
                            <option value="Observacion">Observación</option>
                            <option value="Pendiente">Pendiente</option>
                        </select>
                    </div>
                    <div class="col-md-2"><input id="filterMedReason" class="form-control" placeholder="Filtrar por motivo..." /></div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="applyMedFilters" class="btn btn-action-blue">Aplicar</button>
                        <button id="resetMedFilters" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </div>
            </div>

            <!-- Tutorías -->
            <div id="filtersTutorias" class="d-none">
                <div class="row g-2">
                    <div class="col-md-3"><input id="filterTutName" class="form-control" placeholder="Filtrar por alumno..." /></div>
                    <div class="col-md-2">
                        <select id="filterTutStatus" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="Completado">Completado</option>
                            <option value="Pendiente">Pendiente</option>
                            <option value="En proceso">En proceso</option>
                            <option value="Sin entrevista">Sin entrevista</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select id="filterTutPerformance" class="form-select">
                            <option value="">Todos los niveles</option>
                            <option value="Alto">Alto</option>
                            <option value="Medio">Medio</option>
                            <option value="Bajo">Bajo</option>
                            <option value="Sin monitoreo">Sin monitoreo</option>
                        </select>
                    </div>
                    <div class="col-md-2"><input id="filterTutTeacher" class="form-control" placeholder="Filtrar por tutor..." /></div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="applyTutFilters" class="btn btn-action-blue">Aplicar</button>
                        <button id="resetTutFilters" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ══ Tarjetas CALIFICACIONES ══ -->
<div class="row mb-4" id="studentStats">
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Total alumnos</div><div id="statTotal" class="display-6">@Model.Total</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Inscritos</div><div id="statInscritos" class="display-6">@Model.CountInscrito</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Cursando</div><div id="statCursando" class="display-6">@Model.CountCursando</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Aprobados</div><div id="statAprobados" class="display-6">@Model.CountAprobado</div></div></div>
</div>

<!-- ══ Tarjetas SERVICIOS SOCIALES ══ -->
<div class="row mb-4 d-none" id="socialServiceStats">
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Alumnos con asistencia</div><div id="statSocialTotal" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Asistencias presentes</div><div id="statSocialHours" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Ausencias totales</div><div id="statSocialPending" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Asistencia promedio</div><div id="statSocialAttendance" class="display-6">0%</div></div></div>
</div>

<!-- ══ Tarjetas TRÁMITES ══ -->
<div class="row mb-4 d-none" id="proceduresStats">
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Total solicitudes</div><div id="statProcsTotal" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Acción requerida</div><div id="statProcsAction" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">En proceso</div><div id="statProcsInProgress" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Finalizadas</div><div id="statProcsFinalized" class="display-6">0</div></div></div>
</div>

<!-- ══ Tarjetas PSICOLOGÍA ══ -->
<div class="row mb-4 d-none" id="psychologyStats">
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Total registros</div><div id="statPsyTotal" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Asistió</div><div id="statPsyAttended" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">No asistió</div><div id="statPsyAbsent" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Justificados</div><div id="statPsyJustified" class="display-6">0</div></div></div>
</div>

<!-- ══ Tarjetas ENFERMERÍA ══ -->
<div class="row mb-4 d-none" id="medicalStats">
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Total registros</div><div id="statMedTotal" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Atendidos</div><div id="statMedAttended" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Pendientes</div><div id="statMedPending" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Otros estados</div><div id="statMedOther" class="display-6">0</div></div></div>
</div>

<!-- ══ Tarjetas TUTORÍAS ══ -->
<div class="row mb-4 d-none" id="tutorshipStats">
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Total alumnos</div><div id="statTutTotal" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Entrevistas</div><div id="statTutInterviews" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Monitoreos</div><div id="statTutMonitorings" class="display-6">0</div></div></div>
    <div class="col-sm-6 col-md-3 mb-2"><div class="card p-3"><div class="h6">Sesiones</div><div id="statTutSessions" class="display-6">0</div></div></div>
</div>

<!-- ══════════════════════════════════════
     VIEW: GENERAL
══════════════════════════════════════ -->
<div id="viewGeneral" class="d-none">

    <div class="card p-4 mb-4 general-report-banner">
        <h3 class="general-banner-title mb-1">Resumen General Institucional</h3>
        <p class="general-banner-sub mb-0">Vista ejecutiva de los principales indicadores del sistema académico</p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card general-kpi-card kpi-blue">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="general-kpi-icon"><i class="bi bi-people-fill"></i></div>
                        <div>
                            <div class="general-kpi-value" id="genKpiAlumnos">—</div>
                            <div class="general-kpi-label">Total Alumnos</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card general-kpi-card kpi-green">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="general-kpi-icon"><i class="bi bi-briefcase-fill"></i></div>
                        <div>
                            <div class="general-kpi-value" id="genKpiServicio">—</div>
                            <div class="general-kpi-label">Servicio Social Activos</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
