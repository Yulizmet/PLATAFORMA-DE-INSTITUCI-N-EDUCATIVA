@page "/Estadisticas"
@model SchoolManager.Pages.Estadisticas.IndexModel
@{
    ViewData["Title"] = "Estadísticas";
}
@section Styles {
    <link rel="stylesheet" href="~/css/escuela.css" asp-append-version="true" />
}

<style>
/* Contenedor fijo para las gráficas: evita estirado vertical */
.chart-container {
    height: 300px;
    position: relative;
    width: 100%;
}
.chart-container canvas {
    width: 100% !important;
    height: 100% !important;
    display: block;
}

/* Submenu de filtros colapsable */
.filter-submenu {
    border: 1px solid #e3e6ea;
    padding: 12px;
    border-radius: 6px;
    background: #f8f9fa;
}

/* Estilo del popup de filtro tipo Excel */
.excel-filter-popup {
    position: absolute;
    min-width: 240px;
    max-width: 320px;
    background: #1f1f1f; /* oscuro, no transparente */
    color: #fff;
    border-radius: 6px;
    box-shadow: 0 6px 18px rgba(0,0,0,0.45);
    padding: 10px;
    z-index: 2000;
    border: 1px solid rgba(255,255,255,0.06);
}
.excel-filter-popup .ef-actions { display:flex; gap:6px; margin-bottom:8px; }
.excel-filter-popup button { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.06); padding:4px 8px; border-radius:4px; }
.excel-filter-popup .ef-search input { width:100%; padding:6px; border-radius:4px; border:1px solid rgba(255,255,255,0.08); background:#2a2a2a; color:#fff; }
.excel-filter-popup .ef-list { margin-top:8px; }
.excel-filter-popup .ef-values { max-height:160px; overflow:auto; margin-top:6px; background:#141414; padding:6px; border-radius:4px; border:1px solid rgba(255,255,255,0.04); }
.excel-filter-popup label { display:block; font-size:0.9rem; margin-bottom:4px; }
.excel-filter-popup .ef-buttons { display:flex; justify-content:flex-end; gap:8px; margin-top:8px; }
.excel-filter-popup .ef-accept { background:#0d6efd; border-color:#0d6efd; }
.excel-filter-popup .ef-cancel { background:#6c757d; border-color:#6c757d; }

</style>
<!-- Botones de tipo de estadísticas -->
<div class="row mb-3">
    <div class="col-12">
        <div class="btn-group" role="group">
            <button id="btnCalificaciones" class="btn btn-primary view-btn active">
                Calificaciones
            </button>

            <button id="btnServicios" class="btn btn-outline-primary view-btn">
                Servicios Sociales
            </button>

            <button id="btnTramites" class="btn btn-outline-primary view-btn">
                Trámites
            </button>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 id="pageTitle">Estadísticas de alumnos</h2>
            <p class="text-muted" id="pageSubtitle">Control y seguimiento: inscritos, cursando, aprobados y reprobados.</p>
        </div>
            <!-- Pestañas eliminadas: Vista fija de Alumnos (sin botón de pestañas) -->
            <!-- Botón de exportar (usa tabla visible y respeta filtros aplicados) -->
            <button id="btnExportTable" class="btn btn-success ms-2" title="Exportar tabla visible a Excel/CSV">Exportar a Excel</button>
        </div>
    </div>

<!-- (charts moved below) -->

<!-- Submenu de filtros (colapsable) -->
<div class="row mb-3">
    <div class="col-12">
        <button id="toggleFilters" class="btn btn-sm btn-secondary mb-2" type="button" aria-expanded="false">Filtros</button>
        <div id="filtersArea" class="filter-submenu collapse">
            <!-- Filtros para Alumnos -->
            <div id="filtersStudents">
                <div class="row g-2">
                    <div class="col-md-3">
                        <input id="filterName" class="form-control" placeholder="Filtrar por nombre..." />
                    </div>
                    <div class="col-md-2">
                        <select id="filterStatus" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="Inscrito">Inscrito</option>
                            <option value="Cursando">Cursando</option>
                            <option value="Aprobado">Aprobado</option>
                            <option value="Reprobado">Reprobado</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select id="filterGenero" class="form-select">
                            <option value="">Todos géneros</option>
                            <option value="M">Masculino</option>
                            <option value="F">Femenino</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select id="filterSemestre" class="form-select">
                            <option value="">Todos semestres</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4">4</option>
                            <option value="5">5</option>
                            <option value="6">6</option>
                            <option value="7">7</option>
                            <option value="8">8</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="applyStudentFilters" class="btn btn-primary">Aplicar</button>
                        <button id="resetFilters" class="btn btn-outline-secondary">Reset filtros</button>
                    </div>
                </div>
            </div>

            <!-- Filtros de empleados removidos -->
        </div>
    </div>
</div>

<!-- Estadísticas rápidas - CALIFICACIONES -->
<div class="row mb-4" id="studentStats">
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Total alumnos</div>
            <div id="statTotal" class="display-6">@Model.Total</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Inscritos</div>
            <div id="statInscritos" class="display-6">@Model.CountInscrito</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Cursando</div>
            <div id="statCursando" class="display-6">@Model.CountCursando</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Aprobados</div>
            <div id="statAprobados" class="display-6">@Model.CountAprobado</div>
        </div>
    </div>
</div>

<!-- Estadísticas rápidas - SERVICIOS SOCIALES (oculto) -->
<div class="row mb-4 d-none" id="socialServiceStats">
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Total estudiantes</div>
            <div id="statSocialTotal" class="display-6">0</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Total horas acumuladas</div>
            <div id="statSocialHours" class="display-6">0</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Bitácoras pendientes</div>
            <div id="statSocialPending" class="display-6">0</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Asistencia promedio</div>
            <div id="statSocialAttendance" class="display-6">0%</div>
        </div>
    </div>
</div>

<!-- Estadísticas rápidas - TRÁMITES (oculto) -->
<div class="row mb-4 d-none" id="proceduresStats">
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Total solicitudes</div>
            <div id="statProcsTotal" class="display-6">0</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Acción requerida</div>
            <div id="statProcsAction" class="display-6">0</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">En proceso</div>
            <div id="statProcsInProgress" class="display-6">0</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3">
            <div class="h6">Finalizadas</div>
            <div id="statProcsFinalized" class="display-6">0</div>
        </div>
    </div>
</div>

<!-- Tab Alumnos -->
<div id="viewStudents">
    <div class="row">
        <div class="col-12">
            <div class="table-responsive mb-4">
                <table id="studentsTable" class="table table-striped table-hover">
                    <thead class="table-light">
<tr>
    <th class="excel-header" data-col="0">Id <span class="excel-icon">▼</span></th>
    <th class="excel-header" data-col="1">Nombre <span class="excel-icon">▼</span></th>
    <th class="excel-header" data-col="2">Genero <span class="excel-icon">▼</span></th>
    <th class="excel-header" data-col="3">Curso <span class="excel-icon">▼</span></th>
    <th class="excel-header" data-col="4">Semestre <span class="excel-icon">▼</span></th>
    <th class="excel-header" data-col="5">Estado <span class="excel-icon">▼</span></th>
    <th class="excel-header" data-col="6">Nota <span class="excel-icon">▼</span></th>
    <th class="excel-header" data-col="7">Fecha inscripción <span class="excel-icon">▼</span></th>
</tr>
</thead>
                    <tbody>
                    @foreach (var s in Model.Students)
                    {
                        <tr data-name="@s.Nombre" data-status="@s.Estado" data-genero="@s.Genero" data-semestre="@s.Semestre">
                            <td>@s.Id</td>
                            <td>@s.Nombre</td>
                            <td>@s.Genero</td>
                            <td>@s.Curso</td>
                            <td>@s.Semestre</td>
                            <td>
                                @if (s.Estado == "Aprobado")
                                {
                                    <span class="badge bg-success">Aprobado</span>
                                }
                                else if (s.Estado == "Reprobado")
                                {
                                    <span class="badge bg-danger">Reprobado</span>
                                }
                                else if (s.Estado == "Cursando")
                                {
                                    <span class="badge bg-warning text-dark">Cursando</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inscrito</span>
                                }
                            </td>
                            <td>@s.Nota</td>
                            <td>@s.FechaInscripcion.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <small id="pageInfo">Mostrando 1-15</small>
        </div>
        <div class="btn-group" id="paginationControls">
            <button id="firstPage" class="btn btn-sm btn-outline-secondary" title="Inicio">🏠</button>
            <button id="prevPage" class="btn btn-sm btn-outline-secondary">◀</button>
            <button id="nextPage" class="btn btn-sm btn-outline-secondary">▶</button>
        </div>
    </div>
</div>

<!-- Sección de empleados removida -->

<!-- VIEW: SERVICIOS SOCIALES (oculto) -->
<div id="viewSocialServices" class="d-none">
    <div class="row">
        <div class="col-12">
            <div class="table-responsive mb-4">
                <table id="socialServiceTable" class="table table-striped table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Alumno</th>
                            <th>Maestro asesor</th>
                            <th>Grupo</th>
                            <th>Horas prácticas</th>
                            <th>Horas servicio social</th>
                            <th>Total horas</th>
                            <th>Asistencia</th>
                            <th>Estado</th>
                            <th>Última actualización</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                Cargando datos de Servicios Sociales...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- VIEW: TRÁMITES (oculto) -->
<div id="viewProcedures" class="d-none">
    <div class="row">
        <div class="col-12">
            <div class="table-responsive mb-4">
                <table id="proceduresTable" class="table table-striped table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Folio</th>
                            <th>Usuario</th>
                            <th>Tipo de trámite</th>
                            <th>Área</th>
                            <th>Estado</th>
                            <th>Fecha creación</th>
                            <th>Fecha actualización</th>
                            <th>Días transcurridos</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                Cargando datos de Trámites...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="gradesCharts">
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card p-3">
                <h5>Distribución por estado</h5>
                <div class="chart-container">
                    <canvas id="pieChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-3">
                <h5>Promedio de nota por curso</h5>
                <div class="chart-container">
                    <canvas id="barChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Nuevas gráficas para alumnos: histograma de notas y barra apilada por curso -->
    <div class="row mt-3">
        <div class="col-md-6">
            <div class="card p-3">
                <h5>Histograma de distribución de notas</h5>
                <div class="chart-container">
                    <canvas id="gradeHistogramChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-3">
                <h5>Composición por estado por curso</h5>
                <div class="chart-container">
                    <canvas id="courseStatusStacked"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // datos serializados para JS: alumnos, servicios sociales, procedimientos
        window.__estadisticasData = {
            students: @Html.Raw(Model.JsonStudents),
            socialServices: @Html.Raw(Model.JsonSocialServiceStats),
            procedures: @Html.Raw(Model.JsonProcedureStats)
        };
    </script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/estadisticas.js" asp-append-version="true"></script>

    <script>
        // Lógica de vistas: Calificaciones, Servicios Sociales, Trámites
        (function () {
            // Elementos de botones
            const btnCalificaciones = document.getElementById('btnCalificaciones');
            const btnServicios = document.getElementById('btnServicios');
            const btnTramites = document.getElementById('btnTramites');

            // Elementos de vistas
            const viewStudents = document.getElementById('viewStudents');
            const viewSocialServices = document.getElementById('viewSocialServices');
            const viewProcedures = document.getElementById('viewProcedures');

            // Elementos de estadísticas rápidas
            const studentStats = document.getElementById('studentStats');
            const socialServiceStats = document.getElementById('socialServiceStats');
            const proceduresStats = document.getElementById('proceduresStats');

            // Elementos de gráficas y paginación (solo para Calificaciones)
            const gradesCharts = document.getElementById('gradesCharts');
            const paginationControls = document.getElementById('paginationControls');

            // Elementos de título y subtítulo
            const pageTitle = document.getElementById('pageTitle');
            const pageSubtitle = document.getElementById('pageSubtitle');

            // Elementos de filtros
            const filtersStudents = document.getElementById('filtersStudents');
            const filtersArea = document.getElementById('filtersArea');

            /**
             * Función para mostrar la vista de Calificaciones
             */
            function showCalificaciones() {
                // Botones
                btnCalificaciones.classList.add('btn-primary');
                btnCalificaciones.classList.remove('btn-outline-primary');
                btnServicios.classList.remove('btn-primary');
                btnServicios.classList.add('btn-outline-primary');
                btnTramites.classList.remove('btn-primary');
                btnTramites.classList.add('btn-outline-primary');

                // Vistas
                viewStudents.classList.remove('d-none');
                viewSocialServices.classList.add('d-none');
                viewProcedures.classList.add('d-none');

                // Estadísticas rápidas
                studentStats.classList.remove('d-none');
                socialServiceStats.classList.add('d-none');
                proceduresStats.classList.add('d-none');

                // Gráficas y paginación
                if (gradesCharts) {
                    gradesCharts.classList.remove('d-none');
                }
                if (paginationControls) {
                    paginationControls.classList.remove('d-none');
                }

                // Filtros
                if (filtersStudents) {
                    filtersStudents.classList.remove('d-none');
                }
                if (filtersArea) {
                    filtersArea.classList.remove('collapse', 'show');
                    filtersArea.classList.add('collapse');
                }

                // Títulos
                if (pageTitle) {
                    pageTitle.textContent = 'Estadísticas de alumnos';
                }
                if (pageSubtitle) {
                    pageSubtitle.textContent = 'Control y seguimiento: inscritos, cursando, aprobados y reprobados.';
                }
            }

            /**
             * Función para mostrar la vista de Servicios Sociales
             */
            function showServicios() {
                // Botones
                btnCalificaciones.classList.remove('btn-primary');
                btnCalificaciones.classList.add('btn-outline-primary');
                btnServicios.classList.add('btn-primary');
                btnServicios.classList.remove('btn-outline-primary');
                btnTramites.classList.remove('btn-primary');
                btnTramites.classList.add('btn-outline-primary');

                // Vistas
                viewStudents.classList.add('d-none');
                viewSocialServices.classList.remove('d-none');
                viewProcedures.classList.add('d-none');

                // Estadísticas rápidas
                studentStats.classList.add('d-none');
                socialServiceStats.classList.remove('d-none');
                proceduresStats.classList.add('d-none');

                // Gráficas y paginación (ocultar para Servicios Sociales)
                if (gradesCharts) {
                    gradesCharts.classList.add('d-none');
                }
                if (paginationControls) {
                    paginationControls.classList.add('d-none');
                }

                // Filtros
                if (filtersArea) {
                    filtersArea.classList.remove('collapse', 'show');
                    filtersArea.classList.add('collapse');
                }

                // Títulos
                if (pageTitle) {
                    pageTitle.textContent = 'Estadísticas de Servicios Sociales';
                }
                if (pageSubtitle) {
                    pageSubtitle.textContent = 'Seguimiento de horas, asistencia y bitácoras de estudiantes.';
                }
            }

            /**
             * Función para mostrar la vista de Trámites
             */
            function showTramites() {
                // Botones
                btnCalificaciones.classList.remove('btn-primary');
                btnCalificaciones.classList.add('btn-outline-primary');
                btnServicios.classList.remove('btn-primary');
                btnServicios.classList.add('btn-outline-primary');
                btnTramites.classList.add('btn-primary');
                btnTramites.classList.remove('btn-outline-primary');

                // Vistas
                viewStudents.classList.add('d-none');
                viewSocialServices.classList.add('d-none');
                viewProcedures.classList.remove('d-none');

                // Estadísticas rápidas
                studentStats.classList.add('d-none');
                socialServiceStats.classList.add('d-none');
                proceduresStats.classList.remove('d-none');

                // Gráficas y paginación (ocultar para Trámites)
                if (gradesCharts) {
                    gradesCharts.classList.add('d-none');
                }
                if (paginationControls) {
                    paginationControls.classList.add('d-none');
                }

                // Filtros
                if (filtersArea) {
                    filtersArea.classList.remove('collapse', 'show');
                    filtersArea.classList.add('collapse');
                }

                // Títulos
                if (pageTitle) {
                    pageTitle.textContent = 'Estadísticas de Trámites';
                }
                if (pageSubtitle) {
                    pageSubtitle.textContent = 'Seguimiento y control de solicitudes administrativas.';
                }
            }

            // Event listeners para botones
            if (btnCalificaciones) {
                btnCalificaciones.addEventListener('click', showCalificaciones);
            }
            if (btnServicios) {
                btnServicios.addEventListener('click', showServicios);
            }
            if (btnTramites) {
                btnTramites.addEventListener('click', showTramites);
            }

            // Toggle para submenu de filtros
            const toggleFilters = document.getElementById('toggleFilters');
            if (toggleFilters && filtersArea) {
                toggleFilters.addEventListener('click', function () {
                    if (filtersArea.classList.contains('show')) {
                        filtersArea.classList.remove('show');
                        toggleFilters.setAttribute('aria-expanded', 'false');
                    } else {
                        filtersArea.classList.add('show');
                        toggleFilters.setAttribute('aria-expanded', 'true');
                    }
                });
            }

            // Inicializar con vista de Calificaciones
            showCalificaciones();
        })();
    </script>
}