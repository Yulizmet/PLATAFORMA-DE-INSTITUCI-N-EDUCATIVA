            <div class="col-md-6 mb-3"><div class="card p-3"><h5>Distribución por estado</h5><div class="chart-container"><canvas id="medPieChart"></canvas></div></div></div>
            <div class="col-md-6 mb-3"><div class="card p-3"><h5>Motivos de consulta más frecuentes</h5><div class="chart-container"><canvas id="medReasonBar"></canvas></div></div></div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3"><div class="card p-3"><h5>Consultas registradas por mes</h5><div class="chart-container"><canvas id="medMonthBar"></canvas></div></div></div>
            <div class="col-md-6 mb-3"><div class="card p-3"><h5>Alumnos con más consultas (Top 10)</h5><div class="chart-container"><canvas id="medStudentBar"></canvas></div></div></div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     VIEW: TUTORÍAS
══════════════════════════════════════ -->
<div id="viewTutorias" class="d-none">
    <div class="table-responsive mb-2">
        <table id="tutorshipTable" class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th class="excel-header" data-table="tutorshipTable" data-col="0">Alumno <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="tutorshipTable" data-col="1">Tutor <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="tutorshipTable" data-col="2">Estado entrevista <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="tutorshipTable" data-col="3">Nivel desempeño <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="tutorshipTable" data-col="4">Sesiones <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="tutorshipTable" data-col="5">Entrevistas <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="tutorshipTable" data-col="6">Monitoreos <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="tutorshipTable" data-col="7">Última fecha <span class="excel-icon">▼</span></th>
                </tr>
            </thead>
            <tbody><tr><td colspan="8" class="text-center text-muted py-4">Cargando datos de Tutorías...</td></tr></tbody>
        </table>
    </div>
    <div class="pagination-bar mb-3">
        <small id="pageInfoTut">Mostrando resultados</small>
        <div class="pagination-bar-right">
            <label class="text-muted small mb-0">Filas:</label>
            <select id="pageSizeTut" class="page-size-select">
                <option value="15" selected>15</option>
                <option value="20">20</option>
                <option value="50">50</option>
            </select>
            <div class="btn-group">
                <button id="firstPageTut" class="btn btn-sm btn-outline-secondary">🏠</button>
                <button id="prevPageTut"  class="btn btn-sm btn-outline-secondary">◀</button>
                <button id="nextPageTut"  class="btn btn-sm btn-outline-secondary">▶</button>
            </div>
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-md-6 mb-3"><div class="card p-3"><h5>Distribución por estado</h5><div class="chart-container"><canvas id="tutStatusPie"></canvas></div></div></div>
        <div class="col-md-6 mb-3"><div class="card p-3"><h5>Distribución por nivel de desempeño</h5><div class="chart-container"><canvas id="tutPerfBar"></canvas></div></div></div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3"><div class="card p-3"><h5>Actividad por mes</h5><div class="chart-container"><canvas id="tutMonthBar"></canvas></div></div></div>
        <div class="col-md-6 mb-3"><div class="card p-3"><h5>Alumnos con más actividad (Top 10)</h5><div class="chart-container"><canvas id="tutStudentBar"></canvas></div></div></div>
    </div>
</div>

@section Scripts {
    <script>
        window.__estadisticasData = {
            students:       @Html.Raw(Model.JsonStudents),
            socialServices: @Html.Raw(Model.JsonSocialServiceStats),
            procedures:     @Html.Raw(Model.JsonProcedureStats),
            psychologyLogs: @Html.Raw(Model.JsonPsychologyLogs),
            medicalLogs:    @Html.Raw(Model.JsonMedicalLogs),
            tutorshipStats: @Html.Raw(Model.JsonTutorshipStats)
        };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
    <script src="~/js/estadisticas.js" asp-append-version="true"></script>

    <script>
    (function () {
        const btnGeneral            = document.getElementById('btnGeneral');
        const btnCalificaciones     = document.getElementById('btnCalificaciones');
        const btnServicios          = document.getElementById('btnServicios');
        const btnTramites           = document.getElementById('btnTramites');
        const btnBitacoras          = document.getElementById('btnBitacoras');
        const btnTutorias           = document.getElementById('btnTutorias');
        const viewGeneral           = document.getElementById('viewGeneral');
        const viewStudents          = document.getElementById('viewStudents');
        const viewSocialServices    = document.getElementById('viewSocialServices');
        const viewProcedures        = document.getElementById('viewProcedures');
        const viewBitacoras         = document.getElementById('viewBitacoras');
        const viewTutorias          = document.getElementById('viewTutorias');
        const studentStats          = document.getElementById('studentStats');
        const socialServiceStats    = document.getElementById('socialServiceStats');
        const proceduresStats       = document.getElementById('proceduresStats');
        const psychologyStats       = document.getElementById('psychologyStats');
        const medicalStats          = document.getElementById('medicalStats');
        const tutorshipStatsEl      = document.getElementById('tutorshipStats');
        const filtersStudents       = document.getElementById('filtersStudents');
        const filtersStudentsGrupo  = document.getElementById('filtersStudentsGrupo');
        const filtersSocialServices = document.getElementById('filtersSocialServices');
        const filtersTramites       = document.getElementById('filtersTramites');
        const filtersBitacorasPsy   = document.getElementById('filtersBitacorasPsy');
        const filtersBitacorasMed   = document.getElementById('filtersBitacorasMed');
        const filtersTutorias       = document.getElementById('filtersTutorias');
        const filtersArea           = document.getElementById('filtersArea');

        const allMainBtns = [btnGeneral, btnCalificaciones, btnServicios, btnTramites, btnBitacoras, btnTutorias];
        const allViews    = [viewGeneral, viewStudents, viewSocialServices, viewProcedures, viewBitacoras, viewTutorias];
        const allStats    = [studentStats, socialServiceStats, proceduresStats, psychologyStats, medicalStats, tutorshipStatsEl];
        const allFilters  = [filtersStudents, filtersStudentsGrupo, filtersSocialServices, filtersTramites, filtersBitacorasPsy, filtersBitacorasMed, filtersTutorias];

        function setActiveBtn(active) {
            allMainBtns.forEach(b => { if (!b) return;
                b.classList.toggle('btn-primary',         b === active);
                b.classList.toggle('btn-outline-primary', b !== active);
                b.classList.toggle('active',              b === active);
            });
        }
        function hideAll() {
            allViews.forEach(v => v && v.classList.add('d-none'));
            allStats.forEach(s => s && s.classList.add('d-none'));
            allFilters.forEach(f => f && f.classList.add('d-none'));
            ['toggleFilters','btnExportTable','btnExportPDF'].forEach(id => {
                const el = document.getElementById(id); if (el) el.classList.remove('d-none');
            });
        }
        function collapseFilters() {
            if (filtersArea) {
                filtersArea.classList.remove('show');
                document.getElementById('toggleFilters').setAttribute('aria-expanded', 'false');
            }
        }

        function showGeneral() {
            hideAll(); setActiveBtn(btnGeneral);
            viewGeneral.classList.remove('d-none');
            collapseFilters();
            document.getElementById('pageTitle').textContent = 'Resumen General';
            document.getElementById('pageSubtitle').textContent = 'Vista ejecutiva de los principales indicadores del sistema académico institucional.';
            ['toggleFilters','btnExportTable','btnExportPDF'].forEach(id => {
                const el = document.getElementById(id); if (el) el.classList.add('d-none');
            });
        }
        function showCalificaciones() {
            hideAll(); setActiveBtn(btnCalificaciones);
            viewStudents.classList.remove('d-none');
            studentStats.classList.remove('d-none');
            collapseFilters();
            document.getElementById('pageTitle').textContent = 'Estadísticas de alumnos';
            document.getElementById('pageSubtitle').textContent = 'Control y seguimiento: inscritos, cursando, aprobados y reprobados.';
            switchSubCalificaciones('semestre');
        }
        function switchSubCalificaciones(sub) {
            const subSem = document.getElementById('subViewSemestre');
            const subGrp = document.getElementById('subViewGrupo');
            const btnSem = document.getElementById('btnSubSemestre');
            const btnGrp = document.getElementById('btnSubGrupo');
            if (sub === 'semestre') {
                subSem.classList.remove('d-none'); subGrp.classList.add('d-none');
                filtersStudents.classList.remove('d-none'); filtersStudentsGrupo.classList.add('d-none');
                btnSem.classList.add('btn-primary'); btnSem.classList.remove('btn-outline-primary');
                btnGrp.classList.add('btn-outline-primary'); btnGrp.classList.remove('btn-primary');
                if (typeof window.refreshSemestreCharts === 'function') window.refreshSemestreCharts();
            } else {
                subSem.classList.add('d-none'); subGrp.classList.remove('d-none');
                filtersStudents.classList.add('d-none'); filtersStudentsGrupo.classList.remove('d-none');
                btnGrp.classList.add('btn-primary'); btnGrp.classList.remove('btn-outline-primary');
                btnSem.classList.add('btn-outline-primary'); btnSem.classList.remove('btn-primary');
                if (typeof window.refreshGroupCharts === 'function') window.refreshGroupCharts();
            }
        }
        function showServicios() {
            hideAll(); setActiveBtn(btnServicios);
            viewSocialServices.classList.remove('d-none');
            socialServiceStats.classList.remove('d-none');
            filtersSocialServices.classList.remove('d-none');
            collapseFilters();
            document.getElementById('pageTitle').textContent = 'Estadísticas de Servicio Social';
            document.getElementById('pageSubtitle').textContent = 'Seguimiento de asistencia y bitácoras de estudiantes.';
        }
        function showTramites() {
            hideAll(); setActiveBtn(btnTramites);
            viewProcedures.classList.remove('d-none');
            proceduresStats.classList.remove('d-none');
            filtersTramites.classList.remove('d-none');
            collapseFilters();
            document.getElementById('pageTitle').textContent = 'Estadísticas de Trámites';
            document.getElementById('pageSubtitle').textContent = 'Seguimiento y control de solicitudes administrativas.';
        }
        function showBitacoras(sub) {
            hideAll(); setActiveBtn(btnBitacoras);
            viewBitacoras.classList.remove('d-none');
            collapseFilters();
            document.getElementById('pageTitle').textContent = 'Bitácoras';
            document.getElementById('pageSubtitle').textContent = 'Registros de atención psicológica y de enfermería.';
            switchSubBitacora(sub || 'psicologia');
        }

        function switchSubBitacora(sub) {
            const subPsy = document.getElementById('subViewPsicologia');
            const subEnf = document.getElementById('subViewEnfermeria');
            const btnPsy = document.getElementById('btnSubPsicologia');
            const btnEnf = document.getElementById('btnSubEnfermeria');
            if (sub === 'psicologia') {
                subPsy.classList.remove('d-none'); subEnf.classList.add('d-none');
                psychologyStats.classList.remove('d-none'); medicalStats.classList.add('d-none');
                filtersBitacorasPsy.classList.remove('d-none'); filtersBitacorasMed.classList.add('d-none');
                btnPsy.classList.replace('btn-outline-primary','btn-primary');
                btnEnf.classList.replace('btn-primary','btn-outline-primary');
            } else {
                subPsy.classList.add('d-none'); subEnf.classList.remove('d-none');
                psychologyStats.classList.add('d-none'); medicalStats.classList.remove('d-none');
                filtersBitacorasPsy.classList.add('d-none'); filtersBitacorasMed.classList.remove('d-none');
                btnEnf.classList.replace('btn-outline-primary','btn-primary');
                btnPsy.classList.replace('btn-primary','btn-outline-primary');
            }
        }

        function showTutorias() {
            hideAll(); setActiveBtn(btnTutorias);
            viewTutorias.classList.remove('d-none');
            tutorshipStatsEl.classList.remove('d-none');
            filtersTutorias.classList.remove('d-none');
            collapseFilters();
            document.getElementById('pageTitle').textContent = 'Estadísticas de Tutorías';
            document.getElementById('pageSubtitle').textContent = 'Seguimiento de entrevistas, monitoreos y sesiones de tutoría.';
        }

        if (btnGeneral)        btnGeneral.addEventListener('click', showGeneral);
        if (btnCalificaciones) btnCalificaciones.addEventListener('click', showCalificaciones);
        btnServicios.addEventListener('click', showServicios);
        btnTramites.addEventListener('click', showTramites);
        if (btnBitacoras) btnBitacoras.addEventListener('click', () => showBitacoras('psicologia'));
        if (btnTutorias) btnTutorias.addEventListener('click', showTutorias);

        const btnSubPsy = document.getElementById('btnSubPsicologia');
        const btnSubEnf = document.getElementById('btnSubEnfermeria');
        if (btnSubPsy) btnSubPsy.addEventListener('click', () => switchSubBitacora('psicologia'));
        if (btnSubEnf) btnSubEnf.addEventListener('click', () => switchSubBitacora('enfermeria'));

        const btnSubSem = document.getElementById('btnSubSemestre');
        const btnSubGrp = document.getElementById('btnSubGrupo');
        if (btnSubSem) btnSubSem.addEventListener('click', () => switchSubCalificaciones('semestre'));
        if (btnSubGrp) btnSubGrp.addEventListener('click', () => switchSubCalificaciones('grupo'));

        document.getElementById('toggleFilters').addEventListener('click', function () {
            const open = filtersArea.classList.toggle('show');
            this.setAttribute('aria-expanded', open);
        });

        showGeneral();
    })();
    </script>
}
