@page "/Estadisticas"
@model SchoolManager.Pages.Estadisticas.IndexModel
@{
    Layout = "/Areas/MainScreen/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Estadísticas";
}
@section Styles {
    <link rel="stylesheet" href="~/css/escuela.css" asp-append-version="true" />
}

<style>
.chart-container {
    height: 300px;
    position: relative;
    width: 100%;
}
.chart-container canvas {
    width: 100% !important;
    height: 100% !important;
    display: block;
}
.filter-submenu {
    border: 1px solid #e3e6ea;
    padding: 12px;
    border-radius: 6px;
    background: #f8f9fa;
}
.excel-filter-popup {
    position: fixed;
    min-width: 240px;
    max-width: 320px;
    background: #1f1f1f;
    color: #fff;
    border-radius: 6px;
    box-shadow: 0 6px 18px rgba(0,0,0,0.45);
    padding: 10px;
    z-index: 2000;
    border: 1px solid rgba(255,255,255,0.06);
}
.excel-filter-popup button {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.15);
    padding: 4px 8px;
    border-radius: 4px;
    cursor: pointer;
}
.filter-values {
    max-height: 160px;
    overflow-y: auto;
    background: #141414;
    padding: 6px;
    border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.04);
    margin-top: 6px;
}
.filter-values label {
    display: block;
    font-size: 0.85rem;
    margin-bottom: 4px;
    cursor: pointer;
}
</style>

<!-- Botones de sección -->
<div class="row mb-3">
    <div class="col-12">
        <div class="btn-group" role="group">
            <button id="btnCalificaciones" class="btn btn-primary view-btn active">Calificaciones</button>
            <button id="btnServicios" class="btn btn-outline-primary view-btn">Servicios Sociales</button>
            <button id="btnTramites" class="btn btn-outline-primary view-btn">Trámites</button>
            <button id="btnBitacoras" class="btn btn-outline-primary view-btn">Bitácoras</button>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 id="pageTitle">Estadísticas de alumnos</h2>
            <p class="text-muted" id="pageSubtitle">Control y seguimiento: inscritos, cursando, aprobados y reprobados.</p>
        </div>
        <button id="btnExportTable" class="btn btn-success ms-2">Exportar a Excel</button>
    </div>
</div>

<!-- Filtros colapsables -->
<div class="row mb-3">
    <div class="col-12">
        <button id="toggleFilters" class="btn btn-sm btn-secondary mb-2" type="button" aria-expanded="false">Filtros</button>
        <div id="filtersArea" class="filter-submenu collapse">

            <div id="filtersStudents">
                <div class="row g-2">
                    <div class="col-md-3">
                        <input id="filterName" class="form-control" placeholder="Filtrar por nombre..." />
                    </div>
                    <div class="col-md-2">
                        <select id="filterStatus" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="Inscrito">Inscrito</option>
                            <option value="Cursando">Cursando</option>
                            <option value="Aprobado">Aprobado</option>
                            <option value="Reprobado">Reprobado</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select id="filterGenero" class="form-select">
                            <option value="">Todos géneros</option>
                            <option value="M">Masculino</option>
                            <option value="F">Femenino</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select id="filterSemestre" class="form-select">
                            <option value="">Todos semestres</option>
                            <option value="1">1</option><option value="2">2</option>
                            <option value="3">3</option><option value="4">4</option>
                            <option value="5">5</option><option value="6">6</option>
                            <option value="7">7</option><option value="8">8</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="applyStudentFilters" class="btn btn-primary">Aplicar</button>
                        <button id="resetFilters" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </div>
            </div>

            <div id="filtersSocialServices" class="d-none">
                <div class="row g-2">
                    <div class="col-md-3">
                        <input id="filterSocialName" class="form-control" placeholder="Filtrar por alumno..." />
                    </div>
                    <div class="col-md-2">
                        <input id="filterSocialTeacher" class="form-control" placeholder="Filtrar por maestro..." />
                    </div>
                    <div class="col-md-2">
                        <select id="filterSocialStatus" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="Completado">Completado</option>
                            <option value="En progreso">En progreso</option>
                            <option value="Pendiente">Pendiente</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input id="filterSocialGroup" class="form-control" placeholder="Filtrar por grupo..." />
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="applySocialFilters" class="btn btn-primary">Aplicar</button>
                        <button id="resetSocialFilters" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </div>
            </div>

            <div id="filtersTramites" class="d-none">
                <div class="row g-2">
                    <div class="col-md-3">
                        <input id="filterTramiteUser" class="form-control" placeholder="Filtrar por usuario..." />
                    </div>
                    <div class="col-md-2">
                        <input id="filterTramiteFolio" class="form-control" placeholder="Filtrar por folio..." />
                    </div>
                    <div class="col-md-2">
                        <select id="filterTramiteStatus" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="APPROVED">Pagó inscripción</option>
                            <option value="PENDING">Pendiente</option>
                            <option value="REJECTED">No pagó</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input id="filterTramiteArea" class="form-control" placeholder="Filtrar por área..." />
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button id="applyTramiteFilters" class="btn btn-primary">Aplicar</button>
                        <button id="resetTramiteFilters" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ── Tarjetas CALIFICACIONES ── -->
<div class="row mb-4" id="studentStats">
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Total alumnos</div><div id="statTotal" class="display-6">@Model.Total</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Inscritos</div><div id="statInscritos" class="display-6">@Model.CountInscrito</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Cursando</div><div id="statCursando" class="display-6">@Model.CountCursando</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Aprobados</div><div id="statAprobados" class="display-6">@Model.CountAprobado</div></div>
    </div>
</div>

<!-- ── Tarjetas SERVICIOS SOCIALES ── -->
<div class="row mb-4 d-none" id="socialServiceStats">
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Total estudiantes</div><div id="statSocialTotal" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Total horas acumuladas</div><div id="statSocialHours" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Bitácoras pendientes</div><div id="statSocialPending" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Asistencia promedio</div><div id="statSocialAttendance" class="display-6">0%</div></div>
    </div>
</div>

<!-- ── Tarjetas TRÁMITES ── -->
<div class="row mb-4 d-none" id="proceduresStats">
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Total solicitudes</div><div id="statProcsTotal" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Acción requerida</div><div id="statProcsAction" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">En proceso</div><div id="statProcsInProgress" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Finalizadas</div><div id="statProcsFinalized" class="display-6">0</div></div>
    </div>
</div>

<!-- ── Tarjetas BITÁCORAS PSICOLOGÍA ── -->
<div class="row mb-4 d-none" id="psychologyStats">
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Total registros</div><div id="statPsyTotal" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Asistió</div><div id="statPsyAttended" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">No asistió</div><div id="statPsyAbsent" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Justificados</div><div id="statPsyJustified" class="display-6">0</div></div>
    </div>
</div>

<!-- ── Tarjetas BITÁCORAS ENFERMERÍA ── -->
<div class="row mb-4 d-none" id="medicalStats">
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Total registros</div><div id="statMedTotal" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Atendidos</div><div id="statMedAttended" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Pendientes</div><div id="statMedPending" class="display-6">0</div></div>
    </div>
    <div class="col-sm-6 col-md-3 mb-2">
        <div class="card p-3"><div class="h6">Otros estados</div><div id="statMedOther" class="display-6">0</div></div>
    </div>
</div>

<!-- ══════════════════════════════════════════════
     VIEW: CALIFICACIONES
══════════════════════════════════════════════ -->
<div id="viewStudents">
    <div class="table-responsive mb-2">
        <table id="studentsTable" class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th class="excel-header" data-table="studentsTable" data-col="0">Id <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="studentsTable" data-col="1">Nombre <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="studentsTable" data-col="2">Genero <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="studentsTable" data-col="3">Curso <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="studentsTable" data-col="4">Semestre <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="studentsTable" data-col="5">Estado <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="studentsTable" data-col="6">Nota <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="studentsTable" data-col="7">Fecha inscripción <span class="excel-icon">▼</span></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var s in Model.Students)
            {
                <tr data-name="@s.Nombre" data-status="@s.Estado" data-genero="@s.Genero" data-semestre="@s.Semestre">
                    <td>@s.Id</td>
                    <td>@s.Nombre</td>
                    <td>@s.Genero</td>
                    <td>@s.Curso</td>
                    <td>@s.Semestre</td>
                    <td>
                        @if (s.Estado == "Aprobado") { <span class="badge bg-success">Aprobado</span> }
                        else if (s.Estado == "Reprobado") { <span class="badge bg-danger">Reprobado</span> }
                        else if (s.Estado == "Cursando") { <span class="badge bg-warning text-dark">Cursando</span> }
                        else { <span class="badge bg-secondary">Inscrito</span> }
                    </td>
                    <td>@s.Nota</td>
                    <td>@s.FechaInscripcion.ToString("yyyy-MM-dd")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <small id="pageInfo">Mostrando 1-15</small>
            <div class="btn-group">
                <button id="firstPage" class="btn btn-sm btn-outline-secondary">🏠</button>
                <button id="prevPage" class="btn btn-sm btn-outline-secondary">◀</button>
                <button id="nextPage" class="btn btn-sm btn-outline-secondary">▶</button>
            </div>
        </div>
    </div>
    <!-- Gráficas Calificaciones -->
    <div class="row mt-2">
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Distribución por estado</h5>
                <div class="chart-container"><canvas id="pieChart"></canvas></div></div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Promedio de nota por curso</h5>
                <div class="chart-container"><canvas id="barChart"></canvas></div></div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Histograma de distribución de notas</h5>
                <div class="chart-container"><canvas id="gradeHistogramChart"></canvas></div></div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Composición por estado por curso</h5>
                <div class="chart-container"><canvas id="courseStatusStacked"></canvas></div></div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════
     VIEW: SERVICIOS SOCIALES
══════════════════════════════════════════════ -->
<div id="viewSocialServices" class="d-none">
    <div class="table-responsive mb-2">
        <table id="socialServiceTable" class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th class="excel-header" data-table="socialServiceTable" data-col="0">Alumno <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="socialServiceTable" data-col="1">Maestro asesor <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="socialServiceTable" data-col="2">Grupo <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="socialServiceTable" data-col="3">Horas prácticas <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="socialServiceTable" data-col="4">Horas serv. social <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="socialServiceTable" data-col="5">Total horas <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="socialServiceTable" data-col="6">Asistencia <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="socialServiceTable" data-col="7">Estado <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="socialServiceTable" data-col="8">Última actualización <span class="excel-icon">▼</span></th>
                </tr>
            </thead>
            <tbody>
                <tr><td colspan="9" class="text-center text-muted py-4">Cargando datos...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <small id="pageInfoSocial">Mostrando resultados</small>
            <div class="btn-group">
                <button id="firstPageSocial" class="btn btn-sm btn-outline-secondary">🏠</button>
                <button id="prevPageSocial" class="btn btn-sm btn-outline-secondary">◀</button>
                <button id="nextPageSocial" class="btn btn-sm btn-outline-secondary">▶</button>
            </div>
        </div>
    </div>
    <!-- Gráficas Servicios Sociales -->
    <div class="row mt-2">
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Estado de servicio social</h5>
                <div class="chart-container"><canvas id="socialPieChart"></canvas></div></div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Horas totales por alumno (Top 10)</h5>
                <div class="chart-container"><canvas id="socialHoursBar"></canvas></div></div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Asistencia promedio por grupo</h5>
                <div class="chart-container"><canvas id="socialAttendanceBar"></canvas></div></div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Horas prácticas vs. servicio social</h5>
                <div class="chart-container"><canvas id="socialHoursStacked"></canvas></div></div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════
     VIEW: TRÁMITES
══════════════════════════════════════════════ -->
<div id="viewProcedures" class="d-none">
    <div class="table-responsive mb-2">
        <table id="proceduresTable" class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th class="excel-header" data-table="proceduresTable" data-col="0">Folio <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="proceduresTable" data-col="1">Usuario <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="proceduresTable" data-col="2">Tipo de trámite <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="proceduresTable" data-col="3">Área <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="proceduresTable" data-col="4">Estado <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="proceduresTable" data-col="5">Fecha creación <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="proceduresTable" data-col="6">Fecha actualización <span class="excel-icon">▼</span></th>
                    <th class="excel-header" data-table="proceduresTable" data-col="7">Días transcurridos <span class="excel-icon">▼</span></th>
                </tr>
            </thead>
            <tbody>
                <tr><td colspan="8" class="text-center text-muted py-4">Cargando datos...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <small id="pageInfoTramites">Mostrando resultados</small>
            <div class="btn-group">
                <button id="firstPageTramites" class="btn btn-sm btn-outline-secondary">🏠</button>
                <button id="prevPageTramites" class="btn btn-sm btn-outline-secondary">◀</button>
                <button id="nextPageTramites" class="btn btn-sm btn-outline-secondary">▶</button>
            </div>
        </div>
    </div>
    <!-- Gráficas Trámites -->
    <div class="row mt-2">
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Distribución por estado</h5>
                <div class="chart-container"><canvas id="tramitesPieChart"></canvas></div></div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Trámites por área</h5>
                <div class="chart-container"><canvas id="tramitesAreaBar"></canvas></div></div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Tipos de trámite más solicitados</h5>
                <div class="chart-container"><canvas id="tramitesTipoBar"></canvas></div></div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card p-3"><h5>Días promedio de resolución por área</h5>
                <div class="chart-container"><canvas id="tramitesDiasBar"></canvas></div></div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════
     VIEW: BITÁCORAS
══════════════════════════════════════════════ -->
<div id="viewBitacoras" class="d-none">
    <!-- Sub-botones internos -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="btn-group" role="group">
                <button id="btnSubPsicologia" class="btn btn-sm btn-primary">Psicología</button>
                <button id="btnSubEnfermeria" class="btn btn-sm btn-outline-primary">Enfermería</button>
            </div>
        </div>
    </div>

    <!-- Sub-vista: Psicología -->
    <div id="subViewPsicologia">
        <div class="table-responsive mb-2">
            <table id="psychologyTable" class="table table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Folio</th>
                        <th>Alumno</th>
                        <th>Matrícula</th>
                        <th>Fecha cita</th>
                        <th>Asistencia</th>
                        <th>Observaciones</th>
                        <th>Fecha creación</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="7" class="text-center text-muted py-4">Cargando datos de Psicología...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Sub-vista: Enfermería -->
    <div id="subViewEnfermeria" class="d-none">
        <div class="table-responsive mb-2">
            <table id="medicalTable" class="table table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Folio</th>
                        <th>Alumno</th>
                        <th>Matrícula</th>
                        <th>Fecha registro</th>
                        <th>Motivo de consulta</th>
                        <th>Signos vitales</th>
                        <th>Observaciones</th>
                        <th>Acción tomada</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="9" class="text-center text-muted py-4">Cargando datos de Enfermería...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.__estadisticasData = {
            students:       @Html.Raw(Model.JsonStudents),
            socialServices: @Html.Raw(Model.JsonSocialServiceStats),
            procedures:     @Html.Raw(Model.JsonProcedureStats),
            psychologyLogs: @Html.Raw(Model.JsonPsychologyLogs),
            medicalLogs:    @Html.Raw(Model.JsonMedicalLogs)
        };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/estadisticas.js" asp-append-version="true"></script>

    <script>
    (function () {
        const btnCalificaciones     = document.getElementById('btnCalificaciones');
        const btnServicios          = document.getElementById('btnServicios');
        const btnTramites           = document.getElementById('btnTramites');
        const btnBitacoras          = document.getElementById('btnBitacoras');
        const viewStudents          = document.getElementById('viewStudents');
        const viewSocialServices    = document.getElementById('viewSocialServices');
        const viewProcedures        = document.getElementById('viewProcedures');
        const viewBitacoras         = document.getElementById('viewBitacoras');
        const studentStats          = document.getElementById('studentStats');
        const socialServiceStats    = document.getElementById('socialServiceStats');
        const proceduresStats       = document.getElementById('proceduresStats');
        const psychologyStats       = document.getElementById('psychologyStats');
        const medicalStats          = document.getElementById('medicalStats');
        const filtersStudents       = document.getElementById('filtersStudents');
        const filtersSocialServices = document.getElementById('filtersSocialServices');
        const filtersTramites       = document.getElementById('filtersTramites');
        const filtersArea           = document.getElementById('filtersArea');

        const allMainBtns  = [btnCalificaciones, btnServicios, btnTramites, btnBitacoras];
        const allViews     = [viewStudents, viewSocialServices, viewProcedures, viewBitacoras];
        const allStats     = [studentStats, socialServiceStats, proceduresStats, psychologyStats, medicalStats];

        function setActiveBtn(active) {
            allMainBtns.forEach(b => {
                if (!b) return;
                b.classList.toggle('btn-primary', b === active);
                b.classList.toggle('btn-outline-primary', b !== active);
            });
        }
        function hideAllViews() { allViews.forEach(v => v && v.classList.add('d-none')); }
        function hideAllStats() { allStats.forEach(s => s && s.classList.add('d-none')); }
        function hideAllFilters() {
            [filtersStudents, filtersSocialServices, filtersTramites]
                .forEach(f => f && f.classList.add('d-none'));
        }
        function collapseFilters() {
            if (filtersArea) {
                filtersArea.classList.remove('show');
                const tog = document.getElementById('toggleFilters');
                if (tog) tog.setAttribute('aria-expanded', 'false');
            }
        }

        function showCalificaciones() {
            setActiveBtn(btnCalificaciones);
            hideAllViews(); hideAllStats(); hideAllFilters();
            viewStudents.classList.remove('d-none');
            studentStats.classList.remove('d-none');
            if (filtersStudents) filtersStudents.classList.remove('d-none');
            collapseFilters();
            document.getElementById('pageTitle').textContent = 'Estadísticas de alumnos';
            document.getElementById('pageSubtitle').textContent = 'Control y seguimiento: inscritos, cursando, aprobados y reprobados.';
        }
        function showServicios() {
            setActiveBtn(btnServicios);
            hideAllViews(); hideAllStats(); hideAllFilters();
            viewSocialServices.classList.remove('d-none');
            socialServiceStats.classList.remove('d-none');
            if (filtersSocialServices) filtersSocialServices.classList.remove('d-none');
            collapseFilters();
            document.getElementById('pageTitle').textContent = 'Estadísticas de Servicios Sociales';
            document.getElementById('pageSubtitle').textContent = 'Seguimiento de horas, asistencia y bitácoras de estudiantes.';
        }
        function showTramites() {
            setActiveBtn(btnTramites);
            hideAllViews(); hideAllStats(); hideAllFilters();
            viewProcedures.classList.remove('d-none');
            proceduresStats.classList.remove('d-none');
            if (filtersTramites) filtersTramites.classList.remove('d-none');
            collapseFilters();
            document.getElementById('pageTitle').textContent = 'Estadísticas de Trámites';
            document.getElementById('pageSubtitle').textContent = 'Seguimiento y control de solicitudes administrativas.';
        }
        function showBitacoras() {
            setActiveBtn(btnBitacoras);
            hideAllViews(); hideAllStats(); hideAllFilters();
            viewBitacoras.classList.remove('d-none');
            collapseFilters();
            document.getElementById('pageTitle').textContent = 'Bitácoras';
            document.getElementById('pageSubtitle').textContent = 'Registros de atención psicológica y de enfermería.';
            // mostrar sub-vista activa por defecto (Psicología)
            const subPsy = document.getElementById('subViewPsicologia');
            const subEnf = document.getElementById('subViewEnfermeria');
            if (subPsy) subPsy.classList.remove('d-none');
            if (subEnf) subEnf.classList.add('d-none');
            if (psychologyStats) psychologyStats.classList.remove('d-none');
            if (medicalStats) medicalStats.classList.add('d-none');
            setActiveSubBtn('psicologia');
        }

        // Sub-botones de Bitácoras
        function setActiveSubBtn(active) {
            const btnPsy = document.getElementById('btnSubPsicologia');
            const btnEnf = document.getElementById('btnSubEnfermeria');
            if (!btnPsy || !btnEnf) return;
            if (active === 'psicologia') {
                btnPsy.classList.replace('btn-outline-primary', 'btn-primary');
                btnEnf.classList.replace('btn-primary', 'btn-outline-primary');
            } else {
                btnEnf.classList.replace('btn-outline-primary', 'btn-primary');
                btnPsy.classList.replace('btn-primary', 'btn-outline-primary');
            }
        }

        const btnSubPsy = document.getElementById('btnSubPsicologia');
        const btnSubEnf = document.getElementById('btnSubEnfermeria');
        if (btnSubPsy) {
            btnSubPsy.addEventListener('click', function () {
                document.getElementById('subViewPsicologia').classList.remove('d-none');
                document.getElementById('subViewEnfermeria').classList.add('d-none');
                if (psychologyStats) psychologyStats.classList.remove('d-none');
                if (medicalStats) medicalStats.classList.add('d-none');
                setActiveSubBtn('psicologia');
            });
        }
        if (btnSubEnf) {
            btnSubEnf.addEventListener('click', function () {
                document.getElementById('subViewPsicologia').classList.add('d-none');
                document.getElementById('subViewEnfermeria').classList.remove('d-none');
                if (psychologyStats) psychologyStats.classList.add('d-none');
                if (medicalStats) medicalStats.classList.remove('d-none');
                setActiveSubBtn('enfermeria');
            });
        }

        btnCalificaciones.addEventListener('click', showCalificaciones);
        btnServicios.addEventListener('click', showServicios);
        btnTramites.addEventListener('click', showTramites);
        if (btnBitacoras) btnBitacoras.addEventListener('click', showBitacoras);

        document.getElementById('toggleFilters').addEventListener('click', function () {
            const open = filtersArea.classList.toggle('show');
            this.setAttribute('aria-expanded', open);
        });

        showCalificaciones();
    })();
    </script>
}
